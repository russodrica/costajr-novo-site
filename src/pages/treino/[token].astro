---
export const prerender = false;
import { supabaseAdmin } from "~/lib/supabase";
import { lerTreinoToken, urlAssinadaTreino } from "~/lib/treinoStorage";

const token = Astro.params.token || "";
const dados = await lerTreinoToken(token);

let erro = "";
let titulo = "Treinamento";
let nome = "Colaborador";
let signed: string | null = null;
let vtipo: "video" | "pdf" = "video";
let externo = false; // YouTube/Vimeo
let embed = "";

function toEmbed(url: string): string {
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?/]+)/);
  if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
  const vm = url.match(/vimeo\.com\/(\d+)/);
  if (vm) return `https://player.vimeo.com/video/${vm[1]}`;
  return url;
}

if (!dados) {
  erro = "Este link de treinamento expirou ou é inválido. Peça o link novamente (no portal ou pela JunIA).";
} else {
  nome = dados.nome;
  vtipo = dados.vtipo;
  const sb = supabaseAdmin();
  const tabela = vtipo === "pdf" ? "portal_treinamentos_pdfs" : "portal_treinamentos_videos";
  const { data: item } = await sb.from(tabela).select("*").eq("id", dados.id).maybeSingle();
  if (!item) {
    erro = "Treinamento não encontrado.";
  } else {
    titulo = item.titulo || titulo;
    const original = vtipo === "pdf" ? item.url : item.url_video;
    externo = /^https?:\/\/(www\.)?(youtube|youtu|vimeo)/i.test(original || "");
    if (externo) embed = toEmbed(original);
    else signed = await urlAssinadaTreino(sb, original, 14400); // 4h, cobre a reprodução
  }
}

// marca d'água: nome estampado, repetido em diagonal por cima do player
const xml = (s: string) => String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const hoje = new Date().toLocaleDateString("pt-BR");
const wmText = `${nome} • CJR • uso interno • ${hoje}`;
const wmSvg = `<svg xmlns='http://www.w3.org/2000/svg' width='360' height='210'><text x='18' y='120' transform='rotate(-22 180 105)' fill='rgba(255,255,255,0.14)' font-family='Arial, sans-serif' font-size='15' font-weight='700'>${xml(wmText)}</text></svg>`;
const wmBg = `url("data:image/svg+xml,${encodeURIComponent(wmSvg)}")`;
---
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{titulo} — Costa Júnior</title>
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; background: #0B0D10; color: #E7EAF0; font-family: Arial, Helvetica, sans-serif; }
    .top { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 12px 16px; background: #111418; border-bottom: 1px solid #1E232B; }
    .top h1 { font-size: 15px; margin: 0; font-weight: 700; }
    .top .who { font-size: 12px; color: #9aa3b2; }
    .wrap { max-width: 980px; margin: 18px auto; padding: 0 14px; }
    .stage { position: relative; padding-top: 56.25%; background: #000; border-radius: 12px; overflow: hidden; }
    .stage video, .stage iframe, .stage embed { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
    .wm { position: absolute; inset: 0; pointer-events: none; background-image: var(--wm); background-repeat: repeat; z-index: 5; }
    .pdf .stage { padding-top: 0; height: 82vh; }
    .nota { margin: 14px 2px; font-size: 12.5px; color: #8b94a3; line-height: 1.6; }
    .erro { max-width: 560px; margin: 60px auto; padding: 26px; background: #15191F; border: 1px solid #232a33; border-radius: 14px; text-align: center; }
    .erro h2 { margin: 0 0 8px; font-size: 18px; }
    .badge { display: inline-block; background: #C41E3A; color: #fff; font-weight: 800; font-size: 12px; padding: 3px 9px; border-radius: 6px; }
  </style>
</head>
<body>
  <div class="top">
    <h1><span class="badge">CJR</span> &nbsp;{titulo}</h1>
    <span class="who">👁 {nome}</span>
  </div>

  {erro ? (
    <div class="erro"><h2>Link indisponível</h2><p style="color:#9aa3b2;font-size:14px">{erro}</p></div>
  ) : (
    <div class={`wrap ${vtipo === "pdf" ? "pdf" : ""}`}>
      <div class="stage" style={`--wm:${wmBg}`}>
        {vtipo === "pdf" ? (
          <iframe src={signed || embed} title={titulo}></iframe>
        ) : externo ? (
          <iframe src={embed} title={titulo} allow="autoplay; fullscreen" allowfullscreen></iframe>
        ) : (
          <video src={signed!} controls controlslist="nodownload noplaybackrate" disablepictureinpicture playsinline preload="metadata"></video>
        )}
        <div class="wm"></div>
      </div>
      <p class="nota">🔒 Conteúdo interno da Costa Júnior. Identificado para <strong>{nome}</strong> — não compartilhe; o vídeo está marcado com seu nome.</p>
    </div>
  )}

  <script is:inline>
    // dificulta download/menu de contexto no vídeo (deterrente, não impede expert)
    document.addEventListener("contextmenu", function (e) {
      if (e.target && (e.target.tagName === "VIDEO" || e.target.tagName === "IFRAME")) e.preventDefault();
    });
  </script>
</body>
</html>
