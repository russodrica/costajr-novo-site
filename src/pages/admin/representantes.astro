---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";
import { listarRegrasIndicacao } from "../../lib/manut/indicacao-regras";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const db = supabaseAdmin();

// Lista representantes + conta de cupons + últimos repasses (todos)
const [{ data: reps }, { data: cuponsPorRep }, { data: repasses }] = await Promise.all([
  db.from("manut_representantes").select("*").order("created_at", { ascending: false }),
  db.from("manut_cupons")
    .select("id, codigo, desconto_percentual, duracao_meses, cashback_pct, tipo, ativo, usos_atuais, usos_maximos, validade, representante_id")
    .not("representante_id", "is", null)
    .order("created_at", { ascending: false }),
  db.from("manut_representantes_repasses").select("*, rep:representante_id(nome)").order("created_at", { ascending: false }).limit(50),
]);

// Tabela de regras dinâmicas (mesmo conjunto aplicado em todo cupom tipo=representante)
const regrasIndicacao = listarRegrasIndicacao();

// Indexa cupons completos por representante (não apenas count)
const cuponsPorRepId: Record<string, any[]> = {};
for (const c of cuponsPorRep || []) {
  const id = (c as any).representante_id as string;
  if (!cuponsPorRepId[id]) cuponsPorRepId[id] = [];
  cuponsPorRepId[id].push(c);
}

function fmtMoney(v: number | null) { if (v == null) return "—"; return v.toLocaleString("pt-BR", { style: "currency", currency: "BRL" }); }
function fmtDate(d: string | null) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

const totalAtivos = (reps || []).filter((r: any) => r.ativo).length;
const saldoTotal = (reps || []).reduce((a: number, r: any) => a + Number(r.saldo_acumulado || 0), 0);
const totalPago = (repasses || []).reduce((a: number, r: any) => a + Number(r.valor || 0), 0);
---
<Admin title="Representantes" current="representantes">
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:18px">
    <div class="card" style="text-align:center;padding:18px">
      <div style="font-size:11px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">REPRESENTANTES ATIVOS</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#C41E3A;margin-top:6px">{totalAtivos}</div>
    </div>
    <div class="card" style="text-align:center;padding:18px;background:linear-gradient(135deg,#FEF3C7 0%,#FFF 100%)">
      <div style="font-size:11px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">SALDO A REPASSAR</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#92400E;margin-top:6px">{fmtMoney(saldoTotal)}</div>
    </div>
    <div class="card" style="text-align:center;padding:18px;background:linear-gradient(135deg,#F0FDF4 0%,#FFF 100%)">
      <div style="font-size:11px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">JÁ REPASSADO (ÚLT. 50)</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#166534;margin-top:6px">{fmtMoney(totalPago)}</div>
    </div>
  </div>

  <div class="card" style="margin-bottom:18px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
      <strong style="font-size:14px">Representantes cadastrados</strong>
      <button class="btn btn-primary btn-sm" onclick="abrirNovo()">+ Novo representante</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Nome</th><th>Contato</th><th>PIX</th><th>Cupons</th><th>Saldo acumulado</th><th>Status</th><th style="text-align:right">Ações</th></tr></thead>
        <tbody>
          {(reps || []).map((r: any) => {
            const cupons = cuponsPorRepId[r.id] || [];
            const saldo = Number(r.saldo_acumulado || 0);
            return (
              <tr data-id={r.id} data-nome={r.nome} data-email={r.email} data-telefone={r.telefone || ""} data-ativo={r.ativo ? "1" : "0"} data-saldo={saldo} data-pix={r.chave_pix || ""} data-tipo-pix={r.tipo_chave_pix || ""}>
                <td>
                  <strong>{r.nome}</strong>
                  {r.aprovado_em && <div style="font-size:10px;color:#9CA3AF;margin-top:2px">Aprovado {new Date(r.aprovado_em).toLocaleDateString("pt-BR")}</div>}
                </td>
                <td style="font-size:12px">
                  <div style="color:#2D2F36">{r.email}</div>
                  {r.telefone && <div style="color:#5B5F6B;margin-top:2px">{r.telefone}</div>}
                </td>
                <td style="font-size:12px">
                  {r.chave_pix ? (
                    <div>
                      {r.tipo_chave_pix && (
                        <span style="background:#F0FDF4;color:#166534;padding:1px 6px;border-radius:99px;font-size:9.5px;font-weight:700;text-transform:uppercase">{r.tipo_chave_pix}</span>
                      )}
                      <div style="color:#2D2F36;margin-top:3px;font-family:monospace;font-size:11.5px;word-break:break-all">{r.chave_pix}</div>
                    </div>
                  ) : (
                    <span style="color:#DC2626;font-size:11px;font-weight:600">⚠️ não cadastrado</span>
                  )}
                </td>
                <td style="font-size:12px">
                  {cupons.length === 0 ? <span style="color:#9CA3AF">—</span> : (
                    <div style="display:flex;flex-direction:column;gap:6px">
                      {cupons.map((c: any) => (
                        <div style="display:flex;flex-direction:column;gap:4px;padding:6px 8px;background:#F9FAFB;border-radius:6px;border-left:3px solid #C41E3A">
                          <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                            <code style="font-family:'Montserrat',sans-serif;font-weight:800;color:#C41E3A;font-size:13px;letter-spacing:0.5px">{c.codigo}</code>
                            {c.ativo
                              ? <span style="background:#DCFCE7;color:#166534;padding:1px 6px;border-radius:99px;font-size:9.5px;font-weight:700">ATIVO</span>
                              : <span style="background:#FEE2E2;color:#B91C1C;padding:1px 6px;border-radius:99px;font-size:9.5px;font-weight:700">INATIVO</span>}
                            {c.tipo === "representante" && (
                              <span title="As regras (desconto + comissão) variam conforme o plano que o cliente escolhe" style="background:#EFF6FF;color:#1D4ED8;padding:1px 6px;border-radius:99px;font-size:9.5px;font-weight:700">REGRAS POR PLANO</span>
                            )}
                          </div>
                          {c.tipo === "representante" ? (
                            <div style="display:flex;flex-direction:column;gap:2px;background:#FFF;border:1px solid #E5E7EB;border-radius:4px;padding:4px 6px">
                              {regrasIndicacao.map((r) => (
                                <div style="display:grid;grid-template-columns:80px 1fr;gap:6px;font-size:10.5px;color:#5B5F6B;line-height:1.5">
                                  <strong style="color:#2D2F36">{r.label} ({r.meses}m):</strong>
                                  <span>
                                    cliente <strong>{r.desconto_pct === 0 ? "sem desconto" : `${r.desconto_pct}% × ${r.duracao_desconto_meses} ${r.duracao_desconto_meses === 1 ? "mês" : "meses"}`}</strong>
                                    {" · "}
                                    comissão <strong style="color:#166534">{r.comissao_pct}%</strong>
                                  </span>
                                </div>
                              ))}
                            </div>
                          ) : (
                            <div style="color:#5B5F6B;font-size:11px;line-height:1.4">
                              <strong>{Number(c.desconto_percentual)}%</strong> off × <strong>{Number(c.duracao_meses)} mês{c.duracao_meses != 1 ? "es" : ""}</strong>
                              {" · "}
                              comissão <strong>{Number(c.cashback_pct)}%</strong>
                            </div>
                          )}
                          <div style="color:#9CA3AF;font-size:10.5px">
                            Usos: {c.usos_atuais || 0}{c.usos_maximos ? ` / ${c.usos_maximos}` : ""}
                            {c.validade && ` · Validade: ${fmtDate(c.validade)}`}
                          </div>
                        </div>
                      ))}
                    </div>
                  )}
                </td>
                <td style={`font-weight:700;color:${saldo > 0 ? "#92400E" : "#5B5F6B"}`}>{fmtMoney(saldo)}</td>
                <td>{r.ativo
                  ? <span class="badge" style="background:#DCFCE7;color:#166534">Ativo</span>
                  : <span class="badge" style="background:#F3F4F6;color:#6B7280">Inativo</span>}</td>
                <td style="text-align:right;white-space:nowrap;vertical-align:top">
                  <button class="btn btn-outline btn-sm" onclick={`editar('${r.id}')`}>Editar</button>
                  <button class="btn btn-primary btn-sm" disabled={saldo <= 0} onclick={`abrirRepasse('${r.id}','${r.nome}',${saldo})`} style={saldo <= 0 ? "opacity:0.4;cursor:not-allowed" : ""}>Repasse</button>
                </td>
              </tr>
            );
          })}
          {!(reps || []).length && <tr><td colspan="7" style="text-align:center;color:#9CA3AF;padding:24px">Nenhum representante cadastrado</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <strong style="font-size:14px">Histórico de repasses (últimos 50)</strong>
    <div class="table-wrap" style="margin-top:12px">
      <table>
        <thead><tr><th>Data</th><th>Representante</th><th>Valor</th><th>Observação</th></tr></thead>
        <tbody>
          {(repasses || []).map((r: any) => (
            <tr>
              <td style="font-size:12.5px">{fmtDate(r.data_repasse)}</td>
              <td><strong>{r.rep?.nome || "—"}</strong></td>
              <td style="color:#166534;font-weight:700">{fmtMoney(r.valor)}</td>
              <td style="font-size:12.5px;color:#5B5F6B">{r.observacao || "—"}</td>
            </tr>
          ))}
          {!(repasses || []).length && <tr><td colspan="4" style="text-align:center;color:#9CA3AF;padding:24px">Nenhum repasse registrado</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal: novo / editar representante -->
  <div class="modal-overlay" id="modalRep">
    <div class="modal">
      <div class="modal-title" id="modalRepTitulo">Novo representante</div>
      <form id="formRep">
        <input type="hidden" id="repId" />
        <div class="form-group"><label>Nome *</label><input id="repNome" required /></div>
        <div class="form-group"><label>Email *</label><input id="repEmail" type="email" required /></div>
        <div class="form-group"><label>Telefone</label><input id="repTelefone" type="tel" /></div>

        <div style="background:#F4F6F9;border-radius:8px;padding:12px 14px;margin:14px 0">
          <div style="font-size:12px;font-weight:700;color:#2D2F36;margin-bottom:8px;text-transform:uppercase;letter-spacing:1px">Chave PIX (pra repasses)</div>
          <div style="display:grid;grid-template-columns:140px 1fr;gap:10px">
            <div class="form-group" style="margin:0">
              <label style="font-size:12px">Tipo da chave</label>
              <select id="repTipoPix" style="width:100%;padding:8px;border:1px solid #E5E7EB;border-radius:6px;font-size:13px">
                <option value="">—</option>
                <option value="cpf">CPF</option>
                <option value="cnpj">CNPJ</option>
                <option value="email">Email</option>
                <option value="telefone">Telefone</option>
                <option value="aleatoria">Aleatória</option>
              </select>
            </div>
            <div class="form-group" style="margin:0">
              <label style="font-size:12px">Chave PIX</label>
              <input id="repPix" placeholder="Ex.: 123.456.789-00" />
            </div>
          </div>
          <small style="display:block;margin-top:6px;font-size:11px;color:#5B5F6B">
            💡 Pode deixar em branco se preferir — o representante pode cadastrar depois pelo portal dele.
          </small>
        </div>

        <div class="form-group" id="grupoAtivo" style="display:none">
          <label style="display:flex;align-items:center;gap:8px;font-weight:normal">
            <input type="checkbox" id="repAtivo" /> Representante ativo
          </label>
          <small style="display:block;margin-top:6px;font-size:11.5px;color:#5B5F6B">
            💡 Ao APROVAR pela primeira vez: cupons inativos são ativados, uma senha temporária é gerada e um email de boas-vindas é enviado automaticamente.
          </small>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharRep()">Cancelar</button>
          <button type="submit" class="btn btn-primary" id="btnSalvarRep">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: registrar repasse -->
  <div class="modal-overlay" id="modalRepasse">
    <div class="modal">
      <div class="modal-title">Registrar repasse</div>
      <form id="formRepasse">
        <input type="hidden" id="repasseId" />
        <div style="background:#F4F6F9;padding:10px 14px;border-radius:8px;margin-bottom:14px;font-size:13px">
          <div>Representante: <strong id="repasseNome">—</strong></div>
          <div>Saldo disponível: <strong id="repasseSaldo">—</strong></div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label>Valor (R$) *</label><input id="repasseValor" type="number" step="0.01" min="0.01" required /></div>
          <div class="form-group"><label>Data do repasse *</label><input id="repasseData" type="date" required /></div>
        </div>
        <div class="form-group"><label>Observação (ex: PIX, comprovante #...)</label><input id="repasseObs" /></div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharRepasse()">Cancelar</button>
          <button type="submit" class="btn btn-primary">Registrar repasse</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    /* ---------- Modal Novo / Editar ---------- */
    function abrirNovo() {
      (document.getElementById("formRep") as HTMLFormElement).reset();
      (document.getElementById("repId") as HTMLInputElement).value = "";
      document.getElementById("modalRepTitulo")!.textContent = "Novo representante";
      document.getElementById("grupoAtivo")!.style.display = "none";
      document.getElementById("modalRep")!.classList.add("open");
    }
    function editar(id: string) {
      const tr = document.querySelector(`tr[data-id="${id}"]`) as HTMLElement | null;
      if (!tr) return;
      (document.getElementById("repId") as HTMLInputElement).value = id;
      (document.getElementById("repNome") as HTMLInputElement).value = tr.dataset.nome || "";
      (document.getElementById("repEmail") as HTMLInputElement).value = tr.dataset.email || "";
      (document.getElementById("repTelefone") as HTMLInputElement).value = tr.dataset.telefone || "";
      (document.getElementById("repPix") as HTMLInputElement).value = tr.dataset.pix || "";
      (document.getElementById("repTipoPix") as HTMLSelectElement).value = tr.dataset.tipoPix || "";
      (document.getElementById("repAtivo") as HTMLInputElement).checked = tr.dataset.ativo === "1";
      document.getElementById("modalRepTitulo")!.textContent = "Editar representante";
      document.getElementById("grupoAtivo")!.style.display = "";
      document.getElementById("modalRep")!.classList.add("open");
    }
    function fecharRep() { document.getElementById("modalRep")!.classList.remove("open"); }

    /* ---------- Modal Repasse ---------- */
    function abrirRepasse(id: string, nome: string, saldo: number) {
      if (saldo <= 0) return;
      (document.getElementById("formRepasse") as HTMLFormElement).reset();
      (document.getElementById("repasseId") as HTMLInputElement).value = id;
      document.getElementById("repasseNome")!.textContent = nome;
      document.getElementById("repasseSaldo")!.textContent = saldo.toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
      (document.getElementById("repasseValor") as HTMLInputElement).max = String(saldo);
      (document.getElementById("repasseValor") as HTMLInputElement).value = String(saldo.toFixed(2));
      (document.getElementById("repasseData") as HTMLInputElement).value = new Date().toISOString().slice(0, 10);
      document.getElementById("modalRepasse")!.classList.add("open");
    }
    function fecharRepasse() { document.getElementById("modalRepasse")!.classList.remove("open"); }

    (window as any).abrirNovo = abrirNovo;
    (window as any).editar = editar;
    (window as any).fecharRep = fecharRep;
    (window as any).abrirRepasse = abrirRepasse;
    (window as any).fecharRepasse = fecharRepasse;

    /* ---------- Submits ---------- */
    document.getElementById("formRep")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = (document.getElementById("repId") as HTMLInputElement).value;
      const body: any = {
        nome: (document.getElementById("repNome") as HTMLInputElement).value.trim(),
        email: (document.getElementById("repEmail") as HTMLInputElement).value.trim(),
        telefone: (document.getElementById("repTelefone") as HTMLInputElement).value.trim() || null,
        chave_pix: (document.getElementById("repPix") as HTMLInputElement).value.trim() || null,
        tipo_chave_pix: (document.getElementById("repTipoPix") as HTMLSelectElement).value || null,
      };
      if (id) body.ativo = (document.getElementById("repAtivo") as HTMLInputElement).checked;
      const url = id ? `/api/admin/representantes/${id}` : "/api/admin/representantes";
      const method = id ? "PATCH" : "POST";
      const res = await fetch(url, { method, headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (res.ok) {
        // Detecta primeira aprovação (resposta inclui senhaInicialGerada) e avisa Adriana
        const d = await res.json().catch(() => ({}));
        if (d?.senhaInicialGerada) {
          const msg = d.emailEnviado
            ? `✅ Representante APROVADO!\n\nFoi enviado um email de boas-vindas pra ${d.email} com a senha temporária e o link do portal.\n\nSenha gerada (caso precise repassar manualmente): ${d.senhaInicialGerada}`
            : `✅ Representante APROVADO!\n\n⚠️ Não foi possível enviar o email automático (${d.emailErro || "erro desconhecido"}).\n\nEnvie manualmente:\nEmail: ${d.email}\nSenha temporária: ${d.senhaInicialGerada}\nPortal: /manutencao/representante/login`;
          alert(msg);
        }
        window.location.reload();
      } else {
        const d = await res.json().catch(() => ({}));
        alert(d.error || "Erro ao salvar");
      }
    });

    document.getElementById("formRepasse")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = (document.getElementById("repasseId") as HTMLInputElement).value;
      const body = {
        valor: parseFloat((document.getElementById("repasseValor") as HTMLInputElement).value),
        data_repasse: (document.getElementById("repasseData") as HTMLInputElement).value,
        observacao: (document.getElementById("repasseObs") as HTMLInputElement).value.trim() || null,
      };
      const res = await fetch(`/api/admin/representantes/${id}/repasse`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
      });
      if (res.ok) { window.location.reload(); }
      else { const d = await res.json().catch(() => ({})); alert(d.error || "Erro ao registrar repasse"); }
    });
  </script>
</Admin>
