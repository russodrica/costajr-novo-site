---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";
import { PERFIS, PERFIL_LABEL, PERFIL_BADGE } from "../../lib/permissoes";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const filtroStatus = Astro.url.searchParams.get("status") || "todos";
const db = supabaseAdmin();
let qMembros = db.from("portal_profiles")
  .select("id, email, display_name, full_name, role, roles, tem_trabalhista, avatar_url, approval_status, last_login_at, created_at")
  .order("created_at", { ascending: false });
if (filtroStatus !== "todos") qMembros = qMembros.eq("approval_status", filtroStatus);
const { data: membros, error: membrosErro } = await qMembros;

const contagens: Record<string, number> = { todos: 0, pending: 0, approved: 0, rejected: 0 };
{
  const { data: todosStatus } = await db.from("portal_profiles").select("approval_status");
  for (const r of todosStatus || []) {
    contagens.todos++;
    if (r.approval_status in contagens) contagens[r.approval_status]++;
  }
}
const statusLabels: Record<string, string> = { todos: "Todos", pending: "Pendentes", approved: "Aprovados", rejected: "Rejeitados" };

const badgeSt: Record<string, string> = { pending: "badge-yellow", approved: "badge-green", rejected: "badge-red" };
const badgeRole: Record<string, string> = PERFIL_BADGE;
function fmtDate(d: string | null) { if (!d) return "—"; return new Date(d).toLocaleDateString("pt-BR"); }
const roles = [...PERFIS];

// Membros vinculados a um colaborador (RH) = "Colaboradores"; os demais = "Terceiros".
const { data: vinculos } = await db.from("rh_colaboradores").select("profile_id, status").not("profile_id", "is", null);
const idsColaborador = new Set((vinculos || []).map((v: any) => v.profile_id));
// Inativo = acesso revogado (rejected) OU colaborador do RH desligado → sai da lista por padrão.
const idsDesligado = new Set((vinculos || []).filter((v: any) => v.status === "desligado").map((v: any) => v.profile_id));
const ehColaborador = (m: any) => idsColaborador.has(m.id);
const ehInativo = (m: any) => m.approval_status === "rejected" || idsDesligado.has(m.id);
const ativos = (membros || []).filter((m: any) => !ehInativo(m));
const nColab = ativos.filter(ehColaborador).length;
const nTerceiro = ativos.length - nColab;
const nInativo = (membros || []).length - ativos.length;
---
<Admin title="Membros Portal" current="membros">
  <div class="toolbar">
    <span class="toolbar-title">Membros ({ativos.length})</span>
    <select class="filter-select" onchange="filtrar(this.value)">
      {["todos","pending","approved","rejected"].map(s => <option value={s} selected={s===filtroStatus}>{statusLabels[s]} ({contagens[s]})</option>)}
    </select>
    <button class="btn btn-primary" onclick="abrirModalNovo()">+ Novo membro</button>
  </div>

  <div class="pills" style="margin-bottom:14px">
    <button class="pill active" data-tipo="todos" onclick="filtrarTipo('todos', this)">Todos <span class="count">{ativos.length}</span></button>
    <button class="pill" data-tipo="colaborador" onclick="filtrarTipo('colaborador', this)">🧑‍💼 Colaboradores <span class="count">{nColab}</span></button>
    <button class="pill" data-tipo="terceiro" onclick="filtrarTipo('terceiro', this)">🤝 Terceiros <span class="count">{nTerceiro}</span></button>
    <button class="pill" data-tipo="inativo" onclick="filtrarTipo('inativo', this)">🚫 Inativos <span class="count">{nInativo}</span></button>
  </div>

  {membrosErro && <div class="alert alert-error">Erro ao carregar membros: {membrosErro.message}</div>}

  <div class="card">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Nome</th><th>E-mail</th><th>Perfis</th><th>Status</th><th>Último acesso</th><th>Cadastro</th><th>Ações</th></tr></thead>
        <tbody>
          {membros?.length ? membros.map((m: any) => (
            <tr data-membro-id={m.id} data-tipo={ehColaborador(m) ? "colaborador" : "terceiro"} data-inativo={ehInativo(m) ? "1" : "0"} style={ehInativo(m) ? "display:none" : ""} data-nome={m.display_name || m.full_name || ""} data-email={m.email || ""} data-roles={(m.roles?.length ? m.roles : [m.role]).join(",")}>
              <td>
                <div style="display:flex;align-items:center;gap:10px">
                  <span class="avatar-mini" onclick={`trocarAvatar('${m.id}')`} title="Clique para trocar a foto">
                    {m.avatar_url ? <img src={m.avatar_url} alt="" /> : <span>{(m.display_name || m.full_name || m.email || "?").slice(0, 1).toUpperCase()}</span>}
                  </span>
                  <strong>{m.display_name || m.full_name || "—"}</strong>
                </div>
              </td>
              <td>{m.email}</td>
              <td>
                <div style="display:flex;gap:4px;flex-wrap:wrap">
                  {(m.roles?.length ? m.roles : [m.role]).filter(Boolean).map((r: string) => <span class={`badge ${badgeRole[r] || "badge-gray"}`}>{PERFIL_LABEL[r] || r}</span>)}
                  {m.tem_trabalhista && <span class="badge badge-purple" title="Tem acesso a conteúdo trabalhista">⚖️ trabalhista</span>}
                </div>
              </td>
              <td><span class={`badge ${badgeSt[m.approval_status]}`}>{m.approval_status}</span></td>
              <td>{fmtDate(m.last_login_at)}</td>
              <td>{fmtDate(m.created_at)}</td>
              <td>
                <div style="display:flex;gap:4px;flex-wrap:wrap">
                  {m.approval_status === "pending" && (
                    <>
                      <button class="btn btn-success btn-sm" onclick={`aprovar('${m.id}')`}>Aprovar</button>
                      <button class="btn btn-danger btn-sm" onclick={`rejeitar('${m.id}')`}>Rejeitar</button>
                    </>
                  )}
                  <button class="btn btn-secondary btn-sm" onclick={`editarPerfis('${m.id}')`}>👥 Perfis</button>
                  <button class={`btn btn-sm ${m.tem_trabalhista ? "btn-outline" : "btn-warning"}`} onclick={`toggleTrabalhista('${m.id}', ${m.tem_trabalhista ? "false" : "true"})`}>{m.tem_trabalhista ? "Remover trabalhista" : "⚖️ Dar trabalhista"}</button>
                  <button class="btn btn-secondary btn-sm" onclick={`editarMembro('${m.id}')`}>✏️ Editar</button>
                  <button class="btn btn-info btn-sm" onclick={`resetarSenha('${m.id}')`}>Reset senha</button>
                  <button class="btn btn-danger btn-sm" onclick={`excluirMembro('${m.id}', '${(m.display_name || m.email || "").replace(/'/g, "")}')`}>🗑</button>
                </div>
              </td>
            </tr>
          )) : <tr><td colspan="7" style="text-align:center;color:#999;padding:32px">Nenhum membro encontrado</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal novo membro -->
  <div class="modal-overlay" id="modalNovo">
    <div class="modal">
      <div class="modal-title">Novo Membro</div>
      <div id="msgNovo"></div>
      <form id="formNovo">
        <div class="form-group"><label>Nome *</label><input name="display_name" required /></div>
        <div class="form-group"><label>E-mail *</label><input name="email" type="email" required /></div>
        <div class="form-group"><label>Perfil *</label>
          <select name="role">
            {roles.map(r => <option value={r}>{PERFIL_LABEL[r] || r}</option>)}
          </select>
        </div>
        <div class="form-group"><label>Senha inicial</label><input name="senha" placeholder="Deixe em branco para gerar" /></div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharModal('modalNovo')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Criar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal editar membro (nome/e-mail) -->
  <div class="modal-overlay" id="modalEditarMembro">
    <div class="modal" style="max-width:400px">
      <div class="modal-title">Editar Membro</div>
      <div id="msgEditarMembro"></div>
      <form id="formEditarMembro">
        <input type="hidden" id="editMembroId" />
        <div class="form-group"><label>Nome</label><input id="editDisplayName" /></div>
        <div class="form-group"><label>E-mail</label><input id="editEmail" type="email" /></div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharModal('modalEditarMembro')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal perfis (múltiplos) -->
  <div class="modal-overlay" id="modalPerfis">
    <div class="modal" style="max-width:420px">
      <div class="modal-title">👥 Perfis do membro</div>
      <p style="font-size:12.5px;color:#6B7280;margin:-8px 0 14px">O membro pode acumular vários perfis (como no portal antigo). O primeiro marcado vira o perfil principal.</p>
      <form id="formPerfis">
        <input type="hidden" id="perfisMembroId" />
        <div class="perfis-grid">
          {roles.map(r => (
            <label class="perfil-check">
              <input type="checkbox" name="perfil" value={r} />
              <span>{PERFIL_LABEL[r] || r}</span>
            </label>
          ))}
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharModal('modalPerfis')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar perfis</button>
        </div>
      </form>
    </div>
  </div>

  <input type="file" id="inputAvatar" accept="image/*" style="display:none" />

  <style>
    .avatar-mini {
      width: 34px; height: 34px; border-radius: 50%; overflow: hidden; flex: none;
      background: linear-gradient(135deg, #C41E3A, #8B0F25); color: #fff;
      display: inline-flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 14px; cursor: pointer; border: 2px solid #fff;
      box-shadow: 0 1px 4px rgba(16,24,40,.2); transition: transform .15s;
    }
    .avatar-mini:hover { transform: scale(1.12); }
    .avatar-mini img { width: 100%; height: 100%; object-fit: cover; }
    .perfis-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }
    .perfil-check {
      display: flex; align-items: center; gap: 8px; padding: 9px 12px;
      border: 1.5px solid #E5E7EB; border-radius: 8px; cursor: pointer;
      font-size: .85rem; font-weight: 600; transition: .15s;
    }
    .perfil-check:hover { border-color: #C41E3A; }
    .perfil-check:has(input:checked) { border-color: #C41E3A; background: rgba(196,30,58,.06); }
    .perfil-check input { accent-color: #C41E3A; width: 15px; height: 15px; }
  </style>

  <script>
    function filtrar(s) {
      const url = new URL(window.location.href);
      url.searchParams.set("status", s);
      window.location.href = url.toString();
    }
    function filtrarTipo(tipo, btn) {
      document.querySelectorAll(".pill[data-tipo]").forEach((p) => p.classList.toggle("active", p === btn));
      document.querySelectorAll("tr[data-membro-id]").forEach((tr) => {
        const inativo = (tr as HTMLElement).dataset.inativo === "1";
        let mostra;
        if (tipo === "inativo") mostra = inativo;          // aba Inativos: só os revogados/desligados
        else if (tipo === "todos") mostra = !inativo;       // padrão: só ativos
        else mostra = !inativo && (tr as HTMLElement).dataset.tipo === tipo;
        (tr as HTMLElement).style.display = mostra ? "" : "none";
      });
    }
    function fecharModal(id) { document.getElementById(id).classList.remove("open"); }
    function abrirModalNovo() { document.getElementById("modalNovo").classList.add("open"); }

    // ── Perfis múltiplos ──
    function editarPerfis(id) {
      const linha = document.querySelector(`[data-membro-id="${id}"]`);
      const atuais = (linha?.getAttribute("data-roles") || "").split(",").filter(Boolean);
      (document.getElementById("perfisMembroId") as HTMLInputElement).value = id;
      document.querySelectorAll("#formPerfis input[name=perfil]").forEach((cb: any) => { cb.checked = atuais.includes(cb.value); });
      document.getElementById("modalPerfis")!.classList.add("open");
    }
    document.getElementById("formPerfis")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = (document.getElementById("perfisMembroId") as HTMLInputElement).value;
      const marcados = Array.from(document.querySelectorAll("#formPerfis input[name=perfil]:checked")).map((cb: any) => cb.value);
      if (!marcados.length) { alert("Selecione ao menos 1 perfil."); return; }
      await patch(id, { roles: marcados, role: marcados[0] });
    });

    // ── Trabalhista ──
    async function toggleTrabalhista(id, dar) {
      const msg = dar === true || dar === "true"
        ? "Dar acesso a conteúdo TRABALHISTA para este membro?"
        : "Remover o acesso a conteúdo trabalhista deste membro?";
      if (!confirm(msg)) return;
      await patch(id, { tem_trabalhista: dar === true || dar === "true" });
    }

    // ── Avatar ──
    let avatarMembroId = "";
    function trocarAvatar(id) {
      avatarMembroId = id;
      (document.getElementById("inputAvatar") as HTMLInputElement).click();
    }
    document.getElementById("inputAvatar")?.addEventListener("change", async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file || !avatarMembroId) return;
      if (file.size > 5 * 1024 * 1024) { alert("Imagem muito grande (máx. 5MB)"); return; }
      const b64 = await new Promise<string>((res) => { const r = new FileReader(); r.onload = () => res(String(r.result).split(",")[1]); r.readAsDataURL(file); });
      const resp = await fetch(`/api/admin/membros/${avatarMembroId}/avatar`, { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ imagem_base64: b64, content_type: file.type }) });
      if (resp.ok) window.location.reload();
      else alert((await resp.json()).error || "Erro ao enviar foto");
    });

    async function patch(id, body) {
      const res = await fetch(`/api/admin/membros/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (res.ok) window.location.reload(); else alert("Erro ao atualizar membro");
    }
    function aprovar(id) { patch(id, { approval_status: "approved", approved_at: new Date().toISOString() }); }
    function rejeitar(id) {
      const motivo = prompt("Motivo da rejeição (opcional):") ?? "";
      patch(id, { approval_status: "rejected", rejected_at: new Date().toISOString(), rejection_reason: motivo || null });
    }
    async function resetarSenha(id) {
      const res = await fetch(`/api/admin/membros/${id}/resetar-senha`, { method: "POST", headers: { "content-type": "application/json" }, body: "{}" });
      if (res.ok) {
        const d = await res.json();
        let msg = `Nova senha: ${d.senha}`;
        if (d.emailEnviado) msg += "\n\n✅ Email enviado para o membro.";
        else if (d.emailErro) msg += "\n\n⚠ Email NÃO foi enviado: " + d.emailErro;
        alert(msg);
      } else {
        const d = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
        alert("Erro ao resetar senha: " + (d.error || ""));
      }
    }

    document.getElementById("formNovo")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const body = Object.fromEntries(fd.entries());
      const msg = document.getElementById("msgNovo");
      const res = await fetch("/api/admin/membros", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (res.ok) { window.location.reload(); }
      else { const d = await res.json(); msg.innerHTML = `<div class="alert alert-error">${d.error}</div>`; }
    });

    // editar nome/e-mail
    const membrosDados: Record<string, any> = {};
    document.querySelectorAll("tr[data-membro]").forEach(() => {});
    function editarMembro(id) {
      const linha = document.querySelector(`[data-membro-id="${id}"]`);
      (document.getElementById("editMembroId") as HTMLInputElement).value = id;
      (document.getElementById("editDisplayName") as HTMLInputElement).value = linha?.getAttribute("data-nome") || "";
      (document.getElementById("editEmail") as HTMLInputElement).value = linha?.getAttribute("data-email") || "";
      document.getElementById("modalEditarMembro")!.classList.add("open");
    }
    document.getElementById("formEditarMembro")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = (document.getElementById("editMembroId") as HTMLInputElement).value;
      const body = {
        display_name: (document.getElementById("editDisplayName") as HTMLInputElement).value.trim(),
        email: (document.getElementById("editEmail") as HTMLInputElement).value.trim().toLowerCase(),
      };
      const res = await fetch(`/api/admin/membros/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (res.ok) window.location.reload();
      else { const d = await res.json().catch(() => ({})); document.getElementById("msgEditarMembro")!.innerHTML = `<div class="alert alert-error">${d.error || "Erro ao salvar"}</div>`; }
    });

    async function excluirMembro(id, nome) {
      if (!confirm(`Excluir o membro "${nome}"?\n\nSe ele tiver histórico (fórum, termos), será apenas desativado. Esta ação não pode ser desfeita.`)) return;
      const res = await fetch(`/api/admin/membros/${id}`, { method: "DELETE", headers: { "content-type": "application/json" } });
      const d = await res.json().catch(() => ({}));
      if (res.ok) { if (d.aviso) alert(d.aviso); window.location.reload(); }
      else alert(d.error || "Erro ao excluir");
    }

    (window as any).filtrar = filtrar;
    (window as any).fecharModal = fecharModal;
    (window as any).abrirModalNovo = abrirModalNovo;
    (window as any).editarPerfis = editarPerfis;
    (window as any).toggleTrabalhista = toggleTrabalhista;
    (window as any).trocarAvatar = trocarAvatar;
    (window as any).aprovar = aprovar;
    (window as any).rejeitar = rejeitar;
    (window as any).resetarSenha = resetarSenha;
    (window as any).editarMembro = editarMembro;
    (window as any).excluirMembro = excluirMembro;
  </script>
</Admin>
