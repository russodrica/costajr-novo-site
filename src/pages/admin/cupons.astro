---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const db = supabaseAdmin();

const [{ data: cupons }, { data: usos }, { data: cashbackTop }, { data: representantes }] = await Promise.all([
  db.from("manut_cupons")
    .select("*, cliente_dono:cliente_dono_id(nome,email,saldo_cashback), representante:representante_id(nome,email,saldo_acumulado)")
    .order("created_at", { ascending: false })
    .limit(200),
  db.from("manut_cupons_usos")
    .select("*, cupom:manut_cupons(codigo,tipo), quem_usou:manut_clientes!manut_cupons_usos_cliente_que_usou_id_fkey(nome,email), dono:manut_clientes!manut_cupons_usos_cliente_dono_id_fkey(nome)")
    .order("created_at", { ascending: false })
    .limit(100),
  db.from("manut_clientes").select("id,nome,email,saldo_cashback").gt("saldo_cashback", 0).order("saldo_cashback", { ascending: false }).limit(20),
  db.from("manut_representantes").select("id,nome,email,saldo_acumulado,ativo").eq("ativo", true).order("nome"),
]);

function fmtMoney(v: number | null) { if (v == null) return "—"; return v.toLocaleString("pt-BR", { style: "currency", currency: "BRL" }); }
function fmtDate(d: string | null) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

const tipoLabel: Record<string, string> = {
  desconto: "Desconto",
  indicacao: "Indicação",
  nova_loja: "Nova loja",
  representante: "Representante",
};
const tipoCor: Record<string, string> = {
  desconto: "#5B5F6B",
  indicacao: "#16A34A",
  nova_loja: "#1D4ED8",
  representante: "#9333EA",
};
---
<Admin title="Cupons & Cashback" current="cupons">
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:18px">
    <div class="card" style="text-align:center;padding:18px">
      <div style="font-size:11px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">CUPONS ATIVOS</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#C41E3A;margin-top:6px">{cupons?.filter((c: any) => c.ativo).length || 0}</div>
    </div>
    <div class="card" style="text-align:center;padding:18px">
      <div style="font-size:11px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">USOS TOTAIS</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#C41E3A;margin-top:6px">{usos?.length || 0}</div>
    </div>
    <div class="card" style="text-align:center;padding:18px;background:linear-gradient(135deg,#F0FDF4 0%,#FFF 100%)">
      <div style="font-size:11px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">CASHBACK ACUMULADO</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#166534;margin-top:6px">{fmtMoney((cashbackTop || []).reduce((a: number, c: any) => a + Number(c.saldo_cashback || 0), 0))}</div>
    </div>
  </div>

  <div class="card" style="margin-bottom:18px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
      <strong style="font-size:14px">Cupons cadastrados</strong>
      <button class="btn btn-primary btn-sm" onclick="abrirModal()">+ Novo cupom</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Código</th><th>Tipo</th><th>Desc.</th><th>Cashback</th><th>Duração</th><th>Dono</th><th>Acumulado</th><th>Usos</th><th>Validade</th><th>Status</th></tr></thead>
        <tbody>
          {(cupons || []).map((c: any) => {
            const isRep = c.tipo === "representante" && c.representante;
            const isCliente = c.cliente_dono;
            const donoNome = isRep ? c.representante.nome : (isCliente ? c.cliente_dono.nome : "—");
            const donoSaldo = isRep
              ? Number(c.representante.saldo_acumulado || 0)
              : (isCliente ? Number(c.cliente_dono.saldo_cashback || 0) : 0);
            return (
              <tr>
                <td><code style="font-weight:700;color:#C41E3A">{c.codigo}</code></td>
                <td><span style={`background:${tipoCor[c.tipo]||'#9CA3AF'}22;color:${tipoCor[c.tipo]||'#9CA3AF'};padding:3px 8px;border-radius:99px;font-size:11px;font-weight:700;text-transform:uppercase`}>{tipoLabel[c.tipo] || c.tipo}</span></td>
                <td>{Number(c.desconto_percentual)}%</td>
                <td>{Number(c.cashback_pct || 0)}%</td>
                <td style="font-size:12.5px">{Number(c.duracao_meses || 1)}{Number(c.duracao_meses || 1) === 1 ? " mês" : " meses"}</td>
                <td style="font-size:12.5px">{donoNome}{isRep && <span style="font-size:10px;color:#9333EA;margin-left:4px">REP</span>}</td>
                <td style={`font-weight:700;color:${donoSaldo > 0 ? "#92400E" : "#9CA3AF"};font-size:12.5px`}>{donoSaldo > 0 ? fmtMoney(donoSaldo) : "—"}</td>
                <td>{c.usos_atuais}{c.usos_maximos ? ` / ${c.usos_maximos}` : ""}</td>
                <td style="font-size:12.5px;color:#5B5F6B">{c.validade ? fmtDate(c.validade) : "Sem validade"}</td>
                <td>{c.ativo
                  ? <span class="badge" style="background:#DCFCE7;color:#166534">Ativo</span>
                  : <span class="badge" style="background:#F3F4F6;color:#6B7280">Inativo</span>}</td>
              </tr>
            );
          })}
          {!(cupons || []).length && <tr><td colspan="10" style="text-align:center;color:#9CA3AF;padding:24px">Nenhum cupom cadastrado</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1.4fr 0.6fr;gap:18px">
    <div class="card">
      <strong style="font-size:14px">Histórico de usos (últimos 100)</strong>
      <div class="table-wrap" style="margin-top:12px">
        <table>
          <thead><tr><th>Data</th><th>Cupom</th><th>Quem usou</th><th>Indicador</th><th>Compra</th><th>Cashback gerado</th></tr></thead>
          <tbody>
            {(usos || []).map((u: any) => (
              <tr>
                <td style="font-size:12.5px">{fmtDate(u.created_at)}</td>
                <td><code>{u.cupom?.codigo || "—"}</code></td>
                <td style="font-size:12.5px">{u.quem_usou?.nome || "—"}</td>
                <td style="font-size:12.5px;color:#5B5F6B">{u.dono?.nome || "—"}</td>
                <td>{fmtMoney(u.valor_compra)}</td>
                <td style="color:#166534;font-weight:700">{Number(u.cashback_gerado) > 0 ? "+ " + fmtMoney(u.cashback_gerado) : "—"}</td>
              </tr>
            ))}
            {!(usos || []).length && <tr><td colspan="6" style="text-align:center;color:#9CA3AF;padding:24px">Nenhum uso registrado</td></tr>}
          </tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <strong style="font-size:14px">Top clientes — saldo cashback</strong>
      <div style="margin-top:12px">
        {(cashbackTop || []).map((c: any) => (
          <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #F3F4F6;font-size:13px">
            <div>
              <strong>{c.nome}</strong>
              <div style="font-size:11px;color:#9CA3AF">{c.email}</div>
            </div>
            <strong style="color:#166534">{fmtMoney(c.saldo_cashback)}</strong>
          </div>
        ))}
        {!(cashbackTop || []).length && <p style="color:#9CA3AF;font-size:12.5px;text-align:center;padding:14px 0;margin:0">Nenhum cliente com cashback acumulado</p>}
      </div>
    </div>
  </div>

  <!-- Modal novo cupom -->
  <div class="modal-overlay" id="modalCupom">
    <div class="modal">
      <div class="modal-title">Novo cupom</div>
      <form id="formCupom">
        <div class="form-group">
          <label>Tipo *</label>
          <select id="cupomTipo" required>
            <option value="desconto">Desconto (sem dono)</option>
            <option value="indicacao">Indicação (cliente indica cliente — cashback no indicador)</option>
            <option value="representante">Representante (parceiro externo divulga — comissão no representante)</option>
            <option value="nova_loja">Nova loja</option>
          </select>
        </div>

        <div class="form-group"><label>Código *</label><input id="cupomCodigo" required style="text-transform:uppercase" placeholder="EX: TESTE10" /></div>
        <div class="form-group"><label>Descrição</label><input id="cupomDesc" placeholder="Opcional — aparece para o cliente" /></div>

        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
          <div class="form-group"><label>Desconto % *</label><input id="cupomDesconto" type="number" step="0.01" min="1" max="100" required /></div>
          <div class="form-group"><label>Cashback %</label><input id="cupomCashback" type="number" step="0.01" min="0" max="100" value="0" /></div>
          <div class="form-group"><label>Duração (meses) *</label><input id="cupomDuracao" type="number" min="1" max="36" value="1" required /></div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label>Usos máximos (opcional)</label><input id="cupomUsos" type="number" min="1" placeholder="Em branco = ilimitado" /></div>
          <div class="form-group"><label>Validade (opcional)</label><input id="cupomValidade" type="date" /></div>
        </div>

        <!-- Bloco condicional: Dono cliente -->
        <div class="form-group" id="grupoDonoCliente" style="display:none">
          <label>Email do cliente indicador *</label>
          <input id="cupomDonoClienteEmail" type="email" placeholder="email@cliente.com — o cashback será creditado neste cliente" />
          <div style="font-size:11px;color:#5B5F6B;margin-top:4px">O cliente precisa estar cadastrado em Clientes. Validamos antes de salvar.</div>
        </div>

        <!-- Bloco condicional: Dono representante -->
        <div class="form-group" id="grupoDonoRep" style="display:none">
          <label>Representante *</label>
          <select id="cupomDonoRep">
            <option value="">Selecione um representante…</option>
            {(representantes || []).map((r: any) => (
              <option value={r.id}>{r.nome} ({r.email})</option>
            ))}
          </select>
          {!(representantes || []).length && <div style="font-size:11px;color:#92400E;margin-top:4px">⚠ Nenhum representante ativo. <a href="/admin/representantes" style="color:#C41E3A;text-decoration:underline">Cadastre primeiro</a>.</div>}
        </div>

        <div style="background:#F4F6F9;padding:10px 14px;border-radius:8px;margin-top:6px;font-size:12px;color:#5B5F6B" id="cupomDicaDuracao">
          💡 <strong>Duração:</strong> se mais de 1 mês, o cliente recebe o desconto no 1º mês <em>e</em> crédito automático de cashback nos próximos meses (até completar o total).
        </div>

        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fechar()">Cancelar</button>
          <button type="submit" class="btn btn-primary">Criar cupom</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function abrirModal() {
      (document.getElementById("formCupom") as HTMLFormElement).reset();
      (document.getElementById("cupomTipo") as HTMLSelectElement).value = "desconto";
      (document.getElementById("cupomCashback") as HTMLInputElement).value = "0";
      (document.getElementById("cupomDuracao") as HTMLInputElement).value = "1";
      toggleDono();
      document.getElementById("modalCupom")!.classList.add("open");
    }
    function fechar() { document.getElementById("modalCupom")!.classList.remove("open"); }
    function toggleDono() {
      const tipo = (document.getElementById("cupomTipo") as HTMLSelectElement).value;
      const grpCli = document.getElementById("grupoDonoCliente")!;
      const grpRep = document.getElementById("grupoDonoRep")!;
      grpCli.style.display = tipo === "indicacao" ? "" : "none";
      grpRep.style.display = tipo === "representante" ? "" : "none";
    }
    (window as any).abrirModal = abrirModal;
    (window as any).fechar = fechar;
    (window as any).toggleDono = toggleDono;
    document.getElementById("cupomTipo")!.addEventListener("change", toggleDono);

    document.getElementById("formCupom")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const tipo = (document.getElementById("cupomTipo") as HTMLSelectElement).value;
      const body: any = {
        codigo: (document.getElementById("cupomCodigo") as HTMLInputElement).value.trim().toUpperCase(),
        descricao: (document.getElementById("cupomDesc") as HTMLInputElement).value || null,
        desconto_percentual: parseFloat((document.getElementById("cupomDesconto") as HTMLInputElement).value),
        cashback_pct: parseFloat((document.getElementById("cupomCashback") as HTMLInputElement).value || "0"),
        duracao_meses: parseInt((document.getElementById("cupomDuracao") as HTMLInputElement).value || "1"),
        usos_maximos: (document.getElementById("cupomUsos") as HTMLInputElement).value ? parseInt((document.getElementById("cupomUsos") as HTMLInputElement).value) : null,
        validade: (document.getElementById("cupomValidade") as HTMLInputElement).value || null,
        tipo,
      };

      if (tipo === "indicacao") {
        const email = (document.getElementById("cupomDonoClienteEmail") as HTMLInputElement).value.trim().toLowerCase();
        if (!email) { alert("Email do cliente indicador é obrigatório"); return; }
        body.cliente_dono_email = email;
      } else if (tipo === "representante") {
        const repId = (document.getElementById("cupomDonoRep") as HTMLSelectElement).value;
        if (!repId) { alert("Selecione um representante"); return; }
        body.representante_id = repId;
      }

      const res = await fetch("/api/admin/cupons", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
      });
      if (res.ok) { window.location.reload(); }
      else { const d = await res.json().catch(() => ({})); alert(d.error || "Erro ao criar cupom"); }
    });
  </script>
</Admin>
