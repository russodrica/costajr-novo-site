---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
let claims: AdminClaims;
try { claims = await verifyToken<AdminClaims>(token); if (claims.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }
if (claims.role !== "admin") return Astro.redirect("/admin");
---
<Admin title="Bots Telegram" current="telegram">
  <div class="toolbar"><span class="toolbar-title">🤖 Bots do Telegram</span></div>

  <div class="card" style="padding:20px;max-width:780px">
    <p style="margin:0 0 14px;font-size:1.02rem">São <strong>dois bots</strong>, com públicos separados. A pessoa é sempre identificada pelo <strong>telefone cadastrado na ficha do RH</strong> (empresa ou pessoal).</p>

    <div style="background:#F0F7FF;border:1px solid #DBEAFE;border-radius:10px;padding:14px 16px;margin-bottom:12px">
      <strong style="font-size:.95rem">📦 Bot de Ativos — <code>@cjr_ativo_bot</code> (todo o time)</strong>
      <p style="margin:6px 0 0;font-size:.9rem;line-height:1.6;color:var(--ink-mid)">Registrar movimentação de equipamento: <code>/start</code> → compartilhar telefone → buscar o equipamento → <em>Devolvi ao estoque · Levei para obra · Está com defeito · Entreguei p/ pessoa</em>.</p>
    </div>

    <div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:10px;padding:14px 16px;margin-bottom:12px">
      <strong style="font-size:.95rem">📄 Bot de RH — <code>@cjr_adm_bot</code> (só RH/Admin)</strong>
      <p style="margin:6px 0 0;font-size:.9rem;line-height:1.6;color:var(--ink-mid)"><strong>Enviar documento</strong> (foto/PDF → a IA sugere e você confirma → ficha) e <strong>Alimentar a base</strong> (texto → vira pergunta/resposta na JunIA). Também atende <strong>grupos</strong>: <code>/ativar_grupo</code> (documentos) e <code>/ativar_base</code> (base + perguntas sem resposta).</p>
    </div>

    <div style="background:#FBF0FF;border:1px solid #E9D5FF;border-radius:10px;padding:14px 16px;margin-bottom:16px">
      <strong style="font-size:.95rem">🤖 Bot da JunIA — <code>@CjrJunIA_bot</code> (todo o time)</strong>
      <p style="margin:6px 0 0;font-size:.9rem;line-height:1.6;color:var(--ink-mid)">Qualquer colaborador pergunta no privado e a <strong>JunIA responde na hora</strong> (pela base). Se ela não souber, a pergunta cai no <strong>grupo da Base</strong>; vocês respondem a mensagem por lá, o bot <strong>devolve a resposta pra quem perguntou</strong> e propõe adicionar à base. Requer a var <code>TELEGRAM_BOT_TOKEN_JUNIA</code> na Vercel.</p>
    </div>

    <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
      <button class="btn btn-primary" id="btnAtivar" onclick="ativar()">⚡ Ativar / Reativar os bots</button>
      <button class="btn btn-secondary" id="btnStatus" onclick="verStatus()">🔍 Ver status</button>
    </div>
    <div id="msg" style="margin-top:14px"></div>
    <pre id="out" style="margin-top:10px;background:#0F172A;color:#E2E8F0;border-radius:8px;padding:12px;font-size:12px;overflow:auto;display:none"></pre>

    <p style="margin:18px 0 0;color:var(--ink-light);font-size:.85rem">Obs.: "Ativar" registra os webhooks no Telegram (faça 1x; refaça só se mudar o domínio). O bot de RH precisa da var <code>TELEGRAM_BOT_TOKEN_ADM</code> na Vercel — se faltar, o status mostra "token ausente".</p>
  </div>

  <script>
    function show(html, ok) {
      const m = document.getElementById("msg");
      m.innerHTML = `<div class="alert ${ok ? "alert-success" : "alert-error"}">${html}</div>`;
    }
    function dump(obj) {
      const o = document.getElementById("out");
      o.style.display = "block"; o.textContent = JSON.stringify(obj, null, 2);
    }
    function linhaBot(nome, ok, extra) {
      return `<div>${ok ? "✅" : "⚠️"} <strong>${nome}</strong> — ${extra}</div>`;
    }
    async function ativar() {
      const b = document.getElementById("btnAtivar"); b.disabled = true; b.textContent = "Ativando...";
      try {
        const r = await fetch("/api/admin/telegram/configurar", { method: "POST", headers: { "content-type": "application/json" }, body: "{}" });
        const d = await r.json();
        const res = d.resultados || [];
        if (r.ok && res.length) {
          const html = res.map((x) => linhaBot(x.bot, x.ok, x.ok ? "ativado" : (x.motivo || x.telegram?.description || "falhou"))).join("");
          show(html, res.every((x) => x.ok));
        } else { show("⚠ Não ativou: " + (d.error || JSON.stringify(d)), false); }
        dump(d);
      } catch (e) { show("Erro: " + e, false); }
      b.disabled = false; b.textContent = "⚡ Ativar / Reativar os bots";
    }
    async function verStatus() {
      try {
        const r = await fetch("/api/admin/telegram/configurar");
        const d = await r.json();
        const infos = d.infos || [];
        if (infos.length) {
          const html = infos.map((x) => {
            if (!x.configurado) return linhaBot(x.bot, false, "token ausente na Vercel");
            const i = x.info || {};
            const extra = `<b>${x.username || "?"}</b> · ${i.url ? "webhook ok" : "sem webhook"}${i.pending_update_count ? ` · ${i.pending_update_count} pendentes` : ""}${i.last_error_message ? ` · erro: ${i.last_error_message}` : ""}`;
            return linhaBot(x.bot, !!i.url && !i.last_error_message, extra);
          }).join("");
          show(html, infos.every((x) => x.configurado && x.info?.url && !x.info?.last_error_message));
        } else { show("Sem informação. Toque em Ativar.", false); }
        dump(d);
      } catch (e) { show("Erro: " + e, false); }
    }
    (window as any).ativar = ativar;
    (window as any).verStatus = verStatus;
  </script>
</Admin>
