---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const filtroStatus = Astro.url.searchParams.get("status") || "";
const db = supabaseAdmin();
let q = db.from("manut_pagamentos").select("*, manut_clientes(nome, codigo)").order("data_vencimento", { ascending: false });
if (filtroStatus) q = q.eq("status", filtroStatus);
const { data: pagamentos } = await q;

const badgePg: Record<string, string> = { pendente: "badge-yellow", pago: "badge-green", atrasado: "badge-red", cancelado: "badge-gray" };
function fmtDate(d: string | null) { if (!d) return "—"; return new Date(d).toLocaleDateString("pt-BR"); }
function fmtMoney(v: number | null) { if (v == null) return "—"; return v.toLocaleString("pt-BR", { style: "currency", currency: "BRL" }); }

// Totais
const total     = pagamentos?.reduce((s, p) => s + (p.valor || 0), 0) ?? 0;
const totalPago = pagamentos?.filter(p => p.status === "pago").reduce((s, p) => s + (p.valor || 0), 0) ?? 0;
const totalAtr  = pagamentos?.filter(p => p.status === "atrasado").reduce((s, p) => s + (p.valor || 0), 0) ?? 0;
---
<Admin title="Pagamentos" current="pagamentos">
  <!-- Totais -->
  <div class="card-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px">
    <div class="stat-card"><div class="stat-value" style="color:#22C55E">{fmtMoney(totalPago)}</div><div class="stat-label">Total recebido (filtro)</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#EF4444">{fmtMoney(totalAtr)}</div><div class="stat-label">Em atraso (filtro)</div></div>
    <div class="stat-card"><div class="stat-value">{fmtMoney(total)}</div><div class="stat-label">Total no filtro</div></div>
  </div>

  <div class="toolbar">
    <span class="toolbar-title">Pagamentos ({pagamentos?.length ?? 0})</span>
    <select class="filter-select" onchange="filtrar(this.value)">
      <option value="" selected={!filtroStatus}>Todos</option>
      {["pendente","pago","atrasado","cancelado"].map(s => <option value={s} selected={s===filtroStatus}>{s}</option>)}
    </select>
    <input class="search-input" type="search" placeholder="Buscar cliente, referência…" oninput="buscar(this.value)" />
  </div>

  <div class="card">
    <div class="table-wrap">
      <table id="tabela">
        <thead><tr><th>Cliente</th><th>Código</th><th>Referência</th><th>Valor</th><th>Vencimento</th><th>Pagamento</th><th>Status</th><th>Ação</th></tr></thead>
        <tbody>
          {pagamentos?.length ? pagamentos.map((p: any) => (
            <tr data-search={`${(p.manut_clientes as any)?.nome ?? ""} ${p.referencia ?? ""}`.toLowerCase()}>
              <td>{(p.manut_clientes as any)?.nome ?? "—"}</td>
              <td><code style="font-size:0.8rem">{(p.manut_clientes as any)?.codigo ?? "—"}</code></td>
              <td>{p.referencia || "—"}</td>
              <td><strong>{fmtMoney(p.valor)}</strong></td>
              <td>{fmtDate(p.data_vencimento)}</td>
              <td>{fmtDate(p.data_pagamento)}</td>
              <td><span class={`badge ${badgePg[p.status]}`}>{p.status}</span></td>
              <td>
                {p.status !== "pago" && p.status !== "cancelado" && (
                  <button class="btn btn-success btn-sm" onclick={`marcarPago('${p.id}')`}>Marcar pago</button>
                )}
                {p.status !== "cancelado" && (
                  <button class="btn btn-danger btn-sm" style="margin-left:4px" onclick={`cancelar('${p.id}')`}>Cancelar</button>
                )}
              </td>
            </tr>
          )) : <tr><td colspan="8" style="text-align:center;color:#999;padding:32px">Nenhum pagamento encontrado</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <script>
    function filtrar(s) {
      const url = new URL(window.location.href);
      if (s) url.searchParams.set("status", s); else url.searchParams.delete("status");
      window.location.href = url.toString();
    }
    function buscar(q) {
      document.querySelectorAll("#tabela tbody tr[data-search]").forEach(r => {
        r.style.display = r.dataset.search.includes(q.toLowerCase()) ? "" : "none";
      });
    }
    async function marcarPago(id) {
      const res = await fetch(`/api/admin/pagamentos/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ status: "pago", data_pagamento: new Date().toISOString() }) });
      if (res.ok) window.location.reload(); else alert("Erro ao atualizar");
    }
    async function cancelar(id) {
      if (!confirm("Cancelar este pagamento?")) return;
      const res = await fetch(`/api/admin/pagamentos/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ status: "cancelado" }) });
      if (res.ok) window.location.reload(); else alert("Erro ao cancelar");
    }
  </script>
</Admin>
