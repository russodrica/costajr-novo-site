---
// Se já tem cookie válido, redireciona pro dashboard
import { verifyToken, type AdminClaims } from "../../lib/auth";
const token = Astro.cookies.get("admin_token")?.value;
if (token) {
  try {
    const c = await verifyToken<AdminClaims>(token);
    if (c.tipo === "admin") return Astro.redirect("/admin");
  } catch {}
}
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — CJR Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <meta name="robots" content="noindex,nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Open Sans', sans-serif; background: #1C1E22; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-box { background: #fff; border-radius: 14px; padding: 40px 36px; width: 100%; max-width: 380px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
    .logo { font-family: 'Montserrat', sans-serif; font-size: 2rem; font-weight: 700; color: #C41E3A; text-align: center; }
    .logo-sub { text-align: center; font-size: 0.75rem; color: #888; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 28px; }
    label { display: block; font-size: 0.8rem; font-weight: 600; color: #555; margin-bottom: 5px; }
    input { width: 100%; padding: 10px 14px; border: 1px solid #D1D5DB; border-radius: 7px; font-size: 0.9rem; margin-bottom: 16px; outline: none; }
    input:focus { border-color: #C41E3A; box-shadow: 0 0 0 3px rgba(196,30,58,0.1); }
    button { width: 100%; padding: 11px; background: #C41E3A; color: #fff; border: none; border-radius: 7px; font-size: 0.95rem; font-weight: 600; cursor: pointer; font-family: 'Montserrat', sans-serif; margin-top: 4px; transition: opacity 0.15s; }
    button:hover { opacity: 0.9; }
    button:disabled { opacity: 0.6; cursor: not-allowed; }
    .error { background: #FEE2E2; color: #991B1B; border: 1px solid #FECACA; border-radius: 7px; padding: 10px 14px; font-size: 0.85rem; margin-bottom: 14px; display: none; }
  </style>
</head>
<body>
  <div class="login-box">
    <div class="logo">CJR</div>
    <div class="logo-sub">Painel Administrativo</div>
    <div class="error" id="err"></div>
    <form id="form">
      <label for="email">E-mail</label>
      <input type="email" id="email" name="email" required autocomplete="username" placeholder="adriana@costajr.com.br" />
      <label for="senha">Senha</label>
      <input type="password" id="senha" name="senha" required autocomplete="current-password" placeholder="••••••••" />
      <button type="submit" id="btn">Entrar</button>
    </form>
    <div style="text-align:center;margin-top:14px">
      <a href="#" id="linkForgot" style="font-size:0.8rem;color:#C41E3A;text-decoration:none;font-weight:600">Esqueci minha senha</a>
    </div>

    <!-- Bloco "Esqueci minha senha" (escondido por padrão) -->
    <div id="forgotBox" style="display:none;margin-top:18px;border-top:1px solid #eee;padding-top:18px">
      <div id="forgotMsg" style="display:none;border-radius:7px;padding:10px 14px;font-size:0.85rem;margin-bottom:12px"></div>
      <label for="forgotEmail">E-mail cadastrado</label>
      <input type="email" id="forgotEmail" placeholder="seu.email@costajr.com.br" autocomplete="username" />
      <button type="button" id="btnForgot">Enviar senha temporária</button>
      <div style="text-align:center;margin-top:10px">
        <a href="#" id="linkVoltar" style="font-size:0.8rem;color:#888;text-decoration:none">Voltar ao login</a>
      </div>
    </div>

    <!-- Verificação de novo dispositivo (OTP) — escondido por padrão -->
    <div id="otpBox" style="display:none;margin-top:18px;border-top:1px solid #eee;padding-top:18px">
      <p style="font-size:0.85rem;color:#555;margin-bottom:12px">🔒 Novo dispositivo detectado. Enviamos um código para <b id="otpDestino"></b>. Digite-o abaixo (vale 10 minutos).</p>
      <div class="error" id="otpErr"></div>
      <label for="otpCode">Código de 6 dígitos</label>
      <input type="text" id="otpCode" inputmode="numeric" maxlength="6" autocomplete="one-time-code" placeholder="000000" style="letter-spacing:6px;text-align:center;font-size:1.1rem" />
      <button type="button" id="btnOtp">Verificar e entrar</button>
    </div>
  </div>
  <script>
    document.getElementById("form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = document.getElementById("btn") as HTMLButtonElement;
      const err = document.getElementById("err") as HTMLElement;
      btn.disabled = true;
      btn.textContent = "Entrando...";
      err.style.display = "none";
      const email = (document.getElementById("email") as HTMLInputElement).value;
      const senha = (document.getElementById("senha") as HTMLInputElement).value;
      try {
        const res = await fetch("/api/admin/login", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ email, senha }),
        });
        if (res.ok) {
          const data = await res.json().catch(() => ({}));
          if (data.step === "otp") {
            challengeId = data.challenge_id || "";
            ($("otpDestino")).textContent = data.destino || "seu e-mail";
            formEl.style.display = "none";
            otpBox.style.display = "block";
            ($("otpCode") as HTMLInputElement).focus();
            btn.disabled = false; btn.textContent = "Entrar";
            return;
          }
          window.location.href = data.troca ? "/admin/trocar-senha?forcado=1" : "/admin";
        } else {
          const data = await res.json();
          err.textContent = data.error || "Credenciais inválidas";
          err.style.display = "block";
          btn.disabled = false;
          btn.textContent = "Entrar";
        }
      } catch {
        err.textContent = "Erro de conexão. Tente novamente.";
        err.style.display = "block";
        btn.disabled = false;
        btn.textContent = "Entrar";
      }
    });

    // ─── Esqueci minha senha ───────────────────────────────────────────
    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    const formEl = $("form");
    const forgotBox = $("forgotBox");
    const otpBox = $("otpBox");
    let challengeId = "";
    $("linkForgot")?.addEventListener("click", (e) => {
      e.preventDefault();
      formEl.style.display = "none";
      forgotBox.style.display = "block";
      ($("forgotEmail") as HTMLInputElement).value =
        ($("email") as HTMLInputElement).value || "";
    });
    $("linkVoltar")?.addEventListener("click", (e) => {
      e.preventDefault();
      forgotBox.style.display = "none";
      formEl.style.display = "block";
    });
    $("btnForgot")?.addEventListener("click", async () => {
      const btnF = $("btnForgot") as HTMLButtonElement;
      const msg = $("forgotMsg");
      const email = ($("forgotEmail") as HTMLInputElement).value.trim();
      if (!email) { msg.textContent = "Informe o e-mail."; msg.style.cssText = "display:block;background:#FEE2E2;color:#991B1B;border-radius:7px;padding:10px 14px;font-size:0.85rem;margin-bottom:12px"; return; }
      btnF.disabled = true; btnF.textContent = "Enviando...";
      try {
        const res = await fetch("/api/admin/forgot-senha", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ email }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok) {
          msg.textContent = data.message || "Se o e-mail estiver cadastrado, enviaremos uma senha temporária.";
          msg.style.cssText = "display:block;background:#DCFCE7;color:#166534;border-radius:7px;padding:10px 14px;font-size:0.85rem;margin-bottom:12px";
        } else {
          msg.textContent = data.error || "Não foi possível processar. Tente novamente.";
          msg.style.cssText = "display:block;background:#FEE2E2;color:#991B1B;border-radius:7px;padding:10px 14px;font-size:0.85rem;margin-bottom:12px";
        }
      } catch {
        msg.textContent = "Erro de conexão. Tente novamente.";
        msg.style.cssText = "display:block;background:#FEE2E2;color:#991B1B;border-radius:7px;padding:10px 14px;font-size:0.85rem;margin-bottom:12px";
      } finally {
        btnF.disabled = false; btnF.textContent = "Enviar senha temporária";
      }
    });

    // ─── Verificação de novo dispositivo (OTP) ─────────────────────────
    $("btnOtp")?.addEventListener("click", async () => {
      const b = $("btnOtp") as HTMLButtonElement;
      const oe = $("otpErr");
      const code = ($("otpCode") as HTMLInputElement).value.trim();
      if (!/^\d{6}$/.test(code)) { oe.textContent = "Digite os 6 dígitos do código."; oe.style.display = "block"; return; }
      b.disabled = true; b.textContent = "Verificando...";
      oe.style.display = "none";
      try {
        const res = await fetch("/api/admin/login-otp", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ challenge_id: challengeId, code }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok) {
          window.location.href = data.troca ? "/admin/trocar-senha?forcado=1" : "/admin";
        } else {
          oe.textContent = data.error || "Código incorreto.";
          oe.style.display = "block";
          b.disabled = false; b.textContent = "Verificar e entrar";
        }
      } catch {
        oe.textContent = "Erro de conexão. Tente novamente.";
        oe.style.display = "block";
        b.disabled = false; b.textContent = "Verificar e entrar";
      }
    });
  </script>
</body>
</html>
