---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";
import { AREAS_PORTAL, CATEGORIAS_KB, PERFIS } from "../../lib/permissoes";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const db = supabaseAdmin();
const { data: linhas, error: permErro } = await db.from("portal_permissoes").select("*");
const mapa: Record<string, { areas: string[]; categorias_kb: string[] }> = {};
for (const l of linhas || []) mapa[l.perfil] = { areas: l.areas || [], categorias_kb: l.categorias_kb || [] };

const perfilLabel: Record<string, string> = {
  admin: "Administrador", manutencao_operacao: "Manutenção - Operação",
  manutencao_administrativo: "Manutenção - Administrativo", operacional: "Operação",
  rh: "RH / DP", financeiro: "Financeiro", comercial: "Comercial", juridico: "Jurídico",
};
---
<Admin title="Permissões de Acesso" current="permissoes">

  <div class="perm-tabs">
    <button type="button" class="perm-tab active" data-tab="perfil" onclick="trocarTabPerm('perfil')">👥 Por perfil (portal)</button>
    <button type="button" class="perm-tab" data-tab="usuario" onclick="trocarTabPerm('usuario')">👤 Por usuário (admin) — ajuste fino</button>
  </div>

  <div id="tab-perfil">
  {permErro && <div class="alert alert-error">Erro ao carregar permissões: {permErro.message}. Rode a migration <code>031_permissoes.sql</code> no Supabase.</div>}

  <div class="section-header">
    <div>
      <span class="section-title">Liberações por perfil</span>
      <p style="font-size:13px;color:var(--ink-mid);margin:4px 0 0">Marque o que cada perfil pode acessar no Portal do Colaborador. Quem tem mais de um perfil soma as liberações. <strong>Admin sempre tem acesso total.</strong></p>
    </div>
    <button class="btn btn-primary" onclick="salvarPermissoes()">💾 Salvar alterações</button>
  </div>

  <div id="msgPerm"></div>

  <!-- Módulos do portal -->
  <div class="card" style="margin-bottom:20px;padding:0;overflow:hidden">
    <div class="perm-head">📱 Módulos do Portal</div>
    <div class="table-wrap">
      <table class="perm-table">
        <thead>
          <tr>
            <th>Perfil</th>
            {AREAS_PORTAL.map(a => <th style="text-align:center">{a.label}</th>)}
          </tr>
        </thead>
        <tbody>
          {PERFIS.map(p => (
            <tr>
              <td><strong style="text-transform:capitalize">{perfilLabel[p] || p}</strong>{p === "admin" && <span class="badge badge-gray" style="margin-left:6px">total</span>}</td>
              {AREAS_PORTAL.map(a => (
                <td style="text-align:center">
                  <input type="checkbox" class="perm-check" data-perfil={p} data-tipo="area" data-valor={a.id}
                    checked={p === "admin" ? true : (mapa[p]?.areas || []).includes(a.id)}
                    disabled={p === "admin"} />
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Categorias da KB -->
  <div class="card" style="padding:0;overflow:hidden">
    <div class="perm-head">🔍 Categorias da Base de Conhecimento (Fórum/JunIA)</div>
    <div class="table-wrap">
      <table class="perm-table">
        <thead>
          <tr>
            <th>Perfil</th>
            {CATEGORIAS_KB.map(c => <th style="text-align:center;font-size:.65rem">{c}</th>)}
          </tr>
        </thead>
        <tbody>
          {PERFIS.map(p => (
            <tr>
              <td><strong style="text-transform:capitalize">{perfilLabel[p] || p}</strong></td>
              {CATEGORIAS_KB.map(c => (
                <td style="text-align:center">
                  <input type="checkbox" class="perm-check" data-perfil={p} data-tipo="cat" data-valor={c}
                    checked={p === "admin" ? true : (mapa[p]?.categorias_kb || []).includes(c)}
                    disabled={p === "admin"} />
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <p style="font-size:12.5px;color:var(--ink-light);margin-top:14px">
    💡 Obs.: a categoria <strong>Trabalhista</strong> tem uma trava extra individual — além do perfil liberar a categoria,
    o membro precisa do "⚖️ trabalhista" dado na tela de Membros.
  </p>
  </div><!-- /tab-perfil -->

  <div id="tab-usuario" style="display:none">
    <div class="section-header">
      <div>
        <span class="section-title">Permissões por usuário</span>
        <p style="font-size:13px;color:var(--ink-mid);margin:4px 0 0">Ajuste fino: por pessoa, o acesso a cada módulo do admin. <strong>Herdar</strong> = padrão do perfil · <strong>Ver</strong> = só leitura · <strong>Editar</strong> = completo · <strong>Nenhum</strong> = bloqueia mesmo que o perfil libere. (Admin sempre tem acesso total.)</p>
      </div>
      <button class="btn btn-primary" onclick="salvarMatriz()" id="btnSalvarMatriz">💾 Salvar</button>
    </div>
    <div id="msgMatriz"></div>
    <div class="perm-legenda">
      <span><b class="lg lg-herdar">Herdar</b> padrão do perfil</span>
      <span><b class="lg lg-ver">👁 Ver</b> só leitura</span>
      <span><b class="lg lg-editar">✎ Editar</b> completo</span>
      <span><b class="lg lg-nenhum">✕ Nenhum</b> bloqueado</span>
      <span style="color:var(--ink-light)">Clique na célula p/ alternar.</span>
    </div>
    <div id="matrizUsuarios"><div class="loading"><div class="spinner"></div> Carregando…</div></div>
  </div>

  <style>
    .perm-head { font-family: 'Montserrat', sans-serif; font-size: .85rem; font-weight: 700; padding: 14px 18px; border-bottom: 1px solid var(--border); background: #F8F9FB; }
    .perm-table th { font-size: .68rem; }
    .perm-table td { padding: 9px 12px; }
    .perm-check { width: 17px; height: 17px; accent-color: #C41E3A; cursor: pointer; }
    .perm-check:disabled { opacity: .45; cursor: not-allowed; }
    .perm-table tbody tr:hover td { background: rgba(196,30,58,.03); }

    /* ── Abas + matriz por usuário ── */
    .perm-tabs { display:flex; gap:6px; margin-bottom:18px; border-bottom:2px solid var(--border); }
    .perm-tab { background:none; border:0; padding:10px 16px; font-family:'Montserrat',sans-serif; font-weight:700; font-size:14px; color:var(--ink-light); cursor:pointer; border-bottom:3px solid transparent; margin-bottom:-2px; }
    .perm-tab.active { color:var(--brand); border-bottom-color:var(--brand); }
    .perm-legenda { display:flex; gap:14px; flex-wrap:wrap; font-size:12.5px; color:var(--ink-mid); margin:0 0 14px; align-items:center; }
    .perm-legenda .lg { padding:2px 8px; border-radius:6px; font-weight:700; }
    .lg-herdar { background:#F1F5F9; color:#64748B; }
    .lg-ver { background:#EFF6FF; color:#1D4ED8; }
    .lg-editar { background:#F0FDF4; color:#15803D; }
    .lg-nenhum { background:#FEF2F2; color:#B91C1C; }
    .matriz-wrap { overflow-x:auto; border:1px solid var(--border); border-radius:10px; max-height:72vh; }
    .matriz { border-collapse:separate; border-spacing:0; font-size:13px; }
    .matriz th, .matriz td { border-bottom:1px solid var(--border-light); border-right:1px solid var(--border-light); }
    .matriz thead th { position:sticky; top:0; z-index:3; }
    .mtx-corner { position:sticky; left:0; z-index:4; background:#F1F3F7; text-align:left; padding:8px 12px; min-width:210px; font-size:11.5px; }
    .mtx-user { padding:8px 6px; font-size:11px; white-space:nowrap; background:#F1F3F7; min-width:88px; text-align:center; color:var(--ink-mid); }
    .mtx-grp td { background:#E8ECF3; font-weight:800; font-size:10.5px; text-transform:uppercase; letter-spacing:.05em; color:#475569; padding:6px 12px; }
    .mtx-mod { position:sticky; left:0; z-index:1; background:#fff; padding:5px 12px; white-space:nowrap; font-size:12.5px; }
    .matriz tbody tr:hover .mtx-mod { background:#FAFBFC; }
    .mtx-cel { text-align:center; padding:3px; }
    .cel { width:30px; height:27px; border:1px solid transparent; border-radius:6px; cursor:pointer; font-size:13px; font-weight:700; line-height:1; }
    .cel:disabled { opacity:.55; cursor:not-allowed; }
    .cel-herdar { background:#F1F5F9; color:#94A3B8; }
    .cel-ver { background:#DBEAFE; color:#1D4ED8; }
    .cel-editar { background:#DCFCE7; color:#15803D; }
    .cel-nenhum { background:#FEE2E2; color:#B91C1C; }
  </style>

  <script>
    async function salvarPermissoes() {
      const porPerfil: Record<string, { perfil: string; areas: string[]; categorias_kb: string[] }> = {};
      document.querySelectorAll(".perm-check").forEach((cb: any) => {
        const p = cb.dataset.perfil;
        if (!porPerfil[p]) porPerfil[p] = { perfil: p, areas: [], categorias_kb: [] };
        if (cb.checked) {
          if (cb.dataset.tipo === "area") porPerfil[p].areas.push(cb.dataset.valor);
          else porPerfil[p].categorias_kb.push(cb.dataset.valor);
        }
      });
      const res = await fetch("/api/admin/permissoes", {
        method: "PUT",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ permissoes: Object.values(porPerfil) }),
      });
      const d = await res.json().catch(() => ({}));
      const msg = document.getElementById("msgPerm")!;
      msg.innerHTML = res.ok
        ? `<div class="alert alert-success">✅ Permissões salvas! Os colaboradores verão o efeito no próximo carregamento do portal.</div>`
        : `<div class="alert alert-error">${d.error || "Erro ao salvar"}</div>`;
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
    (window as any).salvarPermissoes = salvarPermissoes;
  </script>

  <script>
    // ── Matriz de permissões por usuário ──
    let MTX: any = null;
    const CICLO = ["herdar", "ver", "editar", "nenhum"];
    const escP = (s: any) => String(s == null ? "" : s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");

    function trocarTabPerm(t: string) {
      document.getElementById("tab-perfil")!.style.display = t === "perfil" ? "" : "none";
      document.getElementById("tab-usuario")!.style.display = t === "usuario" ? "" : "none";
      document.querySelectorAll(".perm-tab").forEach((b: any) => b.classList.toggle("active", b.dataset.tab === t));
      if (t === "usuario" && !MTX) carregarMatriz();
    }

    async function carregarMatriz() {
      const box = document.getElementById("matrizUsuarios")!;
      try {
        const r = await fetch("/api/admin/permissoes-usuarios");
        const d = await r.json();
        if (!r.ok) throw new Error(d.error || "Erro");
        MTX = d;
        renderMatriz();
      } catch (e: any) { box.innerHTML = `<div class="alert alert-error">Erro ao carregar: ${escP(e.message)}</div>`; }
    }

    function celInfo(nivel: string, pad: string): [string, string, string] {
      if (nivel === "ver") return ["👁", "cel-ver", "Ver (só leitura)"];
      if (nivel === "editar") return ["✎", "cel-editar", "Editar (completo)"];
      if (nivel === "nenhum") return ["✕", "cel-nenhum", "Nenhum (bloqueado)"];
      return [pad === "editar" ? "✓" : "·", "cel-herdar", pad === "editar" ? "Herda do perfil — TEM acesso" : "Herda do perfil — sem acesso"];
    }

    function renderMatriz() {
      const { usuarios, grupos, overrides, padrao } = MTX;
      const ehAdmin = (u: any) => u.perfis.includes("admin");
      let h = '<div class="matriz-wrap"><table class="matriz"><thead><tr><th class="mtx-corner">Módulo</th>';
      for (const u of usuarios) h += `<th class="mtx-user" title="${escP(u.email)}">${escP(u.nome.split(" ").slice(0, 2).join(" "))}${ehAdmin(u) ? '<br><span class="badge badge-gray">admin</span>' : ""}</th>`;
      h += "</tr></thead><tbody>";
      for (const g of grupos) {
        if (g.label) h += `<tr class="mtx-grp"><td colspan="${usuarios.length + 1}">${escP(g.label)}</td></tr>`;
        for (const m of g.itens) {
          h += `<tr><td class="mtx-mod">${m.icon || ""} ${escP(m.label)}</td>`;
          for (const u of usuarios) {
            if (ehAdmin(u)) { h += `<td class="mtx-cel"><button type="button" class="cel cel-editar" disabled title="Admin tem acesso total">✎</button></td>`; continue; }
            const niv = (overrides[u.id] && overrides[u.id][m.key]) || "herdar";
            const pad = (padrao[u.id] || {})[m.key] || "nenhum";
            const [txt, cls, tip] = celInfo(niv, pad);
            h += `<td class="mtx-cel"><button type="button" class="cel ${cls}" data-uid="${u.id}" data-mod="${m.key}" data-niv="${niv}" data-pad="${pad}" title="${tip}" onclick="cicloCel(this)">${txt}</button></td>`;
          }
          h += "</tr>";
        }
      }
      h += "</tbody></table></div>";
      document.getElementById("matrizUsuarios")!.innerHTML = h;
    }

    function cicloCel(btn: any) {
      const i = CICLO.indexOf(btn.dataset.niv);
      const prox = CICLO[(i + 1) % CICLO.length];
      btn.dataset.niv = prox;
      const [txt, cls, tip] = celInfo(prox, btn.dataset.pad);
      btn.className = "cel " + cls; btn.textContent = txt; btn.title = tip;
    }

    async function salvarMatriz() {
      if (!MTX) return;
      const usuarios = MTX.usuarios.filter((u: any) => !u.perfis.includes("admin")).map((u: any) => u.id);
      const overrides: any[] = [];
      document.querySelectorAll("#matrizUsuarios .cel[data-uid]").forEach((b: any) => {
        if (b.dataset.niv !== "herdar") overrides.push({ profile_id: b.dataset.uid, modulo: b.dataset.mod, nivel: b.dataset.niv });
      });
      const btn = document.getElementById("btnSalvarMatriz") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Salvando...";
      try {
        const r = await fetch("/api/admin/permissoes-usuarios", { method: "PUT", headers: { "content-type": "application/json" }, body: JSON.stringify({ usuarios, overrides }) });
        const d = await r.json();
        document.getElementById("msgMatriz")!.innerHTML = r.ok
          ? `<div class="alert alert-success">✅ Salvo! ${d.regras} regra(s) específica(s). Cada pessoa vê o efeito no próximo carregamento da página.</div>`
          : `<div class="alert alert-error">${escP(d.error || "Erro")}</div>`;
        window.scrollTo({ top: 0, behavior: "smooth" });
      } catch (e: any) { document.getElementById("msgMatriz")!.innerHTML = `<div class="alert alert-error">${escP(e.message)}</div>`; }
      finally { btn.disabled = false; btn.textContent = "💾 Salvar"; }
    }

    (window as any).trocarTabPerm = trocarTabPerm;
    (window as any).cicloCel = cicloCel;
    (window as any).salvarMatriz = salvarMatriz;
  </script>
</Admin>
