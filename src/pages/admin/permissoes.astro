---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";
import { AREAS_PORTAL, CATEGORIAS_KB, PERFIS } from "../../lib/permissoes";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const db = supabaseAdmin();
const { data: linhas, error: permErro } = await db.from("portal_permissoes").select("*");
const mapa: Record<string, { areas: string[]; categorias_kb: string[] }> = {};
for (const l of linhas || []) mapa[l.perfil] = { areas: l.areas || [], categorias_kb: l.categorias_kb || [] };

const perfilLabel: Record<string, string> = {
  admin: "Administrador", manutencao_operacao: "Manutenção - Operação",
  manutencao_administrativo: "Manutenção - Administrativo", operacional: "Operação",
  rh: "RH / DP", financeiro: "Financeiro", comercial: "Comercial", juridico: "Jurídico",
};
---
<Admin title="Permissões de Acesso" current="permissoes">

  <div class="perm-tabs">
    <button type="button" class="perm-tab active" data-tab="perfil" onclick="trocarTabPerm('perfil')">👥 Por perfil (portal)</button>
    <button type="button" class="perm-tab" data-tab="usuario" onclick="trocarTabPerm('usuario')">👤 Por usuário (admin) — ajuste fino</button>
  </div>

  <div id="tab-perfil">
  {permErro && <div class="alert alert-error">Erro ao carregar permissões: {permErro.message}. Rode a migration <code>031_permissoes.sql</code> no Supabase.</div>}

  <div class="section-header">
    <div>
      <span class="section-title">Liberações por perfil</span>
      <p style="font-size:13px;color:var(--ink-mid);margin:4px 0 0">Marque o que cada perfil pode acessar no Portal do Colaborador. Quem tem mais de um perfil soma as liberações. <strong>Admin sempre tem acesso total.</strong></p>
    </div>
    <button class="btn btn-primary" onclick="salvarPermissoes()">💾 Salvar alterações</button>
  </div>

  <div id="msgPerm"></div>

  <!-- Módulos do portal -->
  <div class="card" style="margin-bottom:20px;padding:0;overflow:hidden">
    <div class="perm-head">📱 Módulos do Portal</div>
    <div class="table-wrap">
      <table class="perm-table">
        <thead>
          <tr>
            <th>Perfil</th>
            {AREAS_PORTAL.map(a => <th style="text-align:center">{a.label}</th>)}
          </tr>
        </thead>
        <tbody>
          {PERFIS.map(p => (
            <tr>
              <td><strong style="text-transform:capitalize">{perfilLabel[p] || p}</strong>{p === "admin" && <span class="badge badge-gray" style="margin-left:6px">total</span>}</td>
              {AREAS_PORTAL.map(a => (
                <td style="text-align:center">
                  <input type="checkbox" class="perm-check" data-perfil={p} data-tipo="area" data-valor={a.id}
                    checked={p === "admin" ? true : (mapa[p]?.areas || []).includes(a.id)}
                    disabled={p === "admin"} />
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Categorias da KB -->
  <div class="card" style="padding:0;overflow:hidden">
    <div class="perm-head">🔍 Categorias da Base de Conhecimento (Fórum/JunIA)</div>
    <div class="table-wrap">
      <table class="perm-table">
        <thead>
          <tr>
            <th>Perfil</th>
            {CATEGORIAS_KB.map(c => <th style="text-align:center;font-size:.65rem">{c}</th>)}
          </tr>
        </thead>
        <tbody>
          {PERFIS.map(p => (
            <tr>
              <td><strong style="text-transform:capitalize">{perfilLabel[p] || p}</strong></td>
              {CATEGORIAS_KB.map(c => (
                <td style="text-align:center">
                  <input type="checkbox" class="perm-check" data-perfil={p} data-tipo="cat" data-valor={c}
                    checked={p === "admin" ? true : (mapa[p]?.categorias_kb || []).includes(c)}
                    disabled={p === "admin"} />
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <p style="font-size:12.5px;color:var(--ink-light);margin-top:14px">
    💡 Obs.: a categoria <strong>Trabalhista</strong> tem uma trava extra individual — além do perfil liberar a categoria,
    o membro precisa do "⚖️ trabalhista" dado na tela de Membros.
  </p>
  </div><!-- /tab-perfil -->

  <div id="tab-usuario" style="display:none">
    <div class="section-header">
      <div>
        <span class="section-title">Permissão por colaborador</span>
        <p style="font-size:13px;color:var(--ink-mid);margin:4px 0 0">Escolha a pessoa e defina o que ela acessa. Ligue o <strong>departamento inteiro</strong> ou abra (▸) pra ajustar <strong>módulo a módulo</strong> — em cada um escolha <strong>👁 Ver</strong> (só leitura) ou <strong>✎ Editar</strong>. O que você não mexer <strong>segue o perfil</strong> da pessoa.</p>
      </div>
      <button class="btn btn-primary" id="btnSalvarPU" onclick="salvarPU()" style="display:none">💾 Salvar permissões</button>
    </div>
    <div class="pu-bar">
      <label style="font-size:13px;font-weight:600;color:var(--ink-mid)">Colaborador:</label>
      <select id="puUser" onchange="puSelecionar()"><option value="">— Selecione —</option></select>
    </div>
    <div id="msgPU"></div>
    <div id="permEditor"><p style="color:var(--ink-light);font-size:14px;padding:8px 0">Selecione um colaborador acima para configurar as permissões.</p></div>
  </div>

  <style is:global>
    .perm-head { font-family: 'Montserrat', sans-serif; font-size: .85rem; font-weight: 700; padding: 14px 18px; border-bottom: 1px solid var(--border); background: #F8F9FB; }
    .perm-table th { font-size: .68rem; }
    .perm-table td { padding: 9px 12px; }
    .perm-check { width: 17px; height: 17px; accent-color: #C41E3A; cursor: pointer; }
    .perm-check:disabled { opacity: .45; cursor: not-allowed; }
    .perm-table tbody tr:hover td { background: rgba(196,30,58,.03); }

    /* ── Abas + matriz por usuário ── */
    .perm-tabs { display:flex; gap:6px; margin-bottom:18px; border-bottom:2px solid var(--border); }
    .perm-tab { background:none; border:0; padding:10px 16px; font-family:'Montserrat',sans-serif; font-weight:700; font-size:14px; color:var(--ink-light); cursor:pointer; border-bottom:3px solid transparent; margin-bottom:-2px; }
    .perm-tab.active { color:var(--brand); border-bottom-color:var(--brand); }
    /* Editor por colaborador (estilo Vobi) */
    .pu-bar { display:flex; gap:10px; align-items:center; margin-bottom:14px; flex-wrap:wrap; }
    .pu-bar select { min-width:300px; max-width:420px; padding:9px 12px; border:1.5px solid var(--border); border-radius:8px; font-size:14px; background:#fff; }
    .pu-perfil { font-size:13px; color:var(--ink-mid); margin-bottom:14px; }
    .pu-admin-nota { background:#F0FDF4; border:1px solid #BBF7D0; color:#15803D; border-radius:8px; padding:12px 14px; font-size:14px; }
    .pu-dep { border:1px solid var(--border); border-radius:10px; margin-bottom:10px; overflow:hidden; }
    .pu-dep-head { display:flex; align-items:center; gap:10px; padding:12px 16px; cursor:pointer; background:#FAFBFC; user-select:none; }
    .pu-dep-head:hover { background:#F2F5F9; }
    .pu-chev { color:var(--ink-light); font-size:12px; transition:transform .15s; display:inline-block; }
    .pu-chev.open { transform:rotate(90deg); }
    .pu-dep-nome { font-family:'Montserrat',sans-serif; font-weight:700; font-size:14.5px; flex:1; }
    .pu-dep-resumo { font-size:12px; color:var(--ink-light); margin-right:4px; }
    .pu-dep-body { border-top:1px solid var(--border-light); }
    .pu-mod { display:flex; align-items:center; gap:12px; padding:10px 16px 10px 40px; border-bottom:1px solid var(--border-light); }
    .pu-mod:last-child { border-bottom:0; }
    .pu-mod-nome { flex:1; font-size:13.5px; color:var(--ink); }
    .pu-mod-ctrl { display:flex; align-items:center; gap:12px; }
    .pu-ve { display:inline-flex; border:1px solid var(--border); border-radius:7px; overflow:hidden; }
    .pu-ve-btn { background:#fff; border:0; padding:5px 11px; font-size:12px; cursor:pointer; color:var(--ink-mid); font-weight:600; font-family:'Open Sans',sans-serif; }
    .pu-ve-btn:hover { background:#F4F6F9; }
    .pu-ve-btn.on { background:var(--brand); color:#fff; }
    .pu-switch { position:relative; display:inline-block; width:40px; height:22px; flex-shrink:0; }
    .pu-switch input { opacity:0; width:0; height:0; }
    .pu-slider { position:absolute; cursor:pointer; inset:0; background:#CBD5E1; border-radius:22px; transition:.2s; }
    .pu-slider:before { content:""; position:absolute; height:16px; width:16px; left:3px; bottom:3px; background:#fff; border-radius:50%; transition:.2s; }
    .pu-switch input:checked + .pu-slider { background:#2563EB; }
    .pu-switch input:checked + .pu-slider:before { transform:translateX(18px); }
  </style>

  <script>
    async function salvarPermissoes() {
      const porPerfil: Record<string, { perfil: string; areas: string[]; categorias_kb: string[] }> = {};
      document.querySelectorAll(".perm-check").forEach((cb: any) => {
        const p = cb.dataset.perfil;
        if (!porPerfil[p]) porPerfil[p] = { perfil: p, areas: [], categorias_kb: [] };
        if (cb.checked) {
          if (cb.dataset.tipo === "area") porPerfil[p].areas.push(cb.dataset.valor);
          else porPerfil[p].categorias_kb.push(cb.dataset.valor);
        }
      });
      const res = await fetch("/api/admin/permissoes", {
        method: "PUT",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ permissoes: Object.values(porPerfil) }),
      });
      const d = await res.json().catch(() => ({}));
      const msg = document.getElementById("msgPerm")!;
      msg.innerHTML = res.ok
        ? `<div class="alert alert-success">✅ Permissões salvas! Os colaboradores verão o efeito no próximo carregamento do portal.</div>`
        : `<div class="alert alert-error">${d.error || "Erro ao salvar"}</div>`;
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
    (window as any).salvarPermissoes = salvarPermissoes;
  </script>

  <script>
    // ── Permissão por colaborador (estilo Vobi: departamento liga/desliga + abrir p/ módulos) ──
    let PUDATA: any = null, PUUID: string = "", PUSTATE: Record<string, string> = {}, PUOPEN = new Set<string>();
    const escP = (s: any) => String(s == null ? "" : s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    const ROTULO: Record<string, string> = {
      admin: "Administrador", manutencao_operacao: "Manutenção - Operação", manutencao_administrativo: "Manutenção - Administrativo",
      operacional: "Operação", rh: "RH / DP", financeiro: "Financeiro", comercial: "Comercial", juridico: "Jurídico", coordenador: "Coordenador",
    };
    const rotulo = (p: string) => ROTULO[p] || p;

    function trocarTabPerm(t: string) {
      document.getElementById("tab-perfil")!.style.display = t === "perfil" ? "" : "none";
      document.getElementById("tab-usuario")!.style.display = t === "usuario" ? "" : "none";
      document.querySelectorAll(".perm-tab").forEach((b: any) => b.classList.toggle("active", b.dataset.tab === t));
      if (t === "usuario" && !PUDATA) carregarPU();
    }

    async function carregarPU() {
      try {
        const r = await fetch("/api/admin/permissoes-usuarios");
        const d = await r.json();
        if (!r.ok) throw new Error(d.error || "Erro");
        PUDATA = d;
        const sel = document.getElementById("puUser") as HTMLSelectElement;
        sel.innerHTML = '<option value="">— Selecione —</option>' +
          d.usuarios.map((u: any) => `<option value="${u.id}">${escP(u.nome)}${u.perfis.includes("admin") ? " (admin)" : ""}</option>`).join("");
      } catch (e: any) { document.getElementById("permEditor")!.innerHTML = `<div class="alert alert-error">Erro ao carregar: ${escP(e.message)}</div>`; }
    }

    function nivelInicial(uid: string, key: string): string {
      const ov = PUDATA.overrides[uid] && PUDATA.overrides[uid][key];
      if (ov) return ov;
      return (PUDATA.padrao[uid] || {})[key] || "nenhum";
    }

    function puSelecionar() {
      PUUID = (document.getElementById("puUser") as HTMLSelectElement).value;
      document.getElementById("msgPU")!.innerHTML = "";
      const ed = document.getElementById("permEditor")!;
      const btn = document.getElementById("btnSalvarPU")!;
      if (!PUUID) { ed.innerHTML = `<p style="color:var(--ink-light);font-size:14px;padding:8px 0">Selecione um colaborador acima para configurar as permissões.</p>`; btn.style.display = "none"; PUSTATE = {}; return; }
      PUSTATE = {};
      for (const g of PUDATA.grupos) for (const m of g.itens) PUSTATE[m.key] = nivelInicial(PUUID, m.key);
      PUOPEN = new Set();
      btn.style.display = "";
      renderPU();
    }

    function renderPU() {
      const u = PUDATA.usuarios.find((x: any) => x.id === PUUID);
      const ed = document.getElementById("permEditor")!;
      const isAdmin = u.perfis.includes("admin");
      let h = `<div class="pu-perfil">Perfil base: <strong>${escP(u.perfis.map(rotulo).join(", ") || "—")}</strong></div>`;
      if (isAdmin) { ed.innerHTML = h + `<p class="pu-admin-nota">🛡️ Administrador tem acesso total a tudo — não há o que restringir aqui.</p>`; document.getElementById("btnSalvarPU")!.style.display = "none"; return; }
      for (const g of PUDATA.grupos) {
        const gl = g.label || "Geral";
        const nAcesso = g.itens.filter((m: any) => PUSTATE[m.key] !== "nenhum").length;
        const aberto = PUOPEN.has(g.id);
        h += `<div class="pu-dep">
          <div class="pu-dep-head" onclick="puToggleDep('${g.id}')">
            <span class="pu-chev ${aberto ? "open" : ""}">▸</span>
            <span class="pu-dep-nome">${escP(gl)}</span>
            <span class="pu-dep-resumo">${nAcesso ? nAcesso + "/" + g.itens.length + " liberado(s)" : "nenhum"}</span>
            <label class="pu-switch" onclick="event.stopPropagation()"><input type="checkbox" ${nAcesso ? "checked" : ""} onchange="puMaster('${g.id}', this.checked)"><span class="pu-slider"></span></label>
          </div>`;
        if (aberto) {
          h += `<div class="pu-dep-body">`;
          for (const m of g.itens) {
            const niv = PUSTATE[m.key];
            h += `<div class="pu-mod">
              <span class="pu-mod-nome">${m.icon || ""} ${escP(m.label)}</span>
              <div class="pu-mod-ctrl">
                <div class="pu-ve" style="${niv === "nenhum" ? "visibility:hidden" : ""}">
                  <button type="button" class="pu-ve-btn ${niv === "ver" ? "on" : ""}" onclick="puVE('${m.key}','ver')">👁 Ver</button>
                  <button type="button" class="pu-ve-btn ${niv === "editar" ? "on" : ""}" onclick="puVE('${m.key}','editar')">✎ Editar</button>
                </div>
                <label class="pu-switch"><input type="checkbox" ${niv !== "nenhum" ? "checked" : ""} onchange="puModSw('${m.key}', this.checked)"><span class="pu-slider"></span></label>
              </div>
            </div>`;
          }
          h += `</div>`;
        }
        h += `</div>`;
      }
      ed.innerHTML = h;
    }

    function puToggleDep(g: string) { if (PUOPEN.has(g)) PUOPEN.delete(g); else PUOPEN.add(g); renderPU(); }
    function puMaster(g: string, on: boolean) {
      const grp = PUDATA.grupos.find((x: any) => x.id === g);
      for (const m of grp.itens) PUSTATE[m.key] = on ? (PUSTATE[m.key] === "nenhum" ? "editar" : PUSTATE[m.key]) : "nenhum";
      if (on) PUOPEN.add(g);
      renderPU();
    }
    function puModSw(key: string, on: boolean) { PUSTATE[key] = on ? (PUSTATE[key] === "nenhum" ? "editar" : PUSTATE[key]) : "nenhum"; renderPU(); }
    function puVE(key: string, v: string) { PUSTATE[key] = v; renderPU(); }

    async function salvarPU() {
      if (!PUUID) return;
      const padrao = PUDATA.padrao[PUUID] || {};
      const overrides: any[] = [];
      for (const k in PUSTATE) { if (PUSTATE[k] !== (padrao[k] || "nenhum")) overrides.push({ profile_id: PUUID, modulo: k, nivel: PUSTATE[k] }); }
      const btn = document.getElementById("btnSalvarPU") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Salvando...";
      try {
        const r = await fetch("/api/admin/permissoes-usuarios", { method: "PUT", headers: { "content-type": "application/json" }, body: JSON.stringify({ usuarios: [PUUID], overrides }) });
        const d = await r.json();
        if (r.ok) { PUDATA.overrides[PUUID] = {}; for (const o of overrides) PUDATA.overrides[PUUID][o.modulo] = o.nivel; }
        const nome = PUDATA.usuarios.find((x: any) => x.id === PUUID).nome;
        document.getElementById("msgPU")!.innerHTML = r.ok
          ? `<div class="alert alert-success">✅ Permissões de <strong>${escP(nome)}</strong> salvas! A pessoa vê o efeito no próximo carregamento da página.</div>`
          : `<div class="alert alert-error">${escP(d.error || "Erro")}</div>`;
        window.scrollTo({ top: 0, behavior: "smooth" });
      } catch (e: any) { document.getElementById("msgPU")!.innerHTML = `<div class="alert alert-error">${escP(e.message)}</div>`; }
      finally { btn.disabled = false; btn.textContent = "💾 Salvar permissões"; }
    }

    (window as any).trocarTabPerm = trocarTabPerm;
    (window as any).puSelecionar = puSelecionar;
    (window as any).puToggleDep = puToggleDep;
    (window as any).puMaster = puMaster;
    (window as any).puModSw = puModSw;
    (window as any).puVE = puVE;
    (window as any).salvarPU = salvarPU;
  </script>
</Admin>
