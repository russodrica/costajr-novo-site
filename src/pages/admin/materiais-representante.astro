---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { listarTodosMateriais } from "../../lib/manut/representantes";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const materiais = await listarTodosMateriais();

const tiposLabel: Record<string, string> = {
  pdf: "📄 PDF",
  video: "🎬 Vídeo",
  link: "🔗 Link",
  texto: "📝 Texto",
  imagem: "🖼️ Imagem",
  script_whatsapp: "💬 Script WhatsApp",
};

const totalAtivos = materiais.filter((m: any) => m.ativo).length;
const totalDestaques = materiais.filter((m: any) => m.destaque && m.ativo).length;
---
<Admin title="Materiais — Indique e Ganhe" current="materiais-representante">
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:18px">
    <div class="card" style="text-align:center;padding:18px">
      <div style="font-size:11px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">Total</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#C41E3A;margin-top:6px">{materiais.length}</div>
    </div>
    <div class="card" style="text-align:center;padding:18px;background:linear-gradient(135deg,#F0FDF4 0%,#FFF 100%)">
      <div style="font-size:11px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">Ativos</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#166534;margin-top:6px">{totalAtivos}</div>
    </div>
    <div class="card" style="text-align:center;padding:18px;background:linear-gradient(135deg,#FEF3C7 0%,#FFF 100%)">
      <div style="font-size:11px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">Destaques</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#92400E;margin-top:6px">{totalDestaques}</div>
    </div>
  </div>

  <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:10px">
      <div>
        <strong style="font-size:14px">Materiais do Portal do Representante</strong>
        <div style="font-size:12px;color:#5B5F6B;margin-top:4px">📌 Tudo que cadastrar aqui aparece para TODOS os representantes ativos. Use <code>{`{SEU_CODIGO}`}</code> no conteúdo de scripts WhatsApp e o sistema substitui pelo código de cada rep automaticamente.</div>
      </div>
      <button class="btn btn-primary btn-sm" onclick="abrirNovo()">+ Novo material</button>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="width:60px">Ordem</th>
            <th>Título / Descrição</th>
            <th style="width:130px">Tipo</th>
            <th style="width:90px;text-align:center">Destaque</th>
            <th style="width:90px;text-align:center">Status</th>
            <th style="text-align:right;width:180px">Ações</th>
          </tr>
        </thead>
        <tbody>
          {materiais.map((m: any) => (
            <tr data-id={m.id}
                data-titulo={m.titulo}
                data-descricao={m.descricao || ""}
                data-tipo={m.tipo}
                data-url={m.url || ""}
                data-conteudo={m.conteudo || ""}
                data-ordem={m.ordem || 0}
                data-ativo={m.ativo ? "1" : "0"}
                data-destaque={m.destaque ? "1" : "0"}
                style={!m.ativo ? "opacity:0.5" : ""}>
              <td style="font-weight:700;text-align:center;color:#5B5F6B">{m.ordem || 0}</td>
              <td>
                <strong style="display:block;color:#2D2F36">{m.titulo}</strong>
                {m.descricao && <div style="font-size:12px;color:#5B5F6B;margin-top:3px">{m.descricao}</div>}
              </td>
              <td>
                <span style="background:#EFF6FF;color:#1D4ED8;padding:2px 8px;border-radius:99px;font-size:11px;font-weight:600">{tiposLabel[m.tipo] || m.tipo}</span>
              </td>
              <td style="text-align:center">
                {m.destaque ? <span style="color:#92400E;font-weight:700">⭐</span> : <span style="color:#D1D5DB">—</span>}
              </td>
              <td style="text-align:center">
                {m.ativo
                  ? <span class="badge" style="background:#DCFCE7;color:#166534">Ativo</span>
                  : <span class="badge" style="background:#F3F4F6;color:#6B7280">Inativo</span>}
              </td>
              <td style="text-align:right;white-space:nowrap">
                <button class="btn btn-outline btn-sm" onclick={`editar('${m.id}')`}>Editar</button>
                <button class="btn btn-sm" style="background:#FEE2E2;color:#B91C1C;border:0" onclick={`excluir('${m.id}','${m.titulo.replace(/'/g, "\\'")}')`}>Excluir</button>
              </td>
            </tr>
          ))}
          {materiais.length === 0 && (
            <tr><td colspan="6" style="text-align:center;color:#9CA3AF;padding:24px">Nenhum material cadastrado ainda</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal -->
  <div class="modal-overlay" id="modalMat">
    <div class="modal" style="max-width:680px">
      <div class="modal-title" id="modalMatTitulo">Novo material</div>
      <form id="formMat">
        <input type="hidden" id="matId" />
        <div class="form-group">
          <label>Título *</label>
          <input id="matTitulo" required maxlength="120" placeholder="Ex.: Como funciona o programa Indique e Ganhe" />
        </div>
        <div class="form-group">
          <label>Descrição (1 linha)</label>
          <input id="matDescricao" maxlength="200" placeholder="Resumo curto que aparece abaixo do título" />
        </div>
        <div style="display:grid;grid-template-columns:1fr 100px 110px;gap:10px">
          <div class="form-group">
            <label>Tipo *</label>
            <select id="matTipo" required>
              <option value="texto">📝 Texto (markdown leve)</option>
              <option value="script_whatsapp">💬 Script WhatsApp</option>
              <option value="link">🔗 Link externo</option>
              <option value="pdf">📄 PDF</option>
              <option value="video">🎬 Vídeo</option>
              <option value="imagem">🖼️ Imagem</option>
            </select>
          </div>
          <div class="form-group">
            <label>Ordem</label>
            <input id="matOrdem" type="number" min="0" value="0" />
          </div>
          <div class="form-group" style="display:flex;flex-direction:column;justify-content:center">
            <label style="display:flex;align-items:center;gap:6px;font-weight:normal;font-size:13px">
              <input type="checkbox" id="matDestaque" /> Destaque ⭐
            </label>
            <label style="display:flex;align-items:center;gap:6px;font-weight:normal;font-size:13px;margin-top:6px">
              <input type="checkbox" id="matAtivo" checked /> Ativo
            </label>
          </div>
        </div>
        <div class="form-group" id="grupoUrl">
          <label>URL (pra link, PDF, vídeo, imagem)</label>
          <input id="matUrl" type="url" placeholder="https://..." />
        </div>
        <div class="form-group">
          <label id="lblConteudo">Conteúdo</label>
          <textarea id="matConteudo" rows="8" placeholder="Texto livre. Use ## Subtitulo e **negrito** pra formatar."></textarea>
          <small id="dicaConteudo" style="display:block;margin-top:6px;font-size:11.5px;color:#5B5F6B">
            💡 Use <code>{`{SEU_CODIGO}`}</code> no texto e o sistema substitui pelo código de cupom de cada representante automaticamente.
          </small>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary" id="btnSalvarMat">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    function abrirNovo() {
      document.getElementById("formMat").reset();
      document.getElementById("matId").value = "";
      document.getElementById("matAtivo").checked = true;
      document.getElementById("matDestaque").checked = false;
      document.getElementById("matTipo").value = "texto";
      document.getElementById("matOrdem").value = "0";
      document.getElementById("modalMatTitulo").textContent = "Novo material";
      document.getElementById("modalMat").classList.add("open");
    }
    function editar(id) {
      const tr = document.querySelector('tr[data-id="' + id + '"]');
      if (!tr) return;
      document.getElementById("matId").value = id;
      document.getElementById("matTitulo").value = tr.dataset.titulo || "";
      document.getElementById("matDescricao").value = tr.dataset.descricao || "";
      document.getElementById("matTipo").value = tr.dataset.tipo || "texto";
      document.getElementById("matUrl").value = tr.dataset.url || "";
      document.getElementById("matConteudo").value = tr.dataset.conteudo || "";
      document.getElementById("matOrdem").value = tr.dataset.ordem || "0";
      document.getElementById("matAtivo").checked = tr.dataset.ativo === "1";
      document.getElementById("matDestaque").checked = tr.dataset.destaque === "1";
      document.getElementById("modalMatTitulo").textContent = "Editar material";
      document.getElementById("modalMat").classList.add("open");
    }
    async function excluir(id, titulo) {
      if (!confirm('Excluir material "' + titulo + '"?\n\nEle deixará de aparecer para todos os representantes. Esta ação não pode ser desfeita.')) return;
      const res = await fetch("/api/admin/materiais-representante/" + id, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) { window.location.reload(); }
      else { const d = await res.json().catch(() => ({})); alert(d.error || "Erro ao excluir"); }
    }
    function fecharModal() { document.getElementById("modalMat").classList.remove("open"); }

    window.abrirNovo = abrirNovo;
    window.editar = editar;
    window.excluir = excluir;
    window.fecharModal = fecharModal;

    document.getElementById("formMat").addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = document.getElementById("matId").value;
      const body = {
        titulo: document.getElementById("matTitulo").value.trim(),
        descricao: document.getElementById("matDescricao").value.trim() || null,
        tipo: document.getElementById("matTipo").value,
        url: document.getElementById("matUrl").value.trim() || null,
        conteudo: document.getElementById("matConteudo").value || null,
        ordem: parseInt(document.getElementById("matOrdem").value || "0", 10),
        ativo: document.getElementById("matAtivo").checked,
        destaque: document.getElementById("matDestaque").checked,
      };
      const url = id ? "/api/admin/materiais-representante/" + id : "/api/admin/materiais-representante";
      const method = id ? "PATCH" : "POST";
      const btn = document.getElementById("btnSalvarMat");
      btn.disabled = true; btn.textContent = "Salvando...";
      try {
        const res = await fetch(url, { method, headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
        if (res.ok) { window.location.reload(); }
        else { const d = await res.json().catch(() => ({})); alert(d.error || "Erro ao salvar"); btn.disabled = false; btn.textContent = "Salvar"; }
      } catch (err) {
        alert((err && err.message) || "Erro ao salvar");
        btn.disabled = false; btn.textContent = "Salvar";
      }
    });
  </script>
</Admin>
