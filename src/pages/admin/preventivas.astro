---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const filtroStatus = Astro.url.searchParams.get("status") || "agendada";
const db = supabaseAdmin();
const { data: preventivas } = await db.from("manut_preventivas")
  .select("*, manut_clientes(nome), manut_tecnicos(nome), manut_lojas(nome)")
  .eq("status", filtroStatus)
  .order("data_agendada", { ascending: true });

const { data: tecnicos } = await db.from("manut_tecnicos").select("id, nome").eq("status", "ativo").order("nome");

const badgeSt: Record<string, string> = { agendada: "badge-blue", em_execucao: "badge-yellow", concluida: "badge-green", cancelada: "badge-gray" };
function fmtDate(d: string | null) { if (!d) return "—"; return new Date(d).toLocaleDateString("pt-BR"); }
---
<Admin title="Preventivas" current="preventivas">
  <div class="toolbar">
    <span class="toolbar-title">Preventivas ({preventivas?.length ?? 0})</span>
    <select class="filter-select" onchange="filtrar(this.value)">
      {["agendada","em_execucao","concluida","cancelada"].map(s =>
        <option value={s} selected={s===filtroStatus}>{s.replace("_"," ")}</option>)}
    </select>
  </div>

  <div class="card">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Cliente</th><th>Loja</th><th>Técnico</th><th>Data agendada</th><th>Data executada</th><th>Visita nº</th><th>Status</th><th>Ações</th></tr></thead>
        <tbody>
          {preventivas?.length ? preventivas.map((p: any) => (
            <tr>
              <td>{(p.manut_clientes as any)?.nome ?? "—"}</td>
              <td>{(p.manut_lojas as any)?.nome ?? "—"}</td>
              <td>{(p.manut_tecnicos as any)?.nome ?? <span style="color:#999">Não atribuído</span>}</td>
              <td><strong>{fmtDate(p.data_agendada)}</strong></td>
              <td>{fmtDate(p.data_executada)}</td>
              <td style="text-align:center">{p.numero_visita ?? "—"}</td>
              <td><span class={`badge ${badgeSt[p.status]}`}>{p.status.replace("_"," ")}</span></td>
              <td>
                <div style="display:flex;gap:4px">
                  <button class="btn btn-secondary btn-sm" onclick={`editar(${JSON.stringify(p)})`}>Editar</button>
                  {p.status === "agendada" && <button class="btn btn-info btn-sm" onclick={`patch('${p.id}',{status:'em_execucao'})`}>Iniciar</button>}
                  {["agendada","em_execucao"].includes(p.status) && <button class="btn btn-success btn-sm" onclick={`patch('${p.id}',{status:'concluida',data_executada:new Date().toISOString()})`}>Concluir</button>}
                </div>
              </td>
            </tr>
          )) : <tr><td colspan="8" style="text-align:center;color:#999;padding:32px">Nenhuma preventiva encontrada</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal editar -->
  <div class="modal-overlay" id="modalPrev">
    <div class="modal" style="max-width:480px">
      <div class="modal-title">Editar Preventiva</div>
      <form id="formPrev">
        <input type="hidden" id="prevId" />
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label>Status</label>
            <select id="prevStatus">
              {["agendada","em_execucao","concluida","cancelada"].map(s => <option value={s}>{s.replace("_"," ")}</option>)}
            </select>
          </div>
          <div class="form-group"><label>Técnico</label>
            <select id="prevTecnico">
              <option value="">Não atribuído</option>
              {tecnicos?.map((t: any) => <option value={t.id}>{t.nome}</option>)}
            </select>
          </div>
          <div class="form-group"><label>Data agendada</label><input id="prevDataAgendada" type="datetime-local" /></div>
          <div class="form-group"><label>Nº da visita</label><input id="prevNumVisita" type="number" /></div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function filtrar(s) { const url = new URL(window.location.href); url.searchParams.set("status", s); window.location.href = url.toString(); }
    function fecharModal() { document.getElementById("modalPrev").classList.remove("open"); }
    function editar(p) {
      document.getElementById("prevId").value = p.id;
      document.getElementById("prevStatus").value = p.status;
      document.getElementById("prevTecnico").value = p.tecnico_atribuido_id || "";
      document.getElementById("prevDataAgendada").value = p.data_agendada?.slice(0,16) || "";
      document.getElementById("prevNumVisita").value = p.numero_visita || "";
      document.getElementById("modalPrev").classList.add("open");
    }
    async function patch(id, body) {
      const res = await fetch(`/api/admin/preventivas/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (res.ok) window.location.reload(); else alert("Erro ao atualizar");
    }
    document.getElementById("formPrev")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = document.getElementById("prevId").value;
      const body = {
        status: document.getElementById("prevStatus").value,
        tecnico_atribuido_id: document.getElementById("prevTecnico").value || null,
        data_agendada: document.getElementById("prevDataAgendada").value || null,
        numero_visita: document.getElementById("prevNumVisita").value ? parseInt(document.getElementById("prevNumVisita").value) : null,
      };
      await patch(id, body);
    });

    (window as any).filtrar = filtrar;
    (window as any).fecharModal = fecharModal;
    (window as any).editar = editar;
  </script>
</Admin>
