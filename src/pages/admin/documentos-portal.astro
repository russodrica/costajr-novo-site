---
export const prerender = false;
import Admin from "~/layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "~/lib/auth";
const _t = Astro.cookies.get("admin_token")?.value;
if (!_t) return Astro.redirect("/admin/login");
try { const _c = await verifyToken<AdminClaims>(_t); if (_c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }
---
<Admin title="Documentos" current="documentos-portal">
  <div class="section-header">
    <input type="text" id="busca" placeholder="Buscar documentos..." style="padding:8px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:13px;font-family:'Open Sans',sans-serif;outline:none;min-width:220px">
  </div>

  <!-- Abas: docs gerais | integração -->
  <div style="display:flex;border-bottom:2px solid var(--border);margin-bottom:24px;gap:0">
    <button id="tab-docs"  class="doc-tab active" onclick="setTab('docs')">Documentos</button>
    <button id="tab-integ" class="doc-tab"        onclick="setTab('integ')">Integração / Manual</button>
  </div>

  <div id="loading" class="loading"><div class="spinner"></div> Carregando...</div>
  <div id="docs-content"  style="display:none"></div>
  <div id="integ-content" style="display:none"></div>

  <style>
    .doc-tab {
      padding: 10px 20px; border: 0; background: transparent; cursor: pointer;
      font-family:'Montserrat',sans-serif; font-size:13px; font-weight:700;
      color: var(--ink-light); border-bottom: 2px solid transparent; margin-bottom: -2px;
      transition: all .15s;
    }
    .doc-tab.active { color: var(--brand); border-bottom-color: var(--brand); }
    .doc-card {
      background: #fff; border: 1px solid var(--border); border-radius: 10px;
      padding: 18px 22px; margin-bottom: 10px;
      display: flex; align-items: center; gap: 16px; transition: all .18s;
    }
    .doc-card:hover { border-color: var(--brand); }
    .doc-icon { font-size: 28px; flex-shrink: 0; }
    .doc-body { flex: 1; min-width: 0; }
    .doc-body h3 { font-family:'Montserrat',sans-serif; font-size:14px; font-weight:800; margin:0 0 3px; color:var(--ink); }
    .doc-body p  { font-size:12.5px; color:var(--ink-mid); margin:0; }
    .doc-meta  { font-size:11px; color:var(--ink-light); margin-top:4px; display:flex; gap:8px; align-items:center; }
    .cat-pill { display:inline-block; padding:1px 6px; border-radius:3px; font-size:10px; font-weight:700; text-transform:uppercase; background:rgba(196,30,58,.08); color:var(--brand); }
    .ver-pill { display:inline-block; padding:1px 6px; border-radius:3px; font-size:10px; font-weight:700; background:#F3F4F6; color:#6B7280; }
  </style>

  <script>
    const token = localStorage.getItem("portal_colab_token") || "";

    let allDocs: any[] = [];
    let allInteg: any[] = [];
    let tab = "docs";

    (window as any).setTab = function(t: string) {
      tab = t;
      document.getElementById("tab-docs")!.className  = `doc-tab ${t==="docs"  ? "active" : ""}`;
      document.getElementById("tab-integ")!.className = `doc-tab ${t==="integ" ? "active" : ""}`;
      document.getElementById("docs-content")!.style.display  = t==="docs"  ? "" : "none";
      document.getElementById("integ-content")!.style.display = t==="integ" ? "" : "none";
    };

    function renderDocs(items: any[], elId: string) {
      const el = document.getElementById(elId)!;
      if (!items.length) { el.innerHTML = '<div class="empty-state"><strong>Nenhum documento encontrado</strong><p>Verifique os filtros ou tente outra busca.</p></div>'; return; }
      el.innerHTML = items.map((d: any) => `
        <div class="doc-card">
          <div class="doc-icon">📄</div>
          <div class="doc-body">
            ${d.category || d.setor ? `<span class="cat-pill">${d.category || d.setor}</span>` : ""}
            <h3>${d.title || d.titulo}</h3>
            <p>${d.description || d.descricao || ""}</p>
            <div class="doc-meta">
              <span>${new Date(d.created_at).toLocaleDateString("pt-BR")}</span>
              ${d.versao ? `<span class="ver-pill">v${d.versao}</span>` : ""}
            </div>
          </div>
          ${(d.url || d.storage_path) ? `<a href="${d.url || d.storage_path}" target="_blank" rel="noopener" class="btn btn-outline btn-sm">Abrir</a>` : ""}
        </div>`).join("");
    }

    async function load() {
      const [dRes, iRes] = await Promise.all([
        fetch("/api/portal/documentos", { headers: { "x-portal-auth": token } }),
        fetch("/api/portal/integracao",  { headers: { "x-portal-auth": token } }),
      ]);
      allDocs  = dRes.ok ? await dRes.json() : [];
      allInteg = iRes.ok ? await iRes.json() : [];
      document.getElementById("loading")!.style.display = "none";
      document.getElementById("docs-content")!.style.display = "";
      renderDocs(allDocs,  "docs-content");
      renderDocs(allInteg, "integ-content");
    }

    document.getElementById("busca")!.addEventListener("input", (e) => {
      const q = (e.target as HTMLInputElement).value.toLowerCase();
      renderDocs(q ? allDocs.filter(d =>  (d.title  ||d.titulo ).toLowerCase().includes(q)) : allDocs,  "docs-content");
      renderDocs(q ? allInteg.filter(d => (d.titulo ||d.title  ).toLowerCase().includes(q)) : allInteg, "integ-content");
    });

    load();
  </script>
</Admin>
