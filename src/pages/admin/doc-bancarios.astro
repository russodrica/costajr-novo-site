---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { temPerfilFresco } from "../../lib/permissoes";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
let claims: AdminClaims;
try { claims = await verifyToken<AdminClaims>(token); if (claims.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }
// perfis FRESCOS (multi-perfil): o token pode ter só o perfil principal
if (!(await temPerfilFresco(claims, ["admin", "financeiro", "juridico"]))) return Astro.redirect("/admin");

const BANCOS = ["Banco do Brasil", "Caixa Econômica Federal", "Santander", "Sicoob", "Bradesco", "Itaú", "Nubank"];
const MESES = ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];

const db = supabaseAdmin();
const [{ data: exRows }, { data: ftRows }, { data: empRows }] = await Promise.all([
  db.from("doc_extratos_bancarios").select("*").order("ano", { ascending: false }).order("mes", { ascending: false }),
  db.from("doc_cartao_faturas").select("*").order("ano", { ascending: false }).order("mes", { ascending: false }),
  db.from("doc_emprestimos").select("*").order("status").order("data_contratacao", { ascending: false }),
]);
const extratos: any[] = exRows || [];
const faturas: any[] = ftRows || [];
const emprestimos: any[] = empRows || [];

// Mapa extratos: ano -> mes -> banco -> [arq]
const mapaEx: Record<number, Record<number, Record<string, any[]>>> = {};
for (const e of extratos) { ((mapaEx[e.ano] ||= {})[e.mes] ||= {})[e.banco] ||= []; mapaEx[e.ano][e.mes][e.banco].push(e); }
// Mapa faturas: ano -> mes -> [faturas]
const mapaFt: Record<number, Record<number, any[]>> = {};
for (const f of faturas) ((mapaFt[f.ano] ||= {})[f.mes] ||= []).push(f);

const hoje = new Date();
const anoVigente = hoje.getFullYear();
const desde = Number(Astro.url.searchParams.get("desde")) || (anoVigente - 1);
function anosDe(mapa: Record<number, any>): number[] {
  const dataAnos = Object.keys(mapa).map(Number);
  const minAno = Math.min(desde, anoVigente - 1, ...(dataAnos.length ? dataAnos : [anoVigente]));
  const out: number[] = []; for (let a = anoVigente; a >= minAno; a--) out.push(a); return out;
}
const anosEx = anosDe(mapaEx);
const anosFt = anosDe(mapaFt);
const anoAnteriorBtn = Math.min(desde, anoVigente - 1) - 1;

function totalAnoEx(a: number) { return Object.values(mapaEx[a] || {}).reduce((s, m) => s + Object.values(m).reduce((x, arr) => x + arr.length, 0), 0); }
function bancosMes(a: number, m: number) { const mm = mapaEx[a]?.[m] || {}; return BANCOS.filter((b) => (mm[b] || []).length > 0).length; }
function totalAnoFt(a: number) { return Object.values(mapaFt[a] || {}).reduce((s, arr) => s + arr.length, 0); }
const fdata = (s: string) => (s ? String(s).split("T")[0].split("-").reverse().join("/") : "—");
const brl = (v: any) => (v != null && v !== "" ? "R$ " + Number(v).toLocaleString("pt-BR", { minimumFractionDigits: 2 }) : "—");
const TIPO_LABEL: Record<string, string> = { emprestimo: "Empréstimo", financiamento: "Financiamento" };
const STATUS_BADGE: Record<string, string> = { ativo: "badge-blue", quitado: "badge-green", renegociado: "badge-orange" };
const STATUS_LABEL: Record<string, string> = { ativo: "Ativo", quitado: "Quitado", renegociado: "Renegociado" };
const empAtivos = emprestimos.filter((e) => e.status === "ativo");
const totalDevendo = empAtivos.reduce((s, e) => s + (Number(e.valor_total) || 0), 0);

// Itens disponíveis para envio por e-mail (apenas os que têm arquivo)
const bancItems = [
  ...extratos.map((e: any) => ({ tipo: "extrato", id: e.id, label: `${e.banco} — ${MESES[e.mes - 1]}/${e.ano}`, aba: "extratos" })),
  ...faturas.map((f: any) => ({ tipo: "fatura", id: f.id, label: `${f.cartao} — ${MESES[f.mes - 1]}/${f.ano}`, aba: "faturas" })),
  ...emprestimos.filter((e: any) => e.storage_path).map((e: any) => ({ tipo: "emprestimo", id: e.id, label: [e.banco, e.descricao].filter(Boolean).join(" — ") || "Contrato", aba: "emprestimos" })),
];
const bancItemsJson = JSON.stringify(bancItems).replace(/</g, "\\u003c");
---

<Admin title="Documentos Bancários" current="doc-bancarios">
  <div class="toolbar" style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:6px">
    <span style="font-size:1.3rem;font-weight:800;color:var(--brand);text-transform:uppercase;letter-spacing:.02em">🏦 Documentos Bancários</span>
    <span style="flex:1"></span>
    <button class="btn btn-secondary" onclick="abrirEnviarDocs()" title="Selecione documentos e envie num e-mail só">📨 Enviar documentos</button>
    <a class="btn btn-outline btn-sm" href="/admin/doc-empresa">← Documentos da Empresa</a>
  </div>
  <p style="margin:0 0 12px;color:var(--muted);font-size:13px">Área sensível: extratos, faturas de cartão e empréstimos/financiamentos. Arquivos no cofre privado da empresa (link temporário). Acesso: admin, financeiro e jurídico.</p>

  <div class="pills" id="bancPills" style="display:flex;gap:8px;flex-wrap:wrap;margin:0 0 16px">
    <button type="button" class="pill active" data-tab="extratos" onclick="setTab(this)">🏦 Extratos</button>
    <button type="button" class="pill" data-tab="faturas" onclick="setTab(this)">💳 Faturas de Cartão</button>
    <button type="button" class="pill" data-tab="emprestimos" onclick="setTab(this)">🏛️ Empréstimos &amp; Financiamentos</button>
  </div>

  <input type="file" id="fileExtrato" accept=".pdf,.jpg,.jpeg,.png,.webp,.xls,.xlsx,.csv,.ofx" style="display:none" />
  <input type="file" id="fileFatura" accept=".pdf,.jpg,.jpeg,.png,.webp,.xls,.xlsx,.csv,.ofx" style="display:none" />
  <input type="file" id="fileContrato" accept=".pdf,.jpg,.jpeg,.png,.webp,.xls,.xlsx,.csv" style="display:none" />

  <!-- ════════ EXTRATOS ════════ -->
  <section data-sec="extratos">
    <div style="display:flex;justify-content:flex-end;margin-bottom:10px">
      <button class="btn btn-primary" onclick="abrirAnexarExtrato()" data-requer-edicao>📎 Anexar extrato</button>
    </div>
    {anosEx.map((a) => (
      <details class="card ano-card" open={a === anoVigente} style="margin-bottom:12px;padding:0;overflow:hidden">
        <summary class="ano-sum"><span class="chev">▸</span><span style="flex:1">📅 {a}{a === anoVigente ? ' · ano vigente' : ''}</span><span class="badge badge-gray">{totalAnoEx(a)} extrato{totalAnoEx(a) === 1 ? '' : 's'}</span></summary>
        <div style="padding:10px 14px 16px">
          {MESES.map((nome, idx) => {
            const m = idx + 1; const preench = bancosMes(a, m);
            const futuro = a === anoVigente && m > (hoje.getMonth() + 1);
            return (
              <details class="mes-card" style={`margin:8px 0;border:1px solid var(--border);border-radius:10px;overflow:hidden;${futuro ? 'opacity:.55' : ''}`}>
                <summary class="mes-sum"><span class="chev">▸</span><span style="flex:1">{nome}</span><span class={`badge ${preench === BANCOS.length ? 'badge-green' : preench === 0 ? 'badge-gray' : 'badge-orange'}`}>{preench}/{BANCOS.length} bancos</span></summary>
                <div class="grid-cells">
                  {BANCOS.map((banco) => {
                    const arqs = mapaEx[a]?.[m]?.[banco] || [];
                    return (
                      <div class="cell" data-drop-ano={String(a)} data-drop-mes={String(m)} data-drop-banco={banco}>
                        <div class="cell-head"><b style="flex:1;font-size:13.5px">{banco}</b>{arqs.length > 0 ? <span class="badge badge-green" style="font-size:10.5px">✓ {arqs.length}</span> : <span class="badge badge-gray" style="font-size:10.5px">falta</span>}</div>
                        {arqs.map((x) => (
                          <div class="cell-file"><span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title={x.nome_arquivo || ''}>📄 {x.nome_arquivo || 'arquivo'}</span><a href={`/api/admin/doc-empresa/extratos/${x.id}`} target="_blank" rel="noopener" title="Ver" style="text-decoration:none">👁</a><button onclick={`excluirItem('extratos','${x.id}', this)`} title="Excluir" data-requer-edicao class="lixo">🗑️</button></div>
                        ))}
                        <button class="btn btn-outline btn-sm" style="width:100%;margin-top:7px" data-requer-edicao onclick={`anexarCelula(${a},${m},${JSON.stringify(banco)})`}>📎 Anexar</button>
                      </div>
                    );
                  })}
                </div>
              </details>
            );
          })}
        </div>
      </details>
    ))}
    {anoAnteriorBtn >= 2015 && <div style="text-align:center;margin-top:6px"><a class="btn btn-outline btn-sm" href={`?desde=${anoAnteriorBtn}`}>➕ Mostrar {anoAnteriorBtn}</a></div>}
  </section>

  <!-- ════════ FATURAS DE CARTÃO ════════ -->
  <section data-sec="faturas" style="display:none">
    <div style="display:flex;justify-content:flex-end;margin-bottom:10px">
      <button class="btn btn-primary" onclick="abrirAnexarFatura()" data-requer-edicao>📎 Anexar fatura</button>
    </div>
    {anosFt.map((a) => (
      <details class="card ano-card" open={a === anoVigente} style="margin-bottom:12px;padding:0;overflow:hidden">
        <summary class="ano-sum"><span class="chev">▸</span><span style="flex:1">📅 {a}{a === anoVigente ? ' · ano vigente' : ''}</span><span class="badge badge-gray">{totalAnoFt(a)} fatura{totalAnoFt(a) === 1 ? '' : 's'}</span></summary>
        <div style="padding:10px 14px 16px">
          {MESES.map((nome, idx) => {
            const m = idx + 1; const fts = mapaFt[a]?.[m] || [];
            const futuro = a === anoVigente && m > (hoje.getMonth() + 1);
            return (
              <details class="mes-card" open={fts.length > 0} style={`margin:8px 0;border:1px solid var(--border);border-radius:10px;overflow:hidden;${futuro ? 'opacity:.55' : ''}`}>
                <summary class="mes-sum"><span class="chev">▸</span><span style="flex:1">{nome}</span><span class={`badge ${fts.length ? 'badge-green' : 'badge-gray'}`}>{fts.length} fatura{fts.length === 1 ? '' : 's'}</span></summary>
                <div style="padding:10px 14px;background:var(--gray-50)" data-drop-ft-ano={String(a)} data-drop-ft-mes={String(m)}>
                  {fts.length === 0 && <p style="margin:0 0 8px;color:var(--muted);font-size:12.5px">Nenhuma fatura neste mês.</p>}
                  {fts.map((f) => (
                    <div class="cell-file" style="background:#fff;border:1px solid var(--border);border-radius:8px;padding:8px 10px;margin-bottom:6px">
                      <span style="flex:1"><b>{f.cartao}</b>{f.valor != null ? ` · ${brl(f.valor)}` : ''}{f.vencimento ? ` · vence ${fdata(f.vencimento)}` : ''} <span style="color:#9CA3AF;font-size:12px">{f.nome_arquivo || ''}</span></span>
                      <a href={`/api/admin/doc-empresa/faturas/${f.id}`} target="_blank" rel="noopener" title="Ver" style="text-decoration:none">👁</a>
                      <button onclick={`excluirItem('faturas','${f.id}', this)`} title="Excluir" data-requer-edicao class="lixo">🗑️</button>
                    </div>
                  ))}
                  <button class="btn btn-outline btn-sm" data-requer-edicao onclick={`anexarFaturaMes(${a},${m})`}>📎 Anexar fatura neste mês</button>
                </div>
              </details>
            );
          })}
        </div>
      </details>
    ))}
  </section>

  <!-- ════════ EMPRÉSTIMOS / FINANCIAMENTOS ════════ -->
  <section data-sec="emprestimos" style="display:none">
    <div class="card-grid" style="margin-bottom:12px">
      <div class="stat-card"><div class="stat-value">{empAtivos.length}</div><div class="stat-label">Ativos</div></div>
      <div class="stat-card"><div class="stat-value" style="font-size:1.4rem">{brl(totalDevendo)}</div><div class="stat-label">Valor contratado (ativos)</div></div>
      <div class="stat-card"><div class="stat-value">{emprestimos.length}</div><div class="stat-label">Total (incl. quitados)</div></div>
    </div>
    <div style="display:flex;justify-content:flex-end;margin-bottom:10px">
      <button class="btn btn-primary" onclick="abrirNovoEmp()" data-requer-edicao>+ Novo empréstimo/financiamento</button>
    </div>
    {emprestimos.length === 0 && <div class="card"><div class="empty-state" style="padding:36px"><strong>Nenhum empréstimo ou financiamento cadastrado</strong><p>Use o botão acima para cadastrar.</p></div></div>}
    {emprestimos.map((e) => (
      <div class="card" style="padding:16px 18px;margin-bottom:12px" data-emp-id={e.id} data-drop-emp={e.id}>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <span style="font-size:1.3rem;font-weight:800;color:var(--brand);line-height:1.1">🏦 {e.banco || 'Banco não informado'}</span>
          <span class="badge badge-gray">{TIPO_LABEL[e.tipo] || e.tipo}</span>
          <span style="flex:1"></span>
          <span class={`badge ${STATUS_BADGE[e.status] || 'badge-gray'}`}>{STATUS_LABEL[e.status] || e.status}</span>
        </div>
        {e.descricao && <div style="font-size:13.5px;color:var(--ink-mid);margin:4px 0 12px">{e.descricao}</div>}
        <div class="emp-cols">
          {e.valor_total != null && <div><div class="emp-lbl">Valor total</div><div class="emp-v">{brl(e.valor_total)}</div></div>}
          {e.num_parcelas != null && <div><div class="emp-lbl">Parcelas</div><div class="emp-v">{e.num_parcelas}x</div></div>}
          {e.valor_parcela != null && <div><div class="emp-lbl">Valor da parcela</div><div class="emp-v">{brl(e.valor_parcela)}</div></div>}
          {e.numero_contrato && <div><div class="emp-lbl">Nº do contrato</div><div class="emp-v">{e.numero_contrato}</div></div>}
          {e.data_contratacao && <div><div class="emp-lbl">Contratação</div><div class="emp-v">{fdata(e.data_contratacao)}</div></div>}
          {e.data_primeira_parcela && <div><div class="emp-lbl">1ª parcela</div><div class="emp-v">{fdata(e.data_primeira_parcela)}</div></div>}
          {e.data_vencimento && <div><div class="emp-lbl">Encerramento</div><div class="emp-v" style={`color:${new Date(e.data_vencimento) < new Date() ? '#DC2626' : '#059669'}`}>{fdata(e.data_vencimento)}</div></div>}
        </div>
        {e.observacao && <div style="font-size:12.5px;color:#9CA3AF;margin-top:10px">{e.observacao}</div>}
        <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap">
          {e.storage_path
            ? <a class="btn btn-outline btn-sm" href={`/api/admin/doc-empresa/emprestimos/${e.id}`} target="_blank" rel="noopener">📄 Ver contrato</a>
            : <button class="btn btn-sm" style="background:#FEF3C7;color:#92400E;border:1.5px solid #FCD34D;border-radius:6px" data-requer-edicao onclick={`anexarContrato('${e.id}')`}>📎 Anexar contrato</button>}
          {e.storage_path && <button class="btn btn-outline btn-sm" data-requer-edicao onclick={`anexarContrato('${e.id}')`}>Trocar contrato</button>}
          <button class="btn btn-secondary btn-sm" data-requer-edicao onclick={`editarEmp(${JSON.stringify(e)})`}>Editar</button>
          <button class="btn btn-danger btn-sm" data-requer-edicao onclick={`excluirItem('emprestimos','${e.id}', this)`}>Excluir</button>
        </div>
      </div>
    ))}
  </section>

  <!-- Modal: enviar documentos por e-mail -->
  <div class="modal-overlay" id="modalEnviarBanc" style="display:none">
    <div class="modal" style="max-width:680px">
      <div class="modal-head"><h3 style="margin:0">📨 Enviar documentos por e-mail</h3><button class="modal-x" onclick="fecharEnviarBanc()">×</button></div>
      <div class="modal-body">
        <div class="form-group"><label>Para (um ou mais e-mails, separados por vírgula) *</label><input id="benvTo" placeholder="cliente@email.com, contador@email.com" /></div>
        <div class="form-group"><label>Assunto</label><input id="benvSubject" placeholder="Documentos Bancários — Costa Júnior Engenharia" /></div>
        <div class="form-group"><label>Mensagem (opcional)</label><textarea id="benvMsg" rows="2" placeholder="Olá, seguem em anexo os documentos solicitados."></textarea></div>
        <div style="display:flex;align-items:center;gap:8px;margin:8px 0 4px">
          <input class="search-input" id="benvBusca" placeholder="Buscar documento…" oninput="filtrarEnvBanc()" style="flex:1" />
          <span id="benvCount" style="font-size:12.5px;color:#6B7280;white-space:nowrap">0 selecionado(s)</span>
        </div>
        <div style="display:flex;gap:6px;margin-bottom:8px">
          <button type="button" class="pill active" data-benv-aba="" onclick="setBenvAba(this)">Todos</button>
          <button type="button" class="pill" data-benv-aba="extratos" onclick="setBenvAba(this)">🏦 Extratos</button>
          <button type="button" class="pill" data-benv-aba="faturas" onclick="setBenvAba(this)">💳 Faturas</button>
          <button type="button" class="pill" data-benv-aba="emprestimos" onclick="setBenvAba(this)">🏛️ Contratos</button>
        </div>
        <div id="benvLista" style="border:1px solid var(--border);border-radius:8px;max-height:35vh;overflow:auto;padding:6px 12px"></div>
        <div id="benvMsgBox" style="margin-top:10px"></div>
        <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:14px">
          <button type="button" class="btn btn-secondary" onclick="fecharEnviarBanc()">Cancelar</button>
          <button type="button" class="btn btn-primary" id="btnEnviarBanc" onclick="enviarDocsBanc()">📨 Enviar e-mail</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal: anexar extrato -->
  <div id="modalExt" class="modal-overlay" style="display:none"><div class="modal" style="max-width:440px">
    <div class="modal-head"><h3 style="margin:0">📎 Anexar extrato</h3><button class="modal-x" onclick="fecharM('modalExt')">×</button></div>
    <div class="modal-body" style="display:grid;gap:12px">
      <label>Ano<br/><input id="exAno" type="number" min="2015" max={anoVigente + 1} value={anoVigente} class="inp" style="width:100%" /></label>
      <label>Mês<br/><select id="exMes" class="inp" style="width:100%">{MESES.map((nome, i) => <option value={i + 1} selected={i === hoje.getMonth()}>{nome}</option>)}</select></label>
      <label>Banco<br/><select id="exBanco" class="inp" style="width:100%">{BANCOS.map((b) => <option value={b}>{b}</option>)}</select></label>
      <button class="btn btn-primary" onclick="extDoModal()">Escolher arquivo e enviar</button>
    </div>
  </div></div>

  <!-- Modal: anexar fatura -->
  <div id="modalFt" class="modal-overlay" style="display:none"><div class="modal" style="max-width:460px">
    <div class="modal-head"><h3 style="margin:0">📎 Anexar fatura de cartão</h3><button class="modal-x" onclick="fecharM('modalFt')">×</button></div>
    <div class="modal-body" style="display:grid;gap:12px">
      <div style="display:flex;gap:10px">
        <label style="flex:1">Ano<br/><input id="ftAno" type="number" min="2015" max={anoVigente + 1} value={anoVigente} class="inp" style="width:100%" /></label>
        <label style="flex:1">Mês<br/><select id="ftMes" class="inp" style="width:100%">{MESES.map((nome, i) => <option value={i + 1} selected={i === hoje.getMonth()}>{nome}</option>)}</select></label>
      </div>
      <label>Cartão *<br/><input id="ftCartao" class="inp" style="width:100%" placeholder="Ex.: Itaú Visa final 1234 / Bradesco PJ" /></label>
      <div style="display:flex;gap:10px">
        <label style="flex:1">Valor (R$)<br/><input id="ftValor" type="number" min="0" step="0.01" class="inp" style="width:100%" placeholder="0,00" /></label>
        <label style="flex:1">Vencimento<br/><input id="ftVenc" type="date" class="inp" style="width:100%" /></label>
      </div>
      <button class="btn btn-primary" onclick="ftDoModal()">Escolher arquivo e enviar</button>
    </div>
  </div></div>

  <!-- Modal: empréstimo/financiamento -->
  <div id="modalEmp" class="modal-overlay" style="display:none"><div class="modal" style="max-width:560px">
    <div class="modal-head"><h3 style="margin:0" id="empTitle">Novo empréstimo/financiamento</h3><button class="modal-x" onclick="fecharM('modalEmp')">×</button></div>
    <div class="modal-body" style="display:grid;gap:12px">
      <input type="hidden" id="empId" />
      <div style="display:flex;gap:10px">
        <label style="flex:1">Tipo<br/><select id="empTipo" class="inp" style="width:100%"><option value="emprestimo">Empréstimo</option><option value="financiamento">Financiamento</option></select></label>
        <label style="flex:1">Status<br/><select id="empStatus" class="inp" style="width:100%"><option value="ativo">Ativo</option><option value="quitado">Quitado</option><option value="renegociado">Renegociado</option></select></label>
      </div>
      <label>Descrição *<br/><input id="empDesc" class="inp" style="width:100%" placeholder="Ex.: Financiamento Veículo HB20 / Capital de giro" /></label>
      <label>Banco / Instituição<br/><input id="empBanco" class="inp" style="width:100%" placeholder="Ex.: Banco do Brasil" /></label>
      <div style="display:flex;gap:10px">
        <label style="flex:1">Valor total (R$)<br/><input id="empValor" type="number" min="0" step="0.01" class="inp" style="width:100%" /></label>
        <label style="flex:1">Nº parcelas<br/><input id="empNP" type="number" min="0" class="inp" style="width:100%" /></label>
        <label style="flex:1">Valor parcela (R$)<br/><input id="empVP" type="number" min="0" step="0.01" class="inp" style="width:100%" /></label>
      </div>
      <label>Nº do Contrato<br/><input id="empNC" class="inp" style="width:100%" placeholder="Ex.: 1623146 / 16627049" /></label>
      <div style="display:flex;gap:10px">
        <label style="flex:1">Assinatura<br/><input id="empDC" type="date" class="inp" style="width:100%" /></label>
        <label style="flex:1">1ª parcela<br/><input id="empD1" type="date" class="inp" style="width:100%" /></label>
        <label style="flex:1">Encerramento<br/><input id="empDV" type="date" class="inp" style="width:100%" /></label>
      </div>
      <label>Observações<br/><textarea id="empObs" class="inp" style="width:100%;min-height:60px"></textarea></label>
      <div style="display:flex;justify-content:flex-end;gap:8px"><button class="btn btn-secondary" onclick="fecharM('modalEmp')">Cancelar</button><button class="btn btn-primary" onclick="salvarEmp()">Salvar</button></div>
    </div>
  </div></div>
</Admin>

<style>
  details.ano-card > summary::-webkit-details-marker, details.mes-card > summary::-webkit-details-marker { display:none; }
  details[open] > summary .chev { transform: rotate(90deg); }
  .chev { transition: transform .15s; display:inline-block; }
  .ano-sum { cursor:pointer;list-style:none;display:flex;align-items:center;gap:10px;padding:14px 18px;background:var(--gray-50);font-weight:700;font-size:16px;text-transform:uppercase;letter-spacing:.01em; }
  .mes-sum { cursor:pointer;list-style:none;display:flex;align-items:center;gap:10px;padding:10px 14px;font-weight:600;text-transform:uppercase;letter-spacing:.01em; }
  .cell-head b { text-transform:uppercase; }
  .grid-cells { display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:10px;padding:12px 14px;background:var(--gray-50); }
  .cell { background:#fff;border:1px solid var(--border);border-radius:10px;padding:11px 12px; }
  .cell-head { display:flex;align-items:center;gap:8px;margin-bottom:6px; }
  .cell-file { display:flex;align-items:center;gap:6px;padding:3px 0;font-size:12.5px;border-top:1px dashed var(--border-light); }
  .lixo { background:none;border:none;cursor:pointer; }
  .emp-cols { display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:14px;border-top:1px solid var(--border);padding-top:12px; }
  .emp-lbl { font-size:11px;color:#9CA3AF;text-transform:uppercase;letter-spacing:.03em;margin-bottom:2px; }
  .emp-v { font-size:14.5px;font-weight:700;color:var(--ink); }
  .inp { padding:9px 11px;border:1px solid var(--border);border-radius:8px;font-size:14px; }
  .modal-overlay { position:fixed;inset:0;background:rgba(0,0,0,.45);display:flex;align-items:center;justify-content:center;z-index:1000; }
  .modal { background:#fff;border-radius:14px;width:92%;box-shadow:var(--shadow-lg);max-height:92vh;overflow:auto; }
  .modal-head { display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--border);position:sticky;top:0;background:#fff; }
  .modal-body { padding:18px; }
  .modal-x { background:none;border:none;font-size:24px;cursor:pointer;color:var(--muted);line-height:1; }
</style>

<script type="application/json" id="bancItemsData" set:html={bancItemsJson} />

<script>
  const BANC_ITEMS: any[] = JSON.parse((document.getElementById("bancItemsData") as HTMLElement)?.textContent || "[]");
  let benvAbaAtiva = "";

  function abrirEnviarDocs() {
    benvAbaAtiva = "";
    document.querySelectorAll("[data-benv-aba]").forEach((b) => b.classList.toggle("active", (b as HTMLElement).dataset.benvAba === ""));
    renderBenvLista();
    (document.getElementById("benvMsgBox") as HTMLElement).innerHTML = "";
    abrirM("modalEnviarBanc");
  }
  function fecharEnviarBanc() { fecharM("modalEnviarBanc"); }
  function setBenvAba(btn: HTMLElement) {
    document.querySelectorAll("[data-benv-aba]").forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
    benvAbaAtiva = btn.dataset.benvAba || "";
    renderBenvLista();
  }
  function renderBenvLista() {
    const busca = (document.getElementById("benvBusca") as HTMLInputElement)?.value.toLowerCase().trim() || "";
    const visivel = BANC_ITEMS.filter((i: any) => (!benvAbaAtiva || i.aba === benvAbaAtiva) && (!busca || i.label.toLowerCase().includes(busca)));
    const icons: Record<string, string> = { extrato: "🏦", fatura: "💳", emprestimo: "🏛️" };
    let html = "";
    for (const it of visivel) {
      html += `<label class="benv-item" style="display:flex;align-items:center;gap:8px;padding:5px 2px;font-size:13px;cursor:pointer">
        <input type="checkbox" class="benv-chk" value="${it.id}" data-tipo="${it.tipo}" onchange="benvCountUpd()" />
        <span>${icons[it.tipo] || "📄"} ${(it.label || "").replace(/</g, "&lt;")}</span></label>`;
    }
    (document.getElementById("benvLista") as HTMLElement).innerHTML = html || `<p style="color:#9CA3AF;padding:10px">Nenhum documento${benvAbaAtiva ? " nesta categoria" : ""} disponível.</p>`;
    benvCountUpd();
  }
  function benvCountUpd() {
    const n = document.querySelectorAll("#benvLista .benv-chk:checked").length;
    (document.getElementById("benvCount") as HTMLElement).textContent = `${n} selecionado(s)`;
  }
  function filtrarEnvBanc() { renderBenvLista(); }
  async function enviarDocsBanc() {
    const to = (document.getElementById("benvTo") as HTMLInputElement).value.trim();
    const chks = Array.from(document.querySelectorAll("#benvLista .benv-chk:checked")) as HTMLInputElement[];
    if (!to) { alert("Informe ao menos um e-mail."); return; }
    if (!chks.length) { alert("Selecione ao menos um documento."); return; }
    const items = chks.map((c) => ({ tipo: c.dataset.tipo, id: c.value }));
    const btn = document.getElementById("btnEnviarBanc") as HTMLButtonElement;
    btn.disabled = true; const orig = btn.textContent; btn.textContent = "Enviando…";
    const box = document.getElementById("benvMsgBox") as HTMLElement;
    try {
      const res = await fetch("/api/admin/doc-empresa/bancarios-email", {
        method: "POST", headers: { "content-type": "application/json" },
        body: JSON.stringify({
          to,
          subject: (document.getElementById("benvSubject") as HTMLInputElement).value.trim(),
          message: (document.getElementById("benvMsg") as HTMLTextAreaElement).value.trim(),
          items,
        }),
      });
      const d = await res.json();
      if (res.ok) {
        box.innerHTML = `<div style="background:#ECFDF5;border:1px solid #6EE7B7;border-radius:8px;padding:10px 12px;color:#065F46;font-size:13px">✓ Enviado: ${d.enviados} documento(s) para ${(d.to || []).join(", ").replace(/</g, "&lt;")}.</div>`;
        chks.forEach((c) => { c.checked = false; }); benvCountUpd();
      } else {
        box.innerHTML = `<div class="alert alert-error">${(d.error || "Erro ao enviar").replace(/</g, "&lt;")}</div>`;
      }
    } catch (e: any) {
      box.innerHTML = `<div class="alert alert-error">${(e?.message || "Erro de rede").replace(/</g, "&lt;")}</div>`;
    }
    btn.disabled = false; btn.textContent = orig;
  }

  function setTab(btn: HTMLElement) {
    document.querySelectorAll("#bancPills .pill").forEach((p) => p.classList.remove("active"));
    btn.classList.add("active");
    const tab = btn.dataset.tab;
    document.querySelectorAll("section[data-sec]").forEach((s) => { (s as HTMLElement).style.display = (s as HTMLElement).dataset.sec === tab ? "" : "none"; });
  }
  function fecharM(id: string) { (document.getElementById(id) as HTMLElement).style.display = "none"; }
  function abrirM(id: string) { (document.getElementById(id) as HTMLElement).style.display = "flex"; }

  // ── Upload genérico (3 passos) ──
  async function subir(arquivo: File, urlEndpoint: string, urlBody: any, registroEndpoint: string, registroExtra: any) {
    if (arquivo.size > 45 * 1024 * 1024) { alert("Arquivo muito grande (máx. 45 MB)."); return false; }
    const r1 = await fetch(urlEndpoint, { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ ...urlBody, nome: arquivo.name }) });
    if (!r1.ok) throw new Error((await r1.json().catch(() => ({}))).error || "Erro ao preparar upload");
    const { signed_url, path, nome_original } = await r1.json();
    const r2 = await fetch(signed_url, { method: "PUT", headers: { "content-type": arquivo.type || "application/octet-stream" }, body: arquivo });
    if (!r2.ok) throw new Error(`Falha no envio (HTTP ${r2.status}).`);
    const method = registroExtra.__method || "POST";
    const extra = { ...registroExtra }; delete extra.__method;
    const r3 = await fetch(registroEndpoint, { method, headers: { "content-type": "application/json" }, body: JSON.stringify({ ...extra, storage_path: path, nome_arquivo: nome_original }) });
    if (!r3.ok) throw new Error((await r3.json().catch(() => ({}))).error || "Falhou ao registrar");
    return true;
  }

  // ── Extratos ──
  let pendExt: { ano: number; mes: number; banco: string } | null = null;
  async function processarExt(ano: number, mes: number, banco: string, arquivo: File) {
    try { if (await subir(arquivo, "/api/admin/doc-empresa/extratos/upload-url", { ano, mes, banco }, "/api/admin/doc-empresa/extratos", { ano, mes, banco })) location.reload(); }
    catch (e: any) { alert("Erro: " + (e?.message || "tente novamente")); }
  }
  function abrirAnexarExtrato() { abrirM("modalExt"); }
  function extDoModal() {
    const ano = Number((document.getElementById("exAno") as HTMLInputElement).value);
    const mes = Number((document.getElementById("exMes") as HTMLSelectElement).value);
    const banco = (document.getElementById("exBanco") as HTMLSelectElement).value;
    if (!ano || !mes || !banco) { alert("Preencha ano, mês e banco."); return; }
    fecharM("modalExt"); dispararExt(ano, mes, banco);
  }
  function anexarCelula(ano: number, mes: number, banco: string) { dispararExt(ano, mes, banco); }
  function dispararExt(ano: number, mes: number, banco: string) { pendExt = { ano, mes, banco }; const fi = document.getElementById("fileExtrato") as HTMLInputElement; fi.value = ""; fi.click(); }
  (document.getElementById("fileExtrato") as HTMLInputElement).addEventListener("change", async (ev) => {
    const fi = ev.target as HTMLInputElement; const arquivo = fi.files?.[0]; if (!arquivo || !pendExt) return; const c = pendExt;
    await processarExt(c.ano, c.mes, c.banco, arquivo);
  });

  // ── Faturas ──
  let pendFtDrop: File | null = null;
  async function processarFt(c: { ano: number; mes: number; cartao: string; valor: string; vencimento: string }, arquivo: File) {
    try { if (await subir(arquivo, "/api/admin/doc-empresa/faturas/upload-url", { ano: c.ano, mes: c.mes, cartao: c.cartao }, "/api/admin/doc-empresa/faturas", { ano: c.ano, mes: c.mes, cartao: c.cartao, valor: c.valor, vencimento: c.vencimento })) location.reload(); }
    catch (e: any) { alert("Erro: " + (e?.message || "tente novamente")); }
  }
  function abrirAnexarFatura() { abrirM("modalFt"); }
  function anexarFaturaMes(ano: number, mes: number) {
    (document.getElementById("ftAno") as HTMLInputElement).value = String(ano);
    (document.getElementById("ftMes") as HTMLSelectElement).value = String(mes);
    abrirM("modalFt");
  }
  function ftDoModal() {
    const ano = Number((document.getElementById("ftAno") as HTMLInputElement).value);
    const mes = Number((document.getElementById("ftMes") as HTMLSelectElement).value);
    const cartao = (document.getElementById("ftCartao") as HTMLInputElement).value.trim();
    if (!ano || !mes || !cartao) { alert("Preencha ano, mês e cartão."); return; }
    const valor = (document.getElementById("ftValor") as HTMLInputElement).value;
    const vencimento = (document.getElementById("ftVenc") as HTMLInputElement).value;
    const ctx = { ano, mes, cartao, valor, vencimento };
    (window as any).__ftCtx = ctx;
    const dropped = pendFtDrop; pendFtDrop = null;
    fecharM("modalFt");
    if (dropped) { processarFt(ctx, dropped); }
    else { const fi = document.getElementById("fileFatura") as HTMLInputElement; fi.value = ""; fi.click(); }
  }
  (document.getElementById("fileFatura") as HTMLInputElement).addEventListener("change", async (ev) => {
    const fi = ev.target as HTMLInputElement; const arquivo = fi.files?.[0]; const c = (window as any).__ftCtx; if (!arquivo || !c) return;
    await processarFt(c, arquivo);
  });

  // ── Empréstimos ──
  function abrirNovoEmp() {
    (document.getElementById("empId") as HTMLInputElement).value = "";
    (document.getElementById("empTitle") as HTMLElement).textContent = "Novo empréstimo/financiamento";
    ["empDesc", "empBanco", "empValor", "empNP", "empVP", "empDC", "empD1", "empDV", "empNC", "empObs"].forEach((id) => (document.getElementById(id) as HTMLInputElement).value = "");
    (document.getElementById("empTipo") as HTMLSelectElement).value = "emprestimo";
    (document.getElementById("empStatus") as HTMLSelectElement).value = "ativo";
    abrirM("modalEmp");
  }
  function editarEmp(e: any) {
    (document.getElementById("empId") as HTMLInputElement).value = e.id;
    (document.getElementById("empTitle") as HTMLElement).textContent = "Editar " + (e.tipo === "financiamento" ? "financiamento" : "empréstimo");
    (document.getElementById("empTipo") as HTMLSelectElement).value = e.tipo || "emprestimo";
    (document.getElementById("empStatus") as HTMLSelectElement).value = e.status || "ativo";
    (document.getElementById("empDesc") as HTMLInputElement).value = e.descricao || "";
    (document.getElementById("empBanco") as HTMLInputElement).value = e.banco || "";
    (document.getElementById("empValor") as HTMLInputElement).value = e.valor_total ?? "";
    (document.getElementById("empNP") as HTMLInputElement).value = e.num_parcelas ?? "";
    (document.getElementById("empVP") as HTMLInputElement).value = e.valor_parcela ?? "";
    (document.getElementById("empDC") as HTMLInputElement).value = e.data_contratacao || "";
    (document.getElementById("empD1") as HTMLInputElement).value = e.data_primeira_parcela || "";
    (document.getElementById("empDV") as HTMLInputElement).value = e.data_vencimento || "";
    (document.getElementById("empNC") as HTMLInputElement).value = e.numero_contrato || "";
    (document.getElementById("empObs") as HTMLTextAreaElement).value = e.observacao || "";
    abrirM("modalEmp");
  }
  async function salvarEmp() {
    const id = (document.getElementById("empId") as HTMLInputElement).value;
    const body = {
      tipo: (document.getElementById("empTipo") as HTMLSelectElement).value,
      status: (document.getElementById("empStatus") as HTMLSelectElement).value,
      descricao: (document.getElementById("empDesc") as HTMLInputElement).value.trim(),
      banco: (document.getElementById("empBanco") as HTMLInputElement).value.trim(),
      valor_total: (document.getElementById("empValor") as HTMLInputElement).value,
      num_parcelas: (document.getElementById("empNP") as HTMLInputElement).value,
      valor_parcela: (document.getElementById("empVP") as HTMLInputElement).value,
      data_contratacao: (document.getElementById("empDC") as HTMLInputElement).value,
      data_primeira_parcela: (document.getElementById("empD1") as HTMLInputElement).value,
      data_vencimento: (document.getElementById("empDV") as HTMLInputElement).value,
      numero_contrato: (document.getElementById("empNC") as HTMLInputElement).value.trim(),
      observacao: (document.getElementById("empObs") as HTMLTextAreaElement).value,
    };
    if (!body.descricao) { alert("Informe a descrição."); return; }
    const res = await fetch(id ? `/api/admin/doc-empresa/emprestimos/${id}` : "/api/admin/doc-empresa/emprestimos", { method: id ? "PATCH" : "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
    if (res.ok) location.reload(); else alert((await res.json().catch(() => ({}))).error || "Erro");
  }
  let pendContrato: string | null = null;
  async function processarEmp(empId: string, arquivo: File) {
    try { if (await subir(arquivo, "/api/admin/doc-empresa/emprestimos/upload-url", { emprestimo_id: empId }, `/api/admin/doc-empresa/emprestimos/${empId}`, { __method: "PATCH" })) location.reload(); }
    catch (e: any) { alert("Erro: " + (e?.message || "tente novamente")); }
  }
  function anexarContrato(empId: string) { pendContrato = empId; const fi = document.getElementById("fileContrato") as HTMLInputElement; fi.value = ""; fi.click(); }
  (document.getElementById("fileContrato") as HTMLInputElement).addEventListener("change", async (ev) => {
    const fi = ev.target as HTMLInputElement; const arquivo = fi.files?.[0]; if (!arquivo || !pendContrato) return;
    await processarEmp(pendContrato, arquivo);
  });

  // ── Arrastar-e-soltar ──
  function ligarDropBanc() {
    const hi = (el: HTMLElement) => { el.style.outline = "2px dashed var(--brand)"; el.style.outlineOffset = "2px"; };
    const lo = (el: HTMLElement) => { el.style.outline = ""; };
    // Células de extrato (ano/mês/banco conhecidos → upload direto)
    document.querySelectorAll<HTMLElement>(".cell[data-drop-ano]").forEach((c) => {
      if ((c as any)._drop) return; (c as any)._drop = true;
      ["dragenter", "dragover"].forEach((ev) => c.addEventListener(ev, (e) => { e.preventDefault(); hi(c); }));
      ["dragleave", "dragend"].forEach((ev) => c.addEventListener(ev, () => lo(c)));
      c.addEventListener("drop", (e: any) => {
        e.preventDefault(); lo(c);
        const f = e.dataTransfer?.files?.[0];
        if (f) processarExt(Number(c.dataset.dropAno), Number(c.dataset.dropMes), c.dataset.dropBanco || "", f);
      });
    });
    // Meses de fatura (abre modal com mês pré-preenchido; arquivo fica em pendFtDrop)
    document.querySelectorAll<HTMLElement>("[data-drop-ft-ano]").forEach((d) => {
      if ((d as any)._drop) return; (d as any)._drop = true;
      ["dragenter", "dragover"].forEach((ev) => d.addEventListener(ev, (e) => { e.preventDefault(); hi(d); }));
      ["dragleave", "dragend"].forEach((ev) => d.addEventListener(ev, () => lo(d)));
      d.addEventListener("drop", (e: any) => {
        e.preventDefault(); lo(d);
        const f = e.dataTransfer?.files?.[0];
        if (!f) return;
        pendFtDrop = f;
        (document.getElementById("ftAno") as HTMLInputElement).value = d.dataset.dropFtAno || "";
        (document.getElementById("ftMes") as HTMLSelectElement).value = d.dataset.dropFtMes || "";
        (document.getElementById("ftCartao") as HTMLInputElement).value = "";
        abrirM("modalFt");
      });
    });
    // Cards de empréstimo (drop no contrato)
    document.querySelectorAll<HTMLElement>(".card[data-drop-emp]").forEach((c) => {
      if ((c as any)._drop) return; (c as any)._drop = true;
      ["dragenter", "dragover"].forEach((ev) => c.addEventListener(ev, (e) => { e.preventDefault(); hi(c); }));
      ["dragleave", "dragend"].forEach((ev) => c.addEventListener(ev, () => lo(c)));
      c.addEventListener("drop", (e: any) => {
        e.preventDefault(); lo(c);
        const f = e.dataTransfer?.files?.[0];
        if (f) processarEmp(c.dataset.dropEmp || "", f);
      });
    });
  }
  ligarDropBanc();

  // ── Excluir (extrato/fatura/empréstimo) ──
  async function excluirItem(tipo: string, id: string, btn: HTMLButtonElement) {
    if (!confirm("Excluir este item? (vai para a Lixeira por 30 dias)")) return;
    btn.disabled = true;
    const res = await fetch(`/api/admin/doc-empresa/${tipo}/${id}`, { method: "DELETE", headers: { "content-type": "application/json" } });
    if (res.ok) location.reload(); else { alert((await res.json().catch(() => ({}))).error || "Erro"); btn.disabled = false; }
  }

  Object.assign(window, { setTab, fecharM, abrirAnexarExtrato, extDoModal, anexarCelula, abrirAnexarFatura, anexarFaturaMes, ftDoModal, abrirNovoEmp, editarEmp, salvarEmp, anexarContrato, excluirItem, processarExt, processarFt, processarEmp, abrirEnviarDocs, fecharEnviarBanc, setBenvAba, benvCountUpd, filtrarEnvBanc, enviarDocsBanc });
</script>
