---
export const prerender = false;
import Admin from "~/layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "~/lib/auth";
import { supabaseAdmin } from "~/lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const db = supabaseAdmin();
const { data: kb } = await db
  .from("portal_kb")
  .select("*")
  .order("category")
  .order("created_at");

function fmtDate(d: string | null) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }
---
<Admin title="Base de Conhecimento" current="portal-kb">
  <div class="toolbar">
    <span class="toolbar-title">Base de Conhecimento ({kb?.length ?? 0})</span>
    <div style="display:flex;gap:8px">
      <button class="btn btn-secondary" onclick="abrirImport()">📥 Importar de PDF/URL</button>
      <button class="btn btn-primary" onclick="openModal()">+ Nova pergunta</button>
    </div>
  </div>

  <div class="card">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Pergunta</th><th>Categoria</th><th>Acesso</th><th>Data</th><th>Ações</th></tr></thead>
        <tbody>
          {kb?.length ? kb.map((k: any) => (
            <tr>
              <td style="max-width:320px">
                <strong style="display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{k.question}</strong>
                <span style="font-size:12px;color:#888;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{k.answer}</span>
              </td>
              <td>{String(k.category || "Geral").split(/[;|]/).map((c: string) => c.trim()).filter(Boolean).map((c: string) => (<span class="badge badge-blue" style="margin:2px 4px 2px 0;display:inline-block">{c}</span>))}</td>
              <td style="font-size:12px">{(k.access_roles || ["all"]).join(", ")}</td>
              <td>{fmtDate(k.created_at)}</td>
              <td>
                <div style="display:flex;gap:4px">
                  <button class="btn btn-secondary btn-sm" onclick={`editar(${JSON.stringify(k)})`}>Editar</button>
                  <button class="btn btn-danger btn-sm" onclick={`excluir('${k.id}')`}>Excluir</button>
                </div>
              </td>
            </tr>
          )) : <tr><td colspan="5" style="text-align:center;color:#999;padding:32px">Nenhum item cadastrado</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <div id="modal" class="modal-overlay" style="display:none">
    <div class="modal-box">
      <div class="modal-header">
        <h2 id="modal-title">Nova Pergunta</h2>
        <button onclick="closeModal()" class="modal-close">✕</button>
      </div>
      <input type="hidden" id="edit-id">
      <div class="form-row">
        <div class="form-group">
          <label>Categorias * <span style="font-weight:400;color:var(--ink-light);font-size:12px">— marque uma ou mais (a pergunta aparece para todas)</span></label>
          <div id="f-cats" style="display:flex;flex-wrap:wrap;gap:7px 14px;padding:6px 2px">
            <label style="display:inline-flex;align-items:center;gap:5px;font-size:13.5px;cursor:pointer;white-space:nowrap"><input type="checkbox" value="Geral" style="margin:0"> Geral</label>
            <label style="display:inline-flex;align-items:center;gap:5px;font-size:13.5px;cursor:pointer;white-space:nowrap"><input type="checkbox" value="Administrativo" style="margin:0"> Administrativo</label>
            <label style="display:inline-flex;align-items:center;gap:5px;font-size:13.5px;cursor:pointer;white-space:nowrap"><input type="checkbox" value="Financeiro" style="margin:0"> Financeiro</label>
            <label style="display:inline-flex;align-items:center;gap:5px;font-size:13.5px;cursor:pointer;white-space:nowrap"><input type="checkbox" value="Trabalhista" style="margin:0"> Trabalhista</label>
            <label style="display:inline-flex;align-items:center;gap:5px;font-size:13.5px;cursor:pointer;white-space:nowrap"><input type="checkbox" value="Segurança do Trabalho" style="margin:0"> Segurança do Trabalho</label>
            <label style="display:inline-flex;align-items:center;gap:5px;font-size:13.5px;cursor:pointer;white-space:nowrap"><input type="checkbox" value="RH" style="margin:0"> RH</label>
            <label style="display:inline-flex;align-items:center;gap:5px;font-size:13.5px;cursor:pointer;white-space:nowrap"><input type="checkbox" value="Recrutamento" style="margin:0"> Recrutamento</label>
            <label style="display:inline-flex;align-items:center;gap:5px;font-size:13.5px;cursor:pointer;white-space:nowrap"><input type="checkbox" value="Comercial" style="margin:0"> Comercial</label>
            <label style="display:inline-flex;align-items:center;gap:5px;font-size:13.5px;cursor:pointer;white-space:nowrap"><input type="checkbox" value="Operacional" style="margin:0"> Operacional</label>
          </div>
          <datalist id="cats-kb">
            <option value="Geral"></option><option value="Administrativo"></option><option value="Financeiro"></option>
            <option value="Trabalhista"></option><option value="Segurança do Trabalho"></option><option value="RH"></option>
            <option value="Recrutamento"></option><option value="Comercial"></option><option value="Operacional"></option>
          </datalist>
        </div>
        <div class="form-group">
          <label>Acesso (roles)</label>
          <select id="f-roles" multiple style="height:80px">
            <option value="all" selected>Todos (all)</option>
            <option value="admin">Administrador</option>
            <option value="manutencao_operacao">Manutenção - Operação</option>
            <option value="manutencao_administrativo">Manutenção - Administrativo</option>
            <option value="operacional">Operação</option>
            <option value="rh">RH / DP</option>
            <option value="financeiro">Financeiro</option>
            <option value="comercial">Comercial</option>
            <option value="juridico">Jurídico</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Pergunta *</label>
        <input type="text" id="f-question" placeholder="Qual é a pergunta frequente?">
      </div>
      <div class="form-group">
        <label>Resposta *</label>
        <textarea id="f-answer" rows="5" placeholder="Resposta completa..."></textarea>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
        <button class="btn btn-primary" id="btnSalvar" onclick="salvar()">Salvar</button>
      </div>
    </div>
  </div>

  <!-- Modal importar PDF/URL -->
  <div id="modalImport" class="modal-overlay" style="display:none">
    <div class="modal-box">
      <div class="modal-header">
        <h2>📥 Importar conteúdo para a base</h2>
        <button onclick="fecharImport()" class="modal-close">✕</button>
      </div>
      <p style="font-size:12.5px;color:var(--ink-light);margin:0 0 14px">
        Envie um PDF (políticas, manuais, normas) ou informe a URL de uma página.
        O texto é dividido em blocos e a JunIA passa a usá-lo nas respostas.
      </p>
      <div class="form-row">
        <div class="form-group">
          <label>Título do conteúdo *</label>
          <input type="text" id="imp-titulo" placeholder="ex: Política de EPIs 2026">
        </div>
        <div class="form-group">
          <label>Categoria *</label>
          <input type="text" id="imp-cat" list="cats-kb" placeholder="ex: Segurança do Trabalho">
        </div>
      </div>
      <div class="form-group">
        <label>Arquivo PDF (máx. 8MB)</label>
        <input type="file" id="imp-arquivo" accept="application/pdf">
      </div>
      <div class="form-group">
        <label>— ou — URL da página/PDF</label>
        <input type="url" id="imp-url" placeholder="https://...">
      </div>
      <div class="form-group">
        <label>Acesso (roles)</label>
        <select id="imp-roles" multiple style="height:80px">
          <option value="all" selected>Todos (all)</option>
          <option value="admin">Administrador</option>
          <option value="manutencao_operacao">Manutenção - Operação</option>
          <option value="manutencao_administrativo">Manutenção - Administrativo</option>
          <option value="operacional">Operação</option>
          <option value="rh">RH / DP</option>
          <option value="financeiro">Financeiro</option>
          <option value="comercial">Comercial</option>
          <option value="juridico">Jurídico</option>
        </select>
      </div>
      <div id="imp-msg"></div>
      <div class="modal-footer">
        <button class="btn btn-secondary" onclick="fecharImport()">Cancelar</button>
        <button class="btn btn-primary" id="btnImportar" onclick="importar()">Importar</button>
      </div>
    </div>
  </div>

  <script>
    function abrirImport() { document.getElementById("modalImport")!.style.display = "flex"; }
    function fecharImport() { document.getElementById("modalImport")!.style.display = "none"; }

    async function importar() {
      const titulo = (document.getElementById("imp-titulo") as HTMLInputElement).value.trim();
      const categoria = (document.getElementById("imp-cat") as HTMLInputElement).value.trim();
      const url = (document.getElementById("imp-url") as HTMLInputElement).value.trim();
      const arquivo = (document.getElementById("imp-arquivo") as HTMLInputElement).files?.[0];
      const roles = Array.from((document.getElementById("imp-roles") as HTMLSelectElement).selectedOptions).map(o => o.value);
      const msg = document.getElementById("imp-msg")!;
      if (!titulo || !categoria) { msg.innerHTML = '<div class="alert alert-error">Preencha título e categoria.</div>'; return; }
      if (!arquivo && !url) { msg.innerHTML = '<div class="alert alert-error">Escolha um PDF ou informe uma URL.</div>'; return; }
      if (arquivo && arquivo.size > 8 * 1024 * 1024) { msg.innerHTML = '<div class="alert alert-error">PDF muito grande (máx. 8MB).</div>'; return; }

      const btn = document.getElementById("btnImportar") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Importando...";
      msg.innerHTML = '<div class="alert" style="background:#FFF8E7;border:1px solid #E8D49A;padding:8px 12px;border-radius:8px;font-size:12.5px">Lendo o conteúdo, aguarde…</div>';

      const body: any = { titulo, categoria, access_roles: roles };
      if (arquivo) {
        body.arquivo_base64 = await new Promise<string>((resolve) => {
          const r = new FileReader();
          r.onload = () => resolve(String(r.result).split(",")[1]);
          r.readAsDataURL(arquivo);
        });
      } else { body.url = url; }

      const res = await fetch("/api/admin/portal/kb/importar", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      const d = await res.json().catch(() => ({}));
      btn.disabled = false; btn.textContent = "Importar";
      if (res.ok) {
        alert(`Importado! ${d.blocos} bloco(s) adicionados à base (${d.caracteres} caracteres).`);
        location.reload();
      } else {
        msg.innerHTML = `<div class="alert alert-error">${d.error || "Erro na importação."}</div>`;
      }
    }
    (window as any).abrirImport = abrirImport; (window as any).fecharImport = fecharImport; (window as any).importar = importar;

    function openModal(k?: any) {
      document.getElementById("edit-id")!.value = k?.id || "";
      const cats = String(k?.category || "").split(/[;|]/).map((c) => c.trim().toLowerCase()).filter(Boolean);
      document.querySelectorAll("#f-cats input[type=checkbox]").forEach((cb) => {
        (cb as HTMLInputElement).checked = cats.includes((cb as HTMLInputElement).value.toLowerCase());
      });
      (document.getElementById("f-question") as HTMLInputElement).value = k?.question || "";
      (document.getElementById("f-answer") as HTMLTextAreaElement).value = k?.answer || "";
      document.getElementById("modal-title")!.textContent = k ? "Editar Pergunta" : "Nova Pergunta";
      document.getElementById("modal")!.style.display = "flex";
    }
    function closeModal() { document.getElementById("modal")!.style.display = "none"; }
    function editar(k: any) { openModal(k); }

    async function salvar() {
      const id       = (document.getElementById("edit-id") as HTMLInputElement).value;
      const cats     = Array.from(document.querySelectorAll("#f-cats input:checked")).map((c) => (c as HTMLInputElement).value);
      const category = cats.join("; ");
      const question = (document.getElementById("f-question") as HTMLInputElement).value.trim();
      const answer   = (document.getElementById("f-answer") as HTMLTextAreaElement).value.trim();
      const sel      = document.getElementById("f-roles") as HTMLSelectElement;
      const access_roles = Array.from(sel.selectedOptions).map(o => o.value);
      if (!question || !answer || !cats.length) return alert("Preencha a pergunta, a resposta e marque ao menos uma categoria.");

      const btn = document.getElementById("btnSalvar") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Salvando...";
      const method = id ? "PUT" : "POST";
      const url = id ? `/api/admin/portal/kb/${id}` : "/api/admin/portal/kb";
      const res = await fetch(url, { method, headers: {"Content-Type":"application/json"}, body: JSON.stringify({ question, answer, category, access_roles }) });
      btn.disabled = false; btn.textContent = "Salvar";
      if (res.ok) { closeModal(); location.reload(); } else { alert("Erro ao salvar."); }
    }

    async function excluir(id: string) {
      if (!confirm("Excluir esta pergunta?")) return;
      const res = await fetch(`/api/admin/portal/kb/${id}`, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) location.reload(); else alert("Erro ao excluir.");
    }

    (window as any).openModal = openModal; (window as any).editar = editar;
    (window as any).closeModal = closeModal; (window as any).salvar = salvar; (window as any).excluir = excluir;
  </script>
</Admin>
