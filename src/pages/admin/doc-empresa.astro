---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, temPerfil, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
let claims: AdminClaims;
try { claims = await verifyToken<AdminClaims>(token); if (claims.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }
if (!temPerfil(claims, ["admin", "financeiro", "juridico"])) return Astro.redirect("/admin");

const db = supabaseAdmin();
// Carrega TODOS (ativos + arquivados) — a aba "Arquivados" filtra no cliente
const { data: docsRaw } = await db.from("doc_empresa")
  .select("*, doc_empresa_arquivos(id,nome,created_at)").order("nome");
const docs: any[] = docsRaw || [];
const docsAtivos    = docs.filter((d: any) => !d.arquivado);
const docsArquivados = docs.filter((d: any) => d.arquivado);

// As 5 abas da plataforma (categorização macro). Também é a ordem de exibição.
const ABAS = [
  { nome: "Documento Fiscal", icon: "🧾" },
  { nome: "Documentos Contábeis", icon: "📊" },
  { nome: "Contrato com Cliente", icon: "🤝" },
  { nome: "Empresas Fornecedoras", icon: "🏢" },
  { nome: "Documentos Institucionais", icon: "🏛️" },
];
const CATEGORIAS = ABAS.map((a) => a.nome);
const PERIODICIDADES = ["Mensal", "Anual", "Consulta Mensal", "Sem validade"];

const hoje = new Date().toISOString().slice(0, 10);
const em30 = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

function situacao(d: any): string {
  if (d.validade_na) return "na";
  if (!d.validade) return "definir";
  if (d.validade < hoje) return "vencido";
  if (d.validade <= em30) return "vencendo";
  return "valido";
}
function badge(d: any): { cls: string; txt: string } {
  if (d.validade_na) return { cls: "badge-gray", txt: "N/A — sem validade" };
  if (!d.validade) return { cls: "badge-gray", txt: "⚠ Definir validade" };
  const f = String(d.validade).split("-").reverse().join("/");
  if (d.validade < hoje) return { cls: "badge-red", txt: `Vencido ${f}` };
  if (d.validade <= em30) return { cls: "badge-orange", txt: `Vence ${f}` };
  return { cls: "badge-green", txt: `Válido até ${f}` };
}

// KPIs apenas de documentos ativos
const kpi = { total: docsAtivos.length, vencido: 0, vencendo: 0, na: 0, definir: 0 };
for (const d of docsAtivos) { const s = situacao(d) as keyof typeof kpi; if (s in kpi) (kpi as any)[s]++; }

// Agrupamento dos ativos por categoria
const porCat = new Map<string, any[]>();
for (const d of docsAtivos) { const c = d.categoria || "Documentos Diversos"; if (!porCat.has(c)) porCat.set(c, []); porCat.get(c)!.push(d); }
const cats = [...CATEGORIAS.filter((c) => porCat.has(c)), ...[...porCat.keys()].filter((c) => !CATEGORIAS.includes(c))];

// Agrupamento dos arquivados por categoria
const porCatArq = new Map<string, any[]>();
for (const d of docsArquivados) { const c = d.categoria || "Documentos Diversos"; if (!porCatArq.has(c)) porCatArq.set(c, []); porCatArq.get(c)!.push(d); }
const catsArq = [...CATEGORIAS.filter((c) => porCatArq.has(c)), ...[...porCatArq.keys()].filter((c) => !CATEGORIAS.includes(c))];

// JSON p/ o JS do cliente — inclui todos para que editar/arquivar/excluir funcione
// em ambas as abas (passamos o id no onclick, o docById resolve pelo JSON).
const docsJs = docs.map((d: any) => ({
  id: d.id, categoria: d.categoria, nome: d.nome, periodicidade: d.periodicidade,
  validade: d.validade, validade_na: d.validade_na, site: d.site, observacoes: d.observacoes,
  arquivado: d.arquivado,
  arquivos: (d.doc_empresa_arquivos || []).map((a: any) => ({ id: a.id, nome: a.nome })),
}));
const docsJson = JSON.stringify(docsJs).replace(/</g, "\\u003c");
---
<Admin title="Documentos da Empresa" current="doc-empresa">
  <div class="toolbar">
    <span class="toolbar-title">📑 Documentos da Empresa</span>
    <input class="search-input" id="busca" placeholder="Buscar documento…" oninput="filtrar()" />
    <!-- filtro de categoria virou abas (pills) logo abaixo -->
    <select class="filter-select" id="fSit" onchange="filtrar()">
      <option value="">Todas as situações</option>
      <option value="vencido">⛔ Vencidos</option>
      <option value="vencendo">🟠 Vencendo (30 dias)</option>
      <option value="valido">🟢 Em dia</option>
      <option value="definir">⚠ A definir validade</option>
      <option value="na">⚪ Não aplicável</option>
    </select>
    <button class="btn btn-secondary" onclick="enviarResumo(this)" title="Envia agora o e-mail de vencimentos para o financeiro/jurídico + Telegram">📧 Enviar resumo</button>
    <button class="btn btn-primary" onclick="abrirNovo()">+ Novo documento</button>
  </div>

  <p style="color:var(--ink-mid);font-size:13px;margin:-4px 0 14px">
    Repositório de documentos institucionais (certidões, contrato social, seguros, contratos…). Documentos com <strong>data de validade</strong> geram alerta automático em 30/15/7 dias e no dia do vencimento. Quando o documento não tem validade, marque <strong>"não aplicável"</strong> e ele não cobra alerta.
  </p>

  <div class="pills" id="abasPills" style="margin:2px 0 16px">
    <button type="button" class="pill active" data-cat="" onclick="setAba(this)">📑 Todas</button>
    {ABAS.map((a) => (
      <button type="button" class="pill" data-cat={a.nome} onclick="setAba(this)">{a.icon} {a.nome} <span class="count">{(porCat.get(a.nome) || []).length}</span></button>
    ))}
    <button type="button" class="pill" data-cat="__arquivados__" onclick="setAba(this)">🗄️ Arquivados <span class="count">{docsArquivados.length}</span></button>
  </div>

  <div id="kpiBar" class="card-grid">
    <div class="stat-card"><div class="stat-value">{kpi.total}</div><div class="stat-label">Documentos ativos</div></div>
    <a class="stat-card" href="?#" onclick="setSit('vencido');return false;"><div class="stat-value" style="color:#B91C1C">{kpi.vencido}</div><div class="stat-label">⛔ Vencidos</div></a>
    <a class="stat-card" href="?#" onclick="setSit('vencendo');return false;"><div class="stat-value" style="color:#B45309">{kpi.vencendo}</div><div class="stat-label">🟠 Vencendo (30d)</div></a>
    <a class="stat-card" href="?#" onclick="setSit('definir');return false;"><div class="stat-value" style="color:#6B7280">{kpi.definir}</div><div class="stat-label">⚠ A definir</div></a>
    <a class="stat-card" href="?#" onclick="setSit('na');return false;"><div class="stat-value" style="color:#6B7280">{kpi.na}</div><div class="stat-label">⚪ Não aplicável</div></a>
  </div>

  <div id="msg"></div>

  <!-- ── SEÇÃO: documentos ativos (agrupados por categoria) ── -->
  <div id="secAtivos">
    {cats.length === 0 && (
      <div class="card"><div class="empty-state" style="padding:40px"><strong>Nenhum documento ainda</strong><p>Cadastre no botão "+ Novo documento" ou rode a importação do Monday.</p></div></div>
    )}

  {cats.map((c) => (
    <div class="card doc-sec" data-cat={c} style="padding:0;overflow:hidden;margin-bottom:18px">
      <div style="padding:12px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;background:#FAFBFC">
        <span class="section-title" style="font-size:1rem">{c}</span>
        <span class="badge badge-gray">{porCat.get(c)!.length}</span>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Documento</th><th>Periodicidade</th><th>Validade</th><th>Anexos</th><th></th></tr></thead>
          <tbody>
            {porCat.get(c)!.map((d: any) => {
              const b = badge(d);
              const nArq = (d.doc_empresa_arquivos || []).length;
              return (
                <tr class="doc-row" data-cat={c} data-sit={situacao(d)} data-nome={(d.nome || "").toLowerCase()} style={d.arquivado ? "opacity:.55" : ""}>
                  <td>
                    <strong>{d.nome}</strong>
                    {d.arquivado && <span class="badge badge-gray" style="margin-left:6px">Arquivado</span>}
                    {d.site && <a href={d.site} target="_blank" rel="noopener" title="Link de emissão/consulta" style="margin-left:6px;text-decoration:none">🔗</a>}
                    {d.observacoes && <div style="font-size:12px;color:#9CA3AF;margin-top:2px">{d.observacoes}</div>}
                  </td>
                  <td style="font-size:12.5px;color:#6B7280">{d.periodicidade || "—"}</td>
                  <td><span class={`badge ${b.cls}`}>{b.txt}</span></td>
                  <td>
                    <button class="btn btn-outline btn-sm" onclick={`anexos('${d.id}')`}>📎 {nArq || 0}</button>
                  </td>
                  <td style="white-space:nowrap;text-align:right">
                    <button class="btn btn-secondary btn-sm" onclick={`editar('${d.id}')`}>Editar</button>
                    {d.arquivado
                      ? <button class="btn btn-success btn-sm" onclick={`setArquivado('${d.id}', false)`}>Reativar</button>
                      : <button class="btn btn-outline btn-sm" onclick={`setArquivado('${d.id}', true)`}>Arquivar</button>}
                    <button class="btn btn-danger btn-sm" onclick={`excluir('${d.id}')`}>Excluir</button>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  ))}
  </div>{/* fim #secAtivos */}

  <!-- ── SEÇÃO: documentos arquivados ── -->
  <div id="secArquivados" style="display:none">
    <p style="color:var(--ink-mid);font-size:13px;margin:0 0 14px">Documentos arquivados não geram alertas. Clique em <strong>Reativar</strong> para devolvê-los ao painel principal.</p>
    {catsArq.length === 0 ? (
      <div class="card"><div class="empty-state" style="padding:40px"><strong>Nenhum documento arquivado</strong></div></div>
    ) : catsArq.map((c) => (
      <div class="card" style="padding:0;overflow:hidden;margin-bottom:18px">
        <div style="padding:12px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;background:#FAFBFC">
          <span class="section-title" style="font-size:1rem">{c}</span>
          <span class="badge badge-gray">{porCatArq.get(c)!.length}</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Documento</th><th>Periodicidade</th><th>Validade</th><th>Anexos</th><th></th></tr></thead>
            <tbody>
              {porCatArq.get(c)!.map((d: any) => {
                const b = badge(d);
                const nArq = (d.doc_empresa_arquivos || []).length;
                return (
                  <tr data-nome={(d.nome || "").toLowerCase()}>
                    <td>
                      <strong>{d.nome}</strong>
                      {d.site && <a href={d.site} target="_blank" rel="noopener" title="Link de emissão/consulta" style="margin-left:6px;text-decoration:none">🔗</a>}
                      {d.observacoes && <div style="font-size:12px;color:#9CA3AF;margin-top:2px">{d.observacoes}</div>}
                    </td>
                    <td style="font-size:12.5px;color:#6B7280">{d.periodicidade || "—"}</td>
                    <td><span class={`badge ${b.cls}`}>{b.txt}</span></td>
                    <td><button class="btn btn-outline btn-sm" onclick={`anexos('${d.id}')`}>📎 {nArq || 0}</button></td>
                    <td style="white-space:nowrap;text-align:right">
                      <button class="btn btn-secondary btn-sm" onclick={`editar('${d.id}')`}>Editar</button>
                      <button class="btn btn-success btn-sm" onclick={`setArquivado('${d.id}', false)`}>Reativar</button>
                      <button class="btn btn-danger btn-sm" onclick={`excluir('${d.id}')`}>Excluir</button>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </div>

  <!-- Modal: documento (novo/editar) -->
  <div class="modal-overlay" id="modalDoc">
    <div class="modal-box">
      <div class="modal-header"><h2 id="modalDocTitle">Novo documento</h2><button class="modal-close" onclick="fechar()">✕</button></div>
      <form id="formDoc">
        <input type="hidden" name="id" />
        <div class="form-group"><label>Nome do documento *</label><input name="nome" required placeholder="Ex: CND Federal" /></div>
        <div class="form-row">
          <div class="form-group">
            <label>Categoria *</label>
            <select name="categoria" required>
              {CATEGORIAS.map((c) => <option value={c}>{c}</option>)}
            </select>
          </div>
          <div class="form-group">
            <label>Periodicidade</label>
            <select name="periodicidade"><option value="">—</option>{PERIODICIDADES.map((p) => <option value={p}>{p}</option>)}</select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Validade (vencimento)</label><input type="date" name="validade" id="fldValidade" /></div>
          <div class="form-group" style="display:flex;align-items:center;gap:8px;padding-top:24px">
            <input type="checkbox" id="fldValidadeNA" name="validade_na" style="width:auto" onchange="toggleNA()" />
            <label for="fldValidadeNA" style="margin:0;cursor:pointer">Não aplicável (sem validade)</label>
          </div>
        </div>
        <div class="form-group"><label>Site / link de emissão</label><input name="site" placeholder="https://…" /></div>
        <div class="form-group"><label>Observações</label><textarea name="observacoes"></textarea></div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="fechar()">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: anexos -->
  <div class="modal-overlay" id="modalArq">
    <div class="modal-box">
      <div class="modal-header"><h2 id="modalArqTitle">Anexos</h2><button class="modal-close" onclick="fecharArq()">✕</button></div>
      <div style="padding:16px 24px">
        <div id="listaArq"></div>
        <form id="formUpload" style="margin-top:14px;border-top:1px solid var(--border);padding-top:14px">
          <input type="hidden" name="doc_id" />
          <label style="display:block;font-size:0.86rem;font-weight:600;color:#555;margin-bottom:5px">Anexar arquivo (PDF, imagem, DOC, XLS — até 25 MB)</label>
          <div style="display:flex;gap:8px;align-items:center">
            <input type="file" name="arquivo" required accept=".pdf,.doc,.docx,.xls,.xlsx,image/*,application/pdf" style="flex:1" />
            <button type="submit" class="btn btn-primary" id="btnUpload">Enviar</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script type="application/json" id="docsData" set:html={docsJson} />

  <script>
    const overlay = (id: string) => document.getElementById(id)!;
    const DOCS: any[] = JSON.parse((document.getElementById("docsData") as HTMLElement)?.textContent || "[]");
    const docById = (id: string) => DOCS.find((x: any) => x.id === id);
    let abaAtiva = "";
    function setAba(btn: HTMLElement) {
      document.querySelectorAll("#abasPills .pill").forEach((p) => p.classList.remove("active"));
      btn.classList.add("active");
      abaAtiva = btn.dataset.cat || "";
      const isArq = abaAtiva === "__arquivados__";
      (document.getElementById("secAtivos") as HTMLElement).style.display     = isArq ? "none" : "";
      (document.getElementById("secArquivados") as HTMLElement).style.display = isArq ? "" : "none";
      (document.getElementById("kpiBar") as HTMLElement).style.display        = isArq ? "none" : "";
      // filtros de situação e busca só fazem sentido nos ativos
      (document.getElementById("fSit") as HTMLElement).style.display = isArq ? "none" : "";
      if (!isArq) filtrar();
    }
    // Preserva a aba ativa ao recarregar a página após uma ação
    function reloadComAba() {
      const u = new URL(location.href);
      if (abaAtiva) u.searchParams.set("aba", abaAtiva);
      else u.searchParams.delete("aba");
      location.replace(u.toString());
    }
    // Restaura a aba ativa a partir de ?aba= (setado pelo reloadComAba)
    (function () {
      const cat = new URLSearchParams(location.search).get("aba");
      if (!cat) return;
      const btn = document.querySelector(`#abasPills .pill[data-cat="${cat.replace(/"/g, '\\"')}"]`) as HTMLElement;
      if (btn) setAba(btn);
    })();

    function fechar() { overlay("modalDoc").classList.remove("open"); }
    function fecharArq() { overlay("modalArq").classList.remove("open"); }

    function toggleNA() {
      const na = document.getElementById("fldValidadeNA") as HTMLInputElement;
      const val = document.getElementById("fldValidade") as HTMLInputElement;
      val.disabled = na.checked;
      if (na.checked) val.value = "";
    }

    function abrirNovo() {
      const f = document.getElementById("formDoc") as HTMLFormElement;
      f.reset();
      (f.querySelector("[name=id]") as HTMLInputElement).value = "";
      (document.getElementById("fldValidade") as HTMLInputElement).disabled = false;
      document.getElementById("modalDocTitle")!.textContent = "Novo documento";
      overlay("modalDoc").classList.add("open");
    }

    function editar(id: string) {
      const d = docById(id);
      if (!d) return;
      const f = document.getElementById("formDoc") as HTMLFormElement;
      f.reset();
      (f.querySelector("[name=id]") as HTMLInputElement).value = d.id || "";
      (f.querySelector("[name=nome]") as HTMLInputElement).value = d.nome || "";
      (f.querySelector("[name=categoria]") as HTMLSelectElement).value = d.categoria || "Documentos Diversos";
      (f.querySelector("[name=periodicidade]") as HTMLSelectElement).value = d.periodicidade || "";
      (f.querySelector("[name=site]") as HTMLInputElement).value = d.site || "";
      (f.querySelector("[name=observacoes]") as HTMLTextAreaElement).value = d.observacoes || "";
      const na = document.getElementById("fldValidadeNA") as HTMLInputElement;
      const val = document.getElementById("fldValidade") as HTMLInputElement;
      na.checked = !!d.validade_na;
      val.value = d.validade || "";
      val.disabled = na.checked;
      document.getElementById("modalDocTitle")!.textContent = "Editar documento";
      overlay("modalDoc").classList.add("open");
    }

    document.getElementById("formDoc")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const fd = new FormData(f);
      const body: Record<string, any> = Object.fromEntries(fd.entries());
      body.validade_na = (f.querySelector("[name=validade_na]") as HTMLInputElement).checked;
      const id = body.id; delete body.id;
      const url = id ? `/api/admin/doc-empresa/${id}` : "/api/admin/doc-empresa";
      const method = id ? "PATCH" : "POST";
      const res = await fetch(url, { method, headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (res.ok) reloadComAba();
      else document.getElementById("msg")!.innerHTML = `<div class="alert alert-error">${(await res.json()).error || "Erro ao salvar"}</div>`;
    });

    async function setArquivado(id: string, arquivado: boolean) {
      if (!confirm(arquivado ? "Arquivar este documento? Ele some do painel e para de gerar alertas (recuperável em 'Ver arquivados')." : "Reativar este documento?")) return;
      const res = await fetch(`/api/admin/doc-empresa/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ arquivado }) });
      if (res.ok) reloadComAba(); else alert((await res.json()).error || "Erro");
    }

    async function excluir(id: string) {
      const d = docById(id);
      const nome = (d && d.nome) || "este documento";
      if (!confirm(`Excluir "${nome}"? Vai para a lixeira (recuperável por 30 dias).`)) return;
      const res = await fetch(`/api/admin/doc-empresa/${id}`, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) reloadComAba(); else alert((await res.json()).error || "Erro");
    }

    // ── Anexos ──
    function anexos(id: string) {
      const d = docById(id);
      const nome = (d && d.nome) || "";
      const arquivos = (d && d.arquivos) || [];
      document.getElementById("modalArqTitle")!.textContent = `Anexos — ${nome}`;
      renderArq(arquivos);
      (document.getElementById("formUpload") as HTMLFormElement).reset();
      (document.querySelector("#formUpload [name=doc_id]") as HTMLInputElement).value = id;
      overlay("modalArq").classList.add("open");
    }
    function renderArq(arquivos: any[]) {
      const box = document.getElementById("listaArq")!;
      if (!arquivos || !arquivos.length) { box.innerHTML = `<p style="color:#9CA3AF;font-size:13px">Nenhum arquivo anexado ainda.</p>`; return; }
      box.innerHTML = arquivos.map((a) => `
        <div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border-light)">
          <span style="flex:1;font-size:13.5px">📄 ${(a.nome || "arquivo").replace(/</g, "&lt;")}</span>
          <a class="btn btn-outline btn-sm" href="/api/admin/doc-empresa/arquivos/${a.id}" target="_blank" rel="noopener">Baixar</a>
          <button class="btn btn-danger btn-sm" onclick="excluirArq('${a.id}', this)">Excluir</button>
        </div>`).join("");
    }
    async function excluirArq(fid: string, btn: HTMLButtonElement) {
      if (!confirm("Excluir este arquivo?")) return;
      btn.disabled = true;
      const res = await fetch(`/api/admin/doc-empresa/arquivos/${fid}`, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) reloadComAba(); else { alert((await res.json()).error || "Erro"); btn.disabled = false; }
    }
    document.getElementById("formUpload")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const id = (f.querySelector("[name=doc_id]") as HTMLInputElement).value;
      const btn = document.getElementById("btnUpload") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Enviando…";
      const fd = new FormData();
      fd.append("arquivo", (f.querySelector("[name=arquivo]") as HTMLInputElement).files![0]);
      const res = await fetch(`/api/admin/doc-empresa/${id}/upload`, { method: "POST", body: fd });
      if (res.ok) reloadComAba();
      else { alert((await res.json()).error || "Erro no envio"); btn.disabled = false; btn.textContent = "Enviar"; }
    });

    // ── Filtro ──
    function filtrar() {
      const t = (document.getElementById("busca") as HTMLInputElement).value.toLowerCase().trim();
      const cat = abaAtiva;
      const sit = (document.getElementById("fSit") as HTMLSelectElement).value;
      document.querySelectorAll(".doc-sec").forEach((secEl) => {
        const sec = secEl as HTMLElement;
        let visiveis = 0;
        sec.querySelectorAll(".doc-row").forEach((rowEl) => {
          const row = rowEl as HTMLElement;
          const okCat = !cat || row.dataset.cat === cat;
          const okSit = !sit || row.dataset.sit === sit;
          const okBusca = !t || (row.dataset.nome || "").includes(t);
          const mostra = okCat && okSit && okBusca;
          row.style.display = mostra ? "" : "none";
          if (mostra) visiveis++;
        });
        sec.style.display = visiveis ? "" : "none";
      });
    }
    function setSit(s: string) {
      (document.getElementById("fSit") as HTMLSelectElement).value = s;
      abaAtiva = "";
      document.querySelectorAll("#abasPills .pill").forEach((p) => (p as HTMLElement).classList.toggle("active", (p as HTMLElement).dataset.cat === ""));
      filtrar();
      window.scrollTo({ top: 260, behavior: "smooth" });
    }

    async function enviarResumo(btn: HTMLButtonElement) {
      btn.disabled = true; const orig = btn.textContent; btn.textContent = "Enviando…";
      try {
        const res = await fetch("/api/cron/doc-empresa-vencimentos?modo=completo");
        const d = await res.json();
        alert(res.ok ? `Resumo enviado. ${d.total || 0} documento(s) a vencer/vencido(s).` : (d.error || "Erro"));
      } catch { alert("Falha ao enviar."); }
      btn.disabled = false; btn.textContent = orig;
    }

    Object.assign(window, { abrirNovo, editar, fechar, setArquivado, excluir, anexos, fecharArq, excluirArq, toggleNA, filtrar, setSit, setAba, enviarResumo });
  </script>
