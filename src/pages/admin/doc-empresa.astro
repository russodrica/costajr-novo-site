---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, temPerfil, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
let claims: AdminClaims;
try { claims = await verifyToken<AdminClaims>(token); if (claims.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }
if (!temPerfil(claims, ["admin", "financeiro", "juridico", "comercial"])) return Astro.redirect("/admin");

const db = supabaseAdmin();
// Carrega TODOS (ativos + arquivados) — a aba "Arquivados" filtra no cliente
const { data: docsRaw } = await db.from("doc_empresa")
  .select("*, doc_empresa_arquivos(id,nome,created_at,competencia)").order("nome");
const docs: any[] = docsRaw || [];

// Catálogo completo de abas. A VIEW (?view=) decide quais aparecem — assim
// "Documentos da Empresa", "Documentos Contratuais" e "Seguros" são entradas de
// menu distintas que compartilham a MESMA base (doc_empresa) e as mesmas APIs.
const ABAS_ALL = [
  { nome: "Documentos da Empresa", icon: "🏢" },
  { nome: "Certidões", icon: "📜" },
  { nome: "Processos da Empresa", icon: "⚖️" },
  { nome: "Contratos", icon: "📝" },
  { nome: "Seguros", icon: "🛡️" },
  { nome: "Clientes", icon: "🤝" },
  { nome: "Guias e Obrigações Fiscais", icon: "🧾" },
  { nome: "Documentos Contábeis", icon: "📊" },
  { nome: "Documentos Institucionais", icon: "🏛️" },
];
const CATEGORIAS = ABAS_ALL.map((a) => a.nome);

const VIEW = (Astro.url.searchParams.get("view") || "empresa").toLowerCase();
const CONTRATOS_CATS = new Set(["Contratos", "Clientes"]);
const SEGUROS_CATS = new Set(["Seguros"]);
const naView = (cat: string) => {
  if (VIEW === "contratos") return CONTRATOS_CATS.has(cat);
  if (VIEW === "seguros") return SEGUROS_CATS.has(cat);
  return !CONTRATOS_CATS.has(cat) && !SEGUROS_CATS.has(cat); // empresa = o restante
};
const VIEW_META: Record<string, { titulo: string; current: string; icon: string }> = {
  empresa:   { titulo: "Documentos da Empresa",  current: "doc-empresa",   icon: "📑" },
  contratos: { titulo: "Documentos Contratuais", current: "doc-contratos", icon: "📝" },
  seguros:   { titulo: "Seguros",                current: "doc-seguros",   icon: "🛡️" },
};
const vmeta = VIEW_META[VIEW] || VIEW_META.empresa;
const viewDefaultCat = VIEW === "contratos" ? "Contratos" : VIEW === "seguros" ? "Seguros" : "Documentos da Empresa";
const ABAS = ABAS_ALL.filter((a) => naView(a.nome));

const docsAtivos    = docs.filter((d: any) => !d.arquivado && naView(d.categoria || ""));
const docsArquivados = docs.filter((d: any) => d.arquivado && naView(d.categoria || ""));
const PERIODICIDADES = ["Mensal", "Anual", "Consulta Mensal", "Sem validade"];

// Categorias por PERÍODO/CONTRATO — não geram alerta de vencimento (validade não se aplica).
// As de validade (Certidões, Documentos da Empresa, Seguros, Fornecedoras) seguem com alerta.
const CATS_SEM_ALERTA = new Set(["Guias e Obrigações Fiscais", "Documentos Contábeis", "Clientes", "Documentos Institucionais", "Contratos", "Processos da Empresa"]);
const CAT_SEM_ALERTA = "Empreiteiros / Terceiros"; // legado (categoria arquivada)
// Categorias PERIÓDICAS — cada card é um TIPO (PGDAS, Balancete…) com competências (meses);
// renderizadas como cards expansíveis ("+") em vez de tabela.
const CATS_PERIODO = new Set(["Guias e Obrigações Fiscais", "Documentos Contábeis"]);

// Sub-grupos de "Documento Fiscal" (definidos aqui para usar no template; porGrupoFiscal calculado depois de porCat)
const GRUPOS_FISCAL = [
  { key: "CND",          label: "CND — Federal, Estadual e Municipal" },
  { key: "Trabalhistas", label: "Trabalhistas — FGTS, INSS e outros" },
  { key: "Sócios",       label: "Sócios — RG, CNH, IR, Comprovante de Residência" },
  { key: "Diversos",     label: "Diversos" },
];

const hoje = new Date().toISOString().slice(0, 10);
const em30 = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

function situacao(d: any, cat?: string): string {
  if (cat && CATS_SEM_ALERTA.has(cat)) return "na"; // por período/contrato — sem alerta de vencimento
  if (d.validade_na) return "na";
  if (!d.validade) return "definir";
  if (d.validade < hoje) return "vencido";
  if (d.validade <= em30) return "vencendo";
  return "valido";
}
function badge(d: any, cat?: string): { cls: string; txt: string } {
  if (cat && CATS_SEM_ALERTA.has(cat)) return { cls: "badge-gray", txt: "—" };
  if (d.validade_na) return { cls: "badge-gray", txt: "N/A — sem validade" };
  const emit = d.data_emissao ? `📅 ${String(d.data_emissao).split("-").reverse().join("/")} · ` : "";
  if (!d.validade) return { cls: "badge-gray", txt: `${emit}⚠ Definir validade` };
  const f = String(d.validade).split("-").reverse().join("/");
  if (d.validade < hoje) return { cls: "badge-red", txt: `${emit}Vencido ${f}` };
  if (d.validade <= em30) return { cls: "badge-orange", txt: `${emit}Vence ${f}` };
  return { cls: "badge-green", txt: `${emit}Válido até ${f}` };
}

// KPIs apenas de documentos ativos (Empreiteiros/Terceiros não contam em vencido/vencendo)
const kpi = { total: docsAtivos.length, vencido: 0, vencendo: 0, na: 0, definir: 0 };
for (const d of docsAtivos) { const s = situacao(d, d.categoria || "") as keyof typeof kpi; if (s in kpi) (kpi as any)[s]++; }

// Agrupamento dos ativos por categoria
const porCat = new Map<string, any[]>();
for (const d of docsAtivos) { const c = d.categoria || "Documentos Diversos"; if (!porCat.has(c)) porCat.set(c, []); porCat.get(c)!.push(d); }
const cats = [...CATEGORIAS.filter((c) => porCat.has(c)), ...[...porCat.keys()].filter((c) => !CATEGORIAS.includes(c))];

// porGrupoFiscal calculado APÓS porCat (depende de porCat.get)
const porGrupoFiscal = new Map<string, any[]>();
for (const { key } of GRUPOS_FISCAL) porGrupoFiscal.set(key, []);
for (const d of (porCat.get("Documento Fiscal") || [])) {
  const gk = d.grupo || "Diversos";
  if (!porGrupoFiscal.has(gk)) porGrupoFiscal.set(gk, []);
  porGrupoFiscal.get(gk)!.push(d);
}

// Sub-grupos da aba "Contratos"
const GRUPOS_FORNECEDOR = [
  { key: "Consultoria", label: "Contratos de Consultoria" },
  { key: "Recorrentes", label: "Contratos Recorrentes" },
  { key: "Plataformas", label: "Plataformas" },
  { key: "Empresas",    label: "Contratos de Empresas (benefícios, locações e diversos)" },
];
const porGrupoFornecedor = new Map<string, any[]>();
for (const { key } of GRUPOS_FORNECEDOR) porGrupoFornecedor.set(key, []);
for (const d of (porCat.get("Contratos") || [])) {
  // sub-tipos antigos (Benefícios/Locações/Diversos) caem em "Empresas"
  const gk = GRUPOS_FORNECEDOR.some((g) => g.key === d.grupo) ? d.grupo : "Empresas";
  porGrupoFornecedor.get(gk)!.push(d);
}

// Agrupamento dos arquivados por categoria
const porCatArq = new Map<string, any[]>();
for (const d of docsArquivados) { const c = d.categoria || "Documentos Diversos"; if (!porCatArq.has(c)) porCatArq.set(c, []); porCatArq.get(c)!.push(d); }
const catsArq = [...CATEGORIAS.filter((c) => porCatArq.has(c)), ...[...porCatArq.keys()].filter((c) => !CATEGORIAS.includes(c))];

// JSON p/ o JS do cliente — inclui todos para que editar/arquivar/excluir funcione
// em ambas as abas (passamos o id no onclick, o docById resolve pelo JSON).
const docsJs = docs.map((d: any) => ({
  id: d.id, categoria: d.categoria, grupo: d.grupo || null, nome: d.nome, periodicidade: d.periodicidade,
  validade: d.validade, validade_na: d.validade_na, data_emissao: d.data_emissao, site: d.site, observacoes: d.observacoes,
  arquivado: d.arquivado, valor_mensal: d.valor_mensal ?? null,
  arquivos: (d.doc_empresa_arquivos || []).map((a: any) => ({ id: a.id, nome: a.nome, competencia: a.competencia || null, created_at: a.created_at || null })),
}));
const docsJson = JSON.stringify(docsJs).replace(/</g, "\\u003c");
---
<Admin title={vmeta.titulo} current={vmeta.current}>
  <div class="toolbar">
    <span class="toolbar-title">{vmeta.icon} {vmeta.titulo}</span>
    <input class="search-input" id="busca" placeholder="Buscar documento…" oninput="filtrar()" />
    <!-- filtro de categoria virou abas (pills) logo abaixo -->
    <select class="filter-select" id="fSit" onchange="filtrar()">
      <option value="">Todas as situações</option>
      <option value="vencido">⛔ Vencidos</option>
      <option value="vencendo">🟠 Vencendo (30 dias)</option>
      <option value="valido">🟢 Em dia</option>
      <option value="definir">⚠ A definir validade</option>
      <option value="na">⚪ Não aplicável</option>
    </select>
    <button class="btn btn-secondary" onclick="enviarResumo(this)" title="Envia agora o e-mail de vencimentos para o financeiro/jurídico + Telegram">📧 Enviar resumo</button>
    <button class="btn btn-primary" onclick="abrirNovo()">+ Novo documento</button>
  </div>

  <p style="color:var(--ink-mid);font-size:13px;margin:-4px 0 14px">
    Repositório de documentos institucionais (certidões, contrato social, seguros, contratos…). Documentos com <strong>data de validade</strong> geram alerta automático em 30/15/7 dias e no dia do vencimento. Quando o documento não tem validade, marque <strong>"não aplicável"</strong> e ele não cobra alerta.
  </p>

  <div class="pills" id="abasPills" style="margin:2px 0 16px">
    <button type="button" class="pill active" data-cat="" onclick="setAba(this)">📑 Todas</button>
    {ABAS.map((a) => (
      <button type="button" class="pill" data-cat={a.nome} onclick="setAba(this)">{a.icon} {a.nome} <span class="count">{(porCat.get(a.nome) || []).length}</span></button>
    ))}
    <button type="button" class="pill" data-cat="__arquivados__" onclick="setAba(this)">🗄️ Arquivados <span class="count">{docsArquivados.length}</span></button>
  </div>

  <div id="kpiBar" class="card-grid">
    <div class="stat-card"><div class="stat-value">{kpi.total}</div><div class="stat-label">Documentos ativos</div></div>
    <a class="stat-card" href="?#" onclick="setSit('vencido');return false;"><div class="stat-value" style="color:#B91C1C">{kpi.vencido}</div><div class="stat-label">⛔ Vencidos</div></a>
    <a class="stat-card" href="?#" onclick="setSit('vencendo');return false;"><div class="stat-value" style="color:#B45309">{kpi.vencendo}</div><div class="stat-label">🟠 Vencendo (30d)</div></a>
    <a class="stat-card" href="?#" onclick="setSit('definir');return false;"><div class="stat-value" style="color:#6B7280">{kpi.definir}</div><div class="stat-label">⚠ A definir</div></a>
    <a class="stat-card" href="?#" onclick="setSit('na');return false;"><div class="stat-value" style="color:#6B7280">{kpi.na}</div><div class="stat-label">⚪ Não aplicável</div></a>
  </div>

  <div id="msg"></div>

  <!-- ── SEÇÃO: documentos ativos (agrupados por categoria) ── -->
  <div id="secAtivos">
    {cats.length === 0 && (
      <div class="card"><div class="empty-state" style="padding:40px"><strong>Nenhum documento ainda</strong><p>Cadastre no botão "+ Novo documento" ou rode a importação do Monday.</p></div></div>
    )}

  {cats.map((c) => {
    const isFiscal = c === "Documento Fiscal";
    const isFornecedor = c === "Contratos";
    const isPeriodo = CATS_PERIODO.has(c);
    const docsInCat = porCat.get(c)!;
    return (
      <div class="card doc-sec" data-cat={c} style="padding:0;overflow:hidden;margin-bottom:18px">
        <div style="padding:12px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;background:#FAFBFC">
          <span class="section-title doc-cat-title">{c}</span>
          <span class="badge badge-gray">{docsInCat.length}</span>
        </div>
        {isFiscal ? (
          // ── Documento Fiscal: tabelas por sub-grupo ──
          GRUPOS_FISCAL.map(({ key, label }) => {
            const docsGrupo = porGrupoFiscal.get(key) || [];
            return docsGrupo.length > 0 ? (
              <div class="doc-subgrupo" data-grupo={key}>
                <div style="padding:7px 18px;font-size:13.5px;font-weight:800;color:var(--brand);text-transform:uppercase;letter-spacing:.04em;background:#F5F5F7;border-bottom:1px solid var(--border)">{label}</div>
                <div class="table-wrap">
                  <table>
                    <thead><tr><th>Documento</th><th>Periodicidade</th><th>Validade</th><th>Anexos</th><th></th></tr></thead>
                    <tbody>
                      {docsGrupo.map((d: any) => {
                        const b = badge(d, c);
                        const nArq = (d.doc_empresa_arquivos || []).length;
                        return (
                          <tr class="doc-row" data-cat={c} data-sit={situacao(d, c)} data-nome={(d.nome || "").toLowerCase()}>
                            <td>
                              <strong>{d.nome}</strong>
                              {d.site && <a href={d.site} target="_blank" rel="noopener" title="Link de emissão/consulta" style="margin-left:6px;text-decoration:none">🔗</a>}
                              {d.observacoes && <div style="font-size:12px;color:#9CA3AF;margin-top:2px">{d.observacoes}</div>}
                            </td>
                            <td style="font-size:12.5px;color:#6B7280">{d.periodicidade || "—"}</td>
                            <td><span class={`badge ${b.cls}`}>{b.txt}</span></td>
                            <td>
                              {nArq === 0
                                ? <button class="btn btn-sm" style="background:#FEF3C7;color:#92400E;border:1.5px solid #FCD34D;border-radius:6px;cursor:pointer;font-size:12px;padding:3px 10px;font-weight:600" onclick={`anexos('${d.id}')`} title="Nenhum arquivo anexado">📎 Sem anexo</button>
                                : <button class="btn btn-outline btn-sm" onclick={`anexos('${d.id}')`} title={`${nArq} arquivo(s)`}>📎 {nArq}</button>}
                            </td>
                            <td style="white-space:nowrap;text-align:right">
                              <button class="btn btn-secondary btn-sm" onclick={`editar('${d.id}')`}>Editar</button>
                              {d.arquivado
                                ? <button class="btn btn-success btn-sm" onclick={`setArquivado('${d.id}', false)`}>Reativar</button>
                                : <button class="btn btn-outline btn-sm" onclick={`setArquivado('${d.id}', true)`}>Arquivar</button>}
                              <button class="btn btn-danger btn-sm" onclick={`excluir('${d.id}')`}>Excluir</button>
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              </div>
            ) : null;
          })
        ) : isFornecedor ? (
          // ── Contratos: tabela por sub-tipo com coluna $/Mês e cabeçalhos ordenáveis ──
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th data-forn-th="nome" onclick="sortForn('nome')" style="cursor:pointer;user-select:none">Contrato <span class="sort-arr">↕</span></th>
                  <th>Periodicidade</th>
                  <th data-forn-th="validade" onclick="sortForn('validade')" style="cursor:pointer;user-select:none">Validade <span class="sort-arr">↕</span></th>
                  <th data-forn-th="val" onclick="sortForn('val')" style="cursor:pointer;user-select:none;text-align:right">$/Mês <span class="sort-arr">↕</span></th>
                  <th>Anexos</th>
                  <th></th>
                </tr>
              </thead>
              <tbody data-forn-tbody-all="1">
                {(GRUPOS_FORNECEDOR.flatMap(({ key, label }) => {
                  const docsGrupo = porGrupoFornecedor.get(key) || [];
                  if (!docsGrupo.length) return [] as any[];
                  const labelRow = (
                    <tr class="sg-label-row" data-sg-forn-label={key}>
                      <td colspan={6} style="padding:7px 18px;font-size:13.5px;font-weight:800;color:var(--brand);text-transform:uppercase;letter-spacing:.04em;background:#F5F5F7;border-bottom:1px solid var(--border)">{label}</td>
                    </tr>
                  );
                  const dataRows = docsGrupo.map((d: any) => {
                    const b = badge(d, c);
                    const nArq = (d.doc_empresa_arquivos || []).length;
                    const vm = d.valor_mensal != null ? `R$ ${Number(d.valor_mensal).toLocaleString("pt-BR", {minimumFractionDigits: 2})}` : "—";
                    return (
                      <tr class="doc-row forn-row" data-cat={c} data-sit={situacao(d, c)} data-nome={(d.nome || "").toLowerCase()} data-val={String(d.valor_mensal || 0)} data-validade={d.validade || "9999-99-99"} data-forn-grp={key}>
                        <td>
                          <strong>{d.nome}</strong>
                          {d.site && <a href={d.site} target="_blank" rel="noopener" title="Link de emissão/consulta" style="margin-left:6px;text-decoration:none">🔗</a>}
                          {d.observacoes && <div style="font-size:12px;color:#9CA3AF;margin-top:2px">{d.observacoes}</div>}
                        </td>
                        <td style="font-size:12.5px;color:#6B7280">{d.periodicidade || "—"}</td>
                        <td><span class={`badge ${b.cls}`}>{b.txt}</span></td>
                        <td style="text-align:right;font-weight:600;font-size:13px;white-space:nowrap">{vm}</td>
                        <td>
                          {nArq === 0
                            ? <button class="btn btn-sm" style="background:#FEF3C7;color:#92400E;border:1.5px solid #FCD34D;border-radius:6px;cursor:pointer;font-size:12px;padding:3px 10px;font-weight:600" onclick={`anexos('${d.id}')`} title="Nenhum arquivo anexado">📎 Sem anexo</button>
                            : <button class="btn btn-outline btn-sm" onclick={`anexos('${d.id}')`} title={`${nArq} arquivo(s)`}>📎 {nArq}</button>}
                        </td>
                        <td style="white-space:nowrap;text-align:right">
                          <button class="btn btn-secondary btn-sm" onclick={`editar('${d.id}')`}>Editar</button>
                          <button class="btn btn-outline btn-sm" onclick={`setArquivado('${d.id}', true)`}>Arquivar</button>
                          <button class="btn btn-danger btn-sm" onclick={`excluir('${d.id}')`}>Excluir</button>
                        </td>
                      </tr>
                    );
                  });
                  return [labelRow, ...dataRows] as any[];
                }) as any)}
              </tbody>
            </table>
          </div>
        ) : isPeriodo ? (
          <div style="padding:8px 12px">
            {docsInCat.map((d: any) => {
              const nArq = (d.doc_empresa_arquivos || []).length;
              return (
                <div class="doc-row" data-cat={c} data-sit={situacao(d, c)} data-nome={(d.nome || "").toLowerCase()} style="border:1px solid var(--border);border-radius:8px;margin:7px 0;overflow:hidden">
                  <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:#FAFBFC;cursor:pointer" onclick={`togglePeriodo('${d.id}')`}>
                    <span id={`exp-${d.id}`} style="font-weight:800;color:var(--brand);font-size:1.05rem;width:14px;text-align:center">+</span>
                    <strong style="flex:1">{d.nome}</strong>
                    <span class="badge badge-blue">{nArq} competência(s)</span>
                    <button class="btn btn-outline btn-sm" onclick={`event.stopPropagation();anexos('${d.id}')`}>+ Anexar</button>
                    <button class="btn btn-secondary btn-sm" onclick={`event.stopPropagation();editar('${d.id}')`}>Editar</button>
                    <button class="btn btn-danger btn-sm" onclick={`event.stopPropagation();excluir('${d.id}')`}>Excluir</button>
                  </div>
                  <div id={`per-${d.id}`} style="display:none;padding:8px 16px 14px"></div>
                </div>
              );
            })}
          </div>
        ) : (
          <div class="table-wrap">
            <table>
              <thead><tr><th>Documento</th><th>Periodicidade</th><th>Validade</th><th>Anexos</th><th></th></tr></thead>
              <tbody>
                {docsInCat.map((d: any) => {
                  const b = badge(d, c);
                  const nArq = (d.doc_empresa_arquivos || []).length;
                  return (
                    <tr class="doc-row" data-cat={c} data-sit={situacao(d, c)} data-nome={(d.nome || "").toLowerCase()} style={d.arquivado ? "opacity:.55" : ""}>
                      <td>
                        <strong>{d.nome}</strong>
                        {d.arquivado && <span class="badge badge-gray" style="margin-left:6px">Arquivado</span>}
                        {d.site && <a href={d.site} target="_blank" rel="noopener" title="Link de emissão/consulta" style="margin-left:6px;text-decoration:none">🔗</a>}
                        {d.observacoes && <div style="font-size:12px;color:#9CA3AF;margin-top:2px">{d.observacoes}</div>}
                      </td>
                      <td style="font-size:12.5px;color:#6B7280">{d.periodicidade || "—"}</td>
                      <td><span class={`badge ${b.cls}`}>{b.txt}</span></td>
                      <td>
                        {nArq === 0
                          ? <button class="btn btn-sm" style="background:#FEF3C7;color:#92400E;border:1.5px solid #FCD34D;border-radius:6px;cursor:pointer;font-size:12px;padding:3px 10px;font-weight:600" onclick={`anexos('${d.id}')`} title="Nenhum arquivo anexado">📎 Sem anexo</button>
                          : <button class="btn btn-outline btn-sm" onclick={`anexos('${d.id}')`} title={`${nArq} arquivo(s)`}>📎 {nArq}</button>}
                      </td>
                      <td style="white-space:nowrap;text-align:right">
                        <button class="btn btn-secondary btn-sm" onclick={`editar('${d.id}')`}>Editar</button>
                        {d.arquivado
                          ? <button class="btn btn-success btn-sm" onclick={`setArquivado('${d.id}', false)`}>Reativar</button>
                          : <button class="btn btn-outline btn-sm" onclick={`setArquivado('${d.id}', true)`}>Arquivar</button>}
                        <button class="btn btn-danger btn-sm" onclick={`excluir('${d.id}')`}>Excluir</button>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>
    );
  })}
  </div>{/* fim #secAtivos */}

  <!-- ── SEÇÃO: documentos arquivados ── -->
  <div id="secArquivados" style="display:none">
    <p style="color:var(--ink-mid);font-size:13px;margin:0 0 14px">Documentos arquivados não geram alertas. Clique em <strong>Reativar</strong> para devolvê-los ao painel principal.</p>
    {catsArq.length === 0 ? (
      <div class="card"><div class="empty-state" style="padding:40px"><strong>Nenhum documento arquivado</strong></div></div>
    ) : catsArq.map((c) => (
      <div class="card" style="padding:0;overflow:hidden;margin-bottom:18px">
        <div style="padding:12px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;background:#FAFBFC">
          <span class="section-title doc-cat-title">{c}</span>
          <span class="badge badge-gray">{porCatArq.get(c)!.length}</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Documento</th><th>Periodicidade</th><th>Validade</th><th>Anexos</th><th></th></tr></thead>
            <tbody>
              {porCatArq.get(c)!.map((d: any) => {
                const b = badge(d);
                const nArq = (d.doc_empresa_arquivos || []).length;
                return (
                  <tr data-nome={(d.nome || "").toLowerCase()}>
                    <td>
                      <strong>{d.nome}</strong>
                      {d.site && <a href={d.site} target="_blank" rel="noopener" title="Link de emissão/consulta" style="margin-left:6px;text-decoration:none">🔗</a>}
                      {d.observacoes && <div style="font-size:12px;color:#9CA3AF;margin-top:2px">{d.observacoes}</div>}
                    </td>
                    <td style="font-size:12.5px;color:#6B7280">{d.periodicidade || "—"}</td>
                    <td><span class={`badge ${b.cls}`}>{b.txt}</span></td>
                    <td><button class="btn btn-outline btn-sm" onclick={`anexos('${d.id}')`}>📎 {nArq || 0}</button></td>
                    <td style="white-space:nowrap;text-align:right">
                      <button class="btn btn-secondary btn-sm" onclick={`editar('${d.id}')`}>Editar</button>
                      <button class="btn btn-success btn-sm" onclick={`setArquivado('${d.id}', false)`}>Reativar</button>
                      <button class="btn btn-danger btn-sm" onclick={`excluir('${d.id}')`}>Excluir</button>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </div>

  <!-- Modal: documento (novo/editar) -->
  <div class="modal-overlay" id="modalDoc">
    <div class="modal-box">
      <div class="modal-header"><h2 id="modalDocTitle">Novo documento</h2><button class="modal-close" onclick="fechar()">✕</button></div>
      <form id="formDoc">
        <input type="hidden" name="id" />
        <div class="form-group"><label>Nome do documento *</label><input name="nome" required placeholder="Ex: CND Federal" /></div>
        <div class="form-row">
          <div class="form-group">
            <label>Categoria *</label>
            <select name="categoria" required onchange="toggleGrupo()">
              {CATEGORIAS.map((c) => <option value={c} selected={c === viewDefaultCat}>{c}</option>)}
            </select>
          </div>
          <div class="form-group">
            <label>Periodicidade</label>
            <select name="periodicidade"><option value="">—</option>{PERIODICIDADES.map((p) => <option value={p}>{p}</option>)}</select>
          </div>
        </div>
        <div class="form-group" id="grupoRow" style="display:none">
          <label id="grupoLabel">Sub-grupo</label>
          <select name="grupo" id="grupoSel"><!-- opções injetadas pelo toggleGrupo() --></select>
        </div>
        <div class="form-group" id="valorMensalRow" style="display:none">
          <label>Custo mensal (R$)</label>
          <input type="number" name="valor_mensal" min="0" step="0.01" placeholder="0,00" style="max-width:180px" />
        </div>
        <div class="form-row">
          <div class="form-group"><label>Data de emissão</label><input type="date" name="data_emissao" id="fldEmissao" /></div>
          <div class="form-group"><label>Validade (vencimento)</label><input type="date" name="validade" id="fldValidade" /></div>
          <div class="form-group" style="display:flex;align-items:center;gap:8px;padding-top:24px">
            <input type="checkbox" id="fldValidadeNA" name="validade_na" style="width:auto" onchange="toggleNA()" />
            <label for="fldValidadeNA" style="margin:0;cursor:pointer">Não aplicável (sem validade)</label>
          </div>
        </div>
        <div class="form-group"><label>Site / link de emissão</label><input name="site" placeholder="https://…" /></div>
        <div class="form-group"><label>Observações</label><textarea name="observacoes"></textarea></div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="fechar()">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: anexos -->
  <div class="modal-overlay" id="modalArq">
    <div class="modal-box">
      <div class="modal-header"><h2 id="modalArqTitle">Anexos</h2><button class="modal-close" onclick="fecharArq()">✕</button></div>
      <div style="padding:16px 24px">
        <div id="listaArq"></div>
        <form id="formUpload" style="margin-top:14px;border-top:1px solid var(--border);padding-top:14px">
          <input type="hidden" name="doc_id" />
          <div id="upCompetenciaRow" style="display:none;margin-bottom:8px">
            <label style="display:block;font-size:0.86rem;font-weight:600;color:#555;margin-bottom:5px">Competência (mês de referência)</label>
            <input type="month" id="upCompetencia" style="max-width:200px" />
          </div>
          <label style="display:block;font-size:0.86rem;font-weight:600;color:#555;margin-bottom:5px">Anexar arquivo (PDF, imagem, DOC, XLS — até 45 MB)</label>
          <div style="display:flex;gap:8px;align-items:center">
            <input type="file" name="arquivo" required accept=".pdf,.doc,.docx,.xls,.xlsx,image/*,application/pdf" style="flex:1" />
            <button type="submit" class="btn btn-primary" id="btnUpload">Enviar</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script type="application/json" id="docsData" set:html={docsJson} />

  <script>
    const overlay = (id: string) => document.getElementById(id)!;
    const DOCS: any[] = JSON.parse((document.getElementById("docsData") as HTMLElement)?.textContent || "[]");
    const docById = (id: string) => DOCS.find((x: any) => x.id === id);
    let abaAtiva = "";
    function setAba(btn: HTMLElement) {
      document.querySelectorAll("#abasPills .pill").forEach((p) => p.classList.remove("active"));
      btn.classList.add("active");
      abaAtiva = btn.dataset.cat || "";
      const isArq = abaAtiva === "__arquivados__";
      (document.getElementById("secAtivos") as HTMLElement).style.display     = isArq ? "none" : "";
      (document.getElementById("secArquivados") as HTMLElement).style.display = isArq ? "" : "none";
      (document.getElementById("kpiBar") as HTMLElement).style.display        = isArq ? "none" : "";
      // filtros de situação e busca só fazem sentido nos ativos
      (document.getElementById("fSit") as HTMLElement).style.display = isArq ? "none" : "";
      if (!isArq) filtrar();
    }
    // Preserva a aba ativa ao recarregar a página após uma ação
    function reloadComAba() {
      const u = new URL(location.href);
      if (abaAtiva) u.searchParams.set("aba", abaAtiva);
      else u.searchParams.delete("aba");
      location.replace(u.toString());
    }
    // Restaura a aba ativa a partir de ?aba= (setado pelo reloadComAba)
    (function () {
      const cat = new URLSearchParams(location.search).get("aba");
      if (!cat) return;
      const btn = document.querySelector(`#abasPills .pill[data-cat="${cat.replace(/"/g, '\\"')}"]`) as HTMLElement;
      if (btn) setAba(btn);
    })();

    function fechar() { overlay("modalDoc").classList.remove("open"); }
    function fecharArq() { overlay("modalArq").classList.remove("open"); }

    function toggleNA() {
      const na = document.getElementById("fldValidadeNA") as HTMLInputElement;
      const val = document.getElementById("fldValidade") as HTMLInputElement;
      val.disabled = na.checked;
      if (na.checked) val.value = "";
    }

    function toggleGrupo() {
      const catVal = (document.querySelector("[name=categoria]") as HTMLSelectElement)?.value || "";
      const isFisc = catVal === "Documento Fiscal";
      const isForn = catVal === "Contratos";
      const grupoRow = document.getElementById("grupoRow");
      const grupoLabel = document.getElementById("grupoLabel");
      const grupoSel = document.getElementById("grupoSel") as HTMLSelectElement;
      const valorMensalRow = document.getElementById("valorMensalRow");
      if (grupoRow) grupoRow.style.display = (isFisc || isForn) ? "" : "none";
      if (valorMensalRow) valorMensalRow.style.display = isForn ? "" : "none";
      if (grupoLabel) grupoLabel.textContent = isFisc ? "Sub-grupo (Documento Fiscal)" : "Tipo de contrato";
      if (grupoSel && (isFisc || isForn)) {
        const opts = isFisc
          ? [["CND","CND — Federal, Estadual e Municipal"],["Trabalhistas","Trabalhistas — FGTS, INSS e outros"],["Sócios","Sócios — RG, CNH, IR, Comprovante de Residência"],["Diversos","Diversos"]]
          : [["Consultoria","Contratos de Consultoria"],["Recorrentes","Contratos Recorrentes"],["Plataformas","Plataformas"],["Empresas","Contratos de Empresas"]];
        grupoSel.innerHTML = opts.map(([v,l]) => `<option value="${v}">${l}</option>`).join("");
      }
    }

    function abrirNovo() {
      const f = document.getElementById("formDoc") as HTMLFormElement;
      f.reset();
      (f.querySelector("[name=id]") as HTMLInputElement).value = "";
      (document.getElementById("fldValidade") as HTMLInputElement).disabled = false;
      document.getElementById("modalDocTitle")!.textContent = "Novo documento";
      toggleGrupo();
      overlay("modalDoc").classList.add("open");
    }

    function editar(id: string) {
      const d = docById(id);
      if (!d) return;
      const f = document.getElementById("formDoc") as HTMLFormElement;
      f.reset();
      (f.querySelector("[name=id]") as HTMLInputElement).value = d.id || "";
      (f.querySelector("[name=nome]") as HTMLInputElement).value = d.nome || "";
      (f.querySelector("[name=categoria]") as HTMLSelectElement).value = d.categoria || "Documentos Diversos";
      (f.querySelector("[name=periodicidade]") as HTMLSelectElement).value = d.periodicidade || "";
      (f.querySelector("[name=site]") as HTMLInputElement).value = d.site || "";
      (f.querySelector("[name=observacoes]") as HTMLTextAreaElement).value = d.observacoes || "";
      const na = document.getElementById("fldValidadeNA") as HTMLInputElement;
      const val = document.getElementById("fldValidade") as HTMLInputElement;
      na.checked = !!d.validade_na;
      val.value = d.validade || "";
      (document.getElementById("fldEmissao") as HTMLInputElement).value = d.data_emissao || "";
      val.disabled = na.checked;
      toggleGrupo();
      const grupoSel = document.getElementById("grupoSel") as HTMLSelectElement;
      if (grupoSel) grupoSel.value = d.grupo || (d.categoria === "Contratos" ? "Empresas" : "Diversos");
      const vmInput = f.querySelector("[name=valor_mensal]") as HTMLInputElement;
      if (vmInput) vmInput.value = d.valor_mensal != null ? String(d.valor_mensal) : "";
      document.getElementById("modalDocTitle")!.textContent = "Editar documento";
      overlay("modalDoc").classList.add("open");
    }

    document.getElementById("formDoc")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const fd = new FormData(f);
      const body: Record<string, any> = Object.fromEntries(fd.entries());
      body.validade_na = (f.querySelector("[name=validade_na]") as HTMLInputElement).checked;
      // grupo vale para Fiscal (sub-grupo) e Contratos (tipo); zera nas demais
      if (body.categoria !== "Documento Fiscal" && body.categoria !== "Contratos") body.grupo = null;
      // valor_mensal só para Contratos; converte para número
      body.valor_mensal = (body.categoria === "Contratos" && body.valor_mensal !== "")
        ? parseFloat(String(body.valor_mensal)) || null : null;
      const id = body.id; delete body.id;
      const url = id ? `/api/admin/doc-empresa/${id}` : "/api/admin/doc-empresa";
      const method = id ? "PATCH" : "POST";
      const res = await fetch(url, { method, headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (res.ok) reloadComAba();
      else document.getElementById("msg")!.innerHTML = `<div class="alert alert-error">${(await res.json()).error || "Erro ao salvar"}</div>`;
    });

    async function setArquivado(id: string, arquivado: boolean) {
      if (!confirm(arquivado ? "Arquivar este documento? Ele some do painel e para de gerar alertas (recuperável em 'Ver arquivados')." : "Reativar este documento?")) return;
      const res = await fetch(`/api/admin/doc-empresa/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ arquivado }) });
      if (res.ok) reloadComAba(); else alert((await res.json()).error || "Erro");
    }

    async function excluir(id: string) {
      const d = docById(id);
      const nome = (d && d.nome) || "este documento";
      if (!confirm(`Excluir "${nome}"? Vai para a lixeira (recuperável por 30 dias).`)) return;
      const res = await fetch(`/api/admin/doc-empresa/${id}`, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) reloadComAba(); else alert((await res.json()).error || "Erro");
    }

    // ── Anexos ──
    function anexos(id: string) {
      const d = docById(id);
      const nome = (d && d.nome) || "";
      const arquivos = (d && d.arquivos) || [];
      document.getElementById("modalArqTitle")!.textContent = `Anexos — ${nome}`;
      renderArq(arquivos);
      (document.getElementById("formUpload") as HTMLFormElement).reset();
      (document.querySelector("#formUpload [name=doc_id]") as HTMLInputElement).value = id;
      // competência só nas categorias periódicas (Guias / Contábeis)
      const ehPeriodo = !!(d && ["Guias e Obrigações Fiscais", "Documentos Contábeis"].includes(d.categoria));
      (document.getElementById("upCompetenciaRow") as HTMLElement).style.display = ehPeriodo ? "" : "none";
      overlay("modalArq").classList.add("open");
    }
    function renderArq(arquivos: any[]) {
      const box = document.getElementById("listaArq")!;
      if (!arquivos || !arquivos.length) { box.innerHTML = `<p style="color:#9CA3AF;font-size:13px">Nenhum arquivo anexado ainda.</p>`; return; }
      // mais recente primeiro → marca a VERSÃO VIGENTE
      const ord = arquivos.slice().sort((a, b) => String(b.created_at || "").localeCompare(String(a.created_at || "")));
      box.innerHTML = ord.map((a, i) => `
        <div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border-light)">
          <span style="flex:1;font-size:13.5px">📄 ${(a.nome || "arquivo").replace(/</g, "&lt;")}${i === 0 ? ' <span class="badge badge-green" style="font-size:10.5px;margin-left:4px">✓ Vigente</span>' : ''}</span>
          <a class="btn btn-outline btn-sm" href="/api/admin/doc-empresa/arquivos/${a.id}" target="_blank" rel="noopener">Baixar</a>
          <button class="btn btn-danger btn-sm" onclick="excluirArq('${a.id}', this)">Excluir</button>
        </div>`).join("");
    }
    async function excluirArq(fid: string, btn: HTMLButtonElement) {
      if (!confirm("Excluir este arquivo?")) return;
      btn.disabled = true;
      const res = await fetch(`/api/admin/doc-empresa/arquivos/${fid}`, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) reloadComAba(); else { alert((await res.json()).error || "Erro"); btn.disabled = false; }
    }
    document.getElementById("formUpload")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const id = (f.querySelector("[name=doc_id]") as HTMLInputElement).value;
      const fileInput = f.querySelector("[name=arquivo]") as HTMLInputElement;
      const arquivo = fileInput.files && fileInput.files[0];
      const btn = document.getElementById("btnUpload") as HTMLButtonElement;
      if (!arquivo) { alert("Selecione um arquivo."); return; }
      if (arquivo.size > 45 * 1024 * 1024) { alert("Arquivo muito grande (máx. 45 MB)."); return; }
      btn.disabled = true; btn.textContent = "Enviando…";
      try {
        // Passo 1: obter URL assinada para upload direto ao Supabase Storage (bypass Vercel)
        const r1 = await fetch(`/api/admin/doc-empresa/${id}/upload-url`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ nome: arquivo.name, content_type: arquivo.type }),
        });
        if (!r1.ok) {
          let msg = "Erro ao preparar upload";
          try { msg = (await r1.json()).error || msg; } catch {}
          throw new Error(msg);
        }
        const { signed_url, path, nome_original } = await r1.json();
        // Passo 2: enviar arquivo direto ao bucket (sem passar pelo Vercel)
        const r2 = await fetch(signed_url, {
          method: "PUT",
          headers: { "content-type": arquivo.type || "application/octet-stream" },
          body: arquivo,
        });
        if (!r2.ok) throw new Error(`Falha no envio do arquivo (HTTP ${r2.status}).`);
        // Passo 3: registrar no banco (com competência, se for categoria periódica)
        const competencia = (document.getElementById("upCompetencia") as HTMLInputElement)?.value || null;
        const r3 = await fetch(`/api/admin/doc-empresa/${id}/upload`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ storage_path: path, nome: nome_original, competencia }),
        });
        if (!r3.ok) {
          let msg = "Arquivo enviado mas falhou ao registrar";
          try { msg = (await r3.json()).error || msg; } catch {}
          throw new Error(msg);
        }
        reloadComAba();
        return;
      } catch (err: any) {
        alert("Erro no upload: " + (err?.message || "tente novamente"));
      }
      btn.disabled = false; btn.textContent = "Enviar";
    });

    // ── Filtro ──
    function filtrar() {
      const t = (document.getElementById("busca") as HTMLInputElement).value.toLowerCase().trim();
      const cat = abaAtiva;
      const sit = (document.getElementById("fSit") as HTMLSelectElement).value;
      document.querySelectorAll(".doc-sec").forEach((secEl) => {
        const sec = secEl as HTMLElement;
        let visiveis = 0;
        sec.querySelectorAll(".doc-row").forEach((rowEl) => {
          const row = rowEl as HTMLElement;
          const okCat = !cat || row.dataset.cat === cat;
          const okSit = !sit || row.dataset.sit === sit;
          const okBusca = !t || (row.dataset.nome || "").includes(t);
          const mostra = okCat && okSit && okBusca;
          row.style.display = mostra ? "" : "none";
          if (mostra) visiveis++;
        });
        sec.style.display = visiveis ? "" : "none";
        // Esconde sub-grupos vazios dentro de "Documento Fiscal"
        sec.querySelectorAll(".doc-subgrupo").forEach((grpEl) => {
          const grp = grpEl as HTMLElement;
          const anyVisible = Array.from(grp.querySelectorAll(".doc-row")).some(
            (r) => (r as HTMLElement).style.display !== "none"
          );
          grp.style.display = anyVisible ? "" : "none";
        });
        // Esconde labels de sub-grupos de "Empresas Fornecedoras" quando todas as linhas estão ocultas
        sec.querySelectorAll("tr.sg-label-row").forEach((labelRow) => {
          const grpKey = (labelRow as HTMLElement).dataset.sgFornLabel || "";
          if (!grpKey) return;
          const anyVisible = Array.from(sec.querySelectorAll(`tr.forn-row[data-forn-grp="${grpKey}"]`))
            .some((r) => (r as HTMLElement).style.display !== "none");
          (labelRow as HTMLElement).style.display = anyVisible ? "" : "none";
        });
      });
    }

    // ── Ordenação de "Empresas Fornecedoras" ──
    let _fSort = { col: "", dir: 1 };
    function sortForn(col: string) {
      _fSort = { col, dir: _fSort.col === col ? -_fSort.dir : 1 };
      // Lê grupos (label + linhas) na ordem atual do DOM e ordena dentro de cada grupo
      const tbody = document.querySelector("[data-forn-tbody-all]") as HTMLElement;
      if (!tbody) return;
      type Grupo = { label: HTMLElement; rows: HTMLElement[] };
      const grupos: Grupo[] = [];
      let cur: Grupo | null = null;
      Array.from(tbody.querySelectorAll("tr")).forEach((tr) => {
        if ((tr as HTMLElement).classList.contains("sg-label-row")) {
          cur = { label: tr as HTMLElement, rows: [] };
          grupos.push(cur);
        } else if (cur && (tr as HTMLElement).classList.contains("forn-row")) {
          cur.rows.push(tr as HTMLElement);
        }
      });
      grupos.forEach(({ label, rows }) => {
        rows.sort((a, b) => {
          if (col === "val") return (parseFloat(a.dataset.val || "0") - parseFloat(b.dataset.val || "0")) * _fSort.dir;
          if (col === "validade") return (a.dataset.validade || "").localeCompare(b.dataset.validade || "") * _fSort.dir;
          return (a.dataset.nome || "").localeCompare(b.dataset.nome || "", "pt-BR") * _fSort.dir;
        });
        tbody.appendChild(label);
        rows.forEach((r) => tbody.appendChild(r));
      });
      // Atualiza setas nos cabeçalhos
      document.querySelectorAll<HTMLElement>("[data-forn-th]").forEach((th) => {
        const isActive = th.dataset.fornTh === col;
        const span = th.querySelector(".sort-arr");
        if (span) span.textContent = isActive ? (_fSort.dir > 0 ? " ▲" : " ▼") : " ↕";
      });
    }
    function setSit(s: string) {
      (document.getElementById("fSit") as HTMLSelectElement).value = s;
      abaAtiva = "";
      document.querySelectorAll("#abasPills .pill").forEach((p) => (p as HTMLElement).classList.toggle("active", (p as HTMLElement).dataset.cat === ""));
      filtrar();
      window.scrollTo({ top: 260, behavior: "smooth" });
    }

    async function enviarResumo(btn: HTMLButtonElement) {
      btn.disabled = true; const orig = btn.textContent; btn.textContent = "Enviando…";
      try {
        const res = await fetch("/api/cron/doc-empresa-vencimentos?modo=completo");
        const d = await res.json();
        alert(res.ok ? `Resumo enviado. ${d.total || 0} documento(s) a vencer/vencido(s).` : (d.error || "Erro"));
      } catch { alert("Falha ao enviar."); }
      btn.disabled = false; btn.textContent = orig;
    }

    // ── Expansão por competência (categorias periódicas: Guias / Contábeis) ──
    const MESES = ["", "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];
    function rotuloCompetencia(a: any): string {
      const c = String(a.competencia || "");
      let m = c.match(/^(\d{4})-(\d{2})/); if (m) return `${MESES[+m[2]] || m[2]}/${m[1]}`;
      if (/^\d{4}$/.test(c)) return `Exercício ${c}`;
      if (c) return c;
      return a.created_at ? String(a.created_at).slice(0, 10).split("-").reverse().join("/") : "sem competência";
    }
    function anoDoArq(a: any): string {
      const c = String(a.competencia || "");
      const m = c.match(/^(\d{4})/);
      if (m) return m[1];
      return a.created_at ? String(a.created_at).slice(0, 4) : "Sem ano";
    }
    function renderCompetencias(id: string): string {
      const d = docById(id); if (!d) return "";
      const arqs = (d.arquivos || []).slice();
      if (!arqs.length) return `<p style="color:#9CA3AF;font-size:13px;margin:4px 0">Nenhuma competência anexada ainda. Use <strong>+ Anexar</strong>.</p>`;
      const linha = (a: any) => `<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border-light)">
        <span style="flex:1;font-size:13.5px">📄 <strong>${rotuloCompetencia(a)}</strong> <span style="color:#9CA3AF;font-size:12px">${String(a.nome || "").replace(/</g, "&lt;")}</span></span>
        <a class="btn btn-outline btn-sm" href="/api/admin/doc-empresa/arquivos/${a.id}" target="_blank" rel="noopener">Baixar</a>
        <button class="btn btn-danger btn-sm" onclick="excluirArq('${a.id}', this)">Excluir</button></div>`;
      // Agrupa por ANO → meses (competências) dentro de cada ano (pedido da Adriana)
      const byAno: Record<string, any[]> = {};
      for (const a of arqs) { const y = anoDoArq(a); (byAno[y] = byAno[y] || []).push(a); }
      const anos = Object.keys(byAno).sort((a, b) => b.localeCompare(a));
      const anoAtual = String(new Date().getFullYear());
      return anos.map((ano) => {
        const items = byAno[ano].sort((a, b) => String(b.competencia || b.created_at || "").localeCompare(String(a.competencia || a.created_at || "")));
        const aberto = ano === anoAtual ? " open" : "";
        return `<details${aberto} style="border:1px solid var(--border);border-radius:8px;margin:6px 0;overflow:hidden">
          <summary style="cursor:pointer;list-style:none;display:flex;align-items:center;gap:8px;padding:8px 12px;background:#FAFBFC;font-weight:700">📅 ${ano} <span class="badge badge-blue" style="font-size:10.5px">${items.length} competência(s)</span></summary>
          <div style="padding:4px 12px 8px">${items.map(linha).join("")}</div>
        </details>`;
      }).join("");
    }
    function togglePeriodo(id: string) {
      const box = document.getElementById("per-" + id) as HTMLElement; const exp = document.getElementById("exp-" + id);
      if (!box) return;
      if (box.style.display === "none") { box.innerHTML = renderCompetencias(id); box.style.display = ""; if (exp) exp.textContent = "−"; }
      else { box.style.display = "none"; if (exp) exp.textContent = "+"; }
    }

    Object.assign(window, { abrirNovo, editar, fechar, setArquivado, excluir, anexos, fecharArq, excluirArq, toggleNA, toggleGrupo, filtrar, setSit, setAba, enviarResumo, sortForn, togglePeriodo });
  </script>

  <style>
    /* Título da categoria em VERMELHO, CAIXA ALTA e maior que as linhas abaixo (pedido da Adriana) */
    .doc-cat-title {
      text-transform: uppercase;
      font-size: 1.2rem !important;
      font-weight: 800;
      color: var(--brand);
      letter-spacing: .02em;
      line-height: 1.2;
    }
  </style>
</Admin>
