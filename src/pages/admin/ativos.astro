---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const db = supabaseAdmin();
const filtroCategoria = Astro.url.searchParams.get("categoria") || "todas";
const filtroStatus = Astro.url.searchParams.get("status") || "todos";
const busca = Astro.url.searchParams.get("busca") || "";

let q = db.from("ativos").select("*").order("created_at", { ascending: false }).limit(1000);
if (filtroCategoria !== "todas") q = q.eq("categoria", filtroCategoria);
if (filtroStatus !== "todos") q = q.eq("status", filtroStatus);
if (busca) {
  const b = busca.replace(/[%,()]/g, " ").trim();
  q = q.or(`descricao.ilike.%${b}%,marca.ilike.%${b}%,modelo.ilike.%${b}%,numero_serie.ilike.%${b}%,numero_patrimonial.ilike.%${b}%,codigo_interno.ilike.%${b}%,alocado_para_nome.ilike.%${b}%`);
}
const { data: ativos, error: ativosErro } = await q;

// Indicadores (sobre todos os ativos, independente do filtro)
const { data: todosAtivos } = await db.from("ativos").select("status, categoria, valor_aquisicao, garantia, garantia_fim, alocado_para_tipo");
const total = todosAtivos?.length ?? 0;
const porStatus: Record<string, number> = {};
for (const a of todosAtivos || []) porStatus[a.status] = (porStatus[a.status] || 0) + 1;
const valorTotal = (todosAtivos || []).reduce((s, a) => s + (Number(a.valor_aquisicao) || 0), 0);
const hoje = new Date(); const em60 = new Date(); em60.setDate(em60.getDate() + 60);
const garantiaVencendo = (todosAtivos || []).filter(a => a.garantia && a.garantia_fim && new Date(a.garantia_fim) >= hoje && new Date(a.garantia_fim) <= em60).length;

// preventivas de ativos vencidas (melhoria #10)
const { count: preventivasVencidas } = await db.from("ativos_manutencao_planos")
  .select("*", { count: "exact", head: true })
  .eq("ativo", true)
  .lte("proxima_em", hoje.toISOString().slice(0, 10));

const categorias: Record<string, string> = {
  telefonia: "Telefonia", informatica: "Informática", equipamento_obra: "Equip. de Obra",
  epi: "EPI", veiculo: "Veículo", mobiliario: "Mobiliário", outros: "Outros",
};
const statusLabels: Record<string, string> = {
  em_estoque: "Em estoque", disponivel: "Disponível", alocado: "Alocado", em_manutencao: "Em manutenção",
  em_transito: "Em trânsito", extraviado: "Extraviado", roubado: "Roubado", danificado: "Danificado",
  baixado: "Baixado", descartado: "Descartado",
};
const statusBadge: Record<string, string> = {
  em_estoque: "badge-blue", disponivel: "badge-green", alocado: "badge-purple", em_manutencao: "badge-orange",
  em_transito: "badge-yellow", extraviado: "badge-red", roubado: "badge-red", danificado: "badge-red",
  baixado: "badge-gray", descartado: "badge-gray",
};
const catIcone: Record<string, string> = {
  telefonia: "📱", informatica: "💻", equipamento_obra: "🛠️", epi: "🦺", veiculo: "🚗", mobiliario: "🪑", outros: "📦",
};
function fmtMoney(v: number | null) { if (v == null) return "—"; return Number(v).toLocaleString("pt-BR", { style: "currency", currency: "BRL" }); }
function fmtDate(d: string | null) { if (!d) return "—"; return new Date(d + (d.length === 10 ? "T12:00:00" : "")).toLocaleDateString("pt-BR"); }
---
<Admin title="Ativos Patrimoniais" current="ativos">

  {ativosErro && <div class="alert alert-error">Erro ao carregar ativos: {ativosErro.message}. Se o módulo é novo, rode a migration <code>020_ativos_obras.sql</code> no Supabase.</div>}

  <!-- Indicadores -->
  <div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(160px,1fr))">
    <div class="stat-card"><div class="stat-value">{total}</div><div class="stat-label">Total de ativos</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#7C3AED">{porStatus.alocado ?? 0}</div><div class="stat-label">Em uso (alocados)</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#1D4ED8">{(porStatus.em_estoque ?? 0) + (porStatus.disponivel ?? 0)}</div><div class="stat-label">Em estoque</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#D97706">{porStatus.em_manutencao ?? 0}</div><div class="stat-label">Em manutenção</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#B91C1C">{(porStatus.extraviado ?? 0) + (porStatus.roubado ?? 0) + (porStatus.danificado ?? 0)}</div><div class="stat-label">Extraviado/roubado/danificado</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#16A34A;font-size:1.35rem">{fmtMoney(valorTotal)}</div><div class="stat-label">Valor do patrimônio</div></div>
    <div class="stat-card"><div class="stat-value" style={garantiaVencendo ? "color:#D97706" : ""}>{garantiaVencendo}</div><div class="stat-label">Garantias vencendo (60d)</div></div>
    <div class="stat-card"><div class="stat-value" style={preventivasVencidas ? "color:#B91C1C" : "color:#16A34A"}>{preventivasVencidas ?? 0}</div><div class="stat-label">Preventivas vencidas</div></div>
  </div>

  <!-- Filtros -->
  <div class="toolbar">
    <span class="toolbar-title">Ativos ({ativos?.length ?? 0})</span>
    <input class="search-input" id="busca" placeholder="Buscar por descrição, série, patrimônio, pessoa..." value={busca} />
    <select class="filter-select" id="fCategoria">
      <option value="todas" selected={filtroCategoria === "todas"}>Todas categorias</option>
      {Object.entries(categorias).map(([k, v]) => <option value={k} selected={k === filtroCategoria}>{v}</option>)}
    </select>
    <select class="filter-select" id="fStatus">
      <option value="todos" selected={filtroStatus === "todos"}>Todos status</option>
      {Object.entries(statusLabels).map(([k, v]) => <option value={k} selected={k === filtroStatus}>{v}</option>)}
    </select>
    <button class="btn btn-primary" onclick="abrirModalNovo()">+ Novo ativo</button>
  </div>

  <div class="card" style="padding:0;overflow:hidden">
    <div class="table-wrap">
      <table>
        <thead><tr><th></th><th>Descrição</th><th>Categoria</th><th>Patrimônio / Série</th><th>Com quem / onde</th><th>Valor</th><th>Status</th><th>Aquisição</th></tr></thead>
        <tbody>
          {ativos?.length ? ativos.map((a: any) => (
            <tr class="row-link" onclick={`window.location.href='/admin/ativos/${a.id}'`}>
              <td style="font-size:1.1rem">{catIcone[a.categoria] || "📦"}</td>
              <td>
                <strong>{a.descricao}</strong>
                {(a.marca || a.modelo) && <div style="font-size:11.5px;color:#9CA3AF">{[a.marca, a.modelo].filter(Boolean).join(" · ")}</div>}
              </td>
              <td>{categorias[a.categoria] || a.categoria}</td>
              <td style="font-size:12.5px">
                {a.numero_patrimonial && <div>Pat. <strong>{a.numero_patrimonial}</strong></div>}
                {a.numero_serie && <div style="color:#6B7280">S/N {a.numero_serie}</div>}
                {!a.numero_patrimonial && !a.numero_serie && "—"}
              </td>
              <td>
                {a.alocado_para_nome
                  ? <span>{a.alocado_para_tipo === "obra" ? "🏗️ " : "👤 "}{a.alocado_para_nome}</span>
                  : <span style="color:#9CA3AF">—</span>}
              </td>
              <td>{fmtMoney(a.valor_aquisicao)}</td>
              <td><span class={`badge ${statusBadge[a.status] || "badge-gray"}`}>{statusLabels[a.status] || a.status}</span></td>
              <td>{fmtDate(a.data_aquisicao)}</td>
            </tr>
          )) : <tr><td colspan="8"><div class="empty-state"><strong>Nenhum ativo encontrado</strong><p>Cadastre o primeiro ativo no botão "+ Novo ativo".</p></div></td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal novo ativo -->
  <div class="modal-overlay" id="modalNovo">
    <div class="modal" style="max-width:680px">
      <div class="modal-title">Novo Ativo</div>
      <div id="msgNovo"></div>
      <form id="formNovo">
        <div class="form-row">
          <div class="form-group"><label>Categoria *</label>
            <select name="categoria" id="selCategoria" required>
              {Object.entries(categorias).map(([k, v]) => <option value={k}>{v}</option>)}
            </select>
          </div>
          <div class="form-group"><label>Subcategoria</label><input name="subcategoria" placeholder="Ex: Notebook, Furadeira, Capacete..." /></div>
        </div>
        <div class="form-group"><label>Descrição *</label><input name="descricao" required placeholder="Ex: Notebook Dell Inspiron 15" /></div>
        <div class="form-row">
          <div class="form-group"><label>Código interno</label><input name="codigo_interno" /></div>
          <div class="form-group"><label>Nº patrimonial</label><input name="numero_patrimonial" /></div>
          <div class="form-group"><label>Nº de série</label><input name="numero_serie" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Marca</label><input name="marca" /></div>
          <div class="form-group"><label>Modelo</label><input name="modelo" /></div>
          <div class="form-group"><label>Fabricante</label><input name="fabricante" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Data de aquisição</label><input name="data_aquisicao" type="date" /></div>
          <div class="form-group"><label>Valor de aquisição (R$)</label><input name="valor_aquisicao" type="number" step="0.01" min="0" /></div>
          <div class="form-group"><label>Fornecedor</label><input name="fornecedor" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Nº da nota fiscal</label><input name="numero_nota_fiscal" /></div>
          <div class="form-group"><label>Data da NF</label><input name="data_nota_fiscal" type="date" /></div>
          <div class="form-group"><label>Link da NF (URL)</label><input name="nota_fiscal_url" type="url" placeholder="https://..." /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Tem garantia?</label>
            <select name="garantia"><option value="false">Não</option><option value="true">Sim</option></select>
          </div>
          <div class="form-group"><label>Garantia até</label><input name="garantia_fim" type="date" /></div>
          <div class="form-group"><label>Link do manual (URL)</label><input name="manual_url" type="url" /></div>
        </div>

        <!-- Campos específicos por categoria -->
        <div id="campos-telefonia" class="campos-cat" style="display:none">
          <div class="cat-head">📱 Dados de telefonia</div>
          <div class="form-row">
            <div class="form-group"><label>IMEI 1</label><input data-campo="imei1" /></div>
            <div class="form-group"><label>IMEI 2</label><input data-campo="imei2" /></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Nº da linha</label><input data-campo="linha" /></div>
            <div class="form-group"><label>Operadora</label><input data-campo="operadora" /></div>
            <div class="form-group"><label>PIN/PUK</label><input data-campo="pin_puk" /></div>
          </div>
        </div>
        <div id="campos-informatica" class="campos-cat" style="display:none">
          <div class="cat-head">💻 Dados de informática</div>
          <div class="form-row">
            <div class="form-group"><label>Processador</label><input data-campo="processador" /></div>
            <div class="form-group"><label>Memória RAM</label><input data-campo="ram" /></div>
            <div class="form-group"><label>HD/SSD</label><input data-campo="armazenamento" /></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Sistema operacional</label><input data-campo="so" /></div>
            <div class="form-group"><label>Nome da máquina</label><input data-campo="hostname" /></div>
            <div class="form-group"><label>Endereço MAC</label><input data-campo="mac" /></div>
          </div>
        </div>
        <div id="campos-veiculo" class="campos-cat" style="display:none">
          <div class="cat-head">🚗 Dados do veículo</div>
          <div class="form-row">
            <div class="form-group"><label>Placa</label><input data-campo="placa" /></div>
            <div class="form-group"><label>Renavam</label><input data-campo="renavam" /></div>
            <div class="form-group"><label>Chassi</label><input data-campo="chassi" /></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Ano</label><input data-campo="ano" /></div>
            <div class="form-group"><label>Quilometragem</label><input data-campo="km" type="number" /></div>
          </div>
        </div>

        <div class="form-group"><label>Observações</label><textarea name="observacoes"></textarea></div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharModal('modalNovo')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Cadastrar ativo</button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .row-link { cursor: pointer; }
    .cat-head { font-size: .8rem; font-weight: 700; color: var(--ink-mid); margin: 6px 0 10px; padding-top: 10px; border-top: 1px dashed var(--border); }
  </style>

  <script>
    function filtrarRecarrega() {
      const url = new URL(window.location.href);
      url.searchParams.set("categoria", (document.getElementById("fCategoria") as HTMLSelectElement).value);
      url.searchParams.set("status", (document.getElementById("fStatus") as HTMLSelectElement).value);
      url.searchParams.set("busca", (document.getElementById("busca") as HTMLInputElement).value);
      window.location.href = url.toString();
    }
    document.getElementById("fCategoria")?.addEventListener("change", filtrarRecarrega);
    document.getElementById("fStatus")?.addEventListener("change", filtrarRecarrega);
    document.getElementById("busca")?.addEventListener("keydown", (e) => { if ((e as KeyboardEvent).key === "Enter") filtrarRecarrega(); });

    function fecharModal(id) { document.getElementById(id).classList.remove("open"); }
    function abrirModalNovo() { document.getElementById("modalNovo").classList.add("open"); atualizarCamposCategoria(); }

    function atualizarCamposCategoria() {
      const cat = (document.getElementById("selCategoria") as HTMLSelectElement).value;
      document.querySelectorAll(".campos-cat").forEach(el => (el as HTMLElement).style.display = "none");
      const alvo = document.getElementById("campos-" + cat);
      if (alvo) alvo.style.display = "";
    }
    document.getElementById("selCategoria")?.addEventListener("change", atualizarCamposCategoria);

    document.getElementById("formNovo")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const body: Record<string, any> = Object.fromEntries(fd.entries());
      body.garantia = body.garantia === "true";
      if (body.valor_aquisicao) body.valor_aquisicao = Number(body.valor_aquisicao);

      // campos específicos visíveis
      const campos: Record<string, string> = {};
      document.querySelectorAll(".campos-cat:not([style*='none']) [data-campo]").forEach((el) => {
        const input = el as HTMLInputElement;
        if (input.value.trim()) campos[input.dataset.campo!] = input.value.trim();
      });
      body.campos = campos;

      const msg = document.getElementById("msgNovo")!;
      const res = await fetch("/api/admin/ativos", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      const d = await res.json();
      if (res.ok) { window.location.href = `/admin/ativos/${d.id}`; }
      else { msg.innerHTML = `<div class="alert alert-error">${d.error || "Erro ao cadastrar"}</div>`; }
    });

    (window as any).fecharModal = fecharModal;
    (window as any).abrirModalNovo = abrirModalNovo;
  </script>
</Admin>
