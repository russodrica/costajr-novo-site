---
import Admin from "../../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../../lib/auth";
import { supabaseAdmin } from "../../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const { id } = Astro.params;
const db = supabaseAdmin();
const { data: cliente } = await db.from("manut_clientes").select("*").eq("id", id!).single();
if (!cliente) return Astro.redirect("/admin/clientes");

const [{ data: lojas }, { data: chamados }, { data: pagamentos }, { data: preventivas }] = await Promise.all([
  db.from("manut_lojas").select("*").eq("cliente_id", id!).order("created_at", { ascending: false }),
  db.from("manut_chamados").select("id, tipo, descricao, status, prioridade, data_abertura, manut_tecnicos(nome)").eq("cliente_id", id!).order("data_abertura", { ascending: false }).limit(10),
  db.from("manut_pagamentos").select("*").eq("cliente_id", id!).order("data_vencimento", { ascending: false }).limit(10),
  db.from("manut_preventivas").select("id, numero_visita, data_agendada, data_executada, status, manut_lojas(nome), manut_tecnicos(nome)").eq("cliente_id", id!).order("data_agendada", { ascending: true }),
]);

const badgeSt: Record<string, string> = { ativo: "badge-green", pendente: "badge-yellow", inadimplente: "badge-red", cancelado: "badge-gray" };
const badgePg: Record<string, string> = { pendente: "badge-yellow", pago: "badge-green", atrasado: "badge-red", cancelado: "badge-gray" };
const badgeCh: Record<string, string> = { aberto: "badge-red", em_andamento: "badge-blue", concluido: "badge-green", cancelado: "badge-gray", aguardando_material: "badge-orange" };
const badgePv: Record<string, string> = { agendada: "badge-blue", em_execucao: "badge-yellow", concluida: "badge-green", cancelada: "badge-gray" };
function fmtDate(d: string | null) { if (!d) return "—"; return new Date(d).toLocaleDateString("pt-BR"); }
function fmtMoney(v: number | null) { if (v == null) return "—"; return v.toLocaleString("pt-BR", { style: "currency", currency: "BRL" }); }
---
<Admin title={`Cliente: ${cliente.nome}`} current="clientes">
  <div style="margin-bottom:16px">
    <a href="/admin/clientes" class="btn btn-secondary btn-sm">← Voltar</a>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
    <!-- Info geral -->
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px">
        <div>
          <h2 style="font-family:'Montserrat',sans-serif;font-size:1.1rem">{cliente.nome}</h2>
          <code style="font-size:0.8rem;color:#888">{cliente.codigo}</code>
        </div>
        <span class={`badge ${badgeSt[cliente.status] || "badge-gray"}`}>{cliente.status}</span>
      </div>
      <div class="info-grid">
        <span class="info-label">E-mail</span><span>{cliente.email}</span>
        <span class="info-label">Telefone</span><span>{cliente.telefone || "—"}</span>
        <span class="info-label">CNPJ/CPF</span><span>{cliente.cnpj_cpf || "—"}</span>
        <span class="info-label">Plano</span><span>{cliente.plano_selecionado || "—"}</span>
        <span class="info-label">Valor/mês</span><span>{fmtMoney(cliente.valor_mensal_contratado)}</span>
        <span class="info-label">Visitas</span><span>{cliente.visitas_contratadas ?? "—"}</span>
        <span class="info-label">Contratação</span><span>{fmtDate(cliente.data_contratacao)}</span>
        <span class="info-label">Próx. vencto</span><span>{fmtDate(cliente.data_proximo_vencimento)}</span>
      </div>
      <div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap">
        {cliente.status === "pendente" && <button class="btn btn-success btn-sm" data-action="patch-status" data-status="ativo">Ativar</button>}
        {cliente.status === "ativo" && <button class="btn btn-warning btn-sm" data-action="patch-status" data-status="inadimplente">Inadimplir</button>}
        {cliente.status !== "cancelado" && <button class="btn btn-danger btn-sm" data-action="patch-status" data-status="cancelado">Cancelar</button>}
        <button class="btn btn-secondary btn-sm" data-action="modal-editar">Editar</button>
        <button class="btn btn-info btn-sm" data-action="resetar-senha">Resetar senha</button>
      </div>
    </div>

    <!-- Lojas -->
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
        <strong>Lojas ({lojas?.length ?? 0})</strong>
        <button class="btn btn-primary btn-sm" data-action="modal-loja">+ Loja</button>
      </div>
      {lojas?.length ? lojas.map((l: any) => (
        <div style="border:1px solid #F0F0F0;border-radius:8px;padding:12px;margin-bottom:8px">
          <strong style="font-size:0.9rem">{l.nome}</strong>
          <div style="font-size:0.8rem;color:#666;margin-top:4px">{l.endereco}, {l.cidade}/{l.uf}</div>
          <div style="display:flex;gap:8px;margin-top:6px">
            <span class={`badge ${l.status === "ativa" ? "badge-green" : "badge-yellow"}`}>{l.status}</span>
            {l.especialidades && <span style="font-size:0.75rem;color:#888">{JSON.stringify(l.especialidades)}</span>}
          </div>
        </div>
      )) : <p style="color:#999;font-size:0.85rem">Nenhuma loja cadastrada</p>}
    </div>
  </div>

  <!-- Chamados -->
  <div class="card" style="margin-bottom:20px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
      <strong>Chamados recentes</strong>
      <a href={`/admin/chamados?cliente_id=${id}`} class="btn btn-secondary btn-sm">Ver todos</a>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Tipo</th><th>Descrição</th><th>Técnico</th><th>Status</th><th>Prioridade</th><th>Data</th></tr></thead>
        <tbody>
          {chamados?.length ? chamados.map((c: any) => (
            <tr>
              <td>{c.tipo}</td>
              <td style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{c.descricao}</td>
              <td>{(c.manut_tecnicos as any)?.nome ?? "Não atribuído"}</td>
              <td><span class={`badge ${badgeCh[c.status]}`}>{c.status.replace("_"," ")}</span></td>
              <td><span class={`badge ${c.prioridade === "urgente" ? "badge-red" : c.prioridade === "alta" ? "badge-orange" : "badge-gray"}`}>{c.prioridade}</span></td>
              <td>{fmtDate(c.data_abertura)}</td>
            </tr>
          )) : <tr><td colspan="6" style="text-align:center;color:#999;padding:20px">Nenhum chamado</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Preventivas -->
  <div class="card" style="margin-bottom:20px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
      <strong>
        Preventivas ({preventivas?.length ?? 0} agendadas
        {cliente.plano_selecionado?.toLowerCase().includes("trimestral") ? " / 3 contratadas" :
         cliente.plano_selecionado?.toLowerCase().includes("semestral") ? " / 6 contratadas" :
         cliente.plano_selecionado?.toLowerCase().includes("anual") ? " / 12 contratadas" : ""})
      </strong>
      <button class="btn btn-primary btn-sm" id="btnGerarPrev">⚙ Gerar preventivas</button>
    </div>
    {!lojas?.length && (
      <div class="alert alert-error" style="margin-bottom:12px">Cadastre ao menos uma loja antes de gerar preventivas.</div>
    )}
    <div class="table-wrap">
      <table>
        <thead><tr><th>Visita</th><th>Loja</th><th>Data agendada</th><th>Data executada</th><th>Técnico</th><th>Status</th><th>Ação</th></tr></thead>
        <tbody>
          {preventivas?.length ? preventivas.map((p: any) => (
            <tr data-prev-id={p.id} data-agendada={p.data_agendada ? p.data_agendada.slice(0,10) : ""}>
              <td>#{p.numero_visita}</td>
              <td>{(p.manut_lojas as any)?.nome ?? "—"}</td>
              <td class="cell-data-agendada">{fmtDate(p.data_agendada)}</td>
              <td>{fmtDate(p.data_executada)}</td>
              <td>{(p.manut_tecnicos as any)?.nome ?? "—"}</td>
              <td><span class={`badge ${badgePv[p.status]}`}>{p.status.replace("_"," ")}</span></td>
              <td>
                {p.status === "agendada" && (
                  <button class="btn btn-secondary btn-sm" data-action="editar-data-prev" data-prev-id={p.id}>📅 Data</button>
                )}
              </td>
            </tr>
          )) : <tr><td colspan="7" style="text-align:center;color:#999;padding:20px">Nenhuma preventiva agendada. Clique em "Gerar preventivas".</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagamentos -->
  <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
      <strong>Pagamentos</strong>
      <button class="btn btn-primary btn-sm" data-action="modal-pgto">+ Lançar</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Referência</th><th>Valor</th><th>Vencimento</th><th>Pagamento</th><th>Status</th><th>Ação</th></tr></thead>
        <tbody>
          {pagamentos?.length ? pagamentos.map((p: any) => (
            <tr>
              <td>{p.referencia || "—"}</td>
              <td>{fmtMoney(p.valor)}</td>
              <td>{fmtDate(p.data_vencimento)}</td>
              <td>{fmtDate(p.data_pagamento)}</td>
              <td><span class={`badge ${badgePg[p.status]}`}>{p.status}</span></td>
              <td>
                {p.status !== "pago" && p.status !== "cancelado" &&
                  <button class="btn btn-success btn-sm" data-action="marcar-pago" data-id={p.id}>Marcar pago</button>
                }
              </td>
            </tr>
          )) : <tr><td colspan="6" style="text-align:center;color:#999;padding:20px">Nenhum pagamento</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal editar -->
  <div class="modal-overlay" id="modalEditar">
    <div class="modal">
      <div class="modal-title">Editar Cliente</div>
      <form id="formEditar">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label>Nome</label><input name="nome" value={cliente.nome} /></div>
          <div class="form-group"><label>Telefone</label><input name="telefone" value={cliente.telefone || ""} /></div>
          <div class="form-group"><label>CNPJ/CPF</label><input name="cnpj_cpf" value={cliente.cnpj_cpf || ""} /></div>
          <div class="form-group"><label>Plano</label>
            <select name="plano_selecionado">
              <option value="">Nenhum</option>
              {["Trimestral","Semestral","Anual"].map(p => <option value={p} selected={cliente.plano_selecionado === p}>{p}</option>)}
            </select>
          </div>
          <div class="form-group"><label>Valor/mês</label><input name="valor_mensal_contratado" type="number" step="0.01" value={cliente.valor_mensal_contratado || ""} /></div>
          <div class="form-group"><label>Visitas contratadas</label><input name="visitas_contratadas" type="number" value={cliente.visitas_contratadas || ""} /></div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" data-action="fechar-modal" data-modal="modalEditar">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal nova loja -->
  <div class="modal-overlay" id="modalLoja">
    <div class="modal">
      <div class="modal-title">Nova Loja</div>
      <div id="msgLoja"></div>
      <form id="formLoja">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group" style="grid-column:span 2"><label>Nome da loja *</label><input name="nome" required /></div>
          <div class="form-group" style="grid-column:span 2"><label>Endereço</label><input name="endereco" /></div>
          <div class="form-group"><label>Cidade</label><input name="cidade" /></div>
          <div class="form-group"><label>UF</label><input name="uf" maxlength="2" /></div>
          <div class="form-group"><label>CEP</label><input name="cep" /></div>
          <div class="form-group"><label>Tamanho (m²)</label><input name="tamanho_m2" type="number" /></div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" data-action="fechar-modal" data-modal="modalLoja">Cancelar</button>
          <button type="submit" class="btn btn-primary">Criar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal novo pagamento -->
  <div class="modal-overlay" id="modalPgto">
    <div class="modal">
      <div class="modal-title">Lançar Pagamento</div>
      <form id="formPgto">
        <div class="form-group"><label>Referência</label><input name="referencia" placeholder="ex: Mai/2026" /></div>
        <div class="form-group"><label>Valor *</label><input name="valor" type="number" step="0.01" required /></div>
        <div class="form-group"><label>Vencimento *</label><input name="data_vencimento" type="date" required /></div>
        <div class="form-group"><label>Status</label>
          <select name="status"><option value="pendente">Pendente</option><option value="pago">Pago</option><option value="atrasado">Atrasado</option></select>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" data-action="fechar-modal" data-modal="modalPgto">Cancelar</button>
          <button type="submit" class="btn btn-primary">Lançar</button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ clienteId: id }}>
    // define:vars força is:inline — sem TypeScript, só JS puro
    document.addEventListener("click", async function(e) {
      var btn = e.target.closest("[data-action]");
      if (!btn) return;
      var action = btn.dataset.action;
      var status = btn.dataset.status;
      var modal  = btn.dataset.modal;
      var dataId = btn.dataset.id;

      if (action === "fechar-modal") {
        document.getElementById(modal).classList.remove("open");
      }
      if (action === "modal-editar") document.getElementById("modalEditar").classList.add("open");
      if (action === "modal-loja")   document.getElementById("modalLoja").classList.add("open");
      if (action === "modal-pgto")   document.getElementById("modalPgto").classList.add("open");

      if (action === "patch-status") {
        if (!confirm('Mudar status para "' + status + '"?')) return;
        var r = await fetch("/api/admin/clientes/" + clienteId, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ status: status }) });
        if (r.ok) window.location.reload(); else alert("Erro ao atualizar");
      }

      if (action === "resetar-senha") {
        if (!confirm("Resetar senha deste cliente? Uma senha inicial será gerada.")) return;
        var r = await fetch("/api/admin/clientes/" + clienteId + "/resetar-senha", { method: "POST", headers: { "content-type": "application/json" }, body: "{}" });
        if (r.ok) {
          var d = await r.json();
          var msg = "Nova senha: " + d.senha;
          if (d.emailEnviado) msg += "\n\n✅ Email enviado para o cliente.";
          else if (d.emailErro) msg += "\n\n⚠ Email NÃO foi enviado: " + d.emailErro;
          alert(msg);
        } else {
          var de = await r.json().catch(function(){ return { error: "HTTP " + r.status }; });
          alert("Erro ao resetar senha: " + (de.error || ""));
        }
      }

      if (action === "marcar-pago") {
        var r = await fetch("/api/admin/pagamentos/" + dataId, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ status: "pago", data_pagamento: new Date().toISOString() }) });
        if (r.ok) window.location.reload(); else alert("Erro ao marcar como pago");
      }

      if (action === "editar-data-prev") {
        var prevId = btn.dataset.prevId;
        var tr = document.querySelector("tr[data-prev-id='" + prevId + "']");
        var cell = tr.querySelector(".cell-data-agendada");
        var dataAtual = tr.dataset.agendada || "";
        // Troca célula por input + botões
        cell.innerHTML =
          '<input type="date" value="' + dataAtual + '" style="font-size:0.8rem;padding:3px 6px;border:1px solid #C41E3A;border-radius:4px" id="inp-' + prevId + '" />' +
          ' <button class="btn btn-primary btn-sm" data-action="salvar-data-prev" data-prev-id="' + prevId + '" style="margin-left:4px">✔</button>' +
          ' <button class="btn btn-secondary btn-sm" data-action="cancelar-data-prev" data-prev-id="' + prevId + '">✕</button>';
        btn.style.display = "none";
      }

      if (action === "cancelar-data-prev") {
        window.location.reload();
      }

      if (action === "salvar-data-prev") {
        var prevId = btn.dataset.prevId;
        var inp = document.getElementById("inp-" + prevId);
        if (!inp || !inp.value) { alert("Selecione uma data."); return; }
        var r = await fetch("/api/admin/preventivas/" + prevId, { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ data_agendada: inp.value }) });
        if (r.ok) window.location.reload();
        else { var d = await r.json().catch(function(){ return { error: "HTTP " + r.status }; }); alert("Erro: " + d.error); }
      }
    });

    document.getElementById("btnGerarPrev").addEventListener("click", async function() {
      if (!confirm("Gerar preventivas automaticamente?\n\n• Quantidade: definida pelo plano (trimestral=3, semestral=6, anual=12)\n• 1ª visita: 10 dias após a contratação\n• Seguintes: a cada 30 dias\n\nPreventivas agendadas existentes serão substituídas.")) return;
      var btn = document.getElementById("btnGerarPrev");
      btn.disabled = true; btn.textContent = "…";
      var r = await fetch("/api/admin/clientes/" + clienteId + "/gerar-preventivas", { method: "POST", headers: { "content-type": "application/json" }, body: "{}" });
      if (r.ok) {
        var d = await r.json();
        alert("✔ " + d.criadas + " preventiva(s) gerada(s) com sucesso!");
        window.location.reload();
      } else {
        var d = await r.json().catch(function() { return { error: "HTTP " + r.status }; });
        alert("Erro: " + d.error);
        btn.disabled = false; btn.textContent = "⚙ Gerar preventivas";
      }
    });

    document.getElementById("formEditar").addEventListener("submit", async function(e) {
      e.preventDefault();
      var fd = new FormData(e.target);
      var body = Object.fromEntries(fd.entries());
      if (body.valor_mensal_contratado) body.valor_mensal_contratado = parseFloat(body.valor_mensal_contratado);
      if (body.visitas_contratadas) body.visitas_contratadas = parseInt(body.visitas_contratadas);
      var r = await fetch("/api/admin/clientes/" + clienteId, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (r.ok) window.location.reload(); else alert("Erro ao salvar");
    });

    document.getElementById("formLoja").addEventListener("submit", async function(e) {
      e.preventDefault();
      var fd = new FormData(e.target);
      var body = Object.fromEntries(fd.entries());
      body.cliente_id = clienteId;
      if (body.tamanho_m2) body.tamanho_m2 = parseInt(body.tamanho_m2);
      var r = await fetch("/api/admin/lojas", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (r.ok) window.location.reload();
      else { var d = await r.json(); document.getElementById("msgLoja").innerHTML = '<div class="alert alert-error">' + d.error + "</div>"; }
    });

    document.getElementById("formPgto").addEventListener("submit", async function(e) {
      e.preventDefault();
      var fd = new FormData(e.target);
      var body = Object.fromEntries(fd.entries());
      body.cliente_id = clienteId;
      body.valor = parseFloat(body.valor);
      var r = await fetch("/api/admin/pagamentos", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (r.ok) window.location.reload(); else alert("Erro ao lançar pagamento");
    });
  </script>

  <style>
    .info-grid { display: grid; grid-template-columns: 130px 1fr; gap: 8px 12px; font-size: 0.875rem; }
    .info-label { color: #666; font-weight: 600; }
  </style>
</Admin>
