---
// HUB de entrada do painel unificado. Mostra um card por módulo que o usuário pode
// acessar (nível != "nenhum"), agrupado por área, no visual amigável do portal.
// O Dashboard virou só mais um card (módulo "dashboard" -> /admin/dashboard).
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";
import {
  GRUPOS_ADMIN, nivelEfetivo, perfisFrescos, carregarOverridesUsuario, rotuloPerfil,
} from "../../lib/permissoes";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
let claims: AdminClaims;
try {
  claims = await verifyToken<AdminClaims>(token);
  if (claims.tipo !== "admin") throw new Error();
} catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const perfis = await perfisFrescos(claims);
const overrides = await carregarOverridesUsuario(claims.sub);

// Identidade para o banner
let nome = "";
try {
  const { data: prof } = await supabaseAdmin()
    .from("portal_profiles")
    .select("display_name, full_name")
    .eq("id", claims.sub)
    .maybeSingle();
  if (prof) nome = prof.display_name || prof.full_name || "";
} catch { /* fallback no e-mail */ }
const primeiroNome = (nome || claims.email?.split("@")[0] || "colaborador").trim().split(" ")[0];
const perfilLabel = perfis.length ? rotuloPerfil(perfis[0]) : "";

// Cor por grupo (barra do topo + círculo do ícone)
const GRUPO_COR: Record<string, string> = {
  "meu-espaco": "#C41E3A",
  geral: "#475569",
  manutencao: "#D97706",
  operacoes: "#EA580C",
  rh: "#0EA5E9",
  financeiro: "#16A34A",
  comercial: "#7C3AED",
  juridico: "#9333EA",
  portal: "#DB2777",
  institucional: "#0D9488",
  sistema: "#64748B",
  conta: "#475569",
};
const GRUPO_TITULO: Record<string, string> = { geral: "Geral" };

// Cores individuais p/ os cards colaborador-facing (visual colorido como o portal antigo).
const MODULO_COR: Record<string, string> = {
  "meu-onboarding": "#2563EB",
  junia: "#C41E3A",
  "documentos-portal": "#0D9488",
  "meus-equipamentos": "#EA580C",
};

// Seções visíveis: cada grupo com seus módulos acessíveis (nível != nenhum).
const secoes = GRUPOS_ADMIN
  .map((g) => ({
    id: g.id,
    titulo: g.label ?? GRUPO_TITULO[g.id] ?? "Geral",
    cor: GRUPO_COR[g.id] || "#C41E3A",
    itens: g.itens.filter((m) => nivelEfetivo(m.key, perfis, overrides) !== "nenhum"),
  }))
  .filter((s) => s.itens.length);
---
<Admin title="Início" current="">
  <div class="hub-banner">
    <div class="hb-text">
      <p class="hb-eyebrow">Portal CJR</p>
      <h2 class="hb-title">Olá, {primeiroNome}! 👋</h2>
      <p class="hb-sub">Bem-vindo ao painel. Escolha um atalho abaixo para começar.</p>
    </div>
    <div class="hb-role">
      <p class="hb-role-label">Seu acesso</p>
      <p class="hb-role-value">{perfilLabel || "—"}</p>
    </div>
  </div>

  {secoes.length === 0 && (
    <div class="hub-vazio">
      <div style="font-size:42px;margin-bottom:10px">🙂</div>
      <strong>Nenhum módulo liberado ainda.</strong>
      <p>Fale com o administrador para liberar seus acessos.</p>
    </div>
  )}

  {secoes.map((s) => (
    <section class="hub-sec">
      <p class="hub-sec-title">{s.titulo}</p>
      <div class="hub-grid">
        {s.itens.map((m) => {
          const cor = MODULO_COR[m.key] || s.cor;
          return (
            <a href={m.href} class="hub-card" style={`border-top-color:${cor}`}>
              <div class="hub-icon" style={`background:${cor}`}>{m.icon}</div>
              <h3>{m.label}</h3>
            </a>
          );
        })}
      </div>
    </section>
  ))}

  <style>
    .hub-banner {
      background: linear-gradient(135deg, #1A1C20 0%, #2D2F36 55%, #3A1419 100%);
      border-radius: 18px; padding: 30px 34px; color: #fff; margin-bottom: 28px;
      display: flex; align-items: center; justify-content: space-between; gap: 24px;
    }
    .hb-eyebrow { font-size: 12px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; color: #FC8181; margin: 0 0 9px; }
    .hb-title { font-family: 'Montserrat', sans-serif; font-size: 29px; font-weight: 800; margin: 0 0 8px; color: #fff; line-height: 1.1; }
    .hb-sub { margin: 0; color: #D1D5DB; font-size: 15.5px; }
    .hb-role { text-align: right; flex-shrink: 0; }
    .hb-role-label { margin: 0; font-size: 11px; color: #9CA3AF; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; }
    .hb-role-value { margin: 6px 0 0; font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 800; color: #FC8181; }

    .hub-sec { margin-bottom: 26px; }
    .hub-sec-title {
      font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 15px;
      color: var(--ink-mid); margin: 0 0 14px; text-transform: uppercase; letter-spacing: .05em;
    }
    .hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(185px, 1fr)); gap: 16px; }
    .hub-card {
      background: #fff; border: 1px solid var(--border); border-top: 5px solid var(--brand);
      border-radius: 14px; padding: 24px 16px 20px; text-decoration: none; color: inherit;
      display: flex; flex-direction: column; align-items: center; text-align: center;
      transition: all .2s ease; box-shadow: 0 2px 6px rgba(16,24,40,.05);
    }
    .hub-card:hover { transform: translateY(-4px); box-shadow: 0 16px 32px rgba(0,0,0,.12); }
    .hub-icon {
      width: 60px; height: 60px; border-radius: 50%; flex-shrink: 0;
      background: var(--brand); color: #fff;
      display: flex; align-items: center; justify-content: center; font-size: 28px; margin-bottom: 14px;
      box-shadow: 0 6px 16px rgba(16,24,40,.16);
    }
    .hub-card h3 {
      font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 700;
      margin: 0; color: var(--ink); line-height: 1.3;
    }

    .hub-vazio { text-align: center; padding: 60px 20px; color: var(--ink-light); }
    .hub-vazio strong { display: block; color: var(--ink-mid); font-size: 1.05rem; margin-bottom: 4px; }

    @media (max-width: 640px) {
      .hub-banner { flex-direction: column; align-items: flex-start; padding: 24px 22px; }
      .hb-role { text-align: left; }
      .hb-title { font-size: 25px; }
      .hub-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
    }
  </style>
</Admin>
