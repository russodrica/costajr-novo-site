---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
let admin: AdminClaims;
try {
  admin = await verifyToken<AdminClaims>(token);
  if (admin.tipo !== "admin") throw new Error();
} catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const db = supabaseAdmin();
const [
  { count: clientesAtivos },
  { count: clientesPendentes },
  { count: clientesInadimplentes },
  { count: chamadosAbertos },
  { count: chamadosAndamento },
  { count: tecnicosAtivos },
  { count: pagamentosAtrasados },
  { count: materiaisPendentes },
  { count: membrosPendentes },
  { count: leadsNovos },
  { count: suporteAberto },
  { count: preventivas },
] = await Promise.all([
  db.from("manut_clientes").select("*", { count: "exact", head: true }).eq("status", "ativo"),
  db.from("manut_clientes").select("*", { count: "exact", head: true }).eq("status", "pendente"),
  db.from("manut_clientes").select("*", { count: "exact", head: true }).eq("status", "inadimplente"),
  db.from("manut_chamados").select("*", { count: "exact", head: true }).eq("status", "aberto"),
  db.from("manut_chamados").select("*", { count: "exact", head: true }).eq("status", "em_andamento"),
  db.from("manut_tecnicos").select("*", { count: "exact", head: true }).eq("status", "ativo"),
  db.from("manut_pagamentos").select("*", { count: "exact", head: true }).eq("status", "atrasado"),
  db.from("manut_materiais").select("*", { count: "exact", head: true }).eq("status", "pendente_aprovacao"),
  db.from("portal_profiles").select("*", { count: "exact", head: true }).eq("approval_status", "pending"),
  db.from("leads").select("*", { count: "exact", head: true }).eq("status", "novo"),
  db.from("manut_suporte").select("*", { count: "exact", head: true }).eq("status", "aberto"),
  db.from("manut_preventivas").select("*", { count: "exact", head: true }).eq("status", "agendada"),
]);

// Chamados recentes
const { data: chamadosRecentes } = await db
  .from("manut_chamados")
  .select("id, tipo, descricao, status, prioridade, data_abertura, manut_clientes(nome)")
  .order("data_abertura", { ascending: false })
  .limit(5);

// Leads recentes
const { data: leadsRecentes } = await db
  .from("leads")
  .select("id, nome, email, telefone, origem, status, created_at")
  .order("created_at", { ascending: false })
  .limit(5);

function badgeChamado(status: string) {
  const m: Record<string, string> = { aberto: "badge-red", em_andamento: "badge-blue", aguardando_material: "badge-orange", concluido: "badge-green", cancelado: "badge-gray" };
  return m[status] || "badge-gray";
}
function fmtDate(d: string | null) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("pt-BR", { day: "2-digit", month: "2-digit", year: "2-digit" });
}
---
<Admin title="Dashboard" current="dashboard">
  <!-- Stats -->
  <div class="card-grid">
    <a href="/admin/clientes?status=ativo" class="stat-card" style="text-decoration:none">
      <div class="stat-value">{clientesAtivos ?? 0}</div>
      <div class="stat-label">Clientes ativos</div>
    </a>
    <a href="/admin/clientes?status=pendente" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#F59E0B">{clientesPendentes ?? 0}</div>
      <div class="stat-label">Aguardando ativação</div>
    </a>
    <a href="/admin/clientes?status=inadimplente" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#EF4444">{clientesInadimplentes ?? 0}</div>
      <div class="stat-label">Inadimplentes</div>
    </a>
    <a href="/admin/chamados?status=aberto" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#EF4444">{chamadosAbertos ?? 0}</div>
      <div class="stat-label">Chamados abertos</div>
    </a>
    <a href="/admin/chamados?status=em_andamento" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#3B82F6">{chamadosAndamento ?? 0}</div>
      <div class="stat-label">Em andamento</div>
    </a>
    <a href="/admin/tecnicos" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#22C55E">{tecnicosAtivos ?? 0}</div>
      <div class="stat-label">Técnicos ativos</div>
    </a>
    <a href="/admin/pagamentos?status=atrasado" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#EF4444">{pagamentosAtrasados ?? 0}</div>
      <div class="stat-label">Pgtos. atrasados</div>
    </a>
    <a href="/admin/materiais" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#F59E0B">{materiaisPendentes ?? 0}</div>
      <div class="stat-label">Materiais p/ aprovar</div>
    </a>
    <a href="/admin/membros" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#F59E0B">{membrosPendentes ?? 0}</div>
      <div class="stat-label">Membros pendentes</div>
    </a>
    <a href="/admin/leads" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#3B82F6">{leadsNovos ?? 0}</div>
      <div class="stat-label">Leads novos</div>
    </a>
    <a href="/admin/suporte" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#F59E0B">{suporteAberto ?? 0}</div>
      <div class="stat-label">Suporte aberto</div>
    </a>
    <a href="/admin/preventivas" class="stat-card" style="text-decoration:none">
      <div class="stat-value" style="color:#22C55E">{preventivas ?? 0}</div>
      <div class="stat-label">Preventivas agendadas</div>
    </a>
  </div>

  <!-- Dois painéis lado a lado -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:8px">
    <!-- Chamados recentes -->
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
        <strong>Chamados recentes</strong>
        <a href="/admin/chamados" class="btn btn-secondary btn-sm">Ver todos</a>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Cliente</th><th>Tipo</th><th>Status</th><th>Data</th></tr></thead>
          <tbody>
            {chamadosRecentes?.length ? chamadosRecentes.map((c: any) => (
              <tr>
                <td>{(c.manut_clientes as any)?.nome ?? "—"}</td>
                <td>{c.tipo}</td>
                <td><span class={`badge ${badgeChamado(c.status)}`}>{c.status.replace("_"," ")}</span></td>
                <td>{fmtDate(c.data_abertura)}</td>
              </tr>
            )) : <tr><td colspan="4" style="text-align:center;color:#999;padding:20px">Nenhum chamado</td></tr>}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Leads recentes -->
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
        <strong>Leads recentes</strong>
        <a href="/admin/leads" class="btn btn-secondary btn-sm">Ver todos</a>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Nome</th><th>Origem</th><th>Status</th><th>Data</th></tr></thead>
          <tbody>
            {leadsRecentes?.length ? leadsRecentes.map((l: any) => (
              <tr>
                <td>{l.nome}</td>
                <td>{l.origem}</td>
                <td><span class={`badge ${l.status === "novo" ? "badge-blue" : l.status === "convertido" ? "badge-green" : "badge-gray"}`}>{l.status}</span></td>
                <td>{fmtDate(l.created_at)}</td>
              </tr>
            )) : <tr><td colspan="4" style="text-align:center;color:#999;padding:20px">Nenhum lead</td></tr>}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <style>
    .stat-card { transition: box-shadow 0.15s; color: inherit; }
    .stat-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
    @media (max-width: 768px) {
      div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
    }
  </style>
</Admin>
