---
// Tela inicial do painel = DASHBOARD DO SITE.
// Mostra pendências que precisam de ação + indicadores principais de CADA área,
// respeitando a permissão do usuário (cada bloco só aparece se o perfil tem acesso).
// O dashboard operacional de Manutenção virou /admin/dashboard (aba Manutenção).
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";
import { nivelEfetivo, perfisFrescos, carregarOverridesUsuario, rotuloPerfil } from "../../lib/permissoes";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
let claims: AdminClaims;
try {
  claims = await verifyToken<AdminClaims>(token);
  if (claims.tipo !== "admin") throw new Error();
} catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const perfis = await perfisFrescos(claims);
const overrides = await carregarOverridesUsuario(claims.sub);
const pode = (key: string) => nivelEfetivo(key, perfis, overrides) !== "nenhum";

const db = supabaseAdmin();
const hoje = new Date().toISOString().slice(0, 10);

// Helper de contagem (Supabase não lança em erro de query — retorna count null).
const cnt = (q: any) => q.select("*", { count: "exact", head: true });

let nome = "";
const [
  prof,
  chamadosAbertos, chamadosAndamento, preventivasAgendadas, clientesAtivos,
  pagamentosAtrasados, materiaisPendentes, suporteAberto,
  leadsNovos, leadsNegociando, leadsConvertidos, propostasTotal,
  membrosPendentes, perguntasPendentes,
  colaboradoresAtivos, colaboradoresFerias, docsVencidos,
  obrasTotal, tarefasAbertas, ativosTotal,
  finResumo,
] = await Promise.all([
  db.from("portal_profiles").select("display_name, full_name").eq("id", claims.sub).maybeSingle(),
  cnt(db.from("manut_chamados")).eq("status", "aberto"),
  cnt(db.from("manut_chamados")).eq("status", "em_andamento"),
  cnt(db.from("manut_preventivas")).eq("status", "agendada"),
  cnt(db.from("manut_clientes")).eq("status", "ativo"),
  cnt(db.from("manut_pagamentos")).eq("status", "atrasado"),
  cnt(db.from("manut_materiais")).eq("status", "pendente_aprovacao"),
  cnt(db.from("manut_suporte")).eq("status", "aberto"),
  cnt(db.from("manut_leads")).eq("etapa", "novo"),
  cnt(db.from("manut_leads")).eq("etapa", "negociando"),
  cnt(db.from("manut_leads")).eq("etapa", "convertido"),
  cnt(db.from("com_propostas")),
  cnt(db.from("portal_profiles")).eq("approval_status", "pending"),
  cnt(db.from("portal_pending_questions")).eq("status", "pending"),
  cnt(db.from("rh_colaboradores")).neq("status", "desligado"),
  cnt(db.from("rh_colaboradores")).eq("status", "ferias"),
  cnt(db.from("rh_documentos")).not("validade", "is", null).lt("validade", hoje),
  cnt(db.from("obras")),
  cnt(db.from("obras_tarefas")).eq("status", "pendente"),
  cnt(db.from("ativos")),
  db.rpc("fin_resumo_caixa", { p_meses: 1 }),
]);

if (prof.data) nome = prof.data.display_name || prof.data.full_name || "";
const primeiroNome = (nome || claims.email?.split("@")[0] || "colaborador").trim().split(" ")[0];
const perfilLabel = perfis.length ? rotuloPerfil(perfis[0]) : "";
const dataHoje = new Date().toLocaleDateString("pt-BR", { weekday: "long", day: "2-digit", month: "long" });

const finCards = (finResumo as any)?.data?.cards || {};
const num = (v: any) => Number(v) || 0;
const fmtMoney = (v: number) => v.toLocaleString("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 });
const fmtNum = (v: any) => String(num(v));

// ── Pendências que precisam de ação (gated por acesso + count > 0) ──
type Pend = { l: string; n: number; href: string; nivel: "alto" | "medio"; ic: string };
const pendencias: Pend[] = ([
  pode("chamados")   && { l: "Chamados abertos",       n: num(chamadosAbertos.count),        href: "/admin/chamados?status=aberto",                 nivel: "alto",  ic: "alert-triangle" },
  pode("pagamentos") && { l: "Pagamentos atrasados",   n: num(pagamentosAtrasados.count),    href: "/admin/pagamentos?status=atrasado",             nivel: "alto",  ic: "cash" },
  pode("financeiro") && { l: "Contas atrasadas",       n: num(finCards.atrasados_pagar_qtd), href: "/admin/financeiro",                             nivel: "alto",  ic: "receipt-2" },
  pode("rh")         && { l: "Documentos vencidos",    n: num(docsVencidos.count),           href: "/admin/rh",                                     nivel: "alto",  ic: "file-text" },
  pode("materiais")  && { l: "Materiais p/ aprovar",   n: num(materiaisPendentes.count),     href: "/admin/materiais?status=pendente_aprovacao",    nivel: "medio", ic: "package" },
  pode("membros")    && { l: "Membros p/ aprovar",     n: num(membrosPendentes.count),       href: "/admin/membros?status=pending",                 nivel: "medio", ic: "user-check" },
  pode("perguntas")  && { l: "Perguntas JunIA",        n: num(perguntasPendentes.count),     href: "/admin/perguntas",                              nivel: "medio", ic: "message-circle" },
  pode("leads")      && { l: "Leads sem contato",      n: num(leadsNovos.count),             href: "/admin/leads",                                  nivel: "medio", ic: "speakerphone" },
  pode("suporte")    && { l: "Suporte aberto",         n: num(suporteAberto.count),          href: "/admin/suporte",                                nivel: "medio", ic: "headset" },
] as (Pend | false)[]).filter((p): p is Pend => !!p && p.n > 0);

// ── Indicadores por área (gated) ──
type Metric = { v: string; l: string };
type Area = { nome: string; cor: string; ic: string; href: string; ver: string; metrics: Metric[]; wide?: boolean };
const areas: Area[] = ([
  pode("chamados") && {
    nome: "Manutenção", cor: "#D97706", ic: "tool", href: "/admin/dashboard", ver: "Abrir painel",
    metrics: [
      { v: fmtNum(chamadosAbertos.count), l: "Chamados abertos" },
      { v: fmtNum(chamadosAndamento.count), l: "Em andamento" },
      { v: fmtNum(preventivasAgendadas.count), l: "Preventivas" },
      { v: fmtNum(clientesAtivos.count), l: "Clientes ativos" },
    ],
  },
  pode("comercial") && {
    nome: "Comercial", cor: "#7C3AED", ic: "businessplan", href: "/admin/comercial", ver: "Abrir CRM",
    metrics: [
      { v: fmtNum(leadsNovos.count), l: "Leads novos" },
      { v: fmtNum(leadsNegociando.count), l: "Negociando" },
      { v: fmtNum(leadsConvertidos.count), l: "Convertidos" },
      { v: fmtNum(propostasTotal.count), l: "Propostas" },
    ],
  },
  pode("rh") && {
    nome: "RH & Pessoas", cor: "#0EA5E9", ic: "users", href: "/admin/rh", ver: "Abrir RH",
    metrics: [
      { v: fmtNum(colaboradoresAtivos.count), l: "Colaboradores" },
      { v: fmtNum(colaboradoresFerias.count), l: "Em férias" },
      { v: fmtNum(docsVencidos.count), l: "Docs vencidos" },
    ],
  },
  (pode("obras") || pode("ativos")) && {
    nome: "Operações & Obras", cor: "#EA580C", ic: "building-skyscraper", href: pode("obras") ? "/admin/obras" : "/admin/ativos", ver: "Abrir",
    metrics: [
      { v: fmtNum(obrasTotal.count), l: "Obras" },
      { v: fmtNum(tarefasAbertas.count), l: "Tarefas abertas" },
      { v: fmtNum(ativosTotal.count), l: "Ativos" },
    ],
  },
  pode("financeiro") && {
    nome: "Financeiro", cor: "#16A34A", ic: "building-bank", href: "/admin/financeiro", ver: "Abrir financeiro", wide: true,
    metrics: [
      { v: fmtMoney(num(finCards.a_receber)), l: "A receber (mês)" },
      { v: fmtMoney(num(finCards.a_pagar)), l: "A pagar (mês)" },
      { v: fmtMoney(num(finCards.atrasados_pagar)), l: "Atrasado a pagar" },
    ],
  },
] as (Area | false)[]).filter((a): a is Area => !!a);
---
<Admin title="Visão geral" current="home">
  <div class="hero">
    <div class="hero-text">
      <p class="hero-eyebrow">Painel Costa Júnior</p>
      <h2 class="hero-title">Olá, {primeiroNome}</h2>
      <p class="hero-sub">Resumo de hoje · <span style="text-transform:capitalize">{dataHoje}</span></p>
    </div>
    {perfilLabel && (
      <div class="hero-role">
        <span class="hero-role-label">Seu acesso</span>
        <span class="hero-role-value">{perfilLabel}</span>
      </div>
    )}
  </div>

  {pendencias.length > 0 && (
    <section class="blk">
      <p class="blk-title"><i class="ti ti-bolt" aria-hidden="true"></i> Pendências que precisam de ação</p>
      <div class="pend-row">
        {pendencias.map(p => (
          <a href={p.href} class={`pend ${p.nivel}`}>
            <span class="pend-ic"><i class={`ti ti-${p.ic}`} aria-hidden="true"></i></span>
            <span class="pend-n">{p.n}</span>
            <span class="pend-l">{p.l}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="blk">
    <p class="blk-title"><i class="ti ti-layout-grid" aria-hidden="true"></i> Indicadores por área</p>
    {areas.length === 0 ? (
      <div class="vazio">
        <i class="ti ti-lock" aria-hidden="true"></i>
        <strong>Nenhuma área liberada ainda.</strong>
        <p>Fale com o administrador para liberar seus acessos.</p>
      </div>
    ) : (
      <div class="area-grid">
        {areas.map(a => (
          <a href={a.href} class={`area-card${a.wide ? " wide" : ""}`} style={`--c:${a.cor}`}>
            <div class="area-head">
              <span class="area-ic"><i class={`ti ti-${a.ic}`} aria-hidden="true"></i></span>
              <span class="area-nome">{a.nome}</span>
              <span class="area-ver">{a.ver} <i class="ti ti-arrow-right" aria-hidden="true"></i></span>
            </div>
            <div class="area-metrics">
              {a.metrics.map(m => (
                <div class="metric">
                  <span class="metric-v">{m.v}</span>
                  <span class="metric-l">{m.l}</span>
                </div>
              ))}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <style>
    .hero {
      background: var(--surface); border: 1px solid var(--border); border-left: 5px solid var(--brand);
      border-radius: var(--radius-lg); padding: 22px 26px; margin-bottom: 24px;
      display: flex; align-items: center; justify-content: space-between; gap: 20px; box-shadow: var(--shadow-sm);
    }
    .hero-eyebrow { font-size: 11px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--brand); margin: 0 0 6px; }
    .hero-title { font-family: 'Montserrat', sans-serif; font-size: 26px; font-weight: 800; margin: 0; color: var(--ink); letter-spacing: -.01em; line-height: 1.1; }
    .hero-sub { margin: 5px 0 0; color: var(--ink-mid); font-size: 14px; }
    .hero-role { text-align: right; flex: none; }
    .hero-role-label { display: block; font-size: 10.5px; color: var(--ink-light); font-weight: 700; text-transform: uppercase; letter-spacing: .08em; }
    .hero-role-value { display: block; margin-top: 4px; font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 700; color: var(--brand); }

    .blk { margin-bottom: 26px; }
    .blk-title { display: flex; align-items: center; gap: 8px; font-family: 'Montserrat', sans-serif; font-size: .82rem; font-weight: 700; color: var(--ink-mid); margin: 0 0 12px; text-transform: uppercase; letter-spacing: .06em; }
    .blk-title i { font-size: 16px; color: var(--brand); }

    /* Pendências */
    .pend-row { display: flex; gap: 10px; flex-wrap: wrap; }
    .pend { display: flex; align-items: center; gap: 9px; padding: 10px 16px; border-radius: var(--radius-md); text-decoration: none; font-size: .85rem; font-weight: 600; border: 1px solid transparent; transition: var(--transition); }
    .pend:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .pend.alto  { background: var(--danger-bg);  color: var(--danger-fg);  border-color: #FECACA; }
    .pend.medio { background: var(--warning-bg); color: var(--warning-fg); border-color: #FDE68A; }
    .pend-ic { font-size: 16px; display: inline-flex; }
    .pend-n  { font-family: 'Montserrat', sans-serif; font-size: 1.1rem; font-weight: 800; }

    /* Cards de área */
    .area-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .area-card {
      background: var(--surface); border: 1px solid var(--border); border-top: 4px solid var(--c);
      border-radius: var(--radius-lg); padding: 18px 20px 16px; text-decoration: none; color: inherit;
      box-shadow: var(--shadow-sm); transition: var(--transition); display: block;
    }
    .area-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
    /* Financeiro: linha própria, largura total, valores com mais respiro */
    .area-card.wide { grid-column: 1 / -1; }
    .area-card.wide .metric { min-width: 150px; padding: 14px 18px; }
    .area-card.wide .metric-v { font-size: 1.7rem; }
    .area-head { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
    .area-ic {
      width: 38px; height: 38px; border-radius: 10px; flex: none; display: inline-flex; align-items: center; justify-content: center;
      font-size: 20px; color: var(--c); background: color-mix(in srgb, var(--c) 13%, #fff);
    }
    .area-nome { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 1rem; color: var(--ink); flex: 1; }
    .area-ver { font-size: .76rem; font-weight: 600; color: var(--c); display: inline-flex; align-items: center; gap: 3px; white-space: nowrap; }
    .area-metrics { display: flex; gap: 8px; flex-wrap: wrap; }
    .metric { flex: 1; min-width: 78px; background: var(--surface-sunken); border-radius: var(--radius-md); padding: 10px 12px; }
    .metric-v { display: block; font-family: 'Montserrat', sans-serif; font-size: 1.32rem; font-weight: 700; color: var(--ink); line-height: 1.1; white-space: nowrap; }
    .metric-l { display: block; font-size: .72rem; color: var(--ink-mid); margin-top: 3px; }

    .vazio { text-align: center; padding: 50px 20px; color: var(--ink-light); }
    .vazio i { font-size: 38px; display: block; margin-bottom: 10px; }
    .vazio strong { display: block; color: var(--ink-mid); font-size: 1.05rem; margin-bottom: 4px; }

    @media (max-width: 640px) {
      .hero { flex-direction: column; align-items: flex-start; }
      .hero-role { text-align: left; }
      .area-grid { grid-template-columns: 1fr; }
    }
  </style>
</Admin>
