    /* Gráfico de barras (padrão do dashboard, agrupado entrada × saída) */
    .bar-chart { display: flex; align-items: flex-end; gap: 8px; height: 160px; }
    .bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; height: 100%; gap: 4px; }
    .bar-group { display: flex; align-items: flex-end; justify-content: center; gap: 4px; height: 100%; width: 100%; }
    .bar { width: 100%; max-width: 26px; border-radius: 6px 6px 2px 2px; min-height: 2px; transition: var(--transition); }
    .bar-entrada { background: linear-gradient(180deg, #22C55E, #15803D); }
    .bar-saida { background: linear-gradient(180deg, #EF4444, #B91C1C); }
    .bar-col:hover .bar { opacity: .8; }
    .bar-lbl { font-size: 10.5px; color: var(--ink-light); text-transform: capitalize; }
    .fluxo-legend { display: flex; gap: 16px; flex-wrap: wrap; }
    .legend-item { display: inline-flex; align-items: center; gap: 6px; font-size: .76rem; color: var(--ink-mid); }
    .legend-dot { width: 10px; height: 10px; border-radius: 3px; flex: none; }

    /* Categorias */
    .cat-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 6px; vertical-align: middle; flex: none; }
    .cat-lista { display: flex; flex-direction: column; gap: 6px; max-height: 240px; overflow-y: auto; }
    .cat-item { display: flex; align-items: center; gap: 8px; font-size: .85rem; padding: 6px 8px; border: 1px solid var(--border-light); border-radius: 8px; }
