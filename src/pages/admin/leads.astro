---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const filtroEtapa = Astro.url.searchParams.get("etapa") || "";
const db = supabaseAdmin();
let q = db.from("manut_leads").select("*").order("created_at", { ascending: false });
if (filtroEtapa) q = q.eq("etapa", filtroEtapa);
const { data: leads } = await q;

const badgeSt: Record<string, string> = { novo: "badge-blue", contato_feito: "badge-yellow", proposta_enviada: "badge-orange", negociando: "badge-yellow", convertido: "badge-green", perdido: "badge-gray" };
function fmtDate(d: string | null) { if (!d) return "—"; return new Date(d).toLocaleDateString("pt-BR"); }
---
<Admin title="Leads" current="leads">
  <div class="toolbar">
    <span class="toolbar-title">Pré-cadastros / Leads ({leads?.length ?? 0})</span>
    <select class="filter-select" onchange="filtrar(this.value)">
      <option value="" selected={!filtroEtapa}>Todos</option>
      {["novo","contato_feito","proposta_enviada","negociando","convertido","perdido"].map(s => <option value={s} selected={s===filtroEtapa}>{s.replace(/_/g," ")}</option>)}
    </select>
    <input class="search-input" type="search" placeholder="Buscar nome, email…" oninput="buscar(this.value)" />
    <button class="btn btn-secondary" onclick="window.location.reload()">↻ Atualizar</button>
  </div>

  <div class="card">
    <div class="table-wrap">
      <table id="tabela">
        <thead><tr><th>Nome</th><th>E-mail</th><th>Telefone</th><th>Loja</th><th>Plano</th><th>Etapa</th><th>Data</th><th>Ação</th></tr></thead>
        <tbody>
          {leads?.length ? leads.map((l: any) => (
            <tr data-search={`${l.nome} ${l.email} ${l.nome_loja||""}`.toLowerCase()}>
              <td><strong>{l.nome}</strong></td>
              <td>{l.email}</td>
              <td>{l.telefone || "—"}</td>
              <td>{l.nome_loja || "—"}</td>
              <td>{l.plano || "—"}</td>
              <td><span class={`badge ${badgeSt[l.etapa]}`}>{l.etapa?.replace(/_/g," ")}</span></td>
              <td>{fmtDate(l.created_at)}</td>
              <td style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
                <select class="filter-select" style="padding:3px 8px;font-size:0.8rem" onchange={`patchLead('${l.id}', this.value)`}>
                  {["novo","contato_feito","proposta_enviada","negociando","perdido"].map(s => <option value={s} selected={s===l.etapa}>{s.replace(/_/g," ")}</option>)}
                </select>
                <button class="btn btn-success btn-sm" data-action="converter" data-id={l.id} data-nome={l.nome}>✔ Converter</button>
                <button class="btn btn-danger btn-sm" data-action="excluir" data-id={l.id} data-nome={l.nome}>🗑</button>
              </td>
            </tr>
          )) : <tr><td colspan="8" style="text-align:center;color:#999;padding:32px">Nenhum pré-cadastro encontrado</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <script>
    function filtrar(s) {
      const url = new URL(window.location.href);
      if (s) url.searchParams.set("etapa", s); else url.searchParams.delete("etapa");
      window.location.href = url.toString();
    }
    function buscar(q) {
      document.querySelectorAll("#tabela tbody tr[data-search]").forEach(r => {
        r.style.display = r.dataset.search.includes(q.toLowerCase()) ? "" : "none";
      });
    }
    document.addEventListener("click", async (e) => {
      const btn = (e.target as Element).closest<HTMLElement>("[data-action]");
      if (!btn) return;
      const { action, id, nome } = btn.dataset as { action: string; id: string; nome: string };

      if (action === "excluir") {
        if (!confirm(`Excluir permanentemente "${nome}"? Esta ação não pode ser desfeita.`)) return;
        const res = await fetch(`/api/admin/leads/${id}`, { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ action: "delete" }) });
        if (res.ok) window.location.reload();
        else { const d = await res.json().catch(() => ({ error: `HTTP ${res.status}` })); alert("Erro: " + d.error); }
      }

      if (action === "converter") {
        if (!confirm(`Converter "${nome}" em cliente? Um cadastro será criado automaticamente.`)) return;
        btn.textContent = "…";
        (btn as HTMLButtonElement).disabled = true;
        const res = await fetch(`/api/admin/leads/${id}/converter`, { method: "POST", headers: { "content-type": "application/json" }, body: "{}" });
        if (res.ok) {
          const d = await res.json();
          alert(`✔ Cliente criado!\nCódigo: ${d.cliente.codigo}\nSenha inicial: ${d.senha_inicial}\n\nGuarde a senha antes de fechar.`);
          window.location.reload();
        } else {
          const d = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
          alert("Erro: " + d.error);
          btn.textContent = "✔ Converter";
          (btn as HTMLButtonElement).disabled = false;
        }
      }
    });
    async function patchLead(id, etapa) {
      await fetch(`/api/admin/leads/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ etapa }) });
    }
  </script>
</Admin>
