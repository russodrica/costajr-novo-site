---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }
---
<Admin title="Recrutamento & Seleção" current="recrutamento">
  <div class="toolbar">
    <span class="toolbar-title">🧲 Recrutamento & Seleção</span>
    <select class="filter-select" id="filtroVaga" onchange="carregarKanban()"><option value="">Todas as vagas</option></select>
    <button class="btn btn-outline" onclick="abrirVaga()">+ Nova vaga</button>
    <button class="btn btn-primary" onclick="abrirCandidato()">+ Novo candidato</button>
  </div>

  <div id="vagasBox" style="margin-bottom:16px"></div>

  <div id="kanban" style="overflow-x:auto;padding-bottom:8px">
    <div class="loading"><div class="spinner"></div> Carregando…</div>
  </div>

  <!-- Modal vaga -->
  <div class="modal-overlay" id="modalVaga">
    <div class="modal" style="max-width:560px">
      <div class="modal-title" id="tituloVaga">Nova vaga</div>
      <div id="msgVaga"></div>
      <form id="formVaga">
        <input type="hidden" name="id" />
        <div class="form-row">
          <div class="form-group"><label>Título da vaga *</label><input name="titulo" required /></div>
          <div class="form-group"><label>Data (abertura)</label><input name="data_abertura" type="date" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Demanda</label>
            <select name="demanda"><option value="">—</option><option>Nova</option><option>Reposição</option><option>Aumento de quadro</option></select>
          </div>
          <div class="form-group"><label>Área</label><input name="setor" placeholder="Ex.: Operação" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Data prevista p/ início</label><input name="data_prevista" type="date" /></div>
          <div class="form-group"><label>Perfil desejado</label>
            <select name="perfil_desejado"><option value="">—</option><option>Colaborativo</option><option>Competitivo</option><option>Analítico</option><option>Executor</option><option>Comunicador</option><option>Planejador</option></select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Habilitação</label>
            <select name="habilitacao"><option value="">—</option><option>Indiferente</option><option>Obrigatória</option></select>
          </div>
          <div class="form-group"><label>Trabalho</label>
            <select name="modo_trabalho"><option value="">—</option><option>Presencial</option><option>Remoto</option><option>Híbrido</option></select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Tipo de contratação</label>
            <select name="tipo_contratacao"><option value="">—</option><option>CLT</option><option>PJ</option><option>CLT, PJ</option><option>Estágio</option><option>Temporário</option></select>
          </div>
          <div class="form-group"><label>Status</label>
            <select name="status"><option value="aberta">Aberta</option><option value="em_andamento">Em andamento</option><option value="preenchida">Preenchida</option><option value="cancelada">Cancelada</option></select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Cargo</label><input name="cargo" /></div>
          <div class="form-group"><label>Demandante</label><input name="demandante" /></div>
          <div class="form-group"><label>Qtd.</label><input name="quantidade" type="number" min="1" value="1" /></div>
        </div>
        <div class="form-group"><label>Descrição</label><textarea name="descricao"></textarea></div>
        <div class="modal-actions"><button type="button" class="btn btn-secondary" onclick="fecharModal('modalVaga')">Cancelar</button><button type="submit" class="btn btn-primary">Salvar</button></div>
      </form>
    </div>
  </div>

  <!-- Modal candidato -->
  <div class="modal-overlay" id="modalCand">
    <div class="modal" style="max-width:560px">
      <div class="modal-title" id="tituloCand">Novo candidato</div>
      <div id="msgCand"></div>
      <form id="formCand">
        <input type="hidden" name="id" />
        <div class="form-group"><label>Nome *</label><input name="nome" required /></div>
        <div class="form-row">
          <div class="form-group"><label>E-mail</label><input name="email" type="email" /></div>
          <div class="form-group"><label>Telefone</label><input name="telefone" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Vaga</label><select name="vaga_id" id="candVaga"><option value="">—</option></select></div>
          <div class="form-group"><label>Origem</label><input name="origem" placeholder="Indicação, Gupy…" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Data de nascimento</label><input name="data_nascimento" type="date" /></div>
          <div class="form-group"><label>Tempo de experiência na área</label><input name="experiencia" placeholder="Ex.: Acima de 5 anos" /></div>
        </div>
        <div class="form-group"><label>Formação</label><input name="formacao" placeholder="Ex.: Superior completo — Engenharia/Arquitetura" /></div>
        <div class="form-group"><label>Conhecimento tecnológico</label><input name="conhecimento_tecnologico" placeholder="Ex.: Excel, Word, SketchUp, AutoCAD" /></div>
        <div class="form-row">
          <div class="form-group"><label>Possui habilitação</label><select name="possui_habilitacao"><option value="">—</option><option value="true">Sim</option><option value="false">Não</option></select></div>
          <div class="form-group"><label>Possui veículo</label><select name="possui_veiculo"><option value="">—</option><option value="true">Sim</option><option value="false">Não</option></select></div>
          <div class="form-group"><label>Disp. imediata</label><select name="disp_imediata"><option value="">—</option><option value="true">Sim</option><option value="false">Não</option></select></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Disp. de viagem</label><select name="disp_viagem"><option value="">—</option><option value="true">Sim</option><option value="false">Não</option></select></div>
          <div class="form-group"><label>Disp. presencial</label><select name="disp_presencial"><option value="">—</option><option value="true">Sim</option><option value="false">Não</option></select></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Como classifica a personalidade</label><input name="personalidade" placeholder="Ex.: Colaborativo" /></div>
          <div class="form-group"><label>Possui alguma restrição?</label><input name="restricao" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Teste DISC</label>
            <select name="teste_disc"><option value="">—</option><option>Dominância (D)</option><option>Influência (I)</option><option>Estabilidade (S)</option><option>Conformidade (C)</option></select>
          </div>
          <div class="form-group"><label>Teste Eneagrama</label>
            <select name="teste_eneagrama"><option value="">—</option><option>Tipo 1 — Perfeccionista</option><option>Tipo 2 — Prestativo</option><option>Tipo 3 — Realizador</option><option>Tipo 4 — Individualista</option><option>Tipo 5 — Investigador</option><option>Tipo 6 — Questionador</option><option>Tipo 7 — Entusiasta</option><option>Tipo 8 — Desafiador</option><option>Tipo 9 — Pacificador</option></select>
          </div>
        </div>
        <div class="form-group"><label>Currículo / documentos (link)</label><input name="curriculo_url" type="url" placeholder="https://… (OneDrive/Drive)" /></div>
        <div class="form-group" id="candCurriculoBox" style="display:none">
          <label>Currículo (arquivo — guardado em cofre privado)</label>
          <div id="candCurriculoStatus" style="font-size:13px;color:#6B7280;margin-bottom:6px"></div>
          <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
            <input type="file" id="candCurriculoFile" accept=".pdf,.doc,.docx,image/*" style="font-size:13px" />
            <button type="button" class="btn btn-outline btn-sm" onclick="enviarCurriculo()">📎 Anexar</button>
          </div>
          <p style="font-size:11.5px;color:#9CA3AF;margin-top:4px">PDF, DOC/DOCX ou imagem · até 10 MB. Salve o candidato primeiro para anexar.</p>
        </div>
        <div class="form-group"><label>Etapa</label>
          <select name="etapa" id="candEtapa"></select>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Entrevista comportamental</label><input name="entrevista_comportamental_em" type="date" /></div>
          <div class="form-group"><label>Entrevista técnica</label><input name="entrevista_tecnica_em" type="date" /></div>
        </div>
        <div class="form-group"><label>Resultado do teste</label><input name="teste_resultado" /></div>
        <div class="form-group"><label>Feedback / Observações</label><textarea name="observacoes"></textarea></div>
        <div class="modal-actions"><button type="button" class="btn btn-secondary" onclick="fecharModal('modalCand')">Cancelar</button><button type="submit" class="btn btn-primary">Salvar</button></div>
      </form>
    </div>
  </div>

  <script is:inline>
    const ETAPAS = [
      { k: "triagem", t: "Triagem", c: "#6B7280" },
      { k: "teste", t: "Teste (PB)", c: "#7C3AED" },
      { k: "entrevista_comportamental", t: "Entrev. Comportamental", c: "#2563EB" },
      { k: "entrevista_tecnica", t: "Entrev. Técnica", c: "#0891B2" },
      { k: "proposta", t: "Proposta", c: "#D97706" },
      { k: "admissao", t: "Admissão", c: "#C026D3" },
      { k: "contratado", t: "Contratado", c: "#16A34A" },
      { k: "reprovado", t: "Reprovado", c: "#B91C1C" },
    ];
    const ETAPA_T = Object.fromEntries(ETAPAS.map(e => [e.k, e]));
    let VAGAS = [], CAND = [];
    const esc = s => String(s ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
    const br = d => d ? String(d).slice(0,10).split("-").reverse().join("/") : "—";
    function fecharModal(id){ document.getElementById(id).classList.remove("open"); }

    async function carregarVagas() {
      const r = await fetch("/api/admin/rh/vagas", { headers: { "content-type": "application/json" } });
      VAGAS = await r.json();
      const stLabel = { aberta:"Aberta", em_andamento:"Em andamento", preenchida:"Preenchida", cancelada:"Cancelada" };
      const stBadge = { aberta:"badge-green", em_andamento:"badge-blue", preenchida:"badge-gray", cancelada:"badge-red" };
      document.getElementById("vagasBox").innerHTML = VAGAS.length
        ? `<div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(230px,1fr))">${VAGAS.map(v => `
          <div class="card" style="padding:12px 14px">
            <div style="display:flex;justify-content:space-between;gap:6px"><strong style="font-size:14px">💼 ${esc(v.titulo)}</strong><span class="badge ${stBadge[v.status]||"badge-gray"}">${stLabel[v.status]||v.status}</span></div>
            <div style="font-size:12.5px;color:#6B7280;margin-top:3px">👤 ${esc(v.perfil_desejado||v.cargo||"—")}${v.setor?" · "+esc(v.setor):""}${v.tipo_contratacao?" · "+esc(v.tipo_contratacao):""}</div>
            <div style="font-size:12px;color:#6B7280;margin-top:6px;background:#F8F9FB;border-radius:6px;padding:5px 8px">
              📅 <strong>Data:</strong> ${br(v.data_abertura)} &nbsp; ⏱ <strong>Prevista:</strong> ${br(v.data_prevista)}</div>
            <div style="font-size:12px;color:#9CA3AF;margin-top:5px">${v.candidatos.ativos} candidato(s) no funil</div>
            <div style="margin-top:8px;display:flex;gap:6px"><button class="btn btn-outline btn-sm" onclick="editarVaga('${v.id}')">Editar</button><button class="btn btn-danger btn-sm" onclick="excluirVaga('${v.id}','${esc(v.titulo).replace(/'/g,'')}')">🗑</button></div>
          </div>`).join("")}</div>`
        : '<div class="card" style="text-align:center;color:#6B7280;padding:18px">Nenhuma vaga. Clique em <strong>+ Nova vaga</strong>.</div>';
      const sel = document.getElementById("filtroVaga"), cs = document.getElementById("candVaga");
      const opts = `<option value="">—</option>` + VAGAS.map(v => `<option value="${v.id}">${esc(v.titulo)}</option>`).join("");
      cs.innerHTML = opts;
      sel.innerHTML = `<option value="">Todas as vagas</option>` + VAGAS.map(v => `<option value="${v.id}">${esc(v.titulo)}</option>`).join("");
      document.getElementById("candEtapa").innerHTML = ETAPAS.map(e => `<option value="${e.k}">${e.t}</option>`).join("");
    }

    async function carregarKanban() {
      const vaga = document.getElementById("filtroVaga").value;
      const r = await fetch("/api/admin/rh/candidatos" + (vaga ? `?vaga_id=${vaga}` : ""), { headers: { "content-type": "application/json" } });
      CAND = await r.json();
      const box = document.getElementById("kanban");
      box.innerHTML = `<div style="display:flex;gap:12px;min-width:max-content">${ETAPAS.map(e => {
        const itens = CAND.filter(c => c.etapa === e.k);
        return `<div style="min-width:210px;width:210px;flex-shrink:0">
          <div style="font-size:12.5px;font-weight:800;color:${e.c};text-transform:uppercase;letter-spacing:.03em;margin-bottom:8px;display:flex;justify-content:space-between">${e.t}<span style="background:#F3F4F6;border-radius:99px;padding:0 8px;color:#6B7280">${itens.length}</span></div>
          ${itens.map(c => cardCand(c)).join("") || '<div style="font-size:12px;color:#C4C7CE;text-align:center;padding:10px;border:1px dashed #E5E7EB;border-radius:8px">vazio</div>'}
        </div>`;
      }).join("")}</div>`;
    }
    function cardCand(c) {
      const idx = ETAPAS.findIndex(e => e.k === c.etapa);
      const podeContratar = ["proposta", "admissao"].includes(c.etapa);
      const final = ["contratado", "reprovado"].includes(c.etapa);
      return `<div class="card" style="padding:9px 11px;margin-bottom:8px">
        <strong style="font-size:13.5px">${esc(c.nome)}</strong>
        <div style="font-size:11.5px;color:#9CA3AF;margin:2px 0 6px">${esc(c.rh_vagas?.titulo || "sem vaga")}${c.email ? " · " + esc(c.email) : ""}</div>
        <div style="display:flex;flex-wrap:wrap;gap:4px">
          ${!final && idx > 0 ? `<button class="btn btn-outline btn-sm" title="Voltar etapa" onclick="moverCand('${c.id}',-1)">◀</button>` : ""}
          ${!final && idx < 5 ? `<button class="btn btn-outline btn-sm" title="Avançar etapa" onclick="moverCand('${c.id}',1)">▶</button>` : ""}
          ${podeContratar ? `<button class="btn btn-success btn-sm" title="Contratar" onclick="contratar('${c.id}','${esc(c.nome).replace(/'/g,'')}')">✓ Contratar</button>` : ""}
          ${!final ? `<button class="btn btn-danger btn-sm" title="Reprovar" onclick="reprovar('${c.id}')">✕</button>` : ""}
          <button class="btn btn-secondary btn-sm" onclick="editarCand('${c.id}')">✎</button>
        </div>
      </div>`;
    }
    async function moverCand(id, dir) {
      const c = CAND.find(x => x.id === id); if (!c) return;
      const idx = ETAPAS.findIndex(e => e.k === c.etapa); const nova = ETAPAS[idx + dir]; if (!nova) return;
      await patchCand(id, { etapa: nova.k });
    }
    async function reprovar(id) {
      const motivo = prompt("Motivo da reprovação (opcional):") || "";
      await patchCand(id, { etapa: "reprovado", motivo_reprovacao: motivo });
    }
    async function contratar(id, nome) {
      if (!confirm(`Contratar "${nome}"? Será criado o colaborador (você completa a ficha, EPI e documentos em seguida).`)) return;
      const res = await fetch(`/api/admin/rh/candidatos/${id}/contratar`, { method: "POST", headers: { "content-type": "application/json" }, body: "{}" });
      const d = await res.json().catch(() => ({}));
      if (res.ok) { alert("Colaborador criado! Abra o RH → Colaboradores para completar a ficha, EPIs e documentos."); carregarVagas(); carregarKanban(); }
      else alert("Erro: " + (d.error || res.status));
    }
    async function patchCand(id, patch) {
      const res = await fetch(`/api/admin/rh/candidatos/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify(patch) });
      if (res.ok) carregarKanban(); else { const d = await res.json().catch(()=>({})); alert("Erro: " + (d.error || res.status)); }
    }

    function abrirVaga() { const f = document.getElementById("formVaga"); f.reset(); f.elements.id.value = ""; document.getElementById("tituloVaga").textContent = "Nova vaga"; document.getElementById("msgVaga").innerHTML=""; document.getElementById("modalVaga").classList.add("open"); }
    function editarVaga(id) { const v = VAGAS.find(x=>x.id===id); if(!v) return; const f=document.getElementById("formVaga"); f.reset(); for(const k of ["id","titulo","cargo","setor","demandante","quantidade","descricao","status","data_abertura","data_prevista","demanda","perfil_desejado","habilitacao","modo_trabalho","tipo_contratacao"]) if(f.elements[k]) f.elements[k].value = (v[k]===null||v[k]===undefined)?"":String(v[k]).slice(0, k.startsWith("data")?10:200); document.getElementById("tituloVaga").textContent="Editar vaga"; document.getElementById("msgVaga").innerHTML=""; document.getElementById("modalVaga").classList.add("open"); }
    async function excluirVaga(id, t) { if(!confirm(`Excluir a vaga "${t}"? (vai para a Lixeira 30 dias)`)) return; const r=await fetch(`/api/admin/rh/vagas/${id}`,{method:"DELETE",headers:{"content-type":"application/json"}}); if(r.ok){carregarVagas();carregarKanban();} else alert("Erro ao excluir."); }
    document.getElementById("formVaga").addEventListener("submit", async e => {
      e.preventDefault(); const fd=new FormData(e.target); const body=Object.fromEntries(fd.entries()); const id=body.id; delete body.id;
      const res=await fetch(id?`/api/admin/rh/vagas/${id}`:"/api/admin/rh/vagas",{method:id?"PATCH":"POST",headers:{"content-type":"application/json"},body:JSON.stringify(body)});
      const d=await res.json().catch(()=>({}));
      if(res.ok){fecharModal("modalVaga");carregarVagas();} else document.getElementById("msgVaga").innerHTML=`<div class="alert alert-error">${d.error||"Erro"}</div>`;
    });

    let _candId = "";
    function renderCurriculoStatus(c) {
      const box = document.getElementById("candCurriculoStatus");
      if (c && c.curriculo_path) {
        box.innerHTML = `✅ <strong>${esc(c.curriculo_nome || "currículo")}</strong> anexado · `
          + `<a href="#" onclick="verCurriculo();return false" style="color:var(--brand);font-weight:600">Ver</a> · `
          + `<a href="#" onclick="removerCurriculo();return false" style="color:#B91C1C">Remover</a>`;
      } else { box.innerHTML = "Nenhum arquivo anexado."; }
    }
    function abrirCandidato() { _candId=""; const f=document.getElementById("formCand"); f.reset(); f.elements.id.value=""; document.getElementById("candCurriculoBox").style.display="none"; document.getElementById("tituloCand").textContent="Novo candidato"; document.getElementById("msgCand").innerHTML=""; document.getElementById("modalCand").classList.add("open"); }
    function editarCand(id) { const c=CAND.find(x=>x.id===id); if(!c) return; _candId=id; const f=document.getElementById("formCand"); f.reset(); const campos=["id","nome","email","telefone","vaga_id","origem","etapa","entrevista_comportamental_em","entrevista_tecnica_em","teste_resultado","observacoes","data_nascimento","experiencia","formacao","conhecimento_tecnologico","possui_habilitacao","possui_veiculo","disp_imediata","disp_viagem","disp_presencial","personalidade","restricao","teste_disc","teste_eneagrama","curriculo_url"]; for(const k of campos){ if(!f.elements[k]) continue; const v=c[k]; f.elements[k].value = (v===null||v===undefined)?"":String(v); } document.getElementById("candCurriculoBox").style.display=""; document.getElementById("candCurriculoFile").value=""; renderCurriculoStatus(c); document.getElementById("tituloCand").textContent="Editar candidato"; document.getElementById("msgCand").innerHTML=""; document.getElementById("modalCand").classList.add("open"); }
    async function enviarCurriculo() {
      if(!_candId){ alert("Salve o candidato primeiro para anexar o currículo."); return; }
      const inp=document.getElementById("candCurriculoFile"); const file=inp.files&&inp.files[0];
      if(!file){ alert("Escolha um arquivo."); return; }
      document.getElementById("candCurriculoStatus").innerHTML="⏳ Enviando…";
      const fd=new FormData(); fd.append("arquivo", file);
      const res=await fetch(`/api/admin/rh/candidatos/${_candId}/curriculo`,{method:"POST",body:fd});
      const d=await res.json().catch(()=>({}));
      if(res.ok){ const i=CAND.findIndex(x=>x.id===_candId); if(i>=0) CAND[i]=d.data||d; inp.value=""; renderCurriculoStatus(d.data||d); }
      else { document.getElementById("candCurriculoStatus").innerHTML=`<span style="color:#B91C1C">${d.error||"Erro ao enviar"}</span>`; }
    }
    async function verCurriculo() {
      const res=await fetch(`/api/admin/rh/candidatos/${_candId}/curriculo`,{headers:{"content-type":"application/json"}});
      const d=await res.json().catch(()=>({})); if(res.ok&&d.url) window.open(d.url,"_blank"); else alert(d.error||"Erro");
    }
    async function removerCurriculo() {
      if(!confirm("Remover o currículo anexado?")) return;
      const res=await fetch(`/api/admin/rh/candidatos/${_candId}/curriculo`,{method:"DELETE",headers:{"content-type":"application/json"}});
      if(res.ok){ const i=CAND.findIndex(x=>x.id===_candId); if(i>=0){ CAND[i].curriculo_path=null; CAND[i].curriculo_nome=null; } renderCurriculoStatus(CAND[i]); }
    }
    document.getElementById("formCand").addEventListener("submit", async e => {
      e.preventDefault(); const fd=new FormData(e.target); const body=Object.fromEntries(fd.entries()); const id=body.id; delete body.id;
      const res=await fetch(id?`/api/admin/rh/candidatos/${id}`:"/api/admin/rh/candidatos",{method:id?"PATCH":"POST",headers:{"content-type":"application/json"},body:JSON.stringify(body)});
      const d=await res.json().catch(()=>({}));
      if(res.ok){fecharModal("modalCand");carregarKanban();} else document.getElementById("msgCand").innerHTML=`<div class="alert alert-error">${d.error||"Erro"}</div>`;
    });

    (async () => { await carregarVagas(); await carregarKanban(); })();
  </script>
</Admin>
