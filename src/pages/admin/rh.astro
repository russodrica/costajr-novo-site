    // ── Documentos ──
    function abrirModalDoc() {
      const form = document.getElementById("formDoc") as any;
      form.reset();
      (document.getElementById("docId") as any).value = "";
      (document.getElementById("docValidade") as HTMLInputElement).disabled = false;
      (document.getElementById("tituloModalDoc") as any).textContent = "Novo documento";
      (document.getElementById("msgDoc") as any).innerHTML = "";
      document.getElementById("modalDoc")?.classList.add("open");
    }

    function editarDoc(id: string) {
      const d = docPorId[id];
      if (!d) { alert("Documento não encontrado nos dados carregados. Recarregue a página."); return; }
      const form = document.getElementById("formDoc") as any;
      form.reset();
      (document.getElementById("docId") as any).value = id;
      for (const campo of ["colaborador_id", "titulo", "tipo", "url", "validade", "observacoes"]) {
        if (form.elements[campo]) form.elements[campo].value = d[campo] ?? "";
      }
      const na = document.getElementById("docValidadeNA") as HTMLInputElement;
      na.checked = !!d.validade_na;
      (document.getElementById("docValidade") as HTMLInputElement).disabled = !!d.validade_na;
      (document.getElementById("tituloModalDoc") as any).textContent = "Editar documento";
      (document.getElementById("msgDoc") as any).innerHTML = "";
      document.getElementById("modalDoc")?.classList.add("open");
    }

    async function excluirDoc(id: string, titulo: string) {
      if (!confirm(`Excluir o documento "${titulo}"?\n\nEssa ação não pode ser desfeita.`)) return;
      const res = await fetch(`/api/admin/rh/documentos/${id}`, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) window.location.reload();
      else { const d = await res.json().catch(() => ({} as any)); alert("Erro ao excluir: " + (d.error || `HTTP ${res.status}`)); }
    }

    document.getElementById("formDoc")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as any);
      const body: Record<string, any> = Object.fromEntries(fd.entries());
      body.validade_na = body.validade_na === "on";       // checkbox → boolean
      if (body.validade_na) body.validade = "";            // N/A: sem data (vira null no servidor)
      const id = body.id;
      delete body.id;
      const msg = document.getElementById("msgDoc") as any;
      const res = await fetch(id ? `/api/admin/rh/documentos/${id}` : "/api/admin/rh/documentos", {
        method: id ? "PATCH" : "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
      });
      if (res.ok) window.location.reload();
      else { const d = await res.json().catch(() => ({} as any)); msg.innerHTML = `<div class="alert alert-error">${d.error || "Erro ao salvar"}</div>`; }
    });

    // ── Admissão digital ──
    function abrirModalAdmissao() {
      const form = document.getElementById("formAdmissao") as any;
      form.reset();
      form.style.display = "";
      (document.getElementById("boxLinkAdmissao") as any).style.display = "none";
      (document.getElementById("msgAdmissao") as any).innerHTML = "";
      document.getElementById("modalAdmissao")?.classList.add("open");
    }

    async function copiarTexto(texto: string) {
      try { await navigator.clipboard.writeText(texto); return true; }
      catch {
        // fallback p/ contextos sem clipboard API
        const ta = document.createElement("textarea");
        ta.value = texto; document.body.appendChild(ta); ta.select();
        try { document.execCommand("copy"); return true; } catch { return false; }
        finally { document.body.removeChild(ta); }
      }
    }

    async function copiarLinkAdmissao(token: string, botao?: any) {
      const link = `${window.location.origin}/admissao/${token}`;
      const ok = await copiarTexto(link);
      if (botao) {
        const original = botao.textContent;
        botao.textContent = ok ? "✓ Copiado!" : "Erro ao copiar";
        setTimeout(() => { botao.textContent = original; }, 1800);
      }
      if (!ok) prompt("Copie o link manualmente:", link);
    }

    async function copiarInputLink(botao: any) {
      const input = document.getElementById("inputLinkAdmissao") as any;
      const ok = await copiarTexto(input.value);
      botao.textContent = ok ? "✓ Copiado!" : "Erro — copie manualmente";
      setTimeout(() => { botao.textContent = "📋 Copiar link"; }, 1800);
    }

    document.getElementById("formAdmissao")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as any);
      const body = Object.fromEntries(fd.entries());
      const msg = document.getElementById("msgAdmissao") as any;
      const res = await fetch("/api/admin/rh/admissoes", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
      });
      const d = await res.json().catch(() => ({} as any));
      if (res.ok) {
        (e.target as any).style.display = "none";
        msg.innerHTML = "";
        (document.getElementById("inputLinkAdmissao") as any).value = `${window.location.origin}/admissao/${d.token}`;
        (document.getElementById("boxLinkAdmissao") as any).style.display = "";
      } else {
        msg.innerHTML = `<div class="alert alert-error">${d.error || "Erro ao criar admissão"}</div>`;
      }
    });

    function verDocsAdmissao(id: string) {
      const a = admPorId[id];
      if (!a) { alert("Admissão não encontrada nos dados carregados. Recarregue a página."); return; }
      (document.getElementById("tituloDocsAdmissao") as any).textContent = `Documentos de ${a.nome}`;
      const docs = a.rh_admissoes_docs || [];
      const esc = (s: string) => String(s || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
      (document.getElementById("listaDocsAdmissao") as any).innerHTML = docs.length
        ? `<ul class="lista-docs-adm">` + docs.map((doc: any) => {
            const data = doc.created_at ? new Date(doc.created_at).toLocaleString("pt-BR") : "";
            return `<li>
              <a href="/api/admin/rh/admissoes/${a.id}/docs/${doc.id}/arquivo" target="_blank" rel="noopener" title="Abre via link seguro temporário (10 min)">📎 ${esc(tiposDocAdm[doc.tipo] || doc.tipo)}</a>
              <span class="sub-info">${esc(doc.nome_arquivo || "")}${data ? " · " + data : ""}</span>
            </li>`;
          }).join("") + `</ul>`
        : `<div class="empty-state"><strong>Nenhum documento enviado ainda</strong></div>`;
      document.getElementById("modalDocsAdmissao")?.classList.add("open");
    }

    async function concluirAdmissao(id: string, nome: string) {
      if (!confirm(`Concluir a admissão de "${nome}"?\n\nIsso vai:\n• Criar o colaborador no RH (status Ativo, admissão hoje)\n• Mover os documentos enviados para a ficha do colaborador\n• Encerrar o link público de admissão`)) return;
      const res = await fetch(`/api/admin/rh/admissoes/${id}`, {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ acao: "concluir" }),
      });
      if (res.ok) window.location.reload();
      else { const d = await res.json().catch(() => ({} as any)); alert("Erro ao concluir: " + (d.error || `HTTP ${res.status}`)); }
    }

    async function cancelarAdmissao(id: string, nome: string) {
      if (!confirm(`Cancelar a admissão de "${nome}"?\n\nO link público deixará de aceitar envios.`)) return;
      const res = await fetch(`/api/admin/rh/admissoes/${id}`, {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ acao: "cancelar" }),
      });
      if (res.ok) window.location.reload();
      else { const d = await res.json().catch(() => ({} as any)); alert("Erro ao cancelar: " + (d.error || `HTTP ${res.status}`)); }
    }

    (window as any).mostrarAba = mostrarAba;
    (window as any).fecharModal = fecharModal;
    (window as any).filtrarColabs = filtrarColabs;
    (window as any).abrirModalColab = abrirModalColab;
    (window as any).editarColab = editarColab;
    (window as any).desligarColab = desligarColab;
    (window as any).abrirModalAusencia = abrirModalAusencia;
    (window as any).mudarStatusAusencia = mudarStatusAusencia;
    (window as any).abrirModalDoc = abrirModalDoc;
    (window as any).editarDoc = editarDoc;
    (window as any).excluirDoc = excluirDoc;
    (window as any).abrirModalAdmissao = abrirModalAdmissao;
    (window as any).copiarLinkAdmissao = copiarLinkAdmissao;
    (window as any).copiarInputLink = copiarInputLink;
    (window as any).verDocsAdmissao = verDocsAdmissao;
    (window as any).concluirAdmissao = concluirAdmissao;
    (window as any).cancelarAdmissao = cancelarAdmissao;
  </script>

  <style>
    .sub-info { font-size: 0.75rem; color: #9CA3AF; margin-top: 2px; }
