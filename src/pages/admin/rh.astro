      <div id="boxLinkAdmissao" style="display:none">
        <div class="alert" style="background:#F0FDF4;border:1px solid #BBF7D0;color:#166534;border-radius:8px;padding:12px;margin-bottom:12px">
          ✅ Admissão criada! Envie o link abaixo ao candidato (WhatsApp ou e-mail) — ele abre no celular, confere os contatos e fotografa os documentos.
        </div>
        <div class="form-group"><label>Link público de admissão</label><input id="inputLinkAdmissao" readonly onclick="this.select()" /></div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="window.location.reload()">Fechar</button>
          <button type="button" class="btn btn-primary" onclick="copiarInputLink(this)">📋 Copiar link</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ════════ MODAL DOCUMENTOS DA ADMISSÃO ════════ -->
  <div class="modal-overlay" id="modalDocsAdmissao">
    <div class="modal">
      <div class="modal-title" id="tituloDocsAdmissao">Documentos enviados</div>
      <div id="listaDocsAdmissao"></div>
      <div class="modal-actions">
        <button type="button" class="btn btn-secondary" onclick="fecharModal('modalDocsAdmissao')">Fechar</button>
      </div>
    </div>
  </div>

  <!-- Dados para os scripts client-side -->
  <script type="application/json" id="dadosRH" set:html={JSON.stringify({ colaboradores, documentos, admissoes, tiposDocAdm })}></script>

  <script>
    const DADOS = JSON.parse((document.getElementById("dadosRH") as any)?.textContent || "{}");
    const colabPorId: Record<string, any> = {};
    for (const c of DADOS.colaboradores || []) colabPorId[c.id] = c;
    const docPorId: Record<string, any> = {};
    for (const d of DADOS.documentos || []) docPorId[d.id] = d;
    const admPorId: Record<string, any> = {};
    for (const a of DADOS.admissoes || []) admPorId[a.id] = a;
    const tiposDocAdm: Record<string, string> = DADOS.tiposDocAdm || {};

    // ── Abas ──
    function mostrarAba(aba: string) {
      document.querySelectorAll(".tab-section").forEach((s) => { (s as any).style.display = "none"; });
      const sec = document.getElementById("aba-" + aba);
      if (sec) sec.style.display = "";
      document.querySelectorAll(".pill[data-aba]").forEach((p) => p.classList.toggle("active", (p as any).dataset.aba === aba));
      if (aba === "alertas" && !(window as any).__alertasCarregados) carregarAlertas();
      if (aba === "ferias" && !(window as any).__feriasCarregados) carregarFerias();
    }
    // abre a aba indicada por ?aba= (links de e-mail)
    (function () {
      const a = new URLSearchParams(location.search).get("aba");
      if (a && document.getElementById("aba-" + a)) setTimeout(() => mostrarAba(a), 0);
    })();

    // ── Férias (programação CLT) ──
    let feriasDados: any[] = [];
    let feriasModalPer: any = null;
    async function carregarFerias() {
      (window as any).__feriasCarregados = true;
      try {
        const res = await fetch("/api/admin/rh/ferias");
        if (!res.ok) { document.getElementById("ferias-conteudo")!.innerHTML = '<div class="card"><div class="alert alert-error">Erro ao carregar.</div></div>'; return; }
        feriasDados = await res.json();
        renderFerias();
      } catch { document.getElementById("ferias-conteudo")!.innerHTML = '<div class="card"><div class="alert alert-error">Erro de conexão.</div></div>'; }
    }
    function statusFerias(p: any) {
      if (p.status === "vencido") return { txt: "Vencido", cor: "#B91C1C", fundo: "#FEE2E2" };
      if (p.resumo.completo) return { txt: `Programado (${p.resumo.somaProgramada}/${p.dias_direito})`, cor: "#166534", fundo: "#DCFCE7" };
      return { txt: `Falta programar (${p.resumo.somaProgramada}/${p.dias_direito})`, cor: "#B91C1C", fundo: "#FEE2E2" };
    }
    function renderFerias() {
      const filtro = (document.getElementById("feriasFiltro") as HTMLSelectElement).value;
      const total = feriasDados.length;
      const programados = feriasDados.filter((p) => p.resumo.completo && p.status !== "vencido").length;
      const faltando = feriasDados.filter((p) => !p.resumo.completo && p.status !== "vencido").length;
      const vencidos = feriasDados.filter((p) => p.status === "vencido").length;
      document.getElementById("feriasBadge")!.textContent = String(faltando + vencidos || "");
      document.getElementById("ferias-cards")!.innerHTML = `
        <div class="stat-card" style="border-left:3px solid #6B7280"><div class="stat-value">${total}</div><div class="stat-label">Períodos CLT/PJ</div></div>
        <div class="stat-card" style="border-left:3px solid #16A34A"><div class="stat-value" style="color:#16A34A">${programados}</div><div class="stat-label">Programados</div></div>
        <div class="stat-card" style="border-left:3px solid #DC2626"><div class="stat-value" style="color:#DC2626">${faltando}</div><div class="stat-label">Falta programar</div></div>
        <div class="stat-card" style="border-left:3px solid #B91C1C"><div class="stat-value" style="color:#B91C1C">${vencidos}</div><div class="stat-label">Vencidos</div></div>`;

      let lista = feriasDados.slice();
      if (filtro === "pendentes") lista = lista.filter((p) => !p.resumo.completo || p.status === "vencido");
      else if (filtro === "programado") lista = lista.filter((p) => p.resumo.completo);
      lista.sort((a, b) => (a.limite_concessivo < b.limite_concessivo ? -1 : 1));

      const box = document.getElementById("ferias-conteudo")!;
      if (!feriasDados.length) { box.innerHTML = '<div class="card" style="text-align:center;padding:30px"><p style="color:#6B7280">Nenhum período de férias ainda. Clique em <strong>⚙️ Gerar períodos</strong> para criar a partir das admissões dos CLT/PJ ativos.</p></div>'; return; }
      if (!lista.length) { box.innerHTML = '<div class="card" style="text-align:center;padding:24px;color:#6B7280">Nada neste filtro. ✅</div>'; return; }

      box.innerHTML = lista.map((p) => {
        const st = statusFerias(p);
        const parcelasHtml = (p.parcelas || []).length
          ? p.parcelas.map((pc: any) => {
              const conf = pc.status === "confirmada";
              return `<span style="display:inline-flex;align-items:center;gap:5px;background:${conf ? "#DCFCE7" : "#EFF6FF"};border:1px solid ${conf ? "#BBF7D0" : "#BFDBFE"};border-radius:6px;padding:3px 8px;font-size:12px;margin:2px 4px 2px 0">
                  <strong>${pc.dias}d</strong> ${brData(pc.data_inicio)}→${brData(pc.data_fim)} ${conf ? "✅" : "⏳"}
                  ${conf ? "" : `<button type="button" title="Confirmar (dar OK)" style="background:none;border:none;cursor:pointer;color:#166534;font-size:13px;padding:0" onclick="confirmarParcela('${pc.id}')">✔</button>
                  <button type="button" title="Remover" style="background:none;border:none;cursor:pointer;color:#DC2626;font-size:12px;padding:0" onclick="removerParcela('${pc.id}')">✕</button>`}
                </span>`;
            }).join("")
          : '<span style="font-size:12px;color:#B91C1C">Nenhuma parcela programada</span>';
        return `<div class="card" style="margin-bottom:10px;padding:12px 14px">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap">
            <div>
              <strong style="font-size:14.5px">${escD(p.colaborador)}</strong>
              <span style="background:${st.fundo};color:${st.cor};border-radius:20px;padding:2px 10px;font-size:11.5px;font-weight:700;margin-left:8px">${st.txt}</span>
              <div style="font-size:12px;color:#6B7280;margin-top:3px">Aquisitivo ${brData(p.inicio_aquisitivo)}–${brData(p.fim_aquisitivo)} · vencimento p/ tirar até <strong>${brData(p.limite_concessivo)}</strong></div>
            </div>
            <button class="btn btn-outline btn-sm" onclick="programarFerias('${p.id}')">📅 Programar</button>
          </div>
          <div style="margin-top:8px">${parcelasHtml}</div>
        </div>`;
      }).join("");
    }

    function programarFerias(periodoId: string) {
      const p = feriasDados.find((x) => x.id === periodoId);
      if (!p) return;
      feriasModalPer = p;
      (document.getElementById("msgFerias") as any).innerHTML = "";
      const confirmadas = (p.parcelas || []).filter((x: any) => x.status === "confirmada");
      const programadas = (p.parcelas || []).filter((x: any) => x.status !== "confirmada");
      const jaConf = confirmadas.reduce((s: number, x: any) => s + x.dias, 0);
      document.getElementById("tituloModalFerias")!.textContent = `Programar férias — ${p.colaborador}`;
      document.getElementById("feriasResumoTopo")!.innerHTML = `Direito: <strong>${p.dias_direito} dias</strong>${jaConf ? ` · já confirmados: <strong>${jaConf}</strong>` : ""} · até <strong>3 parcelas</strong> (mín. 5 dias cada). ${confirmadas.length ? `<br><span style="color:#166534">${confirmadas.map((c: any) => `✅ ${c.dias}d ${brData(c.data_inicio)}`).join(" · ")}</span>` : ""}`;
      const edit = document.getElementById("feriasParcelasEdit")!;
      edit.innerHTML = "";
      if (programadas.length) programadas.forEach((x: any) => addLinhaParcela(x.data_inicio, x.dias));
      else addLinhaParcela("", 10);
      document.getElementById("modalFerias")!.classList.add("open");
    }
    function addLinhaParcela(dataInicio = "", dias: number | string = 10) {
      const edit = document.getElementById("feriasParcelasEdit")!;
      if (edit.querySelectorAll(".parcela-linha").length >= 3) return;
      const div = document.createElement("div");
      div.className = "parcela-linha";
      div.style.cssText = "display:flex;gap:8px;align-items:center;margin-bottom:8px";
      div.innerHTML = `
        <input type="date" class="pl-inicio" value="${dataInicio}" style="flex:1;padding:7px 9px;border:1px solid #E5E7EB;border-radius:8px" />
        <input type="number" class="pl-dias" value="${dias}" min="5" max="30" style="width:80px;padding:7px 9px;border:1px solid #E5E7EB;border-radius:8px" /> <span style="font-size:12px;color:#6B7280">dias</span>
        <button type="button" title="Remover linha" style="background:none;border:none;color:#DC2626;cursor:pointer;font-size:16px" onclick="this.parentElement.remove()">✕</button>`;
      edit.appendChild(div);
    }
    async function salvarParcelas() {
      if (!feriasModalPer) return;
      const linhas = Array.from(document.querySelectorAll("#feriasParcelasEdit .parcela-linha"));
      const parcelas = linhas.map((l) => ({
        data_inicio: (l.querySelector(".pl-inicio") as HTMLInputElement).value,
        dias: parseInt((l.querySelector(".pl-dias") as HTMLInputElement).value, 10),
      })).filter((p) => p.data_inicio && p.dias);
      const msg = document.getElementById("msgFerias") as any;
      const res = await fetch(`/api/admin/rh/ferias/${feriasModalPer.id}/parcelas`, {
        method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ parcelas }),
      });
      const d = await res.json().catch(() => ({}));
      if (res.ok) { fecharModal("modalFerias"); carregarFerias(); }
      else msg.innerHTML = `<div class="alert alert-error">${d.error || "Erro ao salvar"}</div>`;
    }
    async function confirmarParcela(id: string) {
      if (!confirm("Confirmar que estas férias foram gozadas? Ao completar 30 dias confirmados, o período vai para o histórico e o próximo é liberado.")) return;
      const res = await fetch(`/api/admin/rh/ferias/parcela/${id}`, { method: "POST", headers: { "content-type": "application/json" } });
      if (res.ok) carregarFerias(); else alert("Erro ao confirmar.");
    }
    async function removerParcela(id: string) {
      if (!confirm("Remover esta parcela programada?")) return;
      const res = await fetch(`/api/admin/rh/ferias/parcela/${id}`, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) carregarFerias(); else { const d = await res.json().catch(() => ({} as any)); alert("Erro: " + (d.error || res.status)); }
    }
    async function semearFerias() {
      if (!confirm("Gerar o período de férias atual para cada CLT/PJ ativo (a partir da data de admissão)? Não duplica períodos já existentes.")) return;
      const btn = document.getElementById("btnSemearFerias") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Gerando…";
      const res = await fetch("/api/admin/rh/ferias", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ seed: true }) });
      const d = await res.json().catch(() => ({}));
      btn.disabled = false; btn.textContent = "⚙️ Gerar períodos";
      if (res.ok) { alert(`Períodos criados: ${d.criados || 0}. Já existiam: ${d.ja_existiam || 0}. Sem admissão (pulados): ${d.sem_admissao || 0}.`); carregarFerias(); }
      else alert("Erro: " + (d.error || res.status));
    }
    (window as any).renderFerias = renderFerias;
    (window as any).programarFerias = programarFerias;
    (window as any).addLinhaParcela = addLinhaParcela;
    (window as any).salvarParcelas = salvarParcelas;
    (window as any).confirmarParcela = confirmarParcela;
    (window as any).removerParcela = removerParcela;
    (window as any).semearFerias = semearFerias;

    // ── Alertas de RH (vencimentos + compliance) ──
    const escA = (s: any) => String(s ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    function diasTxt(d: number) { return d < 0 ? `vencido há ${Math.abs(d)} dia(s)` : d === 0 ? "vence HOJE" : `vence em ${d} dia(s)`; }
    function corDoc(d: any) { return d.dias < 0 ? "#B91C1C" : d.dias <= 7 ? "#DC2626" : d.dias <= 30 ? "#D97706" : "#6B7280"; }

    async function carregarAlertas() {
      (window as any).__alertasCarregados = true;
      const box = document.getElementById("alertas-conteudo")!;
      const cards = document.getElementById("alertas-cards")!;
      try {
        const res = await fetch("/api/admin/rh/alertas");
        if (!res.ok) { box.innerHTML = '<div class="card"><div class="alert alert-error">Erro ao carregar alertas.</div></div>'; return; }
        const d = await res.json();
        const r = d.resumo || {};
        cards.innerHTML = `
          <div class="stat-card" style="border-left:3px solid #B91C1C"><div class="stat-value" style="color:#B91C1C">${r.vencidos || 0}</div><div class="stat-label">Documentos vencidos</div></div>
          <div class="stat-card" style="border-left:3px solid #DC2626"><div class="stat-value" style="color:#DC2626">${r.criticos_vencidos || 0}</div><div class="stat-label">Críticos vencidos (ASO/CNH)</div></div>
          <div class="stat-card" style="border-left:3px solid #D97706"><div class="stat-value" style="color:#D97706">${r.vencendo_30 || 0}</div><div class="stat-label">Vencendo em 30 dias</div></div>
          <div class="stat-card" style="border-left:3px solid #C41E3A"><div class="stat-value" style="color:#C41E3A">${r.sem_aso || 0}</div><div class="stat-label">Ativos sem ASO</div></div>`;
        const temVenc = (r.vencidos || r.vencendo_30);
        document.getElementById("btnExportVenc")!.style.display = temVenc ? "" : "none";
        document.getElementById("btnEmailVenc")!.style.display = temVenc ? "" : "none";

        const tabelaDocs = (titulo: string, lista: any[], vazio: string) => {
          if (!lista.length) return `<div class="card" style="margin-bottom:14px"><div class="section-title" style="margin-bottom:8px">${titulo}</div><p style="color:var(--ink-light);font-size:13px">${vazio}</p></div>`;
          return `<div class="card" style="margin-bottom:14px">
            <div class="section-title" style="margin-bottom:10px">${titulo} (${lista.length})</div>
            <div class="table-wrap"><table><thead><tr><th>Documento</th><th>Colaborador</th><th>Validade</th><th>Situação</th></tr></thead><tbody>
            ${lista.map(x => `<tr>
              <td>${x.critico ? "🔴 " : ""}<strong>${escA(x.titulo)}</strong> <span style="font-size:11px;color:#9CA3AF">${escA(x.tipo)}</span></td>
              <td>${escA(x.colaborador)}</td>
              <td>${x.validade.split("-").reverse().join("/")}</td>
              <td style="color:${corDoc(x)};font-weight:700">${diasTxt(x.dias)}</td>
            </tr>`).join("")}
            </tbody></table></div></div>`;
        };

        let html = tabelaDocs("⛔ Documentos VENCIDOS", d.vencidos || [], "Nenhum documento vencido. 🎉");
        html += tabelaDocs("⏳ Vencendo (próximos 60 dias)", d.vencendo || [], "Nada vencendo nos próximos 60 dias.");
        if ((d.sem_aso || []).length) {
          html += `<div class="card" style="margin-bottom:14px">
            <div class="section-title" style="margin-bottom:10px">🦺 Colaboradores ativos SEM ASO (${d.sem_aso.length})</div>
            <p style="font-size:12.5px;color:var(--ink-light);margin:0 0 10px">Sem ASO válido, o colaborador não pode trabalhar no canteiro.</p>
            <div class="table-wrap"><table><thead><tr><th>Nome</th><th>Cargo</th><th>Setor</th></tr></thead><tbody>
            ${d.sem_aso.map((c: any) => `<tr><td><strong>${escA(c.nome)}</strong></td><td>${escA(c.cargo) || "—"}</td><td>${escA(c.setor) || "—"}</td></tr>`).join("")}
            </tbody></table></div></div>`;
        }
        if ((d.ausencias_periodo || []).length) {
          html += `<div class="card">
            <div class="section-title" style="margin-bottom:10px">🏖️ Ausências/férias em andamento ou próximas (${d.ausencias_periodo.length})</div>
            <div class="table-wrap"><table><thead><tr><th>Colaborador</th><th>Tipo</th><th>Início</th><th>Fim</th><th>Status</th></tr></thead><tbody>
            ${d.ausencias_periodo.map((a: any) => `<tr><td><strong>${escA(a.colaborador)}</strong></td><td>${escA(a.tipo)}</td><td>${a.data_inicio.split("-").reverse().join("/")}</td><td>${a.data_fim.split("-").reverse().join("/")}</td><td>${escA(a.status)}</td></tr>`).join("")}
            </tbody></table></div></div>`;
        }
        box.innerHTML = html;
      } catch {
        box.innerHTML = '<div class="card"><div class="alert alert-error">Erro de conexão ao carregar alertas.</div></div>';
      }
    }

    async function enviarResumoEmail() {
      if (!confirm("Enviar o resumo de documentos vencidos/vencendo por e-mail para o RH e administradores?")) return;
      const btn = document.getElementById("btnEmailVenc") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Enviando...";
      try {
        const res = await fetch("/api/cron/rh-vencimentos");
        const d = await res.json().catch(() => ({}));
        if (res.ok) alert(`Resumo enviado para ${d.enviados || 0} destinatário(s).${d.aviso ? " (" + d.aviso + ")" : ""}`);
        else alert("Erro ao enviar o resumo.");
      } finally { btn.disabled = false; btn.textContent = "📧 Enviar resumo por e-mail"; }
    }
    (window as any).enviarResumoEmail = enviarResumoEmail;

    // ── Export / Import de colaboradores ──
    function exportarColabs() {
      const p = new URLSearchParams();
      const st = (document.getElementById("filtroStatusColab") as HTMLSelectElement)?.value;
      if (st && st !== "todos") p.set("status", st);
      window.location.href = "/api/admin/rh/colaboradores/export?" + p.toString();
    }
    let csvColabCache = "";
    function renderImpColab(d: any, dry: boolean) {
      const el = document.getElementById("impColabResultado")!;
      const erros = d.erros || [];
      el.innerHTML = `
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin:8px 0 12px">
          <span style="padding:6px 12px;border-radius:8px;font-size:13px;font-weight:700;background:#ECFDF5;color:#047857">➕ Criar: ${d.criar ?? d.criados ?? 0}</span>
          <span style="padding:6px 12px;border-radius:8px;font-size:13px;font-weight:700;background:#EFF6FF;color:#1D4ED8">✏️ Atualizar: ${d.atualizar ?? d.atualizados ?? 0}</span>
          <span style="padding:6px 12px;border-radius:8px;font-size:13px;font-weight:700;background:${erros.length ? "#FEF2F2" : "#F3F4F6"};color:${erros.length ? "#B91C1C" : "#6B7280"}">⚠️ Erros: ${erros.length}</span>
        </div>
        ${erros.length ? `<div style="max-height:150px;overflow-y:auto;background:#FEF2F2;border:1px solid #FECACA;border-radius:8px;padding:8px 12px;font-size:12.5px">${erros.map((e: any) => `<div style="color:#991B1B">Linha ${e.linha}: ${e.motivo}</div>`).join("")}</div>` : ""}
        ${dry ? '<p style="font-size:12.5px;color:var(--ink-light);margin-top:10px">Revise e clique em <strong>Confirmar</strong>. Linhas com erro são puladas.</p>' : '<p style="font-size:13px;color:#047857;font-weight:700;margin-top:10px">✓ Importação concluída!</p>'}`;
    }
    async function analisarImportColab() {
      const f = (document.getElementById("impColabFile") as HTMLInputElement).files?.[0];
      if (!f) { alert("Selecione um arquivo CSV."); return; }
      csvColabCache = await f.text();
      const btn = document.getElementById("btnAnalisarColab") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Analisando...";
      try {
        const res = await fetch("/api/admin/rh/colaboradores/import", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ csv: csvColabCache, confirmar: false }) });
        const d = await res.json();
        if (!res.ok) { document.getElementById("impColabResultado")!.innerHTML = `<div class="alert alert-error">${d.error || "Erro"}</div>`; return; }
        renderImpColab(d, true);
        (document.getElementById("btnConfirmarImportColab") as HTMLElement).style.display = (d.criar || d.atualizar) ? "" : "none";
      } finally { btn.disabled = false; btn.textContent = "Analisar"; }
    }
    async function confirmarImportColab() {
      if (!csvColabCache) return;
      const btn = document.getElementById("btnConfirmarImportColab") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Importando...";
      try {
        const res = await fetch("/api/admin/rh/colaboradores/import", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ csv: csvColabCache, confirmar: true }) });
        const d = await res.json();
        if (!res.ok) { document.getElementById("impColabResultado")!.innerHTML = `<div class="alert alert-error">${d.error || "Erro"}</div>`; return; }
        renderImpColab(d, false);
        setTimeout(() => window.location.reload(), 1500);
      } finally { btn.disabled = false; btn.textContent = "Confirmar importação"; }
    }
    (window as any).exportarColabs = exportarColabs;
    (window as any).analisarImportColab = analisarImportColab;
    (window as any).confirmarImportColab = confirmarImportColab;

    // badge da aba (carrega só o resumo no load da página)
    fetch("/api/admin/rh/alertas").then(r => r.ok ? r.json() : null).then(d => {
      if (!d) return;
      const total = (d.resumo?.vencidos || 0) + (d.resumo?.vencendo_30 || 0) + (d.resumo?.sem_aso || 0);
      const b = document.getElementById("alertasBadge");
      if (b && total) b.textContent = String(total);
    }).catch(() => {});

    // ── Modais ──
    function fecharModal(id: string) { document.getElementById(id)?.classList.remove("open"); }

    // ── Colaboradores: busca + filtro client-side ──
    function toggleBloco(key: string) {
      const body = document.getElementById("bloco-body-" + key);
      const seta = document.querySelector(`.bloco-colab[data-bloco="${key}"] .bloco-seta`) as any;
      if (!body) return;
      const aberto = body.style.display !== "none";
      body.style.display = aberto ? "none" : "";
      if (seta) seta.dataset.aberto = String(!aberto);
    }
    (window as any).toggleBloco = toggleBloco;

    function aplicarFiltroBlocos(rootSel: string, busca: string, status: string) {
      const buscando = !!busca || (status && status !== "todos");
      document.querySelectorAll(`${rootSel} .bloco-colab`).forEach((bloco) => {
        let visiveis = 0;
        bloco.querySelectorAll("tr.colab-row").forEach((tr) => {
          const el = tr as any;
          const okStatus = !status || status === "todos" || el.dataset.status === status;
          const okBusca = !busca || (el.dataset.busca || "").includes(busca);
          const mostra = okStatus && okBusca;
          el.style.display = mostra ? "" : "none";
          if (mostra) visiveis++;
        });
        const semRes = bloco.querySelector(".bloco-sem-res") as any;
        if (semRes) semRes.style.display = (buscando && visiveis === 0) ? "" : "none";
        const body = bloco.querySelector(".bloco-body") as any;
        const seta = bloco.querySelector(".bloco-seta") as any;
        if (buscando) {
          (bloco as any).style.display = visiveis ? "" : "none";
          if (body && visiveis) { body.style.display = ""; if (seta) seta.dataset.aberto = "true"; }
        } else {
          (bloco as any).style.display = "";
        }
      });
    }
    function filtrarColabs() {
      const busca = ((document.getElementById("buscaColab") as any)?.value || "").toLowerCase().trim();
      const status = (document.getElementById("filtroStatusColab") as any)?.value || "todos";
      aplicarFiltroBlocos("#aba-colaboradores", busca, status);
    }
    function filtrarInativos() {
      const busca = ((document.getElementById("buscaInativos") as any)?.value || "").toLowerCase().trim();
      aplicarFiltroBlocos("#aba-inativos", busca, "todos");
    }
    (window as any).filtrarInativos = filtrarInativos;

    // ── Colaboradores: novo / editar / desligar ──
    const camposColab = ["nome","email","telefone","telefone_pessoal","cpf","rg","data_nascimento","cargo","setor","regime","salario","data_admissao","status","endereco","cidade","uf","contato_emergencia_nome","contato_emergencia_telefone","pix","banco","agencia","conta","observacoes"];

    function fichaTab(qual: string) {
      const panes: Record<string, string> = { dados: "fichaPaneDados", docs: "fichaPaneDocs", epi: "fichaPaneEpi" };
      for (const [k, id] of Object.entries(panes)) { const el = document.getElementById(id); if (el) (el as any).style.display = (k === qual ? "" : "none"); }
      document.querySelectorAll(".ficha-tab").forEach((t) => t.classList.toggle("active", (t as any).dataset.ft === qual));
      if (qual === "epi" && (window as any).__fichaColabId) carregarEpi((window as any).__fichaColabId);
    }
    (window as any).fichaTab = fichaTab;

    function abrirModalColab() {
      const form = document.getElementById("formColab") as any;
      form.reset();
      (document.getElementById("colabId") as any).value = "";
      (document.getElementById("tituloModalColab") as any).textContent = "Novo colaborador";
      (document.getElementById("msgColab") as any).innerHTML = "";
      (document.getElementById("fichaTabs") as any).style.display = "none"; // sem aba de docs ao criar
      (document.getElementById("fichaAcessoWrap") as any).style.display = "none";
      fichaTab("dados");
      document.getElementById("modalColab")?.classList.add("open");
    }

    function editarColab(id: string) {
      const c = colabPorId[id];
      if (!c) { alert("Colaborador não encontrado nos dados carregados. Recarregue a página."); return; }
      const form = document.getElementById("formColab") as any;
      form.reset();
      (document.getElementById("colabId") as any).value = id;
      for (const campo of camposColab) {
        if (form.elements[campo]) form.elements[campo].value = c[campo] ?? "";
      }
      (document.getElementById("tituloModalColab") as any).textContent = "Editar colaborador";
      (document.getElementById("msgColab") as any).innerHTML = "";
      (document.getElementById("fichaTabs") as any).style.display = "flex";
      (document.getElementById("fichaAcessoWrap") as any).style.display = "";
      fichaTab("dados"); // sempre abre em Dados gerais
      carregarFicha(id, c.nome || "");
      document.getElementById("modalColab")?.classList.add("open");
    }

    // ── Ficha do colaborador: acesso ao portal + documentos (busca tudo via API) ──
    const hojeStr = new Date().toISOString().slice(0, 10);
    const em30Str = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);
    const escD = (s: any) => String(s ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    const tiposDocMap: Record<string, string> = { contrato: "Contrato", aso: "ASO", ficha_epi: "Ficha EPI", advertencia: "Advertência", atestado: "Atestado", certificado: "Certificado", cnh: "CNH", outro: "Documento" };
    const perfisMap: Record<string, string> = { admin: "Administrador", coordenador: "Coordenador", financeiro: "Financeiro", comercial: "Comercial", rh: "RH / DP", operacional: "Operacional" };

    // ── Slots fixos de anexo (espelham as colunas do Monday) ──
    const normD = (s: string) => String(s || "").normalize("NFD").replace(/[̀-ͯ]/g, "").toLowerCase().replace(/\s+/g, " ").trim();
    const brData = (iso: string) => (iso ? iso.split("-").reverse().join("/") : "");
    const SLOTS_DOC = [
      { key: "contrato", label: "Contrato / Termo", tipo: "contrato", prefixo: "Contrato/Termo", validade: false },
      { key: "rg_hab", label: "RG / Habilitação", tipo: "cnh", prefixo: "RG/Habilitação", validade: false },
      { key: "ficha_registro", label: "Ficha de Registro", tipo: "outro", prefixo: "Ficha de Registro", validade: false },
      { key: "teste", label: "Teste de Personalidade", tipo: "outro", prefixo: "Teste de Personalidade", validade: false },
      { key: "aso", label: "ASO", tipo: "aso", prefixo: "ASO", validade: true },
      { key: "ficha_epi", label: "Ficha de EPI", tipo: "ficha_epi", prefixo: "Ficha EPI", validade: true },
      { key: "os", label: "Ordem de Serviço", tipo: "outro", prefixo: "Ordem de Serviço", validade: false },
      { key: "nr35", label: "NR-35 · Altura", tipo: "certificado", prefixo: "NR35", validade: true },
      { key: "nr10", label: "NR-10 · Eletricidade", tipo: "certificado", prefixo: "NR10", validade: true },
      { key: "nr06", label: "NR-06 · EPI", tipo: "certificado", prefixo: "NR06", validade: true },
      { key: "nr01", label: "NR-01 · GRO", tipo: "certificado", prefixo: "NR01", validade: true },
      { key: "advertencia", label: "Advertência", tipo: "advertencia", prefixo: "Advertência", validade: false },
      { key: "suspensao", label: "Suspensão", tipo: "outro", prefixo: "Suspensão", validade: false },
    ];
    const SLOT_LABEL: Record<string, string> = Object.fromEntries(SLOTS_DOC.map((s) => [s.key, s.label]));
    const SLOT_DEF: Record<string, any> = Object.fromEntries(SLOTS_DOC.map((s) => [s.key, s]));
    // Grupos da ficha (ordem como no Monday): pessoais · técnicos · treinamentos (NRs em ordem)
    const SLOT_GRUPOS = [
      { titulo: "🪪 Documentos pessoais", keys: ["contrato", "rg_hab", "ficha_registro", "teste"] },
      { titulo: "🛠️ Documentos técnicos", keys: ["aso", "ficha_epi", "os"] },
      { titulo: "🦺 Treinamentos (NRs)", keys: ["nr01", "nr06", "nr10", "nr35"] },
      { titulo: "⚠️ Disciplinares", keys: ["advertencia", "suspensao"] },
    ];
    function slotDoDoc(doc: any): string {
      const t = doc.titulo || "";
      const idx = t.indexOf(" — ");
      const np = normD(idx >= 0 ? t.slice(0, idx) : t);
      if (np.includes("contrato") || np.includes("termo")) return "contrato";
      if (np.startsWith("rg") || np.includes("habilita")) return "rg_hab";
      if (np.includes("registro")) return "ficha_registro";
      if (np.includes("personalidade") || np.startsWith("teste")) return "teste";
      if (np.startsWith("aso")) return "aso";
      if (np.includes("epi")) return "ficha_epi";
      if (np.includes("nr35") || np.includes("nr 35")) return "nr35";
      if (np.includes("nr10") || np.includes("nr 10")) return "nr10";
      if (np.includes("nr06") || np.includes("nr 06") || np.includes("nr 6")) return "nr06";
      if (np.includes("nr01") || np.includes("nr 01") || np.includes("nr 1")) return "nr01";
      if (np.includes("ordem") || np === "os") return "os";
      if (np.includes("suspens")) return "suspensao";
      if (np.includes("advert")) return "advertencia";
      const porTipo: Record<string, string> = { contrato: "contrato", aso: "aso", ficha_epi: "ficha_epi", cnh: "rg_hab", advertencia: "advertencia" };
      return porTipo[doc.tipo] || "outros";
    }
    function nomeCurtoDoc(titulo: string): string {
      const idx = titulo.indexOf(" — ");
      return escD(idx >= 0 ? titulo.slice(idx + 3) : titulo);
    }

    async function carregarFicha(colabId: string, nome: string) {
      (window as any).__fichaColabId = colabId;
      (window as any).__fichaColabNome = nome;
      (window as any).__epiCarregadoDe = null; // força recarregar EPIs ao trocar de ficha
      const wrap = document.getElementById("fichaDocsLista")!;
      const acessoBox = document.getElementById("fichaAcessoLista")!;
      wrap.innerHTML = '<div class="loading"><div class="spinner"></div> Carregando documentos...</div>';
      acessoBox.innerHTML = '<div class="loading"><div class="spinner"></div></div>';
      (document.getElementById("btnAnexarDocFicha") as any).onclick = () => abrirModalDocPara(colabId, nome);
      try {
        const res = await fetch(`/api/admin/rh/colaboradores/${colabId}`);
        if (!res.ok) { wrap.innerHTML = '<p style="color:#999;font-size:13px">Erro ao carregar.</p>'; return; }
        const d = await res.json();
        renderAcesso(colabId, nome, d.membro, d.colaborador?.email);
        const docs = d.documentos || [];
        docs.forEach((doc: any) => { docPorId[doc.id] = doc; }); // p/ o ✏️ editar funcionar na ficha
        const nomeJs = escD(nome).replace(/['"]/g, "");
        // agrupa docs por slot
        const porSlot: Record<string, any[]> = {};
        const outros: any[] = [];
        for (const doc of docs) {
          const slot = slotDoDoc(doc);
          if (slot === "outros") { outros.push(doc); continue; }
          (porSlot[slot] = porSlot[slot] || []).push(doc);
        }
        const slotsPreenchidos = SLOTS_DOC.filter((s) => (porSlot[s.key] || []).length).length;
        const cnt = `(${slotsPreenchidos}/${SLOTS_DOC.length})`;
        document.getElementById("fichaDocsCount")!.textContent = cnt;
        const tabCnt = document.getElementById("fichaTabDocsCount"); if (tabCnt) tabCnt.textContent = cnt;

        // badge de vencimento bem claro
        const badgeVenc = (doc: any, slotValidade: boolean) => {
          if (doc.validade) {
            const venc = doc.validade < hojeStr;
            const vencendo = !venc && doc.validade <= em30Str;
            const cor = venc ? "#991B1B" : vencendo ? "#92400E" : "#166534";
            const fundo = venc ? "#FEE2E2" : vencendo ? "#FEF3C7" : "#DCFCE7";
            const txt = venc ? `⚠ Vencido ${brData(doc.validade)}` : `Vence ${brData(doc.validade)}`;
            return `<span style="background:${fundo};color:${cor};font-weight:700;font-size:12px;padding:3px 10px;border-radius:6px;white-space:nowrap">${txt}</span>`;
          }
          if (doc.validade_na) return `<span style="background:#F3F4F6;color:#6B7280;font-size:12px;padding:3px 10px;border-radius:6px;white-space:nowrap">Sem vencimento</span>`;
          if (slotValidade) return `<span style="background:#FEF3C7;color:#92400E;font-size:12px;padding:3px 10px;border-radius:6px;white-space:nowrap" title="Edite (✏️) para informar o vencimento ou marcar Não aplicável">⚠ Definir vencimento</span>`;
          return "";
        };
        // uma linha de documento (coluna única)
        const docItem = (doc: any, slotValidade: boolean) => {
          const temArq = doc.storage_path || doc.url;
          const link = temArq
            ? `<a href="/api/admin/rh/documentos/${doc.id}/arquivo" target="_blank" rel="noopener" title="Abrir (link seguro temporário)">📎 ${nomeCurtoDoc(doc.titulo)}</a>`
            : nomeCurtoDoc(doc.titulo);
          return `<div style="display:flex;align-items:center;gap:10px;padding:3px 0">
            <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:13.5px">${link}</span>
            ${badgeVenc(doc, slotValidade)}
            <button type="button" title="Editar (vencimento / não aplicável)" style="background:none;border:none;color:#2563EB;cursor:pointer;font-size:14px;flex-shrink:0" onclick="editarDoc('${doc.id}')">✏️</button>
            <button type="button" title="Excluir (vai para a Lixeira por 30 dias)" style="background:none;border:none;color:#DC2626;cursor:pointer;font-size:15px;flex-shrink:0" onclick="excluirDocFicha('${doc.id}','${colabId}','${nomeJs}')">🗑️</button>
          </div>`;
        };

        let html = "";
        for (const g of SLOT_GRUPOS) {
          html += `<div style="margin-bottom:16px">
            <div style="font-size:12.5px;font-weight:800;color:#6B7280;text-transform:uppercase;letter-spacing:.04em;margin-bottom:7px">${g.titulo}</div>`;
          for (const key of g.keys) {
            const s = SLOT_DEF[key]; if (!s) continue;
            const lista = porSlot[key] || [];
            const preenchido = lista.length > 0;
            html += `<div style="display:flex;align-items:flex-start;gap:12px;border:1px solid #ECEFF3;border-left:3px solid ${preenchido ? "#16A34A" : "#E5E7EB"};border-radius:8px;padding:10px 12px;margin-bottom:7px;background:#fff">
              <div style="width:160px;flex-shrink:0;font-size:13.5px;font-weight:700;color:#374151">${s.label}${s.validade ? '<span style="font-size:10px;color:#9CA3AF;font-weight:600;display:block;margin-top:1px">com vencimento</span>' : ""}</div>
              <div style="flex:1;min-width:0">${preenchido
                ? lista.map((doc: any) => docItem(doc, s.validade)).join("")
                : '<div style="font-size:13px;color:#B91C1C;font-weight:600;padding:3px 0">○ Não anexado</div>'}</div>
              <button type="button" title="Anexar ${s.label}" class="btn btn-secondary btn-sm" style="flex-shrink:0" onclick="abrirModalDocPara('${colabId}','${nomeJs}','${s.prefixo}','${s.tipo}')">+ Anexar</button>
            </div>`;
          }
          html += "</div>";
        }
        if (outros.length) {
          html += `<div style="margin-bottom:8px"><div style="font-size:12.5px;font-weight:800;color:#6B7280;text-transform:uppercase;letter-spacing:.04em;margin-bottom:7px">Outros documentos</div>
            <div style="border:1px solid #ECEFF3;border-radius:8px;padding:10px 12px;background:#fff">${outros.map((doc: any) => docItem(doc, false)).join("")}</div></div>`;
        }
        wrap.innerHTML = html;
      } catch { wrap.innerHTML = '<p style="color:#999;font-size:13px">Erro de conexão.</p>'; }
    }
    function abrirModalDocPara(colabId: string, nome: string, prefixo?: string, tipoEnum?: string) {
      abrirModalDoc();
      const f = document.getElementById("formDoc") as HTMLFormElement;
      const sel = f.querySelector('select[name="colaborador_id"]') as HTMLSelectElement | null;
      if (sel) sel.value = colabId;
      if (tipoEnum) { const tp = f.querySelector('select[name="tipo"]') as HTMLSelectElement | null; if (tp) tp.value = tipoEnum; }
      if (prefixo) {
        const ti = f.querySelector('input[name="titulo"]') as HTMLInputElement | null;
        if (ti) { ti.value = prefixo + " — "; setTimeout(() => { ti.focus(); ti.setSelectionRange(ti.value.length, ti.value.length); }, 60); }
      }
    }
    async function excluirDocFicha(docId: string, colabId: string, nome: string) {
      if (!confirm("Excluir este documento?")) return;
      const res = await fetch(`/api/admin/rh/documentos/${docId}`, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) carregarFicha(colabId, nome); else alert("Erro ao excluir documento");
    }
    (window as any).excluirDocFicha = excluirDocFicha;

    // ── EPIs (Ficha de EPI gerada no sistema) ──
    const hojeIsoEpi = () => new Date().toISOString().slice(0, 10);
    async function carregarEpi(colabId: string) {
      if ((window as any).__epiCarregadoDe === colabId) return; // já carregado p/ esta ficha
      const box = document.getElementById("epiLista")!;
      box.innerHTML = '<div class="loading"><div class="spinner"></div> Carregando EPIs...</div>';
      try {
        const res = await fetch(`/api/admin/rh/epi?colaborador_id=${colabId}`);
        const d = await res.json();
        if (!res.ok) { box.innerHTML = '<div class="alert alert-error">Erro ao carregar EPIs.</div>'; return; }
        (window as any).__epiCarregadoDe = colabId;
        const hoje = hojeIsoEpi();
        const catalogo: string[] = d.catalogo || [];
        const linhaEpi = (it: any, custom: boolean) => {
          const venc = it.data_validade && it.data_validade < hoje;
          const vencendo = it.data_validade && !venc && it.data_validade <= em30Str;
          const corV = venc ? "#B91C1C" : vencendo ? "#D97706" : "#E5E7EB";
          const nomeCell = custom
            ? `<input class="epi-nome" value="${escD(it.epi || "")}" placeholder="Nome do EPI" style="width:100%;min-width:130px;padding:5px 7px;border:1px solid #E5E7EB;border-radius:6px;font-weight:600" />`
            : `<strong>${escD(it.epi)}</strong>`;
          const acao = custom
            ? `<button type="button" class="btn btn-danger btn-sm" title="Remover este EPI" onclick="removerLinhaEpi(this)">✕</button>`
            : `<button type="button" class="btn btn-outline btn-sm" title="Gerar ficha de reposição só deste item" onclick="gerarFichaEpi('reposicao','${escD(it.epi).replace(/'/g, "")}')">↻</button>`;
          return `<tr data-epi="${custom ? "" : escD(it.epi)}">
            <td>${nomeCell}</td>
            <td><input class="epi-ca" value="${escD(it.ca || "")}" placeholder="CA" style="width:80px;padding:5px 7px;border:1px solid #E5E7EB;border-radius:6px" /></td>
            <td><input class="epi-tam" value="${escD(it.tamanho || "")}" style="width:52px;padding:5px 7px;border:1px solid #E5E7EB;border-radius:6px" /></td>
            <td><input class="epi-ent" type="date" value="${it.data_entrega || hoje}" style="padding:5px 6px;border:1px solid #E5E7EB;border-radius:6px" /></td>
            <td><input class="epi-val" type="date" value="${it.data_validade || ""}" style="padding:5px 6px;border:2px solid ${corV};border-radius:6px" /></td>
            <td><input class="epi-dev" type="date" value="${it.data_devolucao || ""}" style="padding:5px 6px;border:1px solid #E5E7EB;border-radius:6px" /></td>
            <td>${acao}</td>
          </tr>`;
        };
        box.innerHTML = `<div class="table-wrap"><table style="font-size:13px">
          <thead><tr><th style="min-width:150px">EPI</th><th>CA</th><th>Tam.</th><th>Entrega</th><th>Vencimento</th><th>Devolução</th><th></th></tr></thead>
          <tbody id="epiTbody">${(d.itens || []).map((it: any) => linhaEpi(it, !catalogo.includes(it.epi))).join("")}</tbody></table></div>
          <button type="button" class="btn btn-outline btn-sm" style="margin-top:8px" onclick="addLinhaEpiCustom()">+ Adicionar EPI (fora da lista)</button>`;
        // histórico de fichas
        const fbox = document.getElementById("epiFichas")!;
        fbox.innerHTML = (d.fichas || []).length
          ? `<div class="section-title" style="font-size:13.5px;margin-bottom:6px">Fichas geradas</div>${d.fichas.map((f: any) => `
            <div style="display:flex;align-items:center;gap:8px;border:1px solid #ECEFF3;border-radius:8px;padding:8px 10px;margin-bottom:6px">
              <span style="flex:1;font-size:13px"><strong>${f.tipo === "reposicao" ? "Reposição" : "Completa"}</strong> · ${brData(f.data_geracao)} · ${(f.itens || []).length} item(ns)
                ${f.status === "assinada" ? '<span class="badge badge-green" style="margin-left:6px">assinada</span>' : '<span class="badge badge-yellow" style="margin-left:6px">aguarda assinatura</span>'}</span>
              <a class="btn btn-secondary btn-sm" href="/api/admin/rh/epi/fichas/${f.id}/pdf" target="_blank" rel="noopener">🖨️ PDF</a>
              ${f.status === "assinada"
                ? `<a class="btn btn-outline btn-sm" href="/api/admin/rh/epi/fichas/${f.id}/assinado" target="_blank" rel="noopener">📎 Assinado</a>`
                : `<label class="btn btn-outline btn-sm" style="cursor:pointer">📎 Anexar assinado<input type="file" accept="application/pdf,image/*" style="display:none" onchange="anexarAssinadoEpi('${f.id}', this)" /></label>`}
            </div>`).join("")}`
          : '<p style="font-size:12.5px;color:#9CA3AF">Nenhuma ficha gerada ainda.</p>';
      } catch { box.innerHTML = '<div class="alert alert-error">Erro de conexão.</div>'; }
    }
    function coletarEpi() {
      return Array.from(document.querySelectorAll("#epiTbody tr")).map((tr) => {
        const nomeInput = tr.querySelector(".epi-nome") as HTMLInputElement | null;
        const epi = (nomeInput ? nomeInput.value : (tr as any).dataset.epi || "").trim();
        return {
          epi,
          ca: (tr.querySelector(".epi-ca") as HTMLInputElement).value.trim() || null,
          tamanho: (tr.querySelector(".epi-tam") as HTMLInputElement).value.trim() || null,
          data_entrega: (tr.querySelector(".epi-ent") as HTMLInputElement).value || null,
          data_validade: (tr.querySelector(".epi-val") as HTMLInputElement).value || null,
          data_devolucao: (tr.querySelector(".epi-dev") as HTMLInputElement).value || null,
        };
      }).filter((r) => r.epi); // descarta linhas customizadas sem nome
    }
    function addLinhaEpiCustom() {
      const tb = document.getElementById("epiTbody"); if (!tb) return;
      const hoje = hojeIsoEpi();
      const tr = document.createElement("tr");
      tr.setAttribute("data-epi", "");
      const inp = "padding:5px 7px;border:1px solid #E5E7EB;border-radius:6px";
      tr.innerHTML = `
        <td><input class="epi-nome" placeholder="Nome do EPI" style="width:100%;min-width:130px;${inp};font-weight:600" /></td>
        <td><input class="epi-ca" placeholder="CA" style="width:80px;${inp}" /></td>
        <td><input class="epi-tam" style="width:52px;${inp}" /></td>
        <td><input class="epi-ent" type="date" value="${hoje}" style="${inp}" /></td>
        <td><input class="epi-val" type="date" style="${inp}" /></td>
        <td><input class="epi-dev" type="date" style="${inp}" /></td>
        <td><button type="button" class="btn btn-danger btn-sm" title="Remover este EPI" onclick="removerLinhaEpi(this)">✕</button></td>`;
      tb.appendChild(tr);
      (tr.querySelector(".epi-nome") as HTMLInputElement).focus();
    }
    function removerLinhaEpi(btn: HTMLElement) { btn.closest("tr")?.remove(); }
    (window as any).addLinhaEpiCustom = addLinhaEpiCustom;
    (window as any).removerLinhaEpi = removerLinhaEpi;
    async function salvarEpi() {
      const colabId = (window as any).__fichaColabId; if (!colabId) return;
      const msg = document.getElementById("epiMsg")!;
      const res = await fetch("/api/admin/rh/epi/entregas", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ colaborador_id: colabId, itens: coletarEpi() }) });
      const d = await res.json().catch(() => ({}));
      msg.innerHTML = res.ok ? '<div class="alert alert-success">EPIs salvos.</div>' : `<div class="alert alert-error">${d.error || "Erro ao salvar"}</div>`;
      setTimeout(() => { msg.innerHTML = ""; }, 5000);
      return res.ok;
    }
    async function gerarFichaEpi(tipo: string, epi?: string) {
      const colabId = (window as any).__fichaColabId; if (!colabId) return;
      const ok = await salvarEpi(); if (ok === false) return; // salva os campos antes de gerar
      const body: any = { colaborador_id: colabId, tipo };
      if (tipo === "reposicao") body.epis = [epi];
      const res = await fetch("/api/admin/rh/epi/gerar", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      const d = await res.json().catch(() => ({}));
      if (res.ok) { window.open(`/api/admin/rh/epi/fichas/${d.ficha_id}/pdf`, "_blank"); (window as any).__epiCarregadoDe = null; carregarEpi(colabId); }
      else { document.getElementById("epiMsg")!.innerHTML = `<div class="alert alert-error">${d.error || "Erro ao gerar"}</div>`; }
    }
    async function anexarAssinadoEpi(fichaId: string, input: HTMLInputElement) {
      const file = input.files?.[0]; if (!file) return;
      const fd = new FormData(); fd.append("arquivo", file);
      const res = await fetch(`/api/admin/rh/epi/fichas/${fichaId}/assinado`, { method: "POST", body: fd });
      const d = await res.json().catch(() => ({}));
      if (res.ok) { (window as any).__epiCarregadoDe = null; carregarEpi((window as any).__fichaColabId); }
      else alert("Erro ao anexar: " + (d.error || res.status));
    }
    (window as any).carregarEpi = carregarEpi;
    (window as any).salvarEpi = salvarEpi;
    (window as any).gerarFichaEpi = gerarFichaEpi;
    (window as any).anexarAssinadoEpi = anexarAssinadoEpi;

    // ── Acesso ao portal (vínculo RH ↔ Membros) ──
    function renderAcesso(colabId: string, nome: string, membro: any, email: string) {
      const box = document.getElementById("fichaAcessoLista")!;
      const opcoes = Object.entries(perfisMap).map(([v, l]) => `<option value="${v}">${l}</option>`).join("");
      if (membro) {
        const perfilAtual = (membro.roles && membro.roles.length ? membro.roles[0] : membro.role) || "operacional";
        box.innerHTML = `
          <div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:8px;padding:12px 14px">
            <div style="font-size:13.5px;color:#166534;margin-bottom:8px">✅ Tem acesso ao portal — <strong>${escD(membro.email)}</strong></div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
              <label style="font-size:12.5px;color:var(--ink-mid)">Perfil:</label>
              <select id="acessoPerfil" style="max-width:200px">${opcoes}</select>
              <button type="button" class="btn btn-primary btn-sm" onclick="salvarPerfilAcesso('${membro.id}','${colabId}','${escD(nome).replace(/'/g, "")}')">Salvar perfil</button>
              <button type="button" class="btn btn-outline btn-sm" onclick="removerAcesso('${colabId}','${escD(nome).replace(/'/g, "")}')">Remover acesso</button>
            </div>
          </div>`;
        const sel = document.getElementById("acessoPerfil") as HTMLSelectElement; if (sel) sel.value = perfilAtual;
      } else {
        const semEmail = !email;
        box.innerHTML = `
          <div style="background:#FFF8F0;border:1px solid #FED7AA;border-radius:8px;padding:12px 14px">
            <div style="font-size:13px;color:#9A3412;margin-bottom:8px">Este colaborador ainda não acessa o portal.${semEmail ? " <strong>Cadastre um e-mail primeiro</strong> (salve a ficha com o e-mail)." : ""}</div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
              <label style="font-size:12.5px;color:var(--ink-mid)">Perfil:</label>
              <select id="acessoPerfil" ${semEmail ? "disabled" : ""} style="max-width:200px">${opcoes}</select>
              <button type="button" class="btn btn-primary btn-sm" ${semEmail ? "disabled" : ""} onclick="darAcesso('${colabId}','${escD(nome).replace(/'/g, "")}')">🔑 Dar acesso ao portal</button>
            </div>
            <p style="font-size:11.5px;color:var(--ink-light);margin:8px 0 0">A senha é gerada e enviada por e-mail; o colaborador troca no primeiro acesso.</p>
          </div>`;
      }
    }
    async function darAcesso(colabId: string, nome: string) {
      const role = (document.getElementById("acessoPerfil") as HTMLSelectElement)?.value;
      if (!role) return;
      if (!confirm(`Dar acesso ao portal para "${nome}" com o perfil "${perfisMap[role]}"?\n\nUma senha temporária será enviada por e-mail.`)) return;
      const res = await fetch(`/api/admin/rh/colaboradores/${colabId}/acesso`, { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ role }) });
      const d = await res.json().catch(() => ({}));
      if (res.ok) {
        if (d.novo && d.email_enviado === false) alert(`Acesso criado! Não foi possível enviar o e-mail — senha temporária: ${d.senha_inicial}`);
        else if (d.novo) alert("Acesso criado e senha enviada por e-mail! ✅");
        else alert("Colaborador vinculado a um membro já existente. ✅");
        carregarFicha(colabId, nome);
      } else alert(d.error || "Erro ao dar acesso");
    }
    async function salvarPerfilAcesso(membroId: string, colabId: string, nome: string) {
      const role = (document.getElementById("acessoPerfil") as HTMLSelectElement)?.value;
      const res = await fetch(`/api/admin/membros/${membroId}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ role, roles: [role] }) });
      if (res.ok) { alert("Perfil atualizado! ✅"); carregarFicha(colabId, nome); } else alert("Erro ao atualizar perfil");
    }
    async function removerAcesso(colabId: string, nome: string) {
      if (!confirm("Remover o acesso ao portal deste colaborador? (o login deixa de funcionar pelo vínculo; o cadastro de membro não é apagado)")) return;
      const res = await fetch(`/api/admin/rh/colaboradores/${colabId}/acesso`, { method: "DELETE", headers: { "content-type": "application/json" } });
      if (res.ok) carregarFicha(colabId, nome); else alert("Erro ao remover acesso");
    }
    (window as any).darAcesso = darAcesso;
    (window as any).salvarPerfilAcesso = salvarPerfilAcesso;
    (window as any).removerAcesso = removerAcesso;

    function desligarColab(id: string, nome: string) {
      (document.getElementById("deslColabId") as HTMLInputElement).value = id;
      document.getElementById("deslNome")!.textContent = nome;
      (document.getElementById("formDesligamento") as HTMLFormElement).reset();
      (document.querySelector('#formDesligamento [name="data_desligamento"]') as HTMLInputElement).value = new Date().toISOString().slice(0, 10);
      document.getElementById("msgDesl")!.innerHTML = "";
      document.getElementById("modalDesligamento")!.classList.add("open");
    }
    async function confirmarDesligamento() {
      const id = (document.getElementById("deslColabId") as HTMLInputElement).value;
      const f = document.getElementById("formDesligamento") as HTMLFormElement;
      const fd = new FormData(f);
      const data = (fd.get("data_desligamento") as string) || new Date().toISOString().slice(0, 10);
      const msg = document.getElementById("msgDesl")!;
      // 1) status do colaborador → desligado (revoga acesso ao portal)
      const r1 = await fetch(`/api/admin/rh/colaboradores/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ status: "desligado", data_desligamento: data }) });
      if (!r1.ok) { const d = await r1.json().catch(() => ({})); msg.innerHTML = `<div class="alert alert-error">${(d as any).error || "Erro ao desligar"}</div>`; return; }
      // 2) registro do desligamento (entrevista + checklist)
      const entrevista = { motivo_principal: fd.get("motivo_principal"), ambiente: fd.get("ambiente"), relacao_gestao: fd.get("relacao_gestao"), recomendaria: fd.get("recomendaria"), comentarios: fd.get("comentarios") };
      const checklist = { epi_devolvido: fd.get("ck_epi") === "on", ferramentas_devolvidas: fd.get("ck_ferr") === "on", exame_demissional: fd.get("ck_aso") === "on", documentos_entregues: fd.get("ck_docs") === "on", acessos_revogados: true };
      await fetch("/api/admin/rh/desligamentos", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ colaborador_id: id, data_desligamento: data, tipo: fd.get("tipo"), motivo: fd.get("motivo"), entrevista, checklist, status: "concluido" }) });
      window.location.reload();
    }
    (window as any).confirmarDesligamento = confirmarDesligamento;

    // campos obrigatórios da ficha (exceto diaristas, que são esporádicos)
    const OBRIGATORIOS: [string, string][] = [
      ["nome", "Nome"], ["email", "E-mail"], ["telefone", "Telefone (empresa)"], ["telefone_pessoal", "Telefone (pessoal)"],
      ["cpf", "CPF"], ["rg", "RG"], ["data_nascimento", "Nascimento"], ["cargo", "Cargo"],
      ["data_admissao", "Admissão"], ["endereco", "Endereço"],
      ["contato_emergencia_nome", "Contato de emergência (nome)"],
      ["contato_emergencia_telefone", "Contato de emergência (telefone)"],
    ];
    document.getElementById("formColab")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as any);
      const body: Record<string, any> = Object.fromEntries(fd.entries());
      const id = body.id;
      delete body.id;
      const msg = document.getElementById("msgColab") as any;

      // valida obrigatórios (diarista é exceção — profissional esporádico)
      if (body.regime !== "diarista") {
        const faltando = OBRIGATORIOS.filter(([k]) => !String(body[k] || "").trim()).map(([, l]) => l);
        if (faltando.length) {
          msg.innerHTML = `<div class="alert alert-error"><strong>Preencha os campos obrigatórios:</strong><br>${faltando.join(" · ")}</div>`;
          (msg as HTMLElement).scrollIntoView({ behavior: "smooth", block: "nearest" });
          return;
        }
      }

      const res = await fetch(id ? `/api/admin/rh/colaboradores/${id}` : "/api/admin/rh/colaboradores", {
        method: id ? "PATCH" : "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
      });
      if (res.ok) window.location.reload();
      else { const d = await res.json().catch(() => ({} as any)); msg.innerHTML = `<div class="alert alert-error">${d.error || "Erro ao salvar"}</div>`; }
    });

    // ── Ausências ──
    function abrirModalAusencia() {
      (document.getElementById("formAusencia") as any)?.reset();
      (document.getElementById("msgAusencia") as any).innerHTML = "";
      document.getElementById("modalAusencia")?.classList.add("open");
    }

    async function mudarStatusAusencia(id: string, status: string) {
      const labels: Record<string, string> = { aprovada: "aprovar", rejeitada: "rejeitar", concluida: "concluir" };
