---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const db = supabaseAdmin();
const [colabRes, ausRes, docRes, admRes] = await Promise.all([
  db.from("rh_colaboradores").select("*").order("nome", { ascending: true }),
  db.from("rh_ausencias").select("*, rh_colaboradores(nome)").order("data_inicio", { ascending: false }).limit(200),
  db.from("rh_documentos").select("*, rh_colaboradores(nome)").order("created_at", { ascending: false }).limit(200),
  db.from("rh_admissoes").select("*, rh_admissoes_docs(id, tipo, nome_arquivo, created_at)").order("created_at", { ascending: false }).limit(200),
]);
const colaboradores: any[] = colabRes.data || [];
const ausencias: any[] = ausRes.data || [];
const documentos: any[] = docRes.data || [];
const admissoes: any[] = admRes.data || [];
const erros = [
  colabRes.error && `Colaboradores: ${colabRes.error.message}`,
  ausRes.error && `Ausências: ${ausRes.error.message}`,
  docRes.error && `Documentos: ${docRes.error.message}`,
  admRes.error && `Admissões: ${admRes.error.message} (rode a migration 028_melhorias_benchmark.sql no Supabase)`,
].filter(Boolean) as string[];

// ── Datas de referência ──
const hoje = new Date().toISOString().slice(0, 10);
const em30 = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);
const mesAtual = Number(hoje.slice(5, 7));
const nomeMes = new Date().toLocaleDateString("pt-BR", { month: "long" });

// ── Estatísticas dos cards ──
// Diaristas são profissionais esporádicos — NÃO entram na contagem de ativos (CLT+PJ).
const ehDiarista = (c: any) => c.regime === "diarista";
const totalAtivos = colaboradores.filter(c => c.status !== "desligado" && !ehDiarista(c)).length;
const totalAfastados = colaboradores.filter(c => c.status === "afastado").length;
const diaristas = colaboradores.filter(ehDiarista).sort((a, b) => String(a.nome).localeCompare(String(b.nome)));
const emFeriasHoje = new Set(
  ausencias
    .filter(a => a.tipo === "ferias" && a.status === "aprovada" && a.data_inicio <= hoje && a.data_fim >= hoje)
    .map(a => a.colaborador_id)
).size;
// Todos os colaboradores ATIVOS (qualquer regime, inclusive diaristas) — para festejar.
const aniversariantes = colaboradores
  .filter(c => c.status !== "desligado" && c.data_nascimento && Number(String(c.data_nascimento).slice(5, 7)) === mesAtual)
  .sort((a, b) => Number(String(a.data_nascimento).slice(8, 10)) - Number(String(b.data_nascimento).slice(8, 10)));
const docsVencendo = documentos.filter(d => d.validade && d.validade >= hoje && d.validade <= em30).length;

// ── Blocos de colaboradores (estilo Monday): regime × ativo/inativo ──
// "Ativo" = qualquer status diferente de "desligado". "Inativo" = desligado.
// Diaristas NÃO entram aqui — têm aba própria (profissionais esporádicos).
const regimeBloco = (c: any) => (c.regime === "clt" || c.regime === "pj") ? c.regime : "outros";
const blocosDef = [
  { key: "clt_ativo", titulo: "CLT — Ativos", regime: "clt", ativo: true, aberto: true },
  { key: "pj_ativo", titulo: "PJ — Ativos", regime: "pj", ativo: true, aberto: true },
  { key: "outros_ativo", titulo: "Estágio / Temporário / Sócio — Ativos", regime: "outros", ativo: true, aberto: true },
  { key: "clt_inativo", titulo: "CLT — Inativos (desligados)", regime: "clt", ativo: false, aberto: false },
  { key: "pj_inativo", titulo: "PJ — Inativos (desligados)", regime: "pj", ativo: false, aberto: false },
  { key: "outros_inativo", titulo: "Outros — Inativos (desligados)", regime: "outros", ativo: false, aberto: false },
];
const blocosTodos = blocosDef
  .map(b => ({ ...b, itens: colaboradores.filter(c => !ehDiarista(c) && (c.status !== "desligado") === b.ativo && regimeBloco(c) === b.regime) }));
const blocosAtivos = blocosTodos.filter(b => b.ativo && b.itens.length);
// inativos vão para aba própria e abrem expandidos lá
const blocosInativos = blocosTodos.filter(b => !b.ativo && b.itens.length).map(b => ({ ...b, aberto: true }));
const totalInativos = colaboradores.filter(c => c.status === "desligado" && !ehDiarista(c)).length;

// ── Labels e badges ──
const stColab: Record<string, string> = { ativo: "Ativo", ferias: "Férias", afastado: "Afastado", desligado: "Desligado" };
const badgeColab: Record<string, string> = { ativo: "badge-green", ferias: "badge-blue", afastado: "badge-yellow", desligado: "badge-gray" };
const regimes: Record<string, string> = { clt: "CLT", pj: "PJ", estagio: "Estágio", temporario: "Temporário", socio: "Sócio", diarista: "Diarista" };
const tiposAus: Record<string, string> = { ferias: "Férias", atestado: "Atestado", falta: "Falta", licenca: "Licença", folga: "Folga", outro: "Outro" };
const badgeTipoAus: Record<string, string> = { ferias: "badge-blue", atestado: "badge-purple", falta: "badge-red", licenca: "badge-orange", folga: "badge-green", outro: "badge-gray" };
const stAus: Record<string, string> = { solicitada: "Solicitada", aprovada: "Aprovada", rejeitada: "Rejeitada", concluida: "Concluída" };
const badgeStAus: Record<string, string> = { solicitada: "badge-yellow", aprovada: "badge-green", rejeitada: "badge-red", concluida: "badge-gray" };
const tiposDoc: Record<string, string> = { contrato: "Contrato", aso: "ASO", ficha_epi: "Ficha EPI", advertencia: "Advertência", atestado: "Atestado", certificado: "Certificado", cnh: "CNH", outro: "Outro" };
const badgeTipoDoc: Record<string, string> = { contrato: "badge-blue", aso: "badge-green", ficha_epi: "badge-orange", advertencia: "badge-red", atestado: "badge-purple", certificado: "badge-blue", cnh: "badge-gray", outro: "badge-gray" };
const stAdm: Record<string, string> = { aguardando: "Aguardando docs", docs_enviados: "Docs enviados", concluida: "Concluída", cancelada: "Cancelada" };
const badgeStAdm: Record<string, string> = { aguardando: "badge-yellow", docs_enviados: "badge-blue", concluida: "badge-green", cancelada: "badge-gray" };
const tiposDocAdm: Record<string, string> = { rg: "RG ou CNH", cpf: "CPF", cnh: "CNH", ctps: "CTPS digital", comprovante_residencia: "Comprovante de residência", foto: "Foto 3x4", aso: "ASO", outro: "Outro" };
const DOCS_OBRIGATORIOS = ["rg", "cpf", "comprovante_residencia", "ctps", "foto"];
function docsEnviadosAdm(a: any) {
  const tipos = new Set((a.rh_admissoes_docs || []).map((d: any) => d.tipo));
  return DOCS_OBRIGATORIOS.filter(t => tipos.has(t)).length;
}
const admissoesAbertas = admissoes.filter(a => a.status === "aguardando" || a.status === "docs_enviados").length;

function fmtData(d: string | null | undefined) {
  if (!d) return "—";
  const s = String(d).slice(0, 10);
  const [y, m, dd] = s.split("-");
  if (!y || !m || !dd) return "—";
  return `${dd}/${m}/${y}`;
}
function fmtBRL(v: number | string | null | undefined) {
  if (v === null || v === undefined || v === "") return "—";
  return Number(v).toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
}
function classValidade(v: string | null) {
  if (!v) return "";
  if (v < hoje) return "validade-vencida";
  if (v <= em30) return "validade-proxima";
  return "";
}
function buscaColab(c: any) {
  return [c.nome, c.email, c.cargo, c.cpf, c.setor].filter(Boolean).join(" ").toLowerCase();
}
const ufs = ["AC","AL","AP","AM","BA","CE","DF","ES","GO","MA","MT","MS","MG","PA","PB","PR","PE","PI","RJ","RN","RS","RO","RR","SC","SP","SE","TO"];
---
<Admin title="RH — Pessoas" current="rh">
  {erros.map(e => <div class="alert alert-error">Erro ao carregar dados (a tabela pode ainda não existir — rode a migration 021_rh.sql no Supabase): {e}</div>)}

  <!-- ── Cards resumo ── -->
  <div class="card-grid">
    <div class="stat-card">
      <div class="stat-value">{totalAtivos}</div>
      <div class="stat-label">Colaboradores ativos</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{emFeriasHoje}</div>
      <div class="stat-label">Em férias hoje</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{totalAfastados}</div>
      <div class="stat-label">Afastados</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{aniversariantes.length}</div>
      <div class="stat-label">Aniversariantes de {nomeMes}</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style={docsVencendo > 0 ? "color:#B45309" : ""}>{docsVencendo}</div>
      <div class="stat-label">Documentos vencendo em 30 dias</div>
    </div>
  </div>

  <!-- ── Abas ── -->
  <div class="pills" style="margin-bottom:16px">
    <button class="pill" data-aba="alertas" onclick="mostrarAba('alertas')">🚨 Alertas <span class="count" id="alertasBadge" style="background:#FEE2E2;color:#B91C1C"></span></button>
    <button class="pill" data-aba="ferias" onclick="mostrarAba('ferias')">🏖 Férias <span class="count" id="feriasBadge" style="background:#FEE2E2;color:#B91C1C"></span></button>
    <button class="pill active" data-aba="colaboradores" onclick="mostrarAba('colaboradores')">Colaboradores <span class="count">{totalAtivos}</span></button>
    <button class="pill" data-aba="diaristas" onclick="mostrarAba('diaristas')">👷 Diaristas <span class="count">{diaristas.length}</span></button>
    <button class="pill" data-aba="inativos" onclick="mostrarAba('inativos')">Inativos <span class="count">{totalInativos}</span></button>
    <button class="pill" data-aba="ausencias" onclick="mostrarAba('ausencias')">Ausências <span class="count">{ausencias.length}</span></button>
    <button class="pill" data-aba="documentos" onclick="mostrarAba('documentos')">Documentos <span class="count">{documentos.length}</span></button>
    <button class="pill" data-aba="admissoes" onclick="mostrarAba('admissoes')">Admissões <span class="count">{admissoesAbertas}</span></button>
    <button class="pill" data-aba="aniversariantes" onclick="mostrarAba('aniversariantes')">Aniversariantes <span class="count">{aniversariantes.length}</span></button>
  </div>

  <!-- ════════ ABA COLABORADORES ════════ -->
  <section class="tab-section" id="aba-colaboradores">
    <div class="toolbar">
      <span class="toolbar-title">Colaboradores</span>
      <input class="search-input" id="buscaColab" placeholder="Buscar nome, e-mail, cargo, CPF…" oninput="filtrarColabs()" />
      <select class="filter-select" id="filtroStatusColab" onchange="filtrarColabs()">
        <option value="todos">Todos os status</option>
        <option value="ativo">Ativos</option>
        <option value="ferias">Em férias</option>
        <option value="afastado">Afastados</option>
      </select>
      <button class="btn btn-outline" id="btnExportColab" onclick="exportarColabs()" title="Baixar a lista em CSV">⬇️ Exportar</button>
      <button class="btn btn-outline" onclick="document.getElementById('modalImportColab').classList.add('open')" title="Cadastrar/atualizar vários de uma vez por planilha">⬆️ Importar</button>
      <button class="btn btn-primary" onclick="abrirModalColab()">+ Novo colaborador</button>
    </div>
    {!colaboradores.length && <div class="card"><div class="empty-state"><strong>Nenhum colaborador cadastrado</strong>Clique em “+ Novo colaborador” para começar.</div></div>}

    {blocosAtivos.map(b => (
      <div class="card bloco-colab" data-bloco={b.key} style="margin-bottom:14px;padding:0;overflow:hidden">
        <button type="button" class="bloco-head" onclick={`toggleBloco('${b.key}')`} aria-expanded={String(b.aberto)}>
          <span class="bloco-seta" data-aberto={String(b.aberto)}>▸</span>
          <span class="bloco-titulo">{b.titulo}</span>
          <span class="bloco-count">{b.itens.length}</span>
        </button>
        <div class="bloco-body" id={`bloco-body-${b.key}`} style={b.aberto ? "" : "display:none"}>
          <div class="table-wrap">
            <table class="tabela-colab">
              <thead><tr><th>Nome</th><th>Cargo</th><th class="col-salario">Salário</th><th>Admissão</th><th>Status</th><th>Ações</th></tr></thead>
              <tbody>
                {b.itens.map(c => (
                  <tr class="colab-row" data-status={c.status} data-busca={buscaColab(c)}>
                    <td><strong>{c.nome}</strong></td>
                    <td>{c.cargo || "—"}</td>
                    <td class="col-salario">{fmtBRL(c.salario)}</td>
                    <td>{fmtData(c.data_admissao)}</td>
                    <td><span class={`badge ${badgeColab[c.status] || "badge-gray"}`}>{stColab[c.status] || c.status}</span></td>
                    <td>
                      <div style="display:flex;gap:4px;flex-wrap:wrap">
                        <button class="btn btn-secondary btn-sm" onclick={`editarColab('${c.id}')`}>Abrir ficha</button>
                        {c.status !== "desligado" && <button class="btn btn-danger btn-sm" onclick={`desligarColab('${c.id}','${(c.nome || "").replace(/'/g, "")}')`}>Desligar</button>}
                      </div>
                    </td>
                  </tr>
                ))}
                <tr class="bloco-sem-res" style="display:none"><td colspan="6" style="text-align:center;color:#999;padding:16px">Nenhum corresponde à busca neste bloco</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- ════════ ABA INATIVOS (desligados) ════════ -->
  <section class="tab-section" id="aba-inativos" style="display:none">
    <div class="toolbar">
      <span class="toolbar-title">Inativos (desligados)</span>
      <input class="search-input" id="buscaInativos" placeholder="Buscar nome, cargo, CPF…" oninput="filtrarInativos()" />
    </div>
    {!blocosInativos.length && <div class="card"><div class="empty-state"><strong>Nenhum colaborador inativo</strong>Os desligados aparecem aqui.</div></div>}
    {blocosInativos.map(b => (
      <div class="card bloco-colab" data-bloco={b.key} style="margin-bottom:14px;padding:0;overflow:hidden">
        <button type="button" class="bloco-head" onclick={`toggleBloco('${b.key}')`} aria-expanded={String(b.aberto)}>
          <span class="bloco-seta" data-aberto={String(b.aberto)}>▸</span>
          <span class="bloco-titulo">{b.titulo}</span>
          <span class="bloco-count">{b.itens.length}</span>
        </button>
        <div class="bloco-body" id={`bloco-body-${b.key}`} style={b.aberto ? "" : "display:none"}>
          <div class="table-wrap">
            <table class="tabela-colab">
              <thead><tr><th>Nome</th><th>Cargo</th><th>Admissão</th><th>Desligamento</th><th>Ações</th></tr></thead>
              <tbody>
                {b.itens.map(c => (
                  <tr class="colab-row" data-status={c.status} data-busca={buscaColab(c)}>
                    <td><strong>{c.nome}</strong></td>
                    <td>{c.cargo || "—"}</td>
                    <td>{fmtData(c.data_admissao)}</td>
                    <td>{fmtData(c.data_desligamento)}</td>
                    <td><button class="btn btn-secondary btn-sm" onclick={`editarColab('${c.id}')`}>Abrir ficha</button></td>
                  </tr>
                ))}
                <tr class="bloco-sem-res" style="display:none"><td colspan="5" style="text-align:center;color:#999;padding:16px">Nenhum corresponde à busca neste bloco</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- ════════ ABA DIARISTAS ════════ -->
  <section class="tab-section" id="aba-diaristas" style="display:none">
    <div class="toolbar">
      <span class="toolbar-title">👷 Diaristas — profissionais esporádicos ({diaristas.length})</span>
      <button class="btn btn-primary" onclick="abrirModalColab()">+ Novo colaborador</button>
    </div>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead><tr><th>Nome</th><th>Cargo</th><th>Contato</th><th>Início</th><th>Status</th><th>Ações</th></tr></thead>
          <tbody>
            {diaristas.length ? diaristas.map(c => (
              <tr>
                <td><strong>{c.nome}</strong>{c.email && <div class="sub-info">{c.email}</div>}</td>
                <td>{c.cargo || "—"}</td>
                <td>{c.telefone || "—"}</td>
                <td>{fmtData(c.data_admissao)}</td>
                <td><span class={`badge ${badgeColab[c.status] || "badge-gray"}`}>{stColab[c.status] || c.status}</span></td>
                <td>
                  <div style="display:flex;gap:4px;flex-wrap:wrap">
                    <button class="btn btn-secondary btn-sm" onclick={`editarColab('${c.id}')`}>Abrir ficha</button>
                  </div>
                </td>
              </tr>
            )) : <tr><td colspan="6"><div class="empty-state"><strong>Nenhum diarista cadastrado</strong>Diaristas são profissionais esporádicos, separados dos colaboradores fixos.</div></td></tr>}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ════════ ABA AUSÊNCIAS ════════ -->
  <section class="tab-section" id="aba-ausencias" style="display:none">
    <div class="toolbar">
      <span class="toolbar-title">Férias &amp; Ausências</span>
      <button class="btn btn-primary" onclick="abrirModalAusencia()">+ Nova ausência</button>
    </div>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead><tr><th>Colaborador</th><th>Tipo</th><th>Início</th><th>Fim</th><th>Dias</th><th>Status</th><th>Ações</th></tr></thead>
          <tbody>
            {ausencias.length ? ausencias.map(a => (
              <tr>
                <td><strong>{a.rh_colaboradores?.nome || "—"}</strong></td>
                <td><span class={`badge ${badgeTipoAus[a.tipo] || "badge-gray"}`}>{tiposAus[a.tipo] || a.tipo}</span></td>
                <td>{fmtData(a.data_inicio)}</td>
                <td>{fmtData(a.data_fim)}</td>
                <td>{a.dias ?? "—"}</td>
                <td><span class={`badge ${badgeStAus[a.status] || "badge-gray"}`}>{stAus[a.status] || a.status}</span></td>
                <td>
                  <div style="display:flex;gap:4px;flex-wrap:wrap">
                    {a.status === "solicitada" && (
                      <>
                        <button class="btn btn-success btn-sm" onclick={`mudarStatusAusencia('${a.id}','aprovada')`}>Aprovar</button>
                        <button class="btn btn-danger btn-sm" onclick={`mudarStatusAusencia('${a.id}','rejeitada')`}>Rejeitar</button>
                      </>
                    )}
                    {a.status === "aprovada" && <button class="btn btn-secondary btn-sm" onclick={`mudarStatusAusencia('${a.id}','concluida')`}>Concluir</button>}
                  </div>
                </td>
              </tr>
            )) : <tr><td colspan="7"><div class="empty-state"><strong>Nenhuma ausência registrada</strong>Registre férias, atestados e licenças aqui.</div></td></tr>}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ════════ ABA DOCUMENTOS ════════ -->
  <section class="tab-section" id="aba-documentos" style="display:none">
    <div class="toolbar">
      <span class="toolbar-title">Documentos</span>
      <button class="btn btn-primary" onclick="abrirModalDoc()">+ Novo documento</button>
    </div>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead><tr><th>Colaborador</th><th>Título</th><th>Tipo</th><th>Validade</th><th>Ações</th></tr></thead>
          <tbody>
            {documentos.length ? documentos.map(d => (
              <tr>
                <td><strong>{d.rh_colaboradores?.nome || "—"}</strong></td>
                <td>{(d.storage_path || d.url) ? <a href={`/api/admin/rh/documentos/${d.id}/arquivo`} target="_blank" rel="noopener" title="Abre via link seguro temporário">📎 {d.titulo}</a> : d.titulo}</td>
                <td><span class={`badge ${badgeTipoDoc[d.tipo] || "badge-gray"}`}>{tiposDoc[d.tipo] || d.tipo}</span></td>
                <td class={classValidade(d.validade)}>
                  {fmtData(d.validade)}
                  {d.validade && d.validade < hoje && <span class="badge badge-red" style="margin-left:6px">Vencido</span>}
                  {d.validade && d.validade >= hoje && d.validade <= em30 && <span class="badge badge-orange" style="margin-left:6px">Vence em breve</span>}
                </td>
                <td>
                  <div style="display:flex;gap:4px;flex-wrap:wrap">
                    <button class="btn btn-secondary btn-sm" onclick={`editarDoc('${d.id}')`}>Editar</button>
                    <button class="btn btn-danger btn-sm" onclick={`excluirDoc('${d.id}','${(d.titulo || "").replace(/'/g, "")}')`}>Excluir</button>
                  </div>
                </td>
              </tr>
            )) : <tr><td colspan="5"><div class="empty-state"><strong>Nenhum documento cadastrado</strong>Anexe contratos, ASOs, fichas de EPI e certificados.</div></td></tr>}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ════════ ABA ADMISSÕES ════════ -->
  <section class="tab-section" id="aba-admissoes" style="display:none">
    <div class="toolbar">
      <span class="toolbar-title">Admissão digital</span>
      <button class="btn btn-primary" onclick="abrirModalAdmissao()">+ Nova admissão</button>
    </div>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead><tr><th>Nome</th><th>Cargo</th><th>Status</th><th>Docs enviados</th><th>Criada em</th><th>Ações</th></tr></thead>
          <tbody>
            {admissoes.length ? admissoes.map(a => (
              <tr>
                <td><strong>{a.nome}</strong>{(a.email || a.telefone) && <div class="sub-info">{[a.email, a.telefone].filter(Boolean).join(" · ")}</div>}</td>
                <td>{a.cargo || "—"}{a.regime && <div class="sub-info">{regimes[a.regime] || a.regime}</div>}</td>
                <td><span class={`badge ${badgeStAdm[a.status] || "badge-gray"}`}>{stAdm[a.status] || a.status}</span></td>
                <td>
                  <strong>{docsEnviadosAdm(a)}/5</strong>
                  {(a.rh_admissoes_docs || []).length > docsEnviadosAdm(a) && <span class="sub-info"> ({(a.rh_admissoes_docs || []).length} arquivos)</span>}
                </td>
                <td>{fmtData(a.created_at)}</td>
                <td>
                  <div style="display:flex;gap:4px;flex-wrap:wrap">
                    {(a.status === "aguardando" || a.status === "docs_enviados") && (
                      <button class="btn btn-secondary btn-sm" onclick={`copiarLinkAdmissao('${a.token}', this)`}>🔗 Copiar link</button>
                    )}
                    {(a.rh_admissoes_docs || []).length > 0 && (
                      <button class="btn btn-secondary btn-sm" onclick={`verDocsAdmissao('${a.id}')`}>Ver documentos</button>
                    )}
                    {(a.status === "aguardando" || a.status === "docs_enviados") && (
                      <>
                        <button class="btn btn-success btn-sm" onclick={`concluirAdmissao('${a.id}','${(a.nome || "").replace(/'/g, "")}')`}>Concluir → vira colaborador</button>
                        <button class="btn btn-danger btn-sm" onclick={`cancelarAdmissao('${a.id}','${(a.nome || "").replace(/'/g, "")}')`}>Cancelar</button>
                      </>
                    )}
                    {a.status === "concluida" && a.colaborador_id && <span class="sub-info" style="align-self:center">✓ Colaborador criado</span>}
                  </div>
                </td>
              </tr>
            )) : <tr><td colspan="6"><div class="empty-state"><strong>Nenhuma admissão criada</strong>Clique em “+ Nova admissão” para gerar o link e enviar ao candidato — ele preenche e fotografa os documentos pelo celular.</div></td></tr>}
