    function filtrarColabs() {
      const busca = ((document.getElementById("buscaColab") as any)?.value || "").toLowerCase().trim();
      const status = (document.getElementById("filtroStatusColab") as any)?.value || "todos";
      const buscando = !!busca || status !== "todos";
      document.querySelectorAll(".bloco-colab").forEach((bloco) => {
        let visiveis = 0;
        bloco.querySelectorAll("tr.colab-row").forEach((tr) => {
          const el = tr as any;
          const okStatus = status === "todos" || el.dataset.status === status;
          const okBusca = !busca || (el.dataset.busca || "").includes(busca);
          const mostra = okStatus && okBusca;
          el.style.display = mostra ? "" : "none";
          if (mostra) visiveis++;
        });
        const semRes = bloco.querySelector(".bloco-sem-res") as any;
        if (semRes) semRes.style.display = (buscando && visiveis === 0) ? "" : "none";
        // ao buscar/filtrar, abre os blocos que têm resultado e esconde os vazios
        const body = bloco.querySelector(".bloco-body") as any;
        const seta = bloco.querySelector(".bloco-seta") as any;
        if (buscando) {
          (bloco as any).style.display = visiveis ? "" : "none";
          if (body && visiveis) { body.style.display = ""; if (seta) seta.dataset.aberto = "true"; }
