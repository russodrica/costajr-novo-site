      const res = await fetch(`/api/admin/rh/ausencias/${id}`, {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ status }),
      });
      if (res.ok) window.location.reload();
      else { const d = await res.json().catch(() => ({} as any)); alert("Erro ao atualizar ausência: " + (d.error || `HTTP ${res.status}`)); }
    }

    document.getElementById("formAusencia")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as any);
      const body = Object.fromEntries(fd.entries());
      const msg = document.getElementById("msgAusencia") as any;
      const res = await fetch("/api/admin/rh/ausencias", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
