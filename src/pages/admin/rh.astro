      const f = document.getElementById("formDoc") as HTMLFormElement;
      const sel = f.querySelector('select[name="colaborador_id"]') as HTMLSelectElement | null;
      if (sel) sel.value = colabId;
      if (tipoEnum) { const tp = f.querySelector('select[name="tipo"]') as HTMLSelectElement | null; if (tp) tp.value = tipoEnum; }
      if (prefixo) {
        const ti = f.querySelector('input[name="titulo"]') as HTMLInputElement | null;
        if (ti) { ti.value = prefixo + " — "; setTimeout(() => { ti.focus(); ti.setSelectionRange(ti.value.length, ti.value.length); }, 60); }
      }
    }
