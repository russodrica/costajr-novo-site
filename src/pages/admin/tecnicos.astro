---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const db = supabaseAdmin();
const { data: tecnicos } = await db.from("manut_tecnicos").select("*").order("nome");
function fmtDate(d: string | null) { if (!d) return "—"; return new Date(d).toLocaleDateString("pt-BR"); }
---
<Admin title="Técnicos" current="tecnicos">
  <div class="toolbar">
    <span class="toolbar-title">Técnicos ({tecnicos?.length ?? 0})</span>
    <input class="search-input" type="search" placeholder="Buscar nome, email…" oninput="filtrar(this.value)" />
    <button class="btn btn-primary" onclick="abrirModal()">+ Novo técnico</button>
    <button class="btn btn-secondary" onclick="window.location.reload()">↻ Atualizar</button>
  </div>

  <div class="card">
    <div class="table-wrap">
      <table id="tabela">
        <thead>
          <tr><th>Nome</th><th>E-mail</th><th>CPF</th><th>Telefone</th><th>Especialidades</th><th>Status</th><th>Último login</th><th>Ações</th></tr>
        </thead>
        <tbody>
          {tecnicos?.length ? tecnicos.map((t: any) => (
            <tr data-search={`${t.nome} ${t.email}`.toLowerCase()}>
              <td><strong>{t.nome}</strong></td>
              <td>{t.email}</td>
              <td>{t.cpf || "—"}</td>
              <td>{t.telefone || "—"}</td>
              <td style="font-size:0.8rem">{t.especialidades?.join(", ") || "—"}</td>
              <td><span class={`badge ${t.status === "ativo" ? "badge-green" : "badge-gray"}`}>{t.status}</span></td>
              <td>{fmtDate(t.last_login_at)}</td>
              <td>
                <div style="display:flex;gap:6px">
                  <button class="btn btn-secondary btn-sm" onclick={`editarTecnico(${JSON.stringify(t)})`}>Editar</button>
                  <button class="btn btn-info btn-sm" onclick={`resetarSenha('${t.id}')`}>Reset senha</button>
                  {t.status === "ativo"
                    ? <button class="btn btn-warning btn-sm" onclick={`patchStatus('${t.id}','inativo')`}>Inativar</button>
                    : <button class="btn btn-success btn-sm" onclick={`patchStatus('${t.id}','ativo')`}>Ativar</button>}
                  <button class="btn btn-danger btn-sm" data-action="excluir" data-id={t.id} data-nome={t.nome}>🗑 Excluir</button>
                </div>
              </td>
            </tr>
          )) : (
            <tr><td colspan="8" style="text-align:center;color:#999;padding:32px">Nenhum técnico cadastrado</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal técnico -->
  <div class="modal-overlay" id="modalTec">
    <div class="modal" style="max-width:560px">
      <div class="modal-title" id="modalTecTitle">Novo Técnico</div>
      <div id="msgTec"></div>
      <form id="formTec">
        <input type="hidden" id="tecId" />
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group" style="grid-column:span 2"><label>Nome *</label><input id="tecNome" name="nome" required /></div>
          <div class="form-group"><label>E-mail *</label><input id="tecEmail" name="email" type="email" required /></div>
          <div class="form-group"><label>CPF</label><input id="tecCpf" name="cpf" /></div>
          <div class="form-group"><label>Telefone</label><input id="tecTelefone" name="telefone" /></div>
          <div class="form-group"><label>Senha inicial</label><input id="tecSenha" name="senha" placeholder="Deixe em branco para gerar automaticamente" /></div>
        </div>
        <div class="form-group">
          <label>Especialidades</label>
          <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:6px">
            {["eletrica","hidraulica","civil"].map(e => (
              <label style="display:flex;align-items:center;gap:6px;font-size:0.85rem;font-weight:400">
                <input type="checkbox" name="especialidades" value={e} /> {e}
              </label>
            ))}
          </div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary" id="btnSalvarTec">Criar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function filtrar(q) {
      document.querySelectorAll("#tabela tbody tr[data-search]").forEach(r => {
        r.style.display = r.dataset.search.includes(q.toLowerCase()) ? "" : "none";
      });
    }
    function abrirModal() {
      document.getElementById("modalTecTitle").textContent = "Novo Técnico";
      document.getElementById("tecId").value = "";
      document.getElementById("formTec").reset();
      document.getElementById("tecEmail").disabled = false;
      document.getElementById("btnSalvarTec").textContent = "Criar";
      document.getElementById("modalTec").classList.add("open");
    }
    function editarTecnico(t) {
      document.getElementById("modalTecTitle").textContent = "Editar Técnico";
      document.getElementById("tecId").value = t.id;
      document.getElementById("tecNome").value = t.nome;
      document.getElementById("tecEmail").value = t.email;
      document.getElementById("tecEmail").disabled = true;
      document.getElementById("tecCpf").value = t.cpf || "";
      document.getElementById("tecTelefone").value = t.telefone || "";
      const cbs = document.querySelectorAll('input[name="especialidades"]');
      cbs.forEach(cb => { cb.checked = (t.especialidades || []).includes(cb.value); });
      document.getElementById("btnSalvarTec").textContent = "Salvar";
      document.getElementById("modalTec").classList.add("open");
    }
    function fecharModal() { document.getElementById("modalTec").classList.remove("open"); }

    document.addEventListener("click", async (e) => {
      const btn = (e.target as Element).closest<HTMLElement>("[data-action='excluir']");
      if (!btn) return;
      const id = btn.dataset.id!;
      const nome = btn.dataset.nome!;
      if (!confirm(`Excluir permanentemente "${nome}"? Esta ação não pode ser desfeita.`)) return;
      const res = await fetch(`/api/admin/tecnicos/${id}`, { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ action: "delete" }) });
      if (res.ok) window.location.reload();
      else { const d = await res.json().catch(() => ({ error: `HTTP ${res.status}` })); alert("Erro: " + d.error); }
    });
    async function patchStatus(id, status) {
      if (!confirm(`Mudar status para "${status}"?`)) return;
      const res = await fetch(`/api/admin/tecnicos/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ status }) });
      if (res.ok) window.location.reload(); else alert("Erro ao atualizar");
    }
    async function resetarSenha(id) {
      if (!confirm("Resetar senha deste técnico?")) return;
      const res = await fetch(`/api/admin/tecnicos/${id}/resetar-senha`, { method: "POST" });
      if (res.ok) { const d = await res.json(); alert(`Nova senha: ${d.senha}`); }
      else alert("Erro ao resetar senha");
    }

    document.getElementById("formTec")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = document.getElementById("tecId").value;
      const especialidades = [...document.querySelectorAll('input[name="especialidades"]:checked')].map(c => c.value);
      const body = {
        nome: document.getElementById("tecNome").value,
        email: document.getElementById("tecEmail").value,
        cpf: document.getElementById("tecCpf").value || null,
        telefone: document.getElementById("tecTelefone").value || null,
        senha: document.getElementById("tecSenha").value || null,
        especialidades,
      };
      const msg = document.getElementById("msgTec");
      const url = id ? `/api/admin/tecnicos/${id}` : "/api/admin/tecnicos";
      const method = id ? "PATCH" : "POST";
      const res = await fetch(url, { method, headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (res.ok) { window.location.reload(); }
      else { const d = await res.json(); msg.innerHTML = `<div class="alert alert-error">${d.error}</div>`; }
    });
  </script>
</Admin>
