---
import Admin from "../../layouts/Admin.astro";
const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
const anoAtual = new Date().getFullYear();
const anos: number[] = [];
for (let a = anoAtual + 1; a >= anoAtual - 4; a--) anos.push(a);
---
<Admin title="Financeiro (Vobi)" current="vobi-financeiro">
  <div class="toolbar">
    <span class="toolbar-title">Indicadores financeiros — Vobi <span class="live">ao vivo</span></span>
    <select id="anoSel" class="filter-select">
      {anos.map((a) => <option value={a} selected={a === anoAtual}>{a}</option>)}
    </select>
    <button class="btn btn-secondary btn-sm" id="btnReload"><i class="ti ti-refresh" aria-hidden="true"></i> Atualizar</button>
  </div>

  <div id="vfStatus" class="loading"><span class="spinner"></span> Consultando a Vobi…</div>

  <div id="vfContent" style="display:none">
    <div class="kpi-grid" id="vfKpis"></div>
    <div class="card" style="margin-bottom:16px">
      <div class="chart-title">Entradas × Saídas por mês — <span id="vfAno"></span> <span class="leg"><span class="dot" style="background:#16A34A"></span>Entradas <span class="dot" style="background:#C1272D;margin-left:10px"></span>Saídas</span></div>
      <div class="bchart" id="vfChart"></div>
    </div>
    <div class="card" id="vfAberto"></div>
  </div>

  <script>
    const fmt = (v) => Number(v || 0).toLocaleString("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 });
    const el = (id) => document.getElementById(id);
    function statCard(valor, label, sub, cor) {
      const s = String(valor);
      const fs = s.length >= 12 ? "1.15rem" : s.length >= 10 ? "1.3rem" : "1.5rem";
      return `<div class="stat-card"><div class="stat-value" style="color:${cor || "var(--ink)"};font-size:${fs};line-height:1.15;font-variant-numeric:tabular-nums;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${valor}</div><div class="stat-label">${label}</div>${sub ? `<div style="font-size:.72rem;color:var(--ink-light);margin-top:5px;font-weight:600">${sub}</div>` : ""}</div>`;
    }
    async function carregar() {
      const ano = el("anoSel").value;
      el("vfStatus").style.display = "flex";
      el("vfStatus").innerHTML = '<span class="spinner"></span> Consultando a Vobi…';
      el("vfContent").style.display = "none";
      let d;
      try {
        const r = await fetch(`/api/admin/vobi/financeiro?ano=${ano}`);
        d = await r.json();
        if (!r.ok) throw new Error(d.error || "Falha ao consultar a Vobi.");
      } catch (e) {
        el("vfStatus").innerHTML = `<div class="erro"><strong>Não foi possível carregar.</strong><br>${e.message}</div>`;
        return;
      }
      el("vfAno").textContent = d.ano;
      el("vfKpis").innerHTML = [
        statCard(fmt(d.totais.entradas), "Entradas no ano", `previsto ${fmt(d.totais.entradasPrev)}`, "#16A34A"),
        statCard(fmt(d.totais.saidas), "Saídas no ano", `previsto ${fmt(d.totais.saidasPrev)}`, "#C1272D"),
        statCard(fmt(d.totais.resultado), "Resultado no ano", "entradas − saídas", d.totais.resultado >= 0 ? "#16A34A" : "#C1272D"),
        statCard(fmt(d.pagar.aVencer), "A pagar a vencer", `${d.pagar.aVencerQtd} parcela(s) em ${d.ano}`, "#B45309"),
        statCard(fmt(d.pagar.vencidoGeral), "A pagar VENCIDO (em aberto)", `${d.pagar.vencidoGeralQtd} parcela(s)`, "#C1272D"),
        statCard(fmt(d.receber.aVencer), "A receber a vencer", `${d.receber.aVencerQtd} parcela(s) em ${d.ano}`, "#16A34A"),
        statCard(fmt(d.receber.vencidoGeral), "A receber VENCIDO (em aberto)", `${d.receber.vencidoGeralQtd} parcela(s)`, "#B45309"),
      ].join("");

      const MAXBAR = 150;
      const max = Math.max(1, ...d.meses.map((m) => Math.max(m.entradas, m.saidas)));
      const hpx = (v) => (v > 0 ? Math.max(3, Math.round((v / max) * MAXBAR)) : 0);
      el("vfChart").innerHTML = d.meses.map((m) => `
        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:7px">
          <div style="display:flex;align-items:flex-end;gap:3px;height:150px">
            <div style="width:15px;border-radius:3px 3px 0 0;background:#16A34A;height:${hpx(m.entradas)}px" title="${m.mes} · entradas ${fmt(m.entradas)}"></div>
            <div style="width:15px;border-radius:3px 3px 0 0;background:#C1272D;height:${hpx(m.saidas)}px" title="${m.mes} · saídas ${fmt(m.saidas)}"></div>
          </div>
          <div style="font-size:11px;color:var(--ink-light)">${m.mes}</div>
        </div>`).join("");

      const q = (n) => `<span style="color:var(--ink-light);font-size:.82em">(${n})</span>`;
      el("vfAberto").innerHTML = `
        <div style="font-family:'Montserrat',sans-serif;font-size:.9rem;font-weight:700;margin-bottom:16px;color:var(--ink)">Contas em aberto (parcelas não pagas na Vobi)</div>
        <div class="table-wrap"><table>
          <thead><tr><th>Tipo</th><th>Vencido (em aberto, geral)</th><th>A vencer em ${d.ano}</th><th>Total em ${d.ano}</th></tr></thead>
          <tbody>
            <tr><td><strong>A pagar</strong></td><td style="color:#C1272D">${fmt(d.pagar.vencidoGeral)} ${q(d.pagar.vencidoGeralQtd)}</td><td>${fmt(d.pagar.aVencer)} ${q(d.pagar.aVencerQtd)}</td><td><strong>${fmt(d.pagar.total)}</strong> ${q(d.pagar.qtd)}</td></tr>
            <tr><td><strong>A receber</strong></td><td style="color:#B45309">${fmt(d.receber.vencidoGeral)} ${q(d.receber.vencidoGeralQtd)}</td><td style="color:#16A34A">${fmt(d.receber.aVencer)} ${q(d.receber.aVencerQtd)}</td><td><strong>${fmt(d.receber.total)}</strong> ${q(d.receber.qtd)}</td></tr>
          </tbody>
        </table></div>
        <p style="font-size:.76rem;color:var(--ink-light);margin-top:12px">Dados puxados ao vivo da API da Vobi (somente leitura). "Vencido geral" = todas as parcelas em aberto com vencimento já passado, independente do ano.</p>`;

      el("vfStatus").style.display = "none";
      el("vfContent").style.display = "block";
    }
    el("anoSel").addEventListener("change", carregar);
    el("btnReload").addEventListener("click", carregar);
    carregar();
  </script>

  <style>
    .live { background: #DCFCE7; color: #0F6B30; font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: 2px 8px; border-radius: 99px; vertical-align: middle; margin-left: 6px; }
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(186px, 1fr)); gap: 12px; margin-bottom: 18px; }
    .kpi-grid .stat-card { padding: 15px 16px; }
    .kpi-grid .stat-value { font-size: 1.42rem; line-height: 1.15; font-variant-numeric: tabular-nums; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; }
    .kpi-grid .stat-label { font-size: .8rem; margin-top: 4px; }
    .stat-sub { font-size: .72rem; color: var(--ink-light); margin-top: 5px; font-weight: 600; }
    .chart-title { font-family: 'Montserrat', sans-serif; font-size: .9rem; font-weight: 700; margin-bottom: 16px; color: var(--ink); }
    .leg { font-family: 'Open Sans', sans-serif; font-size: .72rem; font-weight: 600; color: var(--ink-mid); float: right; }
    .dot { display: inline-block; width: 10px; height: 10px; border-radius: 3px; vertical-align: middle; margin-right: 4px; }
    /* Gráfico de barras — alturas em PIXELS (render robusto) + grade sutil */
    .bchart { display: flex; align-items: flex-end; justify-content: space-between; gap: 6px; height: 178px; padding-top: 12px; border-bottom: 2px solid var(--border); background: repeating-linear-gradient(to top, transparent 0, transparent 36px, var(--gray-100) 36px, var(--gray-100) 37px); }
    .bcol { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; gap: 7px; }
    .bpair { display: flex; align-items: flex-end; gap: 3px; height: 150px; }
    .bbar { width: 15px; border-radius: 3px 3px 0 0; transition: opacity .15s; }
    .bbar:hover { opacity: .78; }
    .bin { background: #16A34A; }
    .bout { background: #C1272D; }
    .blbl { font-size: 11px; color: var(--ink-light); }
    .q { color: var(--ink-light); font-size: .82em; }
    .nota { font-size: .76rem; color: var(--ink-light); margin-top: 12px; }
    .erro { background: var(--danger-bg); color: var(--danger-fg); border: 1px solid #FECACA; border-radius: 10px; padding: 14px 16px; font-size: .9rem; }
    .loading { min-height: 120px; }
  </style>
</Admin>
