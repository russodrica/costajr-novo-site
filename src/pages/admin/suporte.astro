---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";
import { supabaseAdmin } from "../../lib/supabase";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }

const filtroStatus = Astro.url.searchParams.get("status") || "aberto";
const db = supabaseAdmin();
const { data: tickets } = await db.from("manut_suporte")
  .select("*").eq("status", filtroStatus).order("created_at", { ascending: false });

const badgeSt: Record<string, string> = { aberto: "badge-red", em_atendimento: "badge-blue", resolvido: "badge-green" };
const badgeTipo: Record<string, string> = { cliente: "badge-blue", tecnico: "badge-orange" };
function fmtDate(d: string | null) { if (!d) return "—"; return new Date(d).toLocaleDateString("pt-BR"); }
---
<Admin title="Suporte" current="suporte">
  <div class="toolbar">
    <span class="toolbar-title">Tickets ({tickets?.length ?? 0})</span>
    <select class="filter-select" onchange="filtrar(this.value)">
      {["aberto","em_atendimento","resolvido"].map(s => <option value={s} selected={s===filtroStatus}>{s.replace("_"," ")}</option>)}
    </select>
  </div>

  <div class="card">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Usuário</th><th>Tipo</th><th>Assunto</th><th>Status</th><th>Data</th><th>Ações</th></tr></thead>
        <tbody>
          {tickets?.length ? tickets.map((t: any) => (
            <tr>
              <td>{t.usuario_nome || t.usuario_id}</td>
              <td><span class={`badge ${badgeTipo[t.usuario_tipo]}`}>{t.usuario_tipo}</span></td>
              <td>
                <strong style="display:block">{t.assunto}</strong>
                <span style="font-size:0.8rem;color:#666">{t.descricao?.slice(0,80)}{t.descricao?.length > 80 ? "…" : ""}</span>
                {t.resposta_admin && <div style="margin-top:4px;font-size:0.8rem;background:#F0FDF4;padding:6px 8px;border-radius:5px;border-left:2px solid #22C55E"><strong>Resp:</strong> {t.resposta_admin}</div>}
              </td>
              <td><span class={`badge ${badgeSt[t.status]}`}>{t.status.replace("_"," ")}</span></td>
              <td>{fmtDate(t.created_at)}</td>
              <td>
                <div style="display:flex;gap:4px">
                  <button class="btn btn-primary btn-sm" onclick={`abrirTicket(${JSON.stringify(t).replace(/"/g,"'")})`}>Responder</button>
                  {t.status !== "resolvido" && <button class="btn btn-success btn-sm" onclick={`resolver('${t.id}')`}>Resolver</button>}
                </div>
              </td>
            </tr>
          )) : <tr><td colspan="6" style="text-align:center;color:#999;padding:32px">Nenhum ticket encontrado</td></tr>}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal responder -->
  <div class="modal-overlay" id="modalTicket">
    <div class="modal" style="max-width:560px">
      <div class="modal-title">Responder Ticket</div>
      <div id="ticketInfo" style="background:#F8F8F8;border-radius:8px;padding:12px;margin-bottom:16px;font-size:0.875rem"></div>
      <form id="formTicket">
        <input type="hidden" id="ticketId" />
        <div class="form-group"><label>Resposta *</label><textarea id="ticketResposta" required placeholder="Digite sua resposta…"></textarea></div>
        <div class="form-group"><label>Status</label>
          <select id="ticketStatus">
            <option value="em_atendimento">Em atendimento</option>
            <option value="resolvido">Resolvido</option>
          </select>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="fecharModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary">Enviar resposta</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function filtrar(s) {
      const url = new URL(window.location.href);
      url.searchParams.set("status", s);
      window.location.href = url.toString();
    }
    function fecharModal() { document.getElementById("modalTicket").classList.remove("open"); }
    function abrirTicket(t) {
      document.getElementById("ticketId").value = t.id;
      document.getElementById("ticketInfo").innerHTML = `<strong>${t.assunto}</strong><br/><span style="color:#666">${t.descricao}</span>`;
      document.getElementById("ticketResposta").value = t.resposta_admin || "";
      document.getElementById("modalTicket").classList.add("open");
    }
    async function resolver(id) {
      const res = await fetch(`/api/admin/suporte/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ status: "resolvido" }) });
      if (res.ok) window.location.reload(); else alert("Erro ao atualizar");
    }
    document.getElementById("formTicket")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = document.getElementById("ticketId").value;
      const body = { resposta_admin: document.getElementById("ticketResposta").value, status: document.getElementById("ticketStatus").value };
      const res = await fetch(`/api/admin/suporte/${id}`, { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify(body) });
      if (res.ok) window.location.reload(); else alert("Erro ao enviar resposta");
    });
  </script>
</Admin>
