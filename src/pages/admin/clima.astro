---
import Admin from "../../layouts/Admin.astro";
import { verifyToken, type AdminClaims } from "../../lib/auth";

const token = Astro.cookies.get("admin_token")?.value;
if (!token) return Astro.redirect("/admin/login");
try { const c = await verifyToken<AdminClaims>(token); if (c.tipo !== "admin") throw new Error(); }
catch { Astro.cookies.delete("admin_token", { path: "/" }); return Astro.redirect("/admin/login"); }
---
<Admin title="Pesquisa de Clima" current="clima">
  <div class="toolbar">
    <span class="toolbar-title">🌡️ Pesquisa de Clima / eNPS</span>
    <button class="btn btn-primary" onclick="abrirNova()">+ Nova pesquisa</button>
  </div>
  <div id="lista"><div class="loading"><div class="spinner"></div> Carregando…</div></div>

  <div class="modal-overlay" id="modalNova">
    <div class="modal" style="max-width:460px">
      <div class="modal-title">Nova pesquisa de clima</div>
      <div id="msgNova"></div>
      <div class="form-group"><label>Título *</label><input id="nvTitulo" placeholder="Ex.: Clima organizacional" /></div>
      <div class="form-group"><label>Período</label><input id="nvPeriodo" placeholder="Ex.: 2º trim. 2026" /></div>
      <div class="modal-actions"><button class="btn btn-secondary" onclick="fecharModal('modalNova')">Cancelar</button><button class="btn btn-primary" onclick="criar()">Criar e gerar link</button></div>
    </div>
  </div>

  <script is:inline>
    const esc = s => String(s ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
    function fecharModal(id){ document.getElementById(id).classList.remove("open"); }
    function corEnps(s){ return s>=50?"#16A34A":s>=0?"#D97706":"#B91C1C"; }
    let DIMS = [];

    async function carregar() {
      const r = await fetch("/api/admin/rh/clima", { headers: { "content-type": "application/json" } });
      const d = await r.json(); DIMS = d.dimensoes || [];
      const box = document.getElementById("lista");
      if (!d.pesquisas.length) { box.innerHTML = '<div class="card" style="text-align:center;color:#6B7280;padding:24px">Nenhuma pesquisa. Crie uma e compartilhe o link anônimo com a equipe.</div>'; return; }
      box.innerHTML = d.pesquisas.map(p => {
        const link = `${location.origin}/clima/${p.token}`;
        const e = p.enps;
        return `<div class="card" style="margin-bottom:14px">
          <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap">
            <div><strong style="font-size:15px">${esc(p.titulo)}</strong> ${p.periodo?`<span style="color:#9CA3AF">· ${esc(p.periodo)}</span>`:""}
              <div style="font-size:12.5px;color:#6B7280;margin-top:2px">${p.respostas} resposta(s) · ${p.ativa?'<span class="badge badge-green">ativa</span>':'<span class="badge badge-gray">encerrada</span>'}</div></div>
            <div style="text-align:center"><div style="font-size:1.8rem;font-weight:800;color:${corEnps(e.score)}">${e.total?e.score:"—"}</div><div style="font-size:11px;color:#9CA3AF">eNPS</div></div>
          </div>
          <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap">
            <input readonly value="${link}" style="flex:1;min-width:180px;padding:7px 10px;border:1px solid #E5E7EB;border-radius:8px;font-size:12.5px;color:#374151" onclick="this.select()" />
            <button class="btn btn-outline btn-sm" onclick="navigator.clipboard.writeText('${link}');this.textContent='Copiado!'">📋 Copiar link</button>
            <button class="btn btn-outline btn-sm" onclick="window.open('${link}','_blank')">Abrir</button>
            <button class="btn btn-outline btn-sm" onclick="encerrar('${p.id}',${p.ativa})">${p.ativa?'Encerrar':'Reabrir'}</button>
          </div>
          ${e.total?`<div style="display:flex;gap:14px;margin-top:10px;font-size:12.5px;color:#6B7280">
            <span>👍 Promotores: <strong>${e.promotores}</strong></span><span>😐 Passivos: <strong>${e.passivos}</strong></span><span>👎 Detratores: <strong>${e.detratores}</strong></span></div>`:""}
          <div style="margin-top:10px">${DIMS.map(dim=>{ const v=p.dimMed[dim.k]||0; return `<div style="display:flex;align-items:center;gap:10px;margin-bottom:4px"><span style="flex:1;font-size:12.5px">${esc(dim.t)}</span><div style="width:120px;background:#F3F4F6;border-radius:6px;height:8px"><div style="width:${v/5*100}%;background:var(--brand);height:8px;border-radius:6px"></div></div><strong style="width:34px;text-align:right;font-size:12.5px">${v||"—"}</strong></div>`; }).join("")}</div>
          ${p.comentarios.length?`<details style="margin-top:8px"><summary style="cursor:pointer;font-size:13px;font-weight:700;color:#374151">💬 Comentários (${p.comentarios.length})</summary><div style="margin-top:6px">${p.comentarios.map(c=>`<div style="font-size:13px;color:#5B5F6B;border-left:3px solid #E5E7EB;padding:4px 10px;margin-bottom:5px">${esc(c)}</div>`).join("")}</div></details>`:""}
        </div>`;
      }).join("");
    }
    function abrirNova(){ document.getElementById("nvTitulo").value=""; document.getElementById("nvPeriodo").value=""; document.getElementById("msgNova").innerHTML=""; document.getElementById("modalNova").classList.add("open"); }
    async function criar(){
      const titulo=document.getElementById("nvTitulo").value.trim(); if(!titulo){document.getElementById("msgNova").innerHTML='<div class="alert alert-error">Informe o título.</div>';return;}
      const r=await fetch("/api/admin/rh/clima",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({titulo,periodo:document.getElementById("nvPeriodo").value})});
      if(r.ok){fecharModal("modalNova");carregar();} else {const d=await r.json().catch(()=>({}));document.getElementById("msgNova").innerHTML=`<div class="alert alert-error">${d.error||"Erro"}</div>`;}
    }
    async function encerrar(id,ativa){ await fetch(`/api/admin/rh/clima/${id}`,{method:"PATCH",headers:{"content-type":"application/json"},body:JSON.stringify({ativa:!ativa})}); carregar(); }
    carregar();
  </script>
</Admin>
