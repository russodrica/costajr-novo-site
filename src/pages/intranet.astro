---
import Base from "~/layouts/Base.astro";

const portais = [
  {
    id: "cliente",
    titulo: "Portal do Cliente",
    descricao: "Acompanhe chamados, aprove orçamentos, visualize relatórios e a saúde da sua manutenção.",
    publico: "Para empresas com contrato de manutenção predial.",
    href: "/manutencao/cliente/login",
    icon: "M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10",
    cta: "Acessar como cliente",
  },
  {
    id: "tecnico",
    titulo: "Portal do Técnico",
    descricao: "Agenda do dia, checklist das visitas, abertura e fechamento de chamados em campo.",
    publico: "Para técnicos vinculados à equipe Costa Júnior.",
    href: "/manutencao/tecnico/login",
    icon: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z",
    cta: "Acessar como técnico",
  },
  {
    id: "representante",
    titulo: "Portal do Representante",
    descricao: "Acompanhe vendas, saldo de comissão, repasses via PIX e baixe materiais de divulgação.",
    publico: "Para representantes do programa Indique e Ganhe.",
    href: "/manutencao/representante/login",
    icon: "M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 8 0 4 4 0 0 0-8 0zM19 8v6M22 11h-6",
    cta: "Acessar como representante",
    badge: "🤝 Indique e Ganhe",
  },
  {
    id: "colaborador",
    titulo: "Portal do Colaborador",
    descricao: "Onboarding, treinamentos por setor, fórum interno, documentos técnicos e gestão por área.",
    publico: "Para toda a equipe Costa Júnior.",
    href: "/portal",
    icon: "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75",
    cta: "Acessar como colaborador",
  },
  {
    id: "admin",
    titulo: "Área Administrativa",
    descricao: "Gestão de clientes, contratos, faturamento, equipes e relatórios consolidados.",
    publico: "Para administradores e diretoria Costa Júnior.",
    href: "/admin",
    icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 0 0 1 1h3m10-11l2 2m-2-2v10a1 1 0 0 1-1 1h-3m-6 0a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1m-6 0h6",
    cta: "Acessar área admin",
  },
];
---
<Base
  title="Intranet — Costa Júnior"
  description="Acesso restrito aos portais Costa Júnior. Cliente, Técnico e Administração — escolha sua área."
>
  <section class="page-hero">
    <div class="container page-hero-content">
      <span class="hero-eyebrow">Acesso restrito</span>
      <h1>Intranet <span class="hl">Costa Júnior</span>.</h1>
      <p class="page-hero-sub">
        Escolha o portal correspondente ao seu acesso. Se você ainda não tem cadastro, fale com seu responsável ou com a nossa equipe.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="portais-grid">
        {portais.map((p: any) => (
          <article class="portal-card">
            {p.badge && <span class="portal-badge">{p.badge}</span>}
            <div class="portal-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={`<path d="${p.icon}"/>`}></svg>
            </div>
            <h3>{p.titulo}</h3>
            <p class="portal-desc">{p.descricao}</p>
            <p class="portal-publico">{p.publico}</p>
            <a href={p.href} class="btn btn-primary">
              {p.cta}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <div class="ajuda-box">
        <div>
          <span class="kicker">Precisa de ajuda?</span>
          <h2 style="margin-bottom:12px">Não consegue acessar?</h2>
          <p style="color:var(--ink-mid);font-size:16px;margin:0 0 24px;max-width:520px">
            Se esqueceu a senha, use o link "Esqueci minha senha" na tela do portal. Para outras dúvidas, fale com a nossa equipe.
          </p>
          <a href="/contato" class="btn btn-outline">
            Falar com a equipe
          </a>
        </div>
        <ul class="ajuda-list">
          <li>
            <strong>Suporte cliente</strong>
            <a href="mailto:contato@costajr.com.br">contato@costajr.com.br</a>
          </li>
          <li>
            <strong>Suporte técnico</strong>
            <a href="https://wa.me/551123696462" target="_blank" rel="noopener" class="wa-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Chamar no WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    position: relative;
    background:
      radial-gradient(circle at 78% 30%, rgba(196,30,58,.45) 0%, transparent 55%),
      linear-gradient(135deg, #1A1C20 0%, #2D2F36 60%, #3A1419 100%);
    color: #fff; overflow: hidden;
  }
  .page-hero-content { position: relative; padding: 96px 0 80px; max-width: 820px; }
  .hero-eyebrow {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand);
    border-left: 3px solid var(--brand); padding-left: 12px; margin-bottom: 24px;
  }
  .page-hero h1 { color: #fff; margin: 0 0 20px; }
  .page-hero h1 .hl { color: var(--brand); }
  .page-hero-sub { font-size: clamp(16px, 1.4vw, 18px); line-height: 1.7; color: #E5E7EB; max-width: 680px; margin: 0; }
  .kicker {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;
  }

  .portais-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .portal-card {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 40px 32px;
    display: flex; flex-direction: column; gap: 8px;
    transition: all .2s ease;
    position: relative; overflow: hidden;
  }
  .portal-card::before {
    content: ""; position: absolute; top: 0; left: 0; height: 3px; width: 0;
    background: var(--brand); transition: width .25s ease;
  }
  .portal-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,.08);
    border-color: var(--brand-soft);
  }
  .portal-card:hover::before { width: 100%; }
  .portal-icon {
    width: 64px; height: 64px; border-radius: 12px;
    background: var(--brand-soft); color: var(--brand);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 12px;
  }
  .portal-badge {
    position: absolute; top: 14px; right: 14px;
    background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
    color: #92400E;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 10.5px;
    letter-spacing: 0.06em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 99px;
    border: 1px solid #FCD34D;
  }
  .portal-card h3 { margin: 0 0 4px; font-size: 22px; }
  .portal-desc { color: var(--ink-mid); font-size: 14px; line-height: 1.65; margin: 0 0 8px; flex: 1; }
  .portal-publico {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-light); margin: 0 0 16px;
  }
  .portal-card .btn { justify-content: center; width: 100%; }

  .ajuda-box {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 56px;
    align-items: center;
  }
  .ajuda-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 18px; }
  .ajuda-list li {
    display: flex; flex-direction: column; gap: 4px;
    padding: 18px 22px;
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
  }
  .ajuda-list strong {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--brand);
  }
  .ajuda-list a { font-size: 15px; color: var(--ink); }
  .ajuda-list a:hover { color: var(--brand); }
  .wa-link { display: inline-flex; align-items: center; gap: 8px; color: #25D366 !important; font-weight: 600; }
  .wa-link:hover { color: #128C7E !important; }

  @media (max-width: 900px) {
    .page-hero-content { padding: 64px 0 56px; }
    .ajuda-box { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
