---
import Base from "~/layouts/Base.astro";

const beneficios = [
  { t: "Volume de demanda", d: "Fluxo contínuo de obras em todos os estados." },
  { t: "Pagamento em dia", d: "Repasses programados, sem atrasos. Reputação no mercado." },
  { t: "Suporte técnico", d: "Engenharia disponível para tirar dúvidas e validar soluções." },
  { t: "Crescimento conjunto", d: "Parceria de longo prazo com quem entrega resultado." },
];

const tipos = [
  "Empreiteira de obra civil",
  "Empreiteira de fundação / contenção",
  "Empresa de instalação elétrica",
  "Empresa de hidráulica",
  "Empresa de refrigeração / HVAC",
  "Pintura e acabamento",
  "Marcenaria sob medida",
  "Vidraçaria / esquadrias",
  "Outro",
];
---
<Base
  title="Quero ser parceiro — Costa Júnior"
  description="Empreiteiras e fornecedores: cadastre-se para ser parceiro Costa Júnior. Volume de demanda, pagamento em dia e suporte técnico."
>
  <section class="page-hero">
    <div class="container page-hero-content">
      <span class="hero-eyebrow">Para empreiteiras e fornecedores</span>
      <h1>Construa <span class="hl">conosco</span>.</h1>
      <p class="page-hero-sub">
        Buscamos empreiteiras, prestadores e fornecedores para integrar nossa rede de execução. Trabalhamos em todo o Brasil para clientes-âncora como Coca-Cola, Bradesco, Carrefour e RaiaDrogasil.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="text-align:center;max-width:680px;margin:0 auto 56px">
        <span class="kicker">Por que ser parceiro</span>
        <h2>O que oferecemos a quem trabalha com a gente</h2>
      </div>
      <div class="benef-grid">
        {beneficios.map(b => (
          <article class="benef-card">
            <h3>{b.t}</h3>
            <p>{b.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <div style="text-align:center;max-width:680px;margin:0 auto 40px">
        <span class="kicker">Cadastro de parceiros</span>
        <h2>Conte sobre sua empresa</h2>
        <p class="lead">Nosso time de suprimentos avalia cada cadastro. Resposta em até 5 dias úteis.</p>
      </div>

      <form id="parceiro-form" class="parc-form" novalidate>
        <h3 class="form-section">Empresa</h3>
        <div class="form-row">
          <label>
            <span>Razão social *</span>
            <input type="text" name="razao" required>
          </label>
          <label>
            <span>Nome fantasia</span>
            <input type="text" name="fantasia">
          </label>
        </div>
        <div class="form-row">
          <label>
            <span>CNPJ *</span>
            <input type="text" name="cnpj" required>
          </label>
          <label>
            <span>Tempo de mercado</span>
            <input type="text" name="anos" placeholder="Ex.: 8 anos">
          </label>
        </div>
        <label>
          <span>Tipo de serviço *</span>
          <select name="tipo" required>
            <option value="">Selecione…</option>
            {tipos.map(t => <option value={t}>{t}</option>)}
          </select>
        </label>
        <label>
          <span>Áreas de atuação (estados)</span>
          <input type="text" name="estados" placeholder="Ex.: SP, RJ, MG">
        </label>
        <label>
          <span>Principais clientes / referências</span>
          <textarea name="referencias" rows="3" placeholder="Empresas para as quais já prestou serviço"></textarea>
        </label>

        <h3 class="form-section">Contato</h3>
        <div class="form-row">
          <label>
            <span>Nome do responsável *</span>
            <input type="text" name="resp" required>
          </label>
          <label>
            <span>Cargo</span>
            <input type="text" name="cargo">
          </label>
        </div>
        <div class="form-row">
          <label>
            <span>E-mail *</span>
            <input type="email" name="email" required>
          </label>
          <label>
            <span>Telefone *</span>
            <input type="tel" name="telefone" required>
          </label>
        </div>

        <label class="checkbox">
          <input type="checkbox" name="lgpd" required>
          <span>Concordo com o tratamento dos meus dados conforme a <a href="/privacidade">Política de Privacidade</a>.</span>
        </label>

        <button type="submit" class="btn btn-primary">
          Enviar cadastro
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
        </button>

        <p id="parc-status" class="form-status" hidden></p>
      </form>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById("parceiro-form") as HTMLFormElement | null;
  const status = document.getElementById("parc-status") as HTMLParagraphElement | null;
  if (form && status) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const corpo = [
        `Empresa: ${data.get("razao")}`,
        `Nome fantasia: ${data.get("fantasia") || "—"}`,
        `CNPJ: ${data.get("cnpj")}`,
        `Tempo de mercado: ${data.get("anos") || "—"}`,
        `Tipo de serviço: ${data.get("tipo")}`,
        `Estados de atuação: ${data.get("estados") || "—"}`,
        ``,
        `Referências:`,
        `${data.get("referencias") || "—"}`,
        ``,
        `Responsável: ${data.get("resp")} (${data.get("cargo") || "sem cargo informado"})`,
        `E-mail: ${data.get("email")}`,
        `Telefone: ${data.get("telefone")}`
      ].join("\n");
      const assunto = `[Parceiro] ${data.get("razao")} — ${data.get("tipo")}`;
      window.location.href =
        `mailto:comercial@costajr.com.br?subject=${encodeURIComponent(assunto)}&body=${encodeURIComponent(corpo)}`;
      status.hidden = false;
      status.textContent = "Abrindo seu cliente de e-mail. Se nada acontecer, escreva para comercial@costajr.com.br.";
    });
  }
</script>

<style>
  .page-hero {
    position: relative;
    background:
      radial-gradient(circle at 78% 30%, rgba(196,30,58,.45) 0%, transparent 55%),
      linear-gradient(135deg, #1A1C20 0%, #2D2F36 60%, #3A1419 100%);
    color: #fff; overflow: hidden;
  }
  .page-hero-content { position: relative; padding: 96px 0 80px; max-width: 820px; }
  .hero-eyebrow {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand);
    border-left: 3px solid var(--brand); padding-left: 12px; margin-bottom: 24px;
  }
  .page-hero h1 { color: #fff; margin: 0 0 20px; }
  .page-hero h1 .hl { color: var(--brand); }
  .page-hero-sub { font-size: clamp(16px, 1.4vw, 18px); line-height: 1.7; color: #E5E7EB; max-width: 680px; margin: 0; }
  .kicker {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;
  }

  .benef-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
  }
  .benef-card {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 28px;
    border-left: 4px solid var(--brand);
  }
  .benef-card h3 { font-size: 17px; margin: 0 0 8px; }
  .benef-card p { color: var(--ink-mid); font-size: 14px; line-height: 1.6; margin: 0; }

  .parc-form {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 48px; display: grid; gap: 16px;
    max-width: 780px; margin: 0 auto;
    box-shadow: 0 4px 20px rgba(0,0,0,.04);
  }
  .form-section {
    margin: 16px 0 0; padding-bottom: 8px; border-bottom: 1px solid var(--border);
    font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brand);
    font-family: 'Montserrat', sans-serif; font-weight: 700;
  }
  .parc-form label { display: grid; gap: 6px; }
  .parc-form label > span {
    font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 13px;
    color: var(--ink); letter-spacing: 0.02em;
  }
  .parc-form input,
  .parc-form select,
  .parc-form textarea {
    font-family: 'Open Sans', sans-serif; font-size: 15px; padding: 12px 14px;
    border: 1px solid var(--border); border-radius: 6px; background: #fff; color: var(--ink);
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .parc-form input:focus,
  .parc-form select:focus,
  .parc-form textarea:focus {
    outline: 0; border-color: var(--brand); box-shadow: 0 0 0 3px rgba(196,30,58,.12);
  }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .checkbox { display: flex; gap: 10px; align-items: flex-start; font-size: 13px; color: var(--ink-mid); }
  .checkbox input { width: 16px; height: 16px; margin-top: 3px; }
  .checkbox a { color: var(--brand); border-bottom: 1px solid var(--brand-soft); }
  .form-status { margin: 12px 0 0; padding: 12px 14px; background: var(--brand-soft); color: var(--brand); border-radius: 6px; font-size: 14px; }

  @media (max-width: 900px) {
    .page-hero-content { padding: 64px 0 56px; }
    .parc-form { padding: 28px; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
