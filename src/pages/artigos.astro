---
import Base from "~/layouts/Base.astro";

// Artigos publicados — manutenção em arquivo Astro estático.
// Quando houver CMS/Supabase, substituir por listagem dinâmica.
const artigos: { slug: string; titulo: string; resumo: string; data: string; categoria: string }[] = [
  {
    slug: "quanto-custa-manutencao-predial",
    titulo: "Quanto custa manutenção predial em 2026? Guia de preços por m²",
    resumo: "Faixas reais de preço em SP, o que define o valor, e como evitar pegadinhas comuns ao contratar. Inclui tabela de referência por tamanho de loja.",
    data: "20/05/2026",
    categoria: "Manutenção Predial",
  },
  {
    slug: "manutencao-preventiva-vs-corretiva",
    titulo: "Manutenção preventiva vs corretiva: o comparativo que vai mudar sua decisão",
    resumo: "Comparativo direto com números — quanto cada estratégia custa por ano, riscos operacionais e quando faz sentido cada uma.",
    data: "20/05/2026",
    categoria: "Estratégia",
  },
  {
    slug: "como-escolher-empresa-manutencao-predial",
    titulo: "Como escolher empresa de manutenção predial: 7 critérios que evitam dor de cabeça",
    resumo: "Guia prático com 7 critérios objetivos para escolher prestador em SP. Inclui checklist para a primeira conversa e 5 sinais de alerta.",
    data: "20/05/2026",
    categoria: "Guia",
  },
];
---
<Base
  title="Artigos — Costa Júnior"
  description="Conteúdo técnico de engenharia, manutenção predial e construção. Em breve novidades."
>
  <section class="page-hero">
    <div class="container page-hero-content">
      <span class="hero-eyebrow">Conhecimento técnico</span>
      <h1>Artigos da <span class="hl">engenharia</span> que constrói.</h1>
      <p class="page-hero-sub">
        Estudos de caso, boas práticas em manutenção predial, fundação, contenção e gestão de obras corporativas.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {artigos.length === 0 ? (
        <div class="placeholder">
          <div class="placeholder-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h2>Em breve, nossos primeiros artigos</h2>
          <p class="lead">
            Estamos preparando conteúdo técnico de qualidade — fundação, contenção, manutenção predial e cases de obras corporativas. Volte em breve.
          </p>
          <a href="/contato" class="btn btn-outline">Quer um tema específico? Sugira</a>
        </div>
      ) : (
        <div class="artigos-grid">
          {artigos.map(a => (
            <article class="artigo-card">
              <span class="artigo-categoria">{a.categoria}</span>
              <h3><a href={`/artigos/${a.slug}`}>{a.titulo}</a></h3>
              <p>{a.resumo}</p>
              <span class="artigo-data">{a.data}</span>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .page-hero {
    position: relative;
    background:
      radial-gradient(circle at 78% 30%, rgba(196,30,58,.45) 0%, transparent 55%),
      linear-gradient(135deg, #1A1C20 0%, #2D2F36 60%, #3A1419 100%);
    color: #fff; overflow: hidden;
  }
  .page-hero-content { position: relative; padding: 96px 0 80px; max-width: 820px; }
  .hero-eyebrow {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand);
    border-left: 3px solid var(--brand); padding-left: 12px; margin-bottom: 24px;
  }
  .page-hero h1 { color: #fff; margin: 0 0 20px; }
  .page-hero h1 .hl { color: var(--brand); }
  .page-hero-sub { font-size: clamp(16px, 1.4vw, 18px); line-height: 1.7; color: #E5E7EB; max-width: 680px; margin: 0; }

  .placeholder {
    text-align: center; padding: 64px 24px;
    max-width: 600px; margin: 0 auto;
  }
  .placeholder-icon {
    width: 96px; height: 96px; border-radius: 50%;
    background: var(--brand-soft); color: var(--brand);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px;
  }
  .placeholder h2 { margin: 0 0 16px; }
  .placeholder p { margin: 0 0 24px; color: var(--ink-mid); }

  .artigos-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }
  .artigo-card {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 32px 28px;
    transition: all .2s ease;
  }
  .artigo-card:hover { transform: translateY(-3px); box-shadow: 0 12px 28px rgba(0,0,0,.06); }
  .artigo-categoria {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 11px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--brand);
    margin-bottom: 12px; display: inline-block;
  }
  .artigo-card h3 { margin: 0 0 12px; }
  .artigo-card p { color: var(--ink-mid); font-size: 14px; line-height: 1.65; margin: 0 0 16px; }
  .artigo-data { font-size: 12px; color: var(--ink-light); }

  @media (max-width: 900px) {
    .page-hero-content { padding: 64px 0 56px; }
  }
</style>
