---
import Base from "~/layouts/Base.astro";
import { supabaseAdmin } from "~/lib/supabase";
import { INCLUSOES_POR_DURACAO } from "~/lib/manut/planos-inclusos";

const { data: precificacao } = await supabaseAdmin()
  .from("manut_precificacao")
  .select("tipo_loja, label, preco_base, custo_especialidade")
  .order("ordem");

const tiposLoja = (precificacao ?? []).length > 0
  ? (precificacao as any[]).map(p => ({
      id: p.tipo_loja,
      label: p.label,
      descricao: "",
      precoBase: Number(p.preco_base),
    }))
  : [
      { id: "quiosque",  label: "Quiosque",      descricao: "", precoBase: 250 },
      { id: "ate40",     label: "Até 40 m²",     descricao: "", precoBase: 280 },
      { id: "41a80",     label: "41 a 80 m²",    descricao: "", precoBase: 300 },
      { id: "81a120",    label: "81 a 120 m²",   descricao: "", precoBase: 400 },
      { id: "121a250",   label: "121 a 250 m²",  descricao: "", precoBase: 650 },
    ];

const especialidades = [
  { id: "eletrica",   label: "Elétrica",   icone: "⚡", descricao: "Lâmpadas, tomadas, interruptores" },
  { id: "hidraulica", label: "Hidráulica", icone: "💧", descricao: "Vazamentos, torneiras, registros" },
  { id: "civil",      label: "Civil",      icone: "🏗", descricao: "Pintura, revestimentos, acabamentos" },
];
const custoEsp = Number((precificacao as any[])?.[0]?.custo_especialidade ?? 50);

// Escopo Geral de Manutenção — Detalhamento de Serviços Inclusos e Itens Mediante Orçamento
const escoposManutencao = [
  {
    id: "emergencial",
    icone: "⚠️",
    titulo: "Demanda Emergencial",
    inclusos: [
      "Reparos paliativos urgentes essenciais",
      "Foco em evitar riscos à segurança física",
      "Mitigação de impactos diretos na operação",
      "Estabilização imediata da infraestrutura",
    ],
    orcamento: "Serviços de alta complexidade (troca de quadro, telhado, forro, etc).",
  },
  {
    id: "hidraulica",
    icone: "💧",
    titulo: "Hidráulica",
    inclusos: [
      "Limpeza, desentupimento e vazamentos",
      "Ajuste de bóias e troca de válvulas",
      "Fixação de louças e vedação em geral",
      "Troca de sifões, torneiras e flexíveis",
      "Verificação de pressão do sistema",
    ],
    orcamento: "Desentupimento industrial/caminhão; troca integral de louças e metais.",
  },
  {
    id: "eletrica",
    icone: "⚡",
    titulo: "Elétrica",
    inclusos: [
      "Troca de lâmpadas, reatores e disjuntores",
      "Manutenção de luminárias e tomadas",
      "Reorganização de cabeamentos expostos",
      "Aperto de conexões em quadros e rede",
    ],
    orcamento: "Troca total de luminárias, novos pontos e substituição de letreiros.",
  },
  {
    id: "civil",
    icone: "🧱",
    titulo: "Civil & Acabamentos",
    inclusos: [
      "Substituição de fitas antiderrapantes",
      "Fixação simples e lavagem de toldos",
      "Pequenos reparos em pisos e forros",
      "Recolocação de placas e sinalizações",
      "Retoques de pintura interna (baixa criticidade)",
      "Limpeza trimestral de fachadas",
    ],
    orcamento: "Pinturas completas, troca de pisos/forros, mármores e granitos.",
  },
  {
    id: "ar",
    icone: "❄️",
    titulo: "Ar Condicionado",
    soOrcamento: true,
    inclusos: ["Categoria atendida exclusivamente sob demanda orçada."],
    orcamento: "Testes elétricos, pressão de gás, limpeza química, troca de filtros, bactericida, PMOC e ART.",
  },
  {
    id: "serralheria",
    icone: "🛠️",
    titulo: "Serralheria & Cobertura",
    soOrcamento: true,
    inclusos: ["Categoria atendida exclusivamente sob demanda orçada."],
    orcamento: "Telhados (vedação, limpeza), Portas de Aço (molas, motor, alinhamento) e Serralheria geral.",
  },
];
---
<Base
  title="Contratar manutenção predial — Costa Júnior"
  description="Manutenção preventiva por assinatura. Técnico vinculado, chamados ilimitados, visitas preventivas. Faça uma simulação grátis agora."
>

<!-- PROGRESS BAR -->
<div class="ctr-progress-wrap">
  <div class="ctr-progress">
    {[
      { n: 1, label: "Sua Loja" },
      { n: 2, label: "Simulação" },
      { n: 3, label: "Cadastro" },
      { n: 4, label: "Contrato" },
      { n: 5, label: "Pagamento" },
    ].map(s => (
      <div class={`ctr-step ${s.n === 1 ? "active" : ""}`} data-step={s.n}>
        <div class="ctr-step-circle">{s.n}</div>
        <div class="ctr-step-label">{s.label}</div>
      </div>
    ))}
    <div class="ctr-step-line"></div>
  </div>
</div>

<!-- WRAPPER -->
<div class="ctr-wrap">

  <!-- ── ETAPA 1: Dados da Loja ── -->
  <div class="ctr-card" id="etapa-1">
    <div class="ctr-card-header">
      <span class="ctr-n">1</span>
      <div>
        <h2>Dados da Sua Loja</h2>
        <p>Rápido e sem compromisso — veja o preço antes de decidir</p>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Nome completo do responsável *</label>
        <input type="text" id="e1-nome" placeholder="Nome e sobrenome" required>
      </div>
      <div class="form-group">
        <label>Telefone / WhatsApp *</label>
        <input type="tel" id="e1-tel" placeholder="(11) 99999-9999" required>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>E-mail *</label>
        <input type="email" id="e1-email" placeholder="email@empresa.com.br" required>
      </div>
      <div class="form-group">
        <label>Nome da Loja *</label>
        <input type="text" id="e1-loja" placeholder="Ex: LOJA ABC" required>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Tamanho da Loja *</label>
        <select id="e1-tamanho">
          {tiposLoja.map(t => <option value={t.id} data-preco={t.precoBase}>{t.label}</option>)}
        </select>
      </div>
    </div>

    <label class="form-label-block">Especialidades desejadas *</label>
    <div class="esp-grid">
      {especialidades.map((e, i) => (
        <label class={`esp-card ${i === 0 ? "checked" : ""}`} data-esp={e.id}>
          <input type="checkbox" name="especialidades" value={e.id} checked={i === 0}>
          <span class="esp-icone">{e.icone}</span>
          <strong>{e.label}</strong>
          <span class="esp-desc">{e.descricao}</span>
          <span class="esp-check">✓ Selecionado</span>
        </label>
      ))}
    </div>

    <!-- Escopo Geral de Manutenção -->
    <details class="escopo-block">
      <summary>
        <span class="escopo-summary-titulo">Escopo completo dos serviços</span>
        <span class="escopo-summary-sub">Detalhamento do que está incluso e o que é mediante orçamento</span>
        <span class="escopo-chevron">▾</span>
      </summary>
      <div class="escopo-grid">
        {escoposManutencao.map(area => (
          <article class={`escopo-card ${area.soOrcamento ? "escopo-orc" : ""}`}>
            <h4>
              <span class="escopo-icone">{area.icone}</span>
              {area.titulo}
            </h4>
            <ul class="escopo-inclusos">
              {area.inclusos.map(item => (
                area.soOrcamento
                  ? <li class="escopo-aviso">{item}</li>
                  : <li>{item}</li>
              ))}
            </ul>
            <div class="escopo-orcamento">
              <span class="escopo-orcamento-label">MEDIANTE ORÇAMENTO:</span>
              <span class="escopo-orcamento-texto">{area.orcamento}</span>
            </div>
          </article>
        ))}
      </div>
      <div class="escopo-rodape">
        <strong>Nota Comercial:</strong> a execução preventiva mensal é focada em reparos pontuais para manutenção da operação.
        <span class="escopo-medida">📐 1 m² / 2 peças</span>
      </div>
    </details>

    <div id="e1-alert" class="ctr-alert" style="display:none"></div>
    <div class="ctr-actions">
      <button class="btn btn-primary" id="btn-e1">Ver Simulação de Preço →</button>
    </div>
  </div>

  <!-- ── ETAPA 2: Simulação ── -->
  <div class="ctr-card" id="etapa-2" style="display:none">
    <div class="ctr-card-header">
      <span class="ctr-n">2</span>
      <div>
        <h2>Simulação de Preço</h2>
        <p>Veja o valor exato do seu plano</p>
      </div>
    </div>

    <div class="sim-box">
      <div class="sim-row"><span>Tipo de loja</span><strong id="sim-tipo">—</strong></div>
      <div class="sim-row"><span>Especialidades</span><strong id="sim-esps">—</strong></div>
      <div class="sim-row"><span>Preço base</span><strong id="sim-base">—</strong></div>
      <div class="sim-row" id="sim-extra-row"><span id="sim-extra-label">Especialidades extras</span><strong id="sim-extra">R$ 0</strong></div>
      <div class="sim-row" id="sim-cupom-row" style="display:none"><span id="sim-cupom-label">Cupom</span><strong id="sim-cupom-val" style="color:#22C55E">—</strong></div>
      <div class="sim-total">
        <span>Total mensal</span>
        <strong id="sim-total">—</strong>
      </div>
    </div>

    <!-- Cupom de desconto -->
    <div class="cupom-wrap">
      <label class="form-label-block" style="margin-bottom:8px">Cupom de desconto <span style="font-size:11px;font-weight:400;color:#9CA3AF">(opcional)</span></label>
      <div style="display:flex;gap:8px">
        <input type="text" id="cupomInput" placeholder="Digite o código" style="flex:1;text-transform:uppercase;padding:10px 14px;border:1.5px solid #E5E7EB;border-radius:6px;font-size:14px;outline:none">
        <button class="btn btn-outline" id="btnAplicarCupom" style="white-space:nowrap">Aplicar</button>
        <button class="btn btn-outline" id="btnRemoverCupom" style="display:none;color:#6B7280" title="Remover cupom">✕</button>
      </div>
      <div id="cupomMsg" style="display:none;margin-top:8px;font-size:13px;padding:8px 12px;border-radius:6px"></div>
    </div>

    <!-- Duração / desconto -->
    <div class="dur-titulo">Escolha a duração do plano</div>
    <div class="dur-grid">
      <label class="dur-card" data-meses="3" data-desc="5">
        <input type="radio" name="duracao" value="3" checked>
        <div class="dur-nome">Trimestral</div>
        <div class="dur-desc-tag">5% de desconto</div>
        <div class="dur-preco" id="dur-preco-3">—</div>
        <div class="dur-total" id="dur-total-3"></div>
        <ul class="dur-bonus">
          <li>3 visitas preventivas (1 por mês)</li>
          <li>+1 visita extra durante a vigência</li>
          <li>+1 chamado emergencial durante a vigência</li>
        </ul>
      </label>
      <label class="dur-card" data-meses="6" data-desc="10">
        <input type="radio" name="duracao" value="6">
        <div class="dur-nome">Semestral</div>
        <div class="dur-desc-tag">10% de desconto</div>
        <div class="dur-preco" id="dur-preco-6">—</div>
        <div class="dur-total" id="dur-total-6"></div>
        <ul class="dur-bonus">
          <li>6 visitas preventivas (1 por mês)</li>
          <li>+6 visitas extras durante a vigência</li>
          <li>+2 chamados emergenciais durante a vigência</li>
        </ul>
      </label>
      <label class="dur-card recomendado" data-meses="12" data-desc="15">
        <input type="radio" name="duracao" value="12">
        <div class="dur-badge">Melhor valor</div>
        <div class="dur-nome">Anual</div>
        <div class="dur-desc-tag">15% de desconto</div>
        <div class="dur-preco" id="dur-preco-12">—</div>
        <div class="dur-total" id="dur-total-12"></div>
        <ul class="dur-bonus">
          <li>12 visitas preventivas (1 por mês)</li>
          <li>+14 visitas extras durante a vigência</li>
          <li>+5 chamados emergenciais durante a vigência</li>
        </ul>
      </label>
    </div>

    <div class="sim-bullets">
      <div class="sim-bullet">✔ 1 visita preventiva mensal</div>
      <div class="sim-bullet">✔ Visitas extras e emergenciais inclusas conforme o plano</div>
      <div class="sim-bullet">✔ Chamados ilimitados via plataforma</div>
      <div class="sim-bullet">✔ Técnico responsável vinculado</div>
      <div class="sim-bullet">✔ Relatório mensal em PDF</div>
    </div>

    <div class="ctr-actions">
      <button class="btn btn-outline" onclick="irParaEtapa(1)">← Voltar</button>
      <button class="btn btn-primary" id="btn-e2">Quero contratar →</button>
    </div>
  </div>

  <!-- ── ETAPA 3: Cadastro ── -->
  <div class="ctr-card" id="etapa-3" style="display:none">
    <div class="ctr-card-header">
      <span class="ctr-n">3</span>
      <div>
        <h2>Dados de Cadastro</h2>
        <p>Precisamos dessas informações para formalizar o contrato</p>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>CNPJ ou CPF *</label>
        <input type="text" id="e3-cnpj" placeholder="00.000.000/0001-00" required>
      </div>
      <div class="form-group">
        <label>CEP</label>
        <input type="text" id="e3-cep" placeholder="00000-000">
      </div>
    </div>
    <div class="form-group">
      <label>Endereço completo</label>
      <input type="text" id="e3-end" placeholder="Rua, número, bairro">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Cidade</label>
        <input type="text" id="e3-cidade" placeholder="São Paulo">
      </div>
      <div class="form-group">
        <label>Estado</label>
        <select id="e3-uf">
          {["SP","RJ","MG","ES","PR","SC","RS","BA","GO","DF","MT","MS","PA","AM","CE","PE","RN","PB","AL","SE","PI","MA","TO","AC","AP","RO","RR"].map(uf => (
            <option value={uf} selected={uf === "SP"}>{uf}</option>
          ))}
        </select>
      </div>
    </div>

    <div id="e3-alert" class="ctr-alert" style="display:none"></div>
    <div class="ctr-actions">
      <button class="btn btn-outline" onclick="irParaEtapa(2)">← Voltar</button>
      <button class="btn btn-primary" id="btn-e3">Avançar para o Contrato →</button>
    </div>
  </div>

  <!-- ── ETAPA 4: Contrato ── -->
  <div class="ctr-card" id="etapa-4" style="display:none">
    <div class="ctr-card-header">
      <span class="ctr-n">4</span>
      <div>
        <h2>Contrato de Serviço</h2>
        <p>Leia atentamente antes de prosseguir</p>
      </div>
    </div>

    <!-- Dados do contratante preenchidos automaticamente -->
    <div class="contratante-block">
      <div class="contratante-titulo">CONTRATANTE</div>
      <div class="contratante-linha"><span>Empresa</span><strong id="ctr-empresa">—</strong></div>
      <div class="contratante-linha"><span>CNPJ / CPF</span><strong id="ctr-cnpj-disp">—</strong></div>
      <div class="contratante-linha"><span>Endereço</span><strong id="ctr-end-disp">—</strong></div>
      <div class="contratante-linha"><span>Responsável</span><strong id="ctr-resp-disp">—</strong></div>
    </div>

    <div class="contrato-box" id="contrato-texto">
      <div class="ctr-loading">Carregando contrato...</div>
    </div>

    <label class="aceite-label">
      <input type="checkbox" id="aceite-contrato">
      <span>Li e concordo com os termos do contrato de prestação de serviços acima.</span>
    </label>
    <label class="aceite-label">
      <input type="checkbox" id="aceite-lgpd">
      <span>Concordo com o tratamento dos meus dados conforme a <a href="/privacidade" target="_blank">Política de Privacidade</a>.</span>
    </label>

    <div id="e4-alert" class="ctr-alert" style="display:none"></div>
    <div class="ctr-actions">
      <button class="btn btn-outline" onclick="irParaEtapa(3)">← Voltar</button>
      <button class="btn btn-primary" id="btn-e4">Ir para pagamento →</button>
    </div>
  </div>

  <!-- ── ETAPA 5: Pagamento ── -->
  <div class="ctr-card" id="etapa-5" style="display:none">
    <div class="ctr-card-header">
      <span class="ctr-n">5</span>
      <div>
        <h2>Finalizar Pagamento</h2>
        <p>Estamos quase lá! Revise o resumo e confirme</p>
      </div>
    </div>

    <div class="resumo-final" id="resumo-final"></div>

    <div id="e5-alert" class="ctr-alert" style="display:none"></div>
    <div id="e5-loading" style="display:none" class="ctr-loading">Processando seu cadastro...</div>
    <div class="ctr-actions" id="e5-actions">
      <button class="btn btn-outline" onclick="irParaEtapa(4)">← Voltar</button>
      <button class="btn btn-primary" id="btn-e5">Confirmar e ir para pagamento →</button>
    </div>

    <!-- Selo de pagamento seguro Mercado Pago -->
    <div class="mp-trust" role="note" aria-label="Pagamento seguro Mercado Pago">
      <div class="mp-trust-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <div class="mp-trust-text">
        <strong>Pagamento processado com segurança pelo Mercado Pago</strong>
        <span>Seus dados de cartão não passam pelo nosso servidor. Aceitamos Pix, cartão (até 12×) e boleto. <a href="https://www.mercadopago.com.br/ajuda/conheca-os-meios-de-pagamento-seguros-do-mp_4147" target="_blank" rel="noopener noreferrer">Saiba mais</a></span>
      </div>
    </div>

    <div id="e5-sucesso" style="display:none" class="ctr-sucesso">
      <div class="sucesso-icone">✓</div>
      <h3>Cadastro realizado!</h3>
      <p id="e5-sucesso-msg">Redirecionando para o pagamento...</p>
      <p style="margin-top:20px">
        <a href="/manutencao/contratar" style="font-size:13px;color:#9CA3AF;text-decoration:underline">
          Precisa corrigir algum dado? Clique aqui para recomeçar.
        </a>
      </p>
    </div>
  </div>

</div><!-- /ctr-wrap -->

</Base>

<script define:vars={{ tiposLoja, especialidades, custoEsp, INCLUSOES_POR_DURACAO }}>
  // ─── Estado global ───────────────────────────────────────────────
  let leadId = null;
  let etapaAtual = 1;
  let cupomAtivo = null; // { id, codigo, descricao, desconto_percentual }
  const dados = {
    nome: "", email: "", telefone: "", nomeLoja: "",
    tamanho: "", especialidades: [],
    cnpj: "", cep: "", endereco: "", cidade: "", uf: "SP",
    valorMensal: 0, planoLabel: "",
    duracaoMeses: 3, desconto: 5,
  };

  const duracaoLabels = { 1: "mensal", 3: "trimestral", 6: "semestral", 12: "anual" };

  // ─── Helpers ─────────────────────────────────────────────────────
  const $ = id => document.getElementById(id);
  const fmtMoney = v => "R$ " + Number(v).toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  function calcular() {
    const sel = document.querySelector('#e1-tamanho option:checked');
    const preco = sel ? Number(sel.dataset.preco || sel.value) : 280;
    const tipo = tiposLoja.find(t => t.id === document.getElementById("e1-tamanho").value) || tiposLoja[1];
    const esps = Array.from(document.querySelectorAll('input[name="especialidades"]:checked')).map(c => c.value);
    const extras = Math.max(0, esps.length - 1) * custoEsp;
    const total = preco + extras;
    dados.valorMensal = total;
    dados.especialidades = esps;
    dados.tamanho = tipo.id;
    dados.planoLabel = `${tipo.label} · ${esps.map(id => especialidades.find(e => e.id === id)?.label || id).join(" + ")}`;
    return { tipo, esps, preco, extras, total };
  }

  // ─── Navegação de etapas ─────────────────────────────────────────
  window.irParaEtapa = function(n) {
    etapaAtual = n;
    [1,2,3,4,5].forEach(i => {
      const card = $(`etapa-${i}`);
      if (card) card.style.display = i === n ? "" : "none";
      const stepEl = document.querySelector(`.ctr-step[data-step="${i}"]`);
      if (stepEl) {
        stepEl.classList.toggle("active", i === n);
        stepEl.classList.toggle("done", i < n);
      }
    });
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  // ─── Persistir lead ──────────────────────────────────────────────
  const etapaToPasso = { "contato_feito": 1, "proposta_enviada": 2, "negociando": 3, "convertido": 5 };
  async function salvarLead(etapa, extra = {}) {
    try {
      const res = await fetch("/api/manut/leads", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          nome: dados.nome,
          nome_loja: dados.nomeLoja,
          email: dados.email,
          telefone: dados.telefone,
          plano: dados.planoLabel,
          valor: dados.valorMensal,
          etapa,
          passo_wizard: etapaToPasso[etapa] ?? null,
          ...extra,
        }),
      });
      const d = await res.json();
      if (d.id) leadId = d.id;
    } catch {}
  }

  // ─── Máscaras de input ───────────────────────────────────────────
  $("e1-tel").addEventListener("input", (e) => {
    let v = e.target.value.replace(/\D/g, "").slice(0, 11);
    if (v.length > 6) v = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7)}`;
    else if (v.length > 2) v = `(${v.slice(0,2)}) ${v.slice(2)}`;
    e.target.value = v;
  });

  $("e3-cnpj").addEventListener("input", (e) => {
    let v = e.target.value.replace(/\D/g, "").slice(0, 14);
    if (v.length > 12) v = `${v.slice(0,2)}.${v.slice(2,5)}.${v.slice(5,8)}/${v.slice(8,12)}-${v.slice(12)}`;
    else if (v.length > 8) v = `${v.slice(0,2)}.${v.slice(2,5)}.${v.slice(5,8)}/${v.slice(8)}`;
    else if (v.length > 5) v = `${v.slice(0,2)}.${v.slice(2,5)}.${v.slice(5)}`;
    else if (v.length > 2) v = `${v.slice(0,2)}.${v.slice(2)}`;
    e.target.value = v;
  });

  $("e3-cep").addEventListener("input", (e) => {
    let v = e.target.value.replace(/\D/g, "").slice(0, 8);
    if (v.length > 5) v = `${v.slice(0,5)}-${v.slice(5)}`;
    e.target.value = v;
  });

  // ─── ETAPA 1 ─────────────────────────────────────────────────────
  // Visual das especialidades
  document.querySelectorAll('.esp-card').forEach(card => {
    card.addEventListener("click", () => {
      const cb = card.querySelector("input[type=checkbox]");
      cb.checked = !cb.checked;
      card.classList.toggle("checked", cb.checked);
    });
  });

  $("btn-e1").addEventListener("click", async () => {
    const nome = $("e1-nome").value.trim();
    const tel  = $("e1-tel").value.trim();
    const email= $("e1-email").value.trim();
    const loja = $("e1-loja").value.trim();
    const alert = $("e1-alert");

    if (!nome || !tel || !email || !loja) {
      alert.textContent = "Preencha todos os campos obrigatórios.";
      alert.style.display = "";
      return;
    }
    if (nome.trim().split(/\s+/).filter(Boolean).length < 2) {
      alert.textContent = "Por favor, informe o nome completo (nome e sobrenome).";
      alert.style.display = "";
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      alert.textContent = "E-mail inválido.";
      alert.style.display = "";
      return;
    }
    const { esps } = calcular();
    if (esps.length === 0) {
      alert.textContent = "Selecione ao menos uma especialidade.";
      alert.style.display = "";
      return;
    }
    alert.style.display = "none";
    dados.nome = nome; dados.telefone = tel; dados.email = email; dados.nomeLoja = loja;

    // Salva lead assim que preenche etapa 1
    await salvarLead("contato_feito");

    // Monta simulação
    const { tipo, esps: espsNomes, preco, extras, total } = calcular();
    const espLabels = espsNomes.map(id => especialidades.find(e => e.id === id)?.label || id);
    $("sim-tipo").textContent = tipo.label;
    $("sim-esps").textContent = espLabels.join(", ");
    $("sim-base").textContent = fmtMoney(preco);
    $("sim-extra-label").textContent = extras > 0 ? `+${espsNomes.length - 1} especialidade(s) extra` : "Sem especialidades extras";
    $("sim-extra").textContent = fmtMoney(extras);
    $("sim-extra-row").style.opacity = extras > 0 ? "1" : "0.4";
    $("sim-total").textContent = fmtMoney(total);

    // Preenche cards de duração
    atualizarDuracao();
    irParaEtapa(2);
  });

  // ─── Duração ─────────────────────────────────────────────────────
  function precoFinal(base, durDesc, cupDesc) {
    return base * (1 - durDesc / 100) * (1 - cupDesc / 100);
  }

  // Calcula o valor total do plano considerando que o desconto do cupom
  // só vale por `mesesCupom` meses (não por todos os `mesesPlano`).
  // Desconto de duração (durDesc) continua valendo em todos os meses (é da assinatura).
  function calcularValorTotalReal(base, durDesc, cupDesc, mesesPlano, mesesCupom) {
    const mensalSemCupom = base * (1 - durDesc / 100);
    const mensalComCupom = mensalSemCupom * (1 - cupDesc / 100);
    const mc = Math.max(0, Math.min(mesesCupom || 0, mesesPlano));
    const ms = mesesPlano - mc;
    return Math.round((mensalComCupom * mc + mensalSemCupom * ms) * 100) / 100;
  }

  function atualizarDuracao() {
    const base = dados.valorMensal;
    const cupDesc = cupomAtivo ? Number(cupomAtivo.desconto_percentual) : 0;
    [3, 6, 12].forEach(m => {
      const durDesc = { 3: 5, 6: 10, 12: 15 }[m];
      const final = precoFinal(base, durDesc, cupDesc);
      const totalPeriodo = final * m;
      const el = $(`dur-preco-${m}`);
      const elT = $(`dur-total-${m}`);
      if (el) el.textContent = fmtMoney(final) + "/mês";
      if (elT) elT.textContent = `Total: ${fmtMoney(totalPeriodo)}`;
    });
    atualizarVisualDuracao();
  }

  function atualizarVisualDuracao() {
    document.querySelectorAll(".dur-card").forEach(card => {
      const rb = card.querySelector("input[type=radio]");
      card.classList.toggle("checked", rb?.checked);
    });
    const sel = document.querySelector("input[name=duracao]:checked");
    if (sel) {
      const m = parseInt(sel.value);
      const durDesc = { 3: 5, 6: 10, 12: 15 }[m] || 0;
      const cupDesc = cupomAtivo ? Number(cupomAtivo.desconto_percentual) : 0;
      dados.duracaoMeses = m;
      dados.desconto = durDesc;
      const final = precoFinal(dados.valorMensal, durDesc, cupDesc);

      // Atualiza total exibido
      let totalStr = fmtMoney(final) + `/mês · ${duracaoLabels[m]}`;
      $("sim-total").textContent = totalStr;

      // Linha de cupom no sim-box
      const cupomRow = $("sim-cupom-row");
      if (cupomAtivo && cupDesc > 0) {
        const cupDur = Number(cupomAtivo.duracao_meses || 1);
        const durStr = (cupDur > 1 && cupDur < m) ? ` × ${cupDur} ${cupDur === 1 ? "mês" : "meses"}` : "";
        $("sim-cupom-label").textContent = `Cupom ${cupomAtivo.codigo}`;
        $("sim-cupom-val").textContent = `-${cupDesc}%${durStr}`;
        cupomRow.style.display = "";
      } else {
        cupomRow.style.display = "none";
      }
    }
  }

  document.querySelectorAll(".dur-card").forEach(card => {
    card.addEventListener("click", () => {
      const rb = card.querySelector("input");
      if (rb) { rb.checked = true; atualizarVisualDuracao(); }
    });
  });

  // ─── ETAPA 2 ─────────────────────────────────────────────────────

  // Validação e aplicação de cupom
  $("btnAplicarCupom").addEventListener("click", async () => {
    const codigo = $("cupomInput").value.trim().toUpperCase();
    const msgEl = $("cupomMsg");
    if (!codigo) return;
    $("btnAplicarCupom").disabled = true;
    $("btnAplicarCupom").textContent = "...";
    try {
      const res = await fetch(`/api/manut/cupom?codigo=${encodeURIComponent(codigo)}`);
      const d = await res.json();
      if (d.valido) {
        cupomAtivo = d;
        msgEl.style.background = "#F0FDF4";
        msgEl.style.color = "#15803D";
        msgEl.textContent = `✓ ${d.descricao || "Cupom válido"} — ${d.desconto_percentual}% de desconto aplicado`;
        msgEl.style.display = "";
        $("btnRemoverCupom").style.display = "";
        atualizarDuracao();
      } else {
        const motivos = { nao_encontrado: "Cupom não encontrado.", expirado: "Este cupom está expirado.", esgotado: "Este cupom já atingiu o limite de usos." };
        cupomAtivo = null;
        msgEl.style.background = "#FEF2F2";
        msgEl.style.color = "#B91C1C";
        msgEl.textContent = motivos[d.motivo] || "Cupom inválido.";
        msgEl.style.display = "";
        $("btnRemoverCupom").style.display = "none";
        atualizarDuracao();
      }
    } catch {
      msgEl.style.background = "#FEF2F2";
      msgEl.style.color = "#B91C1C";
      msgEl.textContent = "Erro ao validar cupom. Tente novamente.";
      msgEl.style.display = "";
    } finally {
      $("btnAplicarCupom").disabled = false;
      $("btnAplicarCupom").textContent = "Aplicar";
    }
  });

  $("btnRemoverCupom").addEventListener("click", () => {
    cupomAtivo = null;
    $("cupomInput").value = "";
    $("cupomMsg").style.display = "none";
    $("btnRemoverCupom").style.display = "none";
    atualizarDuracao();
  });

  // Pré-preenche cupom se vier por query string (?cupom=XXX) — ex.: cliente vindo da
  // tela "adicionar nova loja", ou indicação enviada por amigo
  try {
    const params = new URLSearchParams(window.location.search);
    const cupomQS = params.get("cupom");
    if (cupomQS) {
      $("cupomInput").value = cupomQS.toUpperCase();
      // Aplica automaticamente quando o usuário chegar na etapa 2 (input já existe agora)
      setTimeout(() => $("btnAplicarCupom").click(), 200);
    }
  } catch {}

  $("btn-e2").addEventListener("click", async () => {
    const m = dados.duracaoMeses;
    const durDesc = dados.desconto;
    const cupDesc = cupomAtivo ? Number(cupomAtivo.desconto_percentual) : 0;
    const cupDur = cupomAtivo ? Number(cupomAtivo.duracao_meses || 1) : 0;
    const baseOriginal = dados.valorMensal;
    // valorMensal mostrado: preço cheio com cupom (representa o valor durante o período do cupom)
    dados.valorMensal = precoFinal(baseOriginal, durDesc, cupDesc);
    // valorTotal real: respeita a duração do cupom (só desconta nos N meses, não em todos)
    dados.valorTotal = calcularValorTotalReal(baseOriginal, durDesc, cupDesc, m, cupDur);
    dados.planoLabel = `${dados.planoLabel} · ${duracaoLabels[m]}`;
    if (cupomAtivo) {
      const sufixoDur = (cupDur && cupDur < m) ? ` (${cupDur}/${m} mes${cupDur === 1 ? "" : "es"})` : "";
      dados.planoLabel += ` · Cupom ${cupomAtivo.codigo}${sufixoDur}`;
    }
    await salvarLead("proposta_enviada");
    irParaEtapa(3);
  });

  // ─── ETAPA 3 ─────────────────────────────────────────────────────
  $("btn-e3").addEventListener("click", async () => {
    const cnpj = $("e3-cnpj").value.trim();
    if (!cnpj) {
      const a = $("e3-alert");
      a.textContent = "CNPJ ou CPF é obrigatório.";
      a.style.display = "";
      return;
    }
    $("e3-alert").style.display = "none";
    dados.cnpj    = cnpj;
    dados.cep     = $("e3-cep").value.trim();
    dados.endereco= $("e3-end").value.trim();
    dados.cidade  = $("e3-cidade").value.trim();
    dados.uf      = $("e3-uf").value;

    await salvarLead("negociando");

    // Preenche bloco contratante
    const endFull2 = [dados.endereco, dados.cidade, dados.uf].filter(Boolean).join(", ") || "—";
    $("ctr-empresa").textContent = dados.nomeLoja || "—";
    $("ctr-cnpj-disp").textContent = dados.cnpj || "—";
    $("ctr-end-disp").textContent = endFull2;
    $("ctr-resp-disp").textContent = dados.nome || "—";

    // Carrega contrato
    const contratoBox = $("contrato-texto");
    contratoBox.innerHTML = '<div class="ctr-loading">Carregando contrato...</div>';
    try {
      const res = await fetch("/api/manut/contrato");
      const d = await res.json();
      if (d.texto && d.texto.trim()) {
        const endFull = [dados.endereco, dados.cidade, dados.uf].filter(Boolean).join(", ") || "—";
        const dataHoje = new Date().toLocaleDateString("pt-BR");
        const textoPreenchido = d.texto
          .replace(/\{\{RESPONSAVEL\}\}/g, dados.nome || "—")
          .replace(/\{\{NOME_LOJA\}\}/g, dados.nomeLoja || "—")
          .replace(/\{\{CNPJ\}\}/g, dados.cnpj || "—")
          .replace(/\{\{ENDERECO\}\}/g, endFull)
          .replace(/\{\{EMAIL\}\}/g, dados.email || "—")
          .replace(/\{\{TELEFONE\}\}/g, dados.telefone || "—")
          .replace(/\{\{DATA\}\}/g, dataHoje)
          .replace(/\[Nome da empresa\]/gi, dados.nomeLoja || "—")
          .replace(/\[Nome do Responsável\]/gi, dados.nome || "—")
          .replace(/^(CNPJ[^:\n]*:\s*)\[\S{1,10}\]/gim, `$1${dados.cnpj || "—"}`)
          .replace(/^(Endere[çc]o[^:\n]*:\s*)\[\S{1,10}\]/gim, `$1${endFull}`)
          .replace(/^(Respons[aá]vel[^:\n]*:\s*)\[\S{1,10}\]/gim, `$1${dados.nome || "—"}`)
          .replace(/\[\S{1,10}\]/g, "—");
        contratoBox.innerHTML = `<pre style="white-space:pre-wrap;font-family:inherit;font-size:13px;line-height:1.7">${textoPreenchido}</pre>`;
      } else {
        contratoBox.innerHTML = `<div class="ctr-sem-contrato">
          <strong>Contrato de Prestação de Serviços de Manutenção Predial</strong><br><br>
          O contrato completo será enviado por e-mail após a confirmação do pagamento.<br>
          Ao prosseguir, você concorda com os termos padrão de prestação de serviços da Costa Júnior Engenharia e Construções LTDA.<br><br>
          <em>CNPJ: 07.132.942/0001-72 — Av. Eng. Luís Carlos Berrini, 1140 — 7º andar, Brooklin, São Paulo/SP</em>
        </div>`;
      }
    } catch {
      contratoBox.innerHTML = '<div class="ctr-sem-contrato">Não foi possível carregar o contrato. Prossiga — ele será enviado por e-mail.</div>';
    }

    irParaEtapa(4);
  });

  // ─── ETAPA 4 ─────────────────────────────────────────────────────
  $("btn-e4").addEventListener("click", () => {
    const a = $("e4-alert");
    if (!$("aceite-contrato").checked || !$("aceite-lgpd").checked) {
      a.textContent = "Você precisa aceitar o contrato e a política de privacidade para continuar.";
      a.style.display = "";
      return;
    }
    a.style.display = "none";

    // Monta resumo final
    const inc = INCLUSOES_POR_DURACAO[dados.duracaoMeses] || { extras: 0, emergenciais: 0 };
    const inclusoesStr = inc.extras > 0 || inc.emergenciais > 0
      ? `${inc.extras} visita${inc.extras !== 1 ? "s" : ""} extra${inc.extras !== 1 ? "s" : ""} + ${inc.emergenciais} ${inc.emergenciais === 1 ? "emergencial" : "emergenciais"}`
      : "—";
    $("resumo-final").innerHTML = `
      <div class="resumo-linha"><span>Responsável</span><strong>${dados.nome}</strong></div>
      <div class="resumo-linha"><span>E-mail / Login</span><strong>${dados.email}</strong></div>
      <div class="resumo-linha"><span>Loja</span><strong>${dados.nomeLoja}</strong></div>
      <div class="resumo-linha"><span>Telefone</span><strong>${dados.telefone}</strong></div>
      <div class="resumo-linha"><span>Plano</span><strong>${dados.planoLabel}</strong></div>
      <div class="resumo-linha"><span>Inclusos no plano</span><strong style="color:#15803D">${inclusoesStr}</strong></div>
      <div class="resumo-linha resumo-total"><span>Valor mensal</span><strong>${fmtMoney(dados.valorMensal)}</strong></div>
      <div class="resumo-linha" style="background:#F0FDF4"><span>Total ${duracaoLabels[dados.duracaoMeses]} (${dados.duracaoMeses}x)</span><strong style="color:#15803D;font-family:'Montserrat',sans-serif;font-size:18px">${fmtMoney(dados.valorTotal)}</strong></div>
    `;
    irParaEtapa(5);
  });

  // ─── ETAPA 5 ─────────────────────────────────────────────────────
  $("btn-e5").addEventListener("click", async () => {
    const a = $("e5-alert");
    a.style.display = "none";
    $("e5-actions").style.display = "none";
    $("e5-loading").style.display = "";

    const esps = dados.especialidades;
    const payload = {
      loja: {
        email: dados.email,
        nomeResp: dados.nome,
        nomeLoja: dados.nomeLoja,
        telefone: dados.telefone,
        especialidades: esps,
      },
      plano: {
        id: `${dados.tamanho}-${esps.join("_")}`,
        nome: dados.planoLabel,
        valorMensal: dados.valorMensal,
        valorTotal: dados.valorTotal,
        duracaoMeses: dados.duracaoMeses,
        visitas: 1,
      },
      cadastro: {
        cnpjCpf: dados.cnpj,
        endereco: dados.endereco || undefined,
        cidade: dados.cidade || undefined,
        uf: dados.uf || undefined,
        cep: dados.cep || undefined,
      },
      cupom: cupomAtivo?.codigo ? { codigo: cupomAtivo.codigo } : undefined,
    };

    try {
      const res = await fetch("/api/manut/contratar", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      const d = await res.json();
      if (!res.ok || !d.ok) throw new Error(d?.error || "Erro ao processar");

      // Atualiza lead para convertido
      await salvarLead("convertido");

      $("e5-loading").style.display = "none";
      $("e5-sucesso").style.display = "";
      if (d.linkPagamento) {
        $("e5-sucesso-msg").innerHTML = `Seu cadastro foi criado com sucesso!<br><br>
          <a href="${d.linkPagamento}" target="_blank" rel="noopener" class="btn btn-primary" style="display:inline-block;font-size:15px;padding:12px 28px">
            Ir para o pagamento →
          </a>
          <br><small style="color:#9CA3AF;margin-top:8px;display:block">O link também foi enviado por e-mail.</small>`;
      } else {
        const motivo = d.mpMotivo ? ` (${d.mpMotivo})` : "";
        $("e5-sucesso-msg").innerHTML = `Cadastro realizado! Houve um problema ao gerar o link de pagamento${motivo}.<br>
          <small style="color:#9CA3AF">Entre em contato: <a href="mailto:comercial@costajr.com.br" style="color:#C41E3A">comercial@costajr.com.br</a></small>`;
      }
    } catch (err) {
      $("e5-loading").style.display = "none";
      $("e5-actions").style.display = "";
      a.textContent = "Não foi possível processar agora. Tente novamente ou entre em contato: comercial@costajr.com.br";
      a.style.display = "";
    }
  });
</script>

<style>
  /* ── Progress bar ── */
  .ctr-progress-wrap {
    background: #1E2128; padding: 20px 0;
  }
  .ctr-progress {
    max-width: 640px; margin: 0 auto;
    display: flex; align-items: flex-start; justify-content: space-between;
    position: relative; padding: 0 24px;
  }
  .ctr-step-line {
    position: absolute; top: 18px; left: 56px; right: 56px;
    height: 2px; background: #374151; z-index: 0;
  }
  .ctr-step {
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    position: relative; z-index: 1;
  }
  .ctr-step-circle {
    width: 36px; height: 36px; border-radius: 50%;
    background: #374151; color: #9CA3AF;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 14px;
    transition: all .2s;
  }
  .ctr-step.active .ctr-step-circle { background: #C41E3A; color: #fff; }
  .ctr-step.done .ctr-step-circle { background: #22C55E; color: #fff; }
  .ctr-step-label {
    font-size: 11px; font-weight: 600; color: #6B7280;
    font-family: 'Montserrat', sans-serif; text-transform: uppercase; letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .ctr-step.active .ctr-step-label { color: #C41E3A; }
  .ctr-step.done .ctr-step-label { color: #22C55E; }

  /* ── Wrap & Card ── */
  .ctr-wrap {
    background: #F4F6F9; min-height: calc(100vh - 80px);
    padding: 40px 24px; display: flex; flex-direction: column; align-items: center;
  }
  .ctr-card {
    background: #fff; border-radius: 12px; border: 1px solid #E5E7EB;
    padding: 36px; width: 100%; max-width: 700px;
    box-shadow: 0 2px 16px rgba(0,0,0,.06);
  }
  .ctr-card-header {
    display: flex; align-items: flex-start; gap: 16px; margin-bottom: 28px;
  }
  .ctr-n {
    width: 40px; height: 40px; border-radius: 50%;
    background: #C41E3A; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 16px;
    flex-shrink: 0;
  }
  .ctr-card-header h2 { margin: 0 0 4px; font-size: 20px; }
  .ctr-card-header p { margin: 0; color: #5B5F6B; font-size: 14px; }

  /* ── Form ── */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { margin-bottom: 16px; }
  .form-group label, .form-label-block { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; color: #2D2F36; }
  .form-label-block { margin-bottom: 12px; }
  .form-group input, .form-group select {
    width: 100%; padding: 10px 14px; border: 1.5px solid #E5E7EB;
    border-radius: 6px; font-size: 14px; font-family: 'Open Sans', sans-serif;
    color: #2D2F36; outline: none; transition: border .15s;
  }
  .form-group input:focus, .form-group select:focus { border-color: #C41E3A; }

  /* ── Especialidades ── */
  .esp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 24px; }
  .esp-card {
    border: 2px solid #E5E7EB; border-radius: 10px; padding: 18px 14px;
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    cursor: pointer; transition: all .15s; text-align: center; user-select: none;
  }
  .esp-card input { display: none; }
  .esp-icone { font-size: 28px; }
  .esp-card strong { font-size: 14px; font-family: 'Montserrat', sans-serif; }
  .esp-desc { font-size: 12px; color: #6B7280; }
  .esp-check { font-size: 11px; font-weight: 700; color: #C41E3A; display: none; }
  .esp-card.checked { border-color: #C41E3A; background: rgba(196,30,58,.05); }
  .esp-card.checked .esp-check { display: block; }
  .esp-card:hover { border-color: #C41E3A; }

  /* ── Escopo de manutenção ── */
