---
import Base from "~/layouts/Base.astro";

// PLACEHOLDER de planos — Adriana, ajustar valores reais antes de divulgar
const planos = [
  {
    id: "essencial",
    nome: "Essencial",
    valorMensal: 890,
    visitas: 1,
    destaque: false,
    bullets: [
      "1 visita preventiva mensal",
      "Chamados ilimitados via plataforma",
      "Técnico responsável vinculado",
      "Relatório mensal em PDF",
      "Suporte em horário comercial",
    ],
  },
  {
    id: "completo",
    nome: "Completo",
    valorMensal: 1490,
    visitas: 2,
    destaque: true,
    bullets: [
      "2 visitas preventivas mensais",
      "Chamados ilimitados via plataforma",
      "Técnico responsável vinculado",
      "Relatório mensal + checklist técnico",
      "Suporte em horário comercial",
      "Aprovação de orçamentos online",
    ],
  },
  {
    id: "premium",
    nome: "Premium",
    valorMensal: 2290,
    visitas: 4,
    destaque: false,
    bullets: [
      "4 visitas preventivas mensais",
      "Chamados ilimitados + plantão 24/7",
      "Técnico exclusivo dedicado",
      "Relatório mensal + dashboard online",
      "Engenharia consultiva inclusa",
      "Aprovação de orçamentos online",
    ],
  },
];

const especialidadesLista = ["Elétrica", "Hidráulica", "Civil", "Refrigeração / HVAC", "Pintura", "Marcenaria"];
---
<Base
  title="Contratar manutenção predial — Costa Júnior"
  description="Plataforma digital de manutenção predial. Técnico vinculado, chamados ilimitados, visitas preventivas e assinatura via Mercado Pago. Monte seu plano em 2 minutos."
>
  <section class="page-hero">
    <div class="container page-hero-content">
      <span class="hero-eyebrow">Manutenção predial sem dor de cabeça</span>
      <h1>Sua loja sob cuidado da <span class="hl">engenharia certa</span>.</h1>
      <p class="page-hero-sub">
        Técnico responsável vinculado, chamados ilimitados, visitas preventivas e relatórios em PDF. Pagamento via Mercado Pago — assinatura mensal automatizada.
      </p>
    </div>
  </section>

  <!-- 1. PLANOS -->
  <section class="section">
    <div class="container">
      <div style="text-align:center;max-width:680px;margin:0 auto 56px">
        <span class="kicker">1. Escolha seu plano</span>
        <h2>Plano sob medida pro seu metro quadrado</h2>
        <p class="lead">Você pode mudar de plano a qualquer momento. Sem fidelidade.</p>
      </div>

      <div class="planos-grid">
        {planos.map(p => (
          <article class={`plano-card ${p.destaque ? "destaque" : ""}`} data-plano={p.id}>
            {p.destaque && <span class="plano-badge">Mais escolhido</span>}
            <h3>{p.nome}</h3>
            <div class="plano-preco">
              <span class="moeda">R$</span>
              <strong>{p.valorMensal.toLocaleString("pt-BR")}</strong>
              <span class="periodo">/mês</span>
            </div>
            <p class="plano-visitas">{p.visitas} {p.visitas === 1 ? "visita" : "visitas"} preventiva{p.visitas === 1 ? "" : "s"}/mês</p>
            <ul>
              {p.bullets.map(b => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <button type="button" class={`btn ${p.destaque ? "btn-primary" : "btn-outline"} plano-cta`} data-plano-id={p.id}>
              Escolher {p.nome}
            </button>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 2. FORMULÁRIO -->
  <section class="section section-soft">
    <div class="container">
      <div style="text-align:center;max-width:680px;margin:0 auto 40px">
        <span class="kicker">2. Cadastre sua loja</span>
        <h2>Dados pra gente preparar tudo</h2>
        <p class="lead">A senha de acesso ao Portal do Cliente é gerada automaticamente após o pagamento.</p>
      </div>

      <form id="contratar-form" class="contratar-form" novalidate>
        <input type="hidden" name="planoId" id="planoId" required>

        <h3 class="form-section">Loja / unidade</h3>
        <div class="form-row">
          <label>
            <span>Nome da loja *</span>
            <input type="text" name="nomeLoja" required>
          </label>
          <label>
            <span>Tamanho aproximado (m²)</span>
            <input type="number" name="tamanho" min="1">
          </label>
        </div>

        <label>
          <span>Especialidades necessárias</span>
          <div class="checkboxes">
            {especialidadesLista.map(e => (
              <label class="check-item">
                <input type="checkbox" name="especialidades" value={e.toLowerCase()}>
                <span>{e}</span>
              </label>
            ))}
          </div>
        </label>

        <h3 class="form-section">Responsável</h3>
        <div class="form-row">
          <label>
            <span>Nome *</span>
            <input type="text" name="nomeResp" required>
          </label>
          <label>
            <span>Telefone *</span>
            <input type="tel" name="telefone" required>
          </label>
        </div>
        <label>
          <span>E-mail (será o login no Portal) *</span>
          <input type="email" name="email" required>
        </label>

        <h3 class="form-section">Cadastro fiscal</h3>
        <div class="form-row">
          <label>
            <span>CNPJ ou CPF *</span>
            <input type="text" name="cnpjCpf" required>
          </label>
          <label>
            <span>CEP</span>
            <input type="text" name="cep">
          </label>
        </div>
        <label>
          <span>Endereço completo</span>
          <input type="text" name="endereco" placeholder="Rua, número, bairro">
        </label>
        <div class="form-row">
          <label>
            <span>Cidade</span>
            <input type="text" name="cidade">
          </label>
          <label>
            <span>UF</span>
            <input type="text" name="uf" maxlength="2" placeholder="SP">
          </label>
        </div>

        <label class="checkbox">
          <input type="checkbox" name="lgpd" required>
          <span>Concordo com o tratamento dos meus dados conforme a <a href="/privacidade">Política de Privacidade</a>.</span>
        </label>

        <button type="submit" class="btn btn-primary btn-submit">
          Avançar para pagamento
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
        </button>

        <p id="contratar-status" class="form-status" hidden></p>
      </form>
    </div>
  </section>
</Base>

<script define:vars={{ planos }}>
  // Seleção de plano
  const cards = document.querySelectorAll(".plano-card");
  const planoIdInput = document.getElementById("planoId");

  function selecionarPlano(id) {
    cards.forEach(c => c.classList.toggle("selected", c.dataset.plano === id));
    if (planoIdInput) planoIdInput.value = id;
    document.getElementById("contratar-form")?.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  document.querySelectorAll(".plano-cta").forEach(btn => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-plano-id");
      if (id) selecionarPlano(id);
    });
  });

  // Submit
  const form = document.getElementById("contratar-form");
  const status = document.getElementById("contratar-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!status) return;
    const data = new FormData(form);
    const planoId = data.get("planoId");
    if (!planoId) {
      status.hidden = false;
      status.className = "form-status form-status-erro";
      status.textContent = "Selecione um plano antes de enviar.";
      window.scrollTo({ top: 0, behavior: "smooth" });
      return;
    }
    const plano = planos.find(p => p.id === planoId);
    if (!plano) return;

    const especialidades = Array.from(form.querySelectorAll('input[name="especialidades"]:checked'))
      .map(el => el.value);

    const payload = {
      loja: {
        email: data.get("email"),
        nomeResp: data.get("nomeResp"),
        nomeLoja: data.get("nomeLoja"),
        telefone: data.get("telefone"),
        tamanho: data.get("tamanho") ? Number(data.get("tamanho")) : undefined,
        especialidades,
      },
      plano: { id: plano.id, nome: plano.nome, valorMensal: plano.valorMensal, visitas: plano.visitas },
      cadastro: {
        cnpjCpf: data.get("cnpjCpf"),
        endereco: data.get("endereco") || undefined,
        cidade: data.get("cidade") || undefined,
        uf: data.get("uf") || undefined,
        cep: data.get("cep") || undefined,
      },
    };

    const btn = form.querySelector(".btn-submit");
    btn?.setAttribute("disabled", "true");
    status.hidden = false;
    status.className = "form-status";
    status.textContent = "Enviando seus dados…";

    try {
      const r = await fetch("/api/manut/contratar", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      const j = await r.json();
      if (!r.ok || !j.ok) throw new Error(j?.error || "Falha ao enviar");
      if (j.linkPagamento) {
        status.textContent = "Tudo certo! Redirecionando para o pagamento…";
        setTimeout(() => { window.location.href = j.linkPagamento; }, 1200);
      } else {
        status.textContent = "Cadastro recebido! Em breve enviaremos o link de pagamento por e-mail.";
      }
    } catch (err) {
      status.className = "form-status form-status-erro";
      status.textContent = "Não foi possível enviar agora. Tente novamente em instantes ou escreva para comercial@costajr.com.br.";
      btn?.removeAttribute("disabled");
    }
  });
</script>

<style>
  .page-hero {
    position: relative;
    background:
      radial-gradient(circle at 78% 30%, rgba(196,30,58,.45) 0%, transparent 55%),
      linear-gradient(135deg, #1A1C20 0%, #2D2F36 60%, #3A1419 100%);
    color: #fff; overflow: hidden;
  }
  .page-hero-content { position: relative; padding: 96px 0 80px; max-width: 820px; }
  .hero-eyebrow {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand);
    border-left: 3px solid var(--brand); padding-left: 12px; margin-bottom: 24px;
  }
  .page-hero h1 { color: #fff; margin: 0 0 20px; }
  .page-hero h1 .hl { color: var(--brand); }
  .page-hero-sub { font-size: clamp(16px, 1.4vw, 18px); line-height: 1.7; color: #E5E7EB; max-width: 680px; margin: 0; }

  .kicker {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;
  }

  /* PLANOS */
  .planos-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px; align-items: stretch;
  }
  .plano-card {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 36px 32px;
    display: flex; flex-direction: column; gap: 14px;
    position: relative;
    transition: all .2s ease;
  }
  .plano-card:hover { transform: translateY(-3px); box-shadow: 0 14px 32px rgba(0,0,0,.06); }
  .plano-card.destaque {
    border: 2px solid var(--brand);
    box-shadow: 0 14px 40px rgba(196,30,58,.12);
  }
  .plano-card.selected { border: 2px solid var(--brand); background: var(--brand-soft); }
  .plano-badge {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    background: var(--brand); color: #fff;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 11px;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 5px 14px; border-radius: 99px;
  }
  .plano-card h3 { margin: 0; font-size: 22px; }
  .plano-preco { display: flex; align-items: baseline; gap: 4px; }
  .plano-preco .moeda { font-size: 14px; color: var(--ink-mid); font-weight: 600; }
  .plano-preco strong { font-family: 'Montserrat', sans-serif; font-size: 44px; font-weight: 800; color: var(--ink); line-height: 1; }
  .plano-preco .periodo { font-size: 14px; color: var(--ink-mid); }
  .plano-visitas {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--brand);
    margin: 0 0 8px;
  }
  .plano-card ul { list-style: none; padding: 0; margin: 0 0 12px; display: grid; gap: 10px; flex: 1; }
  .plano-card li {
    display: flex; gap: 10px; align-items: flex-start;
    font-size: 14px; color: var(--ink-mid); line-height: 1.55;
  }
  .plano-card li svg { flex: none; margin-top: 4px; }
  .plano-cta { justify-content: center; width: 100%; }

  /* FORM */
  .contratar-form {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 48px;
    display: grid; gap: 16px;
    max-width: 780px; margin: 0 auto;
    box-shadow: 0 4px 20px rgba(0,0,0,.04);
  }
  .form-section {
    margin: 16px 0 0; padding-bottom: 8px; border-bottom: 1px solid var(--border);
    font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brand);
    font-family: 'Montserrat', sans-serif; font-weight: 700;
  }
  .contratar-form label { display: grid; gap: 6px; }
  .contratar-form label > span {
    font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 13px;
    color: var(--ink); letter-spacing: 0.02em;
  }
  .contratar-form input,
  .contratar-form select,
  .contratar-form textarea {
    font-family: 'Open Sans', sans-serif; font-size: 15px; padding: 12px 14px;
    border: 1px solid var(--border); border-radius: 6px; background: #fff; color: var(--ink);
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .contratar-form input:focus,
  .contratar-form select:focus,
  .contratar-form textarea:focus {
    outline: 0; border-color: var(--brand); box-shadow: 0 0 0 3px rgba(196,30,58,.12);
  }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .checkboxes {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px;
    background: var(--bg-soft); padding: 14px; border-radius: 6px;
  }
  .check-item { display: flex; gap: 8px; align-items: center; font-size: 14px; }
  .check-item input { width: 16px; height: 16px; }
  .checkbox { display: flex; gap: 10px; align-items: flex-start; font-size: 13px; color: var(--ink-mid); }
  .checkbox input { width: 16px; height: 16px; margin-top: 3px; }
  .checkbox a { color: var(--brand); border-bottom: 1px solid var(--brand-soft); }
  .btn-submit:disabled { opacity: .6; cursor: not-allowed; }

  .form-status {
    margin: 12px 0 0; padding: 12px 14px;
    background: var(--brand-soft); color: var(--brand);
    border-radius: 6px; font-size: 14px;
  }
  .form-status-erro { background: #FEE2E2; color: #B91C1C; }

  @media (max-width: 900px) {
    .page-hero-content { padding: 64px 0 56px; }
    .contratar-form { padding: 28px; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
