---
import Base from "~/layouts/Base.astro";

// Regra base de precificação — espelha a tabela `manut_precificacao` do banco.
// Estes valores podem ser editados pelo admin. Quando a API GET /api/manut/precificacao
// estiver implementada, o front passa a buscar de lá; por ora usa este fallback.
const tiposLoja = [
  { id: "quiosque",   label: "Quiosque",       descricao: "Ponto compacto, baixa metragem", precoBase: 250 },
  { id: "ate40",      label: "Até 40 m²",      descricao: "Loja pequena de rua ou shopping",  precoBase: 280 },
  { id: "41a80",      label: "41 a 80 m²",     descricao: "Loja média",                       precoBase: 300 },
  { id: "81a120",     label: "81 a 120 m²",    descricao: "Loja grande",                      precoBase: 400 },
  { id: "121a250",    label: "121 a 250 m²",   descricao: "Loja âncora ou centro de distribuição pequeno", precoBase: 650 },
];

const especialidades = [
  { id: "civil",      label: "Civil",     descricao: "Pintura, alvenaria, gesso, marcenaria, esquadrias" },
  { id: "eletrica",   label: "Elétrica",  descricao: "Quadros, iluminação, tomadas, instalações de baixa tensão" },
  { id: "hidraulica", label: "Hidráulica", descricao: "Águas, esgoto, louças, registros e infraestrutura sanitária" },
];

const custoEspecialidade = 50; // R$ por especialidade adicional
---
<Base
  title="Contratar manutenção predial — Costa Júnior"
  description="Plataforma digital de manutenção predial. Técnico vinculado, chamados ilimitados, visitas preventivas e assinatura via Mercado Pago. Preço sob medida pra sua loja."
>
  <section class="page-hero">
    <div class="container page-hero-content">
      <span class="hero-eyebrow">Manutenção predial sem dor de cabeça</span>
      <h1>Sua loja sob cuidado da <span class="hl">engenharia certa</span>.</h1>
      <p class="page-hero-sub">
        Técnico responsável vinculado, chamados ilimitados, visita preventiva mensal e relatórios em PDF. Pagamento via Mercado Pago — assinatura mensal automatizada.
      </p>
    </div>
  </section>

  <!-- 1. CALCULADORA -->
  <section class="section">
    <div class="container">
      <div style="text-align:center;max-width:680px;margin:0 auto 56px">
        <span class="kicker">1. Monte seu plano</span>
        <h2>Preço sob medida pro seu metro quadrado</h2>
        <p class="lead">Selecione o porte da loja e as especialidades necessárias. Sem fidelidade, sem letra miúda.</p>
      </div>

      <div class="calc-grid">
        <!-- COLUNA ESQUERDA — opções -->
        <div class="calc-opcoes">
          <h3 class="calc-titulo">Porte da loja</h3>
          <div class="opcoes-stack" role="radiogroup" aria-label="Tipo de loja">
            {tiposLoja.map((t, i) => (
              <label class={`opcao ${i === 1 ? "checked" : ""}`} data-tipo={t.id}>
                <input type="radio" name="tipoLoja" value={t.id} checked={i === 1} data-preco={t.precoBase}>
                <span class="opcao-radio"></span>
                <span class="opcao-conteudo">
                  <strong>{t.label}</strong>
                  <span>{t.descricao}</span>
                </span>
                <span class="opcao-preco">R$ {t.precoBase}<small>/mês</small></span>
              </label>
            ))}
          </div>

          <h3 class="calc-titulo">Especialidades incluídas</h3>
          <p class="calc-aux">Toda manutenção inclui no mínimo uma especialidade. Cada adicional soma R$ {custoEspecialidade}/mês.</p>
          <div class="opcoes-stack">
            {especialidades.map((e, i) => (
              <label class={`opcao opcao-check ${i === 0 ? "checked" : ""}`} data-esp={e.id}>
                <input type="checkbox" name="especialidades" value={e.id} checked={i === 0} data-custo={custoEspecialidade}>
                <span class="opcao-check-mark">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <span class="opcao-conteudo">
                  <strong>{e.label}</strong>
                  <span>{e.descricao}</span>
                </span>
                <span class="opcao-preco-add">+R$ {custoEspecialidade}<small>/mês</small></span>
              </label>
            ))}
          </div>
        </div>

        <!-- COLUNA DIREITA — resumo / preço -->
        <aside class="calc-resumo">
          <span class="kicker" style="color:#fff;opacity:.85">Seu plano</span>
          <h3 id="resumo-tipo">Até 40 m²</h3>
          <p id="resumo-esp">1 especialidade · Civil</p>

          <div class="resumo-preco">
            <div class="preco-linha">
              <span>Base</span>
              <strong id="preco-base">R$ 280</strong>
            </div>
            <div class="preco-linha">
              <span id="preco-extras-label">+0 especialidade extra</span>
              <strong id="preco-extras">R$ 0</strong>
            </div>
            <div class="preco-total">
              <span>Total mensal</span>
              <strong><span class="moeda">R$</span><span id="preco-total">280</span><small>/mês</small></strong>
            </div>
          </div>

          <ul class="resumo-bullets">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>1 visita preventiva mensal</span>
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Chamados ilimitados via plataforma</span>
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Técnico responsável vinculado</span>
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Relatório mensal em PDF</span>
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Sem fidelidade · cancele quando quiser</span>
            </li>
          </ul>

          <button type="button" class="btn btn-primary calc-cta" id="btn-avancar">
            Avançar para cadastro
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
          </button>
        </aside>
      </div>
    </div>
  </section>

  <!-- 2. CADASTRO -->
  <section class="section section-soft" id="cadastro">
    <div class="container">
      <div style="text-align:center;max-width:680px;margin:0 auto 40px">
        <span class="kicker">2. Cadastre sua loja</span>
        <h2>Dados pra gente preparar tudo</h2>
        <p class="lead">A senha de acesso ao Portal do Cliente é gerada automaticamente após o pagamento.</p>
      </div>

      <form id="contratar-form" class="contratar-form" novalidate>
        <h3 class="form-section">Loja / unidade</h3>
        <label>
          <span>Nome da loja *</span>
          <input type="text" name="nomeLoja" required>
        </label>

        <h3 class="form-section">Responsável</h3>
        <div class="form-row">
          <label>
            <span>Nome *</span>
            <input type="text" name="nomeResp" required>
          </label>
          <label>
            <span>Telefone *</span>
            <input type="tel" name="telefone" required>
          </label>
        </div>
        <label>
          <span>E-mail (será o login no Portal) *</span>
          <input type="email" name="email" required>
        </label>

        <h3 class="form-section">Cadastro fiscal</h3>
        <div class="form-row">
          <label>
            <span>CNPJ ou CPF *</span>
            <input type="text" name="cnpjCpf" required>
          </label>
          <label>
            <span>CEP</span>
            <input type="text" name="cep">
          </label>
        </div>
        <label>
          <span>Endereço completo</span>
          <input type="text" name="endereco" placeholder="Rua, número, bairro">
        </label>
        <div class="form-row">
          <label>
            <span>Cidade</span>
            <input type="text" name="cidade">
          </label>
          <label>
            <span>UF</span>
            <input type="text" name="uf" maxlength="2" placeholder="SP">
          </label>
        </div>

        <label class="checkbox">
          <input type="checkbox" name="lgpd" required>
          <span>Concordo com o tratamento dos meus dados conforme a <a href="/privacidade">Política de Privacidade</a>.</span>
        </label>

        <button type="submit" class="btn btn-primary btn-submit">
          Avançar para pagamento
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
        </button>

        <p id="contratar-status" class="form-status" hidden></p>
      </form>
    </div>
  </section>
</Base>

<script define:vars={{ tiposLoja, especialidades, custoEspecialidade }}>
  const tipos = tiposLoja;
  const espMap = Object.fromEntries(especialidades.map(e => [e.id, e]));

  const $ = (s) => document.querySelector(s);

  function lerSelecao() {
    const tipoEl = document.querySelector('input[name="tipoLoja"]:checked');
    const tipoId = tipoEl ? tipoEl.value : tipos[0].id;
    const tipo = tipos.find(t => t.id === tipoId) || tipos[0];

    const espIds = Array.from(document.querySelectorAll('input[name="especialidades"]:checked'))
      .map(el => el.value);

    return { tipo, espIds };
  }

  function calcular() {
    const { tipo, espIds } = lerSelecao();
    const numEsp = espIds.length;
    const extras = Math.max(0, numEsp - 1);
    const valorExtras = extras * custoEspecialidade;
    const total = tipo.precoBase + valorExtras;

    $("#resumo-tipo").textContent = tipo.label;
    $("#resumo-esp").textContent =
      numEsp === 0
        ? "Selecione ao menos 1 especialidade"
        : `${numEsp} especialidade${numEsp > 1 ? "s" : ""} · ${espIds.map(id => espMap[id].label).join(", ")}`;
    $("#preco-base").textContent = `R$ ${tipo.precoBase}`;
    $("#preco-extras-label").textContent =
      extras === 0 ? "Nenhuma especialidade extra" : `+${extras} especialidade${extras > 1 ? "s" : ""} extra`;
    $("#preco-extras").textContent = `R$ ${valorExtras}`;
    $("#preco-total").textContent = total.toLocaleString("pt-BR");

    const cta = $("#btn-avancar");
    if (cta) cta.disabled = numEsp === 0;
  }

  // Atualização visual das opções
  function refreshVisual() {
    document.querySelectorAll('label.opcao').forEach(label => {
      const input = label.querySelector('input');
      if (!input) return;
      label.classList.toggle("checked", input.checked);
    });
  }

  document.querySelectorAll('input[name="tipoLoja"], input[name="especialidades"]').forEach(input => {
    input.addEventListener("change", () => { refreshVisual(); calcular(); });
  });

  // CTA → scroll para cadastro
  $("#btn-avancar")?.addEventListener("click", () => {
    const { espIds } = lerSelecao();
    if (espIds.length === 0) return;
    document.getElementById("cadastro")?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  // Submit do form
  const form = document.getElementById("contratar-form");
  const status = document.getElementById("contratar-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!status) return;

    const { tipo, espIds } = lerSelecao();
    if (espIds.length === 0) {
      status.hidden = false;
      status.className = "form-status form-status-erro";
      status.textContent = "Selecione ao menos 1 especialidade antes de continuar.";
      window.scrollTo({ top: 0, behavior: "smooth" });
      return;
    }

    const valorMensal = tipo.precoBase + Math.max(0, espIds.length - 1) * custoEspecialidade;
    const data = new FormData(form);

    const payload = {
      loja: {
        email: data.get("email"),
        nomeResp: data.get("nomeResp"),
        nomeLoja: data.get("nomeLoja"),
        telefone: data.get("telefone"),
        especialidades: espIds,
      },
      plano: {
        id: `${tipo.id}-${espIds.join("_")}`,
        nome: `${tipo.label} · ${espIds.map(id => espMap[id].label).join(" + ")}`,
        valorMensal,
        visitas: 1,
      },
      cadastro: {
        cnpjCpf: data.get("cnpjCpf"),
        endereco: data.get("endereco") || undefined,
        cidade: data.get("cidade") || undefined,
        uf: data.get("uf") || undefined,
        cep: data.get("cep") || undefined,
      },
    };

    const btn = form.querySelector(".btn-submit");
    btn?.setAttribute("disabled", "true");
    status.hidden = false;
    status.className = "form-status";
    status.textContent = "Enviando seus dados…";

    try {
      const r = await fetch("/api/manut/contratar", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      const j = await r.json();
      if (!r.ok || !j.ok) throw new Error(j?.error || "Falha ao enviar");
      if (j.linkPagamento) {
        status.textContent = "Tudo certo! Redirecionando para o pagamento…";
        setTimeout(() => { window.location.href = j.linkPagamento; }, 1200);
      } else {
        status.textContent = "Cadastro recebido! Em breve enviaremos o link de pagamento por e-mail.";
      }
    } catch (err) {
      status.className = "form-status form-status-erro";
      status.textContent = "Não foi possível enviar agora. Tente novamente em instantes ou escreva para comercial@costajr.com.br.";
      btn?.removeAttribute("disabled");
    }
  });

  // Inicial
  refreshVisual();
  calcular();
</script>

<style>
  .page-hero {
    position: relative;
    background:
      radial-gradient(circle at 78% 30%, rgba(196,30,58,.45) 0%, transparent 55%),
      linear-gradient(135deg, #1A1C20 0%, #2D2F36 60%, #3A1419 100%);
    color: #fff; overflow: hidden;
  }
  .page-hero-content { position: relative; padding: 96px 0 80px; max-width: 820px; }
  .hero-eyebrow {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand);
    border-left: 3px solid var(--brand); padding-left: 12px; margin-bottom: 24px;
  }
  .page-hero h1 { color: #fff; margin: 0 0 20px; }
  .page-hero h1 .hl { color: var(--brand); }
  .page-hero-sub { font-size: clamp(16px, 1.4vw, 18px); line-height: 1.7; color: #E5E7EB; max-width: 680px; margin: 0; }

  .kicker {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;
  }

  /* CALCULADORA */
  .calc-grid {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 40px;
    align-items: flex-start;
  }
  .calc-titulo {
    margin: 0 0 12px; font-size: 14px;
    font-family: 'Montserrat', sans-serif; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--ink);
  }
  .calc-titulo:not(:first-child) { margin-top: 32px; }
  .calc-aux { font-size: 13px; color: var(--ink-mid); margin: 0 0 12px; }
  .opcoes-stack { display: grid; gap: 10px; }
  .opcao {
    display: grid;
    grid-template-columns: 24px 1fr auto;
    align-items: center;
    gap: 16px;
    background: #fff; border: 2px solid var(--border); border-radius: 10px;
    padding: 16px 20px;
    cursor: pointer;
    transition: all .15s ease;
  }
  .opcao input { position: absolute; opacity: 0; pointer-events: none; }
  .opcao:hover { border-color: var(--brand-soft); background: #FAFAFB; }
  .opcao.checked { border-color: var(--brand); background: var(--brand-soft); }
  .opcao-radio {
    width: 20px; height: 20px; border-radius: 50%;
    border: 2px solid var(--border);
    position: relative;
  }
  .opcao.checked .opcao-radio { border-color: var(--brand); }
  .opcao.checked .opcao-radio::after {
    content: ""; position: absolute; inset: 4px;
    border-radius: 50%; background: var(--brand);
  }
  .opcao-check-mark {
    width: 20px; height: 20px; border-radius: 4px;
    border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: transparent;
  }
  .opcao.checked .opcao-check-mark {
    border-color: var(--brand); background: var(--brand); color: #fff;
  }
  .opcao-conteudo { display: flex; flex-direction: column; gap: 2px; }
  .opcao-conteudo strong {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 15px;
    color: var(--ink);
  }
  .opcao-conteudo span { font-size: 13px; color: var(--ink-mid); line-height: 1.4; }
  .opcao-preco, .opcao-preco-add {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 15px;
    color: var(--ink); white-space: nowrap;
  }
  .opcao-preco-add { color: var(--brand); font-size: 13px; }
  .opcao-preco small, .opcao-preco-add small { font-weight: 500; color: var(--ink-light); margin-left: 2px; }

  /* RESUMO */
  .calc-resumo {
    background: linear-gradient(135deg, #1F2126 0%, #2D2F36 100%);
    color: #fff;
    border-radius: 16px;
    padding: 36px 32px;
    position: sticky; top: 96px;
    overflow: hidden;
  }
  .calc-resumo::before {
    content: ""; position: absolute; top: -30%; right: -15%;
    width: 360px; height: 360px; border-radius: 50%;
    background: radial-gradient(circle, rgba(196,30,58,.25) 0%, transparent 65%);
    pointer-events: none;
  }
  .calc-resumo > * { position: relative; }
  .calc-resumo h3 { color: #fff; font-size: 22px; margin: 0 0 4px; }
  #resumo-esp { color: #C8CACE; font-size: 14px; margin: 0 0 24px; }

  .resumo-preco {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 10px; padding: 18px 20px; margin-bottom: 24px;
  }
  .preco-linha {
    display: flex; justify-content: space-between; align-items: center;
    padding: 6px 0; color: #C8CACE; font-size: 14px;
  }
  .preco-linha strong { color: #fff; font-family: 'Montserrat', sans-serif; }
  .preco-total {
    border-top: 1px solid rgba(255,255,255,.18); margin-top: 8px; padding-top: 14px;
    display: flex; justify-content: space-between; align-items: baseline;
    color: #fff;
  }
  .preco-total > span {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  .preco-total strong {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    display: flex; align-items: baseline; gap: 2px;
  }
  .preco-total .moeda { font-size: 16px; color: #C8CACE; font-weight: 600; }
  .preco-total #preco-total { font-size: 40px; line-height: 1; }
  .preco-total small { font-size: 13px; color: #C8CACE; font-weight: 500; margin-left: 4px; }

  .resumo-bullets {
    list-style: none; padding: 0; margin: 0 0 24px;
    display: grid; gap: 10px;
  }
  .resumo-bullets li {
    display: flex; gap: 10px; align-items: flex-start;
    font-size: 13px; color: #E5E7EB; line-height: 1.5;
  }
  .resumo-bullets svg { flex: none; margin-top: 3px; }

  .calc-cta { width: 100%; justify-content: center; }
  .calc-cta:disabled { opacity: .5; cursor: not-allowed; }

  /* FORM */
  .contratar-form {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 48px;
    display: grid; gap: 16px;
    max-width: 780px; margin: 0 auto;
    box-shadow: 0 4px 20px rgba(0,0,0,.04);
  }
  .form-section {
    margin: 16px 0 0; padding-bottom: 8px; border-bottom: 1px solid var(--border);
    font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brand);
    font-family: 'Montserrat', sans-serif; font-weight: 700;
  }
  .contratar-form label { display: grid; gap: 6px; }
  .contratar-form label > span {
    font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 13px;
    color: var(--ink); letter-spacing: 0.02em;
  }
  .contratar-form input,
  .contratar-form select {
    font-family: 'Open Sans', sans-serif; font-size: 15px; padding: 12px 14px;
    border: 1px solid var(--border); border-radius: 6px; background: #fff; color: var(--ink);
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .contratar-form input:focus,
  .contratar-form select:focus {
    outline: 0; border-color: var(--brand); box-shadow: 0 0 0 3px rgba(196,30,58,.12);
  }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .checkbox { display: flex; gap: 10px; align-items: flex-start; font-size: 13px; color: var(--ink-mid); }
  .checkbox input { width: 16px; height: 16px; margin-top: 3px; }
  .checkbox a { color: var(--brand); border-bottom: 1px solid var(--brand-soft); }
  .btn-submit:disabled { opacity: .6; cursor: not-allowed; }

  .form-status {
    margin: 12px 0 0; padding: 12px 14px;
    background: var(--brand-soft); color: var(--brand);
    border-radius: 6px; font-size: 14px;
  }
  .form-status-erro { background: #FEE2E2; color: #B91C1C; }

  @media (max-width: 980px) {
    .calc-grid { grid-template-columns: 1fr; }
    .calc-resumo { position: static; }
  }
  @media (max-width: 900px) {
    .page-hero-content { padding: 64px 0 56px; }
    .contratar-form { padding: 28px; }
    .form-row { grid-template-columns: 1fr; }
    .opcao { grid-template-columns: 24px 1fr; }
