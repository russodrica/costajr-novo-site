---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Minha Conta" tipo="cliente" activePage="minha-conta">
  <div id="loadingState" class="loading">Carregando...</div>
  <div id="pageContent" style="display:none">

    <div class="grid-2" style="gap:20px;margin-bottom:20px">
      <!-- Dados pessoais -->
      <div class="card">
        <h3 style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
          Dados Cadastrais
          <a href="/manutencao/cliente/trocar-senha" class="btn btn-outline btn-sm">Alterar senha</a>
        </h3>
        <div class="info-lista" id="dadosPessoais"></div>
      </div>

      <!-- Plano -->
      <div class="card">
        <h3 style="margin-bottom:16px">Plano Contratado</h3>
        <div class="info-lista" id="dadosPlano"></div>
      </div>
    </div>

    <!-- Lojas -->
    <div class="card">
      <h3 style="margin-bottom:16px">Minhas Lojas</h3>
      <div id="lojasContent"></div>
    </div>

  </div>
</Portal>

<style>
  .info-lista { display: flex; flex-direction: column; gap: 0; }
  .info-row {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 10px 0; border-bottom: 1px solid #E5E7EB; font-size: 14px;
  }
  .info-row:last-child { border-bottom: 0; }
  .info-label { color: #6B7280; font-size: 13px; min-width: 130px; }
  .info-val { font-weight: 600; text-align: right; }
  .status-pill {
    display: inline-block; padding: 3px 12px; border-radius: 100px;
    font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .pill-ativo       { background: #F0FDF4; color: #15803D; }
  .pill-pendente    { background: #FFFBEB; color: #92400E; }
  .pill-inadimplente{ background: #FEF2F2; color: #B91C1C; }
  .pill-cancelado   { background: #F9FAFB; color: #6B7280; }
  .loja-card {
    border: 1px solid #E5E7EB; border-radius: 8px; padding: 16px 20px;
    margin-bottom: 12px;
  }
  .loja-card:last-child { margin-bottom: 0; }
  .loja-nome { font-weight: 700; font-size: 15px; margin-bottom: 6px; }
  .loja-detail { font-size: 13px; color: #6B7280; display: flex; flex-wrap: wrap; gap: 12px; }
  .esp-tag {
    display: inline-block; padding: 2px 8px; border-radius: 4px;
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    background: #F1F5F9; color: #475569;
  }
  .esp-tag.eletrica   { background: #EFF6FF; color: #1D4ED8; }
  .esp-tag.hidraulica { background: #F0FDF4; color: #15803D; }
  .esp-tag.civil      { background: #FFF7ED; color: #C2410C; }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }
  function fmtMoney(v) {
    if (!v && v !== 0) return "—";
    return "R$ " + Number(v).toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function row(label, val) {
    return `<div class="info-row"><span class="info-label">${label}</span><span class="info-val">${val}</span></div>`;
  }
  function statusPill(s) {
    const labels = { ativo: "Ativo", pendente: "Aguard. pagamento", inadimplente: "Inadimplente", cancelado: "Cancelado" };
    return `<span class="status-pill pill-${s}">${labels[s] || s}</span>`;
  }

  async function load() {
    try {
      const res = await fetch("/api/manut/cliente/me", { headers: { "x-cliente-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      const { cliente, dashboard } = await res.json();

      if (cliente.senha_troca_obrigatoria) { window.location.replace("/manutencao/cliente/trocar-senha"); return; }

      // Dados pessoais
      document.getElementById("dadosPessoais").innerHTML =
        row("Nome", cliente.nome || "—") +
        row("E-mail", cliente.email || "—") +
        row("Telefone", cliente.telefone || "—") +
        row("CNPJ / CPF", cliente.cnpj_cpf || "—") +
        row("Código", `<code style="font-size:12px;background:#F1F5F9;padding:2px 6px;border-radius:4px">${cliente.codigo || "—"}</code>`);

      // Plano
      const planLabel = {
        quiosque: "Quiosque", ate40: "Até 40 m²", "41a80": "41–80 m²",
        "81a120": "81–120 m²", "121a250": "121–250 m²"
      };
      document.getElementById("dadosPlano").innerHTML =
        row("Status", statusPill(cliente.status)) +
        row("Plano", planLabel[cliente.plano_selecionado] || cliente.plano_selecionado || "—") +
        row("Valor contratado", fmtMoney(cliente.valor_mensal_contratado)) +
        row("Visitas/mês", cliente.visitas_contratadas ?? "—") +
        row("Desde", fmtDate(cliente.data_contratacao)) +
        row("Próx. vencimento", fmtDate(cliente.data_proximo_vencimento));

      // Lojas
      const lojas = dashboard.lojas || [];
      const lojasEl = document.getElementById("lojasContent");
      if (!lojas.length) {
        lojasEl.innerHTML = '<p style="color:#9CA3AF;font-size:14px">Nenhuma loja cadastrada.</p>';
      } else {
        lojasEl.innerHTML = lojas.map(l => `
          <div class="loja-card">
            <div class="loja-nome">${l.nome}</div>
            <div class="loja-detail">
              ${l.endereco ? `<span>📍 ${[l.endereco, l.cidade, l.uf].filter(Boolean).join(", ")}</span>` : ""}
              ${l.cep ? `<span>CEP: ${l.cep}</span>` : ""}
              ${l.tamanho_m2 ? `<span>${l.tamanho_m2} m²</span>` : ""}
              <span>${badge(l.status)}</span>
            </div>
            ${l.especialidades?.length ? `<div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">
              ${l.especialidades.map(e => `<span class="esp-tag ${e}">${e}</span>`).join("")}
            </div>` : ""}
          </div>
        `).join("");
      }

      document.getElementById("loadingState").style.display = "none";
      document.getElementById("pageContent").style.display = "";
    } catch {
      document.getElementById("loadingState").textContent = "Erro ao carregar. Recarregue a página.";
    }
  }

  function badge(s) {
    const map = { ativo: "badge-ativo", pendente: "badge-pendente", cancelado: "badge-cancelado" };
    const labels = { ativo: "Ativo", pendente: "Pendente", cancelado: "Cancelado" };
    return `<span class="badge ${map[s] || "badge-pendente"}">${labels[s] || s}</span>`;
  }

  load();
</script>
