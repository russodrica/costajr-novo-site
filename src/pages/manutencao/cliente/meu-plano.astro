---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Meu Plano" tipo="cliente" activePage="meu-plano">
  <div id="loadingState" class="loading">Carregando informações do plano...</div>
  <div id="planoContent" style="display:none">

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px" class="grid-dash">
      <div class="card">
        <h3>Plano Contratado</h3>
        <div id="planoInfo"></div>
      </div>
      <div class="card">
        <h3>Uso do Contrato</h3>
        <div id="usoInfo"></div>
      </div>
    </div>

    <div class="card" id="inclusosCard" style="margin-bottom:24px;display:none">
      <h3>Visitas e chamados inclusos no plano</h3>
      <div id="inclusosInfo" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:12px"></div>
      <p style="margin:12px 0 0;font-size:12.5px;color:#6B7280">
        Use suas visitas extras e chamados emergenciais inclusos antes que expirem com o contrato.
        Após esgotar o saldo, novos chamados extras (R$ 250) ou emergenciais (R$ 350) serão cobrados via Pix.
      </p>
    </div>

    <div class="card">
      <h3>Histórico de Pagamentos</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Referência</th>
              <th>Vencimento</th>
              <th>Pagamento</th>
              <th>Valor</th>
              <th>Status</th>
              <th>Link</th>
            </tr>
          </thead>
          <tbody id="pagTbody"></tbody>
        </table>
      </div>
      <div id="pagEmpty" style="display:none;text-align:center;padding:32px;color:#9CA3AF;font-size:14px">Nenhum pagamento encontrado.</div>
    </div>
  </div>
</Portal>

<style>
  @media (max-width:760px) { .grid-dash { grid-template-columns:1fr !important; } }
  .plano-row { display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #E5E7EB;font-size:14px; }
  .plano-row:last-child { border-bottom:0; }
  .plano-label { color:#6B7280;font-size:13px; }
  .plano-val { font-weight:600; }
  .uso-bar-bg { background:#E5E7EB;border-radius:100px;height:8px;margin:6px 0 12px; }
  .uso-bar-fill { background:#C41E3A;border-radius:100px;height:8px;transition:width .4s; }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  function fmt(v) { return v != null ? "R$ " + Number(v).toLocaleString("pt-BR",{minimumFractionDigits:2}) : "—"; }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function statusPag(s) {
    const m = { pendente:"badge-pendente", pago:"badge-concluido", vencido:"badge-inadimplente", cancelado:"badge-cancelado" };
    const l = { pendente:"Pendente", pago:"Pago", vencido:"Vencido", cancelado:"Cancelado" };
    return `<span class="badge ${m[s] || ""}">${l[s] || s}</span>`;
  }
  function nomePlano(p) {
    const m = { trimestral:"Trimestral", semestral:"Semestral", anual:"Anual" };
    return m[p] || (p ? p.charAt(0).toUpperCase() + p.slice(1) : "—");
  }

  async function load() {
    try {
      const res = await fetch("/api/manut/cliente/plano", { headers: { "x-cliente-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      const { cliente, pagamentos, visitasAno } = await res.json();

      // Plano info
      const statusColor = { ativo:"#15803D", pendente:"#A16207", cancelado:"#B91C1C", inadimplente:"#B91C1C" };
      document.getElementById("planoInfo").innerHTML = `
        <div class="plano-row"><span class="plano-label">Plano</span><span class="plano-val">${nomePlano(cliente?.plano_selecionado)}</span></div>
        <div class="plano-row"><span class="plano-label">Status</span><span class="plano-val" style="color:${statusColor[cliente?.status]||'#2D2F36'}">${cliente?.status ? cliente.status.charAt(0).toUpperCase()+cliente.status.slice(1) : "—"}</span></div>
        <div class="plano-row"><span class="plano-label">Mensalidade</span><span class="plano-val">${fmt(cliente?.valor_mensal_contratado)}</span></div>
        <div class="plano-row"><span class="plano-label">Visitas/mês</span><span class="plano-val">${cliente?.visitas_contratadas || "—"}</span></div>
        <div class="plano-row"><span class="plano-label">Início do contrato</span><span class="plano-val">${fmtDate(cliente?.data_contratacao)}</span></div>
      `;

      // Uso
      const visContr = cliente?.visitas_contratadas || 0;
      const visPct = visContr > 0 ? Math.min(100, Math.round(visitasAno / visContr * 100)) : 0;
      document.getElementById("usoInfo").innerHTML = `
        <div style="font-size:13px;color:#6B7280;margin-bottom:4px">Preventivas realizadas este ano</div>
        <div style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:28px;color:#2D2F36;margin-bottom:4px">${visitasAno} <span style="font-size:14px;color:#9CA3AF;font-weight:400">de ${visContr || "—"}</span></div>
        <div class="uso-bar-bg"><div class="uso-bar-fill" style="width:${visPct}%"></div></div>
        <div style="font-size:12px;color:#9CA3AF">${visPct}% do contrato utilizado</div>
      `;

      // Inclusos no plano (extras + emergenciais)
      const extrasTot = Number(cliente?.extras_contratados || 0);
      const extrasDisp = Number(cliente?.extras_disponiveis || 0);
      const emergTot = Number(cliente?.emergenciais_contratados || 0);
      const emergDisp = Number(cliente?.emergenciais_disponiveis || 0);
      if (extrasTot > 0 || emergTot > 0) {
        document.getElementById("inclusosCard").style.display = "";
        const extrasUsadas = Math.max(0, extrasTot - extrasDisp);
        const emergUsadas = Math.max(0, emergTot - emergDisp);
        const extrasPct = extrasTot > 0 ? Math.round((extrasUsadas / extrasTot) * 100) : 0;
        const emergPct = emergTot > 0 ? Math.round((emergUsadas / emergTot) * 100) : 0;
        document.getElementById("inclusosInfo").innerHTML = `
          <div>
            <div style="font-size:13px;color:#6B7280;margin-bottom:4px">Visitas extras inclusas</div>
            <div style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:26px;color:#15803D;margin-bottom:4px">${extrasDisp} <span style="font-size:14px;color:#9CA3AF;font-weight:400">de ${extrasTot} disponíveis</span></div>
            <div class="uso-bar-bg"><div class="uso-bar-fill" style="width:${extrasPct}%;background:#15803D"></div></div>
            <div style="font-size:12px;color:#9CA3AF">${extrasUsadas} já utilizada${extrasUsadas !== 1 ? "s" : ""}</div>
          </div>
          <div>
            <div style="font-size:13px;color:#6B7280;margin-bottom:4px">Chamados emergenciais inclusos</div>
            <div style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:26px;color:#15803D;margin-bottom:4px">${emergDisp} <span style="font-size:14px;color:#9CA3AF;font-weight:400">de ${emergTot} disponíveis</span></div>
            <div class="uso-bar-bg"><div class="uso-bar-fill" style="width:${emergPct}%;background:#15803D"></div></div>
            <div style="font-size:12px;color:#9CA3AF">${emergUsadas} já utilizado${emergUsadas !== 1 ? "s" : ""}</div>
          </div>
        `;
      }

      // Pagamentos
      const tbody = document.getElementById("pagTbody");
      const empty = document.getElementById("pagEmpty");
      if (!pagamentos.length) {
        tbody.innerHTML = "";
        empty.style.display = "";
      } else {
        empty.style.display = "none";
        tbody.innerHTML = pagamentos.map(p => `
          <tr>
            <td>${p.referencia || "—"}</td>
            <td>${fmtDate(p.data_vencimento)}</td>
            <td>${fmtDate(p.data_pagamento)}</td>
            <td><strong>${fmt(p.valor)}</strong></td>
            <td>${statusPag(p.status)}</td>
            <td>${p.mercado_pago_id
              ? `<a href="https://www.mercadopago.com.br/subscriptions/${p.mercado_pago_id}" target="_blank" class="btn btn-outline btn-sm">Pagar</a>`
              : "—"
            }</td>
          </tr>
        `).join("");
      }

      document.getElementById("loadingState").style.display = "none";
      document.getElementById("planoContent").style.display = "";
    } catch {
      document.getElementById("loadingState").textContent = "Erro ao carregar. Recarregue a página.";
    }
  }
  load();
</script>
