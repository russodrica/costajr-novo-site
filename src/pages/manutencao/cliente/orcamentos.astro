---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Orçamentos" tipo="cliente" activePage="orcamentos">
  <div class="section-header">
    <p style="margin:0;font-size:13.5px;color:#5B5F6B">Solicite orçamentos para serviços fora do contrato de manutenção.</p>
    <button class="btn btn-primary" id="btnNovo">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Solicitar Orçamento
    </button>
  </div>

  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando orçamentos...</div>

  <div class="card" id="tableWrap" style="display:none">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Data</th>
            <th>Loja</th>
            <th>Descrição</th>
            <th>Valor proposto</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
    <div id="emptyMsg" style="display:none">
      <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        <strong>Nenhum orçamento ainda</strong>
        <p>Solicite um orçamento para serviços extras.</p>
      </div>
    </div>
  </div>

  <!-- Modal novo -->
  <div class="modal-bg" id="modalNovo">
    <div class="modal">
      <button class="modal-close" onclick="document.getElementById('modalNovo').classList.remove('open')">×</button>
      <h2>Solicitar Orçamento</h2>
      <div id="alertNovo" class="alert alert-error" style="display:none"></div>
      <div class="form-group">
        <label>Loja</label>
        <select id="selLoja"><option value="">Carregando lojas...</option></select>
      </div>
      <div class="form-group">
        <label>Descrição do serviço solicitado</label>
        <textarea id="descSol" placeholder="Descreva o serviço que você precisa, com o máximo de detalhes..."></textarea>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:4px">
        <button class="btn btn-outline" onclick="document.getElementById('modalNovo').classList.remove('open')">Cancelar</button>
        <button class="btn btn-primary" id="btnSubmitNovo">Solicitar</button>
      </div>
    </div>
  </div>

  <!-- Modal resposta -->
  <div class="modal-bg" id="modalResp">
    <div class="modal">
      <button class="modal-close" id="btnFecharResp">×</button>
      <h2>Responder Orçamento</h2>
      <div id="alertResp" class="alert alert-error" style="display:none"></div>
      <div id="modalRespBody"></div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:16px">
        <button class="btn btn-outline" id="btnCancelarResp">Fechar</button>
        <button class="btn btn-outline" id="btnRejeitar" style="border-color:#B91C1C;color:#B91C1C">Rejeitar</button>
        <button class="btn btn-primary" id="btnAprovar">✓ Aprovar</button>
      </div>
    </div>
  </div>
</Portal>

<style>
  .status-pill { display:inline-block;padding:3px 10px;border-radius:100px;font-size:10.5px;font-weight:700;text-transform:uppercase;white-space:nowrap }
  .status-em_analise          { background:#EFF6FF;color:#1D4ED8 }
  .status-em_ajuste           { background:#FFF7ED;color:#C2410C }
  .status-proposta_enviada    { background:#FEF3C7;color:#92400E }
  .status-aprovado            { background:#F0FDF4;color:#15803D }
  .status-rejeitado           { background:#F3F4F6;color:#6B7280 }
  .status-cancelado           { background:#FEF2F2;color:#B91C1C }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  let allOrc = [];
  let lojas = [];
  let orcAtivo = null;

  const statusLabel = { em_analise:"Em análise", em_ajuste:"Em ajuste", proposta_enviada:"Proposta enviada", aprovado:"Aprovado", rejeitado:"Rejeitado", cancelado:"Cancelado" };
  function fmt(v) { return v != null ? "R$ " + Number(v).toLocaleString("pt-BR",{minimumFractionDigits:2}) : "—"; }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function render() {
    const tbody = document.getElementById("tbody");
    const empty = document.getElementById("emptyMsg");
    if (!allOrc.length) { tbody.innerHTML = ""; empty.style.display = ""; return; }
    empty.style.display = "none";
    tbody.innerHTML = allOrc.map(o => `
      <tr>
        <td style="color:#9CA3AF;font-size:12.5px">${fmtDate(o.created_at)}</td>
        <td style="font-weight:600">${o.manut_lojas?.nome || "—"}</td>
        <td style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:12.5px;color:#5B5F6B">${o.descricao_solicitacao}</td>
        <td style="font-weight:700;font-family:'Montserrat',sans-serif">${fmt(o.valor)}</td>
        <td><span class="status-pill status-${o.status}">${statusLabel[o.status] || o.status}</span></td>
        <td style="white-space:nowrap">
          ${o.proposta_pdf_url ? `<a href="${o.proposta_pdf_url}" target="_blank" class="btn btn-outline btn-sm" style="margin-right:6px">📄 PDF</a>` : ""}
          ${o.status === "proposta_enviada" ? `<button class="btn btn-primary btn-sm" onclick="abrirResposta('${o.id}')">Responder</button>` : ""}
        </td>
      </tr>
    `).join("");
  }

  window.abrirResposta = function(id) {
    orcAtivo = allOrc.find(o => o.id === id);
    if (!orcAtivo) return;
    document.getElementById("alertResp").style.display = "none";
    document.getElementById("modalRespBody").innerHTML = `
      <div style="background:#F9FAFB;border-radius:8px;padding:16px;margin-bottom:16px">
        <div style="font-size:12px;color:#9CA3AF;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Resumo do orçamento</div>
        <div style="font-size:14px;margin-bottom:4px"><strong>Loja:</strong> ${orcAtivo.manut_lojas?.nome || "—"}</div>
        <div style="font-size:14px;margin-bottom:4px"><strong>Serviço:</strong> ${orcAtivo.descricao_solicitacao}</div>
        <div style="font-size:18px;font-weight:800;font-family:'Montserrat',sans-serif;color:#C41E3A;margin-top:8px">${fmt(orcAtivo.valor)}</div>
      </div>
      ${orcAtivo.proposta_pdf_url ? `<a href="${orcAtivo.proposta_pdf_url}" target="_blank" class="btn btn-outline btn-sm" style="margin-bottom:16px">📄 Ver proposta completa em PDF</a>` : ""}
      <div class="form-group">
        <label>Comentário <span style="font-weight:400;color:#9CA3AF">(opcional)</span></label>
        <textarea id="comentarioResp" placeholder="Observações ou motivo da decisão..."></textarea>
      </div>
    `;
    document.getElementById("modalResp").classList.add("open");
  };

  async function responder(acao) {
    if (!orcAtivo) return;
    const alertEl = document.getElementById("alertResp");
    alertEl.style.display = "none";
    const comentario = document.getElementById("comentarioResp")?.value || "";
    const btn = acao === "aprovar" ? document.getElementById("btnAprovar") : document.getElementById("btnRejeitar");
    btn.disabled = true;
    try {
      const res = await fetch("/api/manut/cliente/orcamentos", {
        method: "PUT",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: JSON.stringify({ id: orcAtivo.id, acao, comentario_cliente: comentario }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      const idx = allOrc.findIndex(o => o.id === orcAtivo.id);
      if (idx >= 0) allOrc[idx] = { ...allOrc[idx], ...data };
      document.getElementById("modalResp").classList.remove("open");
      orcAtivo = null;
      render();
      window.toast?.(acao === "aprovar" ? "Orçamento aprovado!" : "Orçamento rejeitado.", acao === "aprovar" ? "success" : "info");
    } catch (err) {
      alertEl.textContent = err.message; alertEl.style.display = "";
    } finally { btn.disabled = false; }
  }

  document.getElementById("btnAprovar").onclick = () => responder("aprovar");
  document.getElementById("btnRejeitar").onclick = () => responder("rejeitar");
  document.getElementById("btnCancelarResp").onclick = () => { document.getElementById("modalResp").classList.remove("open"); orcAtivo = null; };
  document.getElementById("btnFecharResp").onclick  = () => { document.getElementById("modalResp").classList.remove("open"); orcAtivo = null; };

  document.getElementById("btnNovo").onclick = async () => {
    document.getElementById("alertNovo").style.display = "none";
    if (!lojas.length) {
      try { const r = await fetch("/api/manut/cliente/lojas",{ headers:{"x-cliente-auth":token} }); lojas = await r.json(); } catch {}
    }
    const sel = document.getElementById("selLoja");
    sel.innerHTML = lojas.length
      ? '<option value="">Selecione a loja...</option>' + lojas.map(l => `<option value="${l.id}">${l.nome}</option>`).join("")
      : '<option value="">Nenhuma loja disponível</option>';
    document.getElementById("descSol").value = "";
    document.getElementById("modalNovo").classList.add("open");
  };

  document.getElementById("btnSubmitNovo").onclick = async () => {
    const alertEl = document.getElementById("alertNovo");
    alertEl.style.display = "none";
    const loja_id = document.getElementById("selLoja").value;
    const descricao_solicitacao = document.getElementById("descSol").value.trim();
    if (!loja_id || !descricao_solicitacao) { alertEl.textContent = "Preencha todos os campos."; alertEl.style.display = ""; return; }
    const btn = document.getElementById("btnSubmitNovo");
    btn.disabled = true; btn.textContent = "Enviando...";
    try {
      const res = await fetch("/api/manut/cliente/orcamentos", {
        method: "POST",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: JSON.stringify({ loja_id, descricao_solicitacao }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      allOrc.unshift({ ...data, manut_lojas: lojas.find(l => l.id === loja_id) });
      document.getElementById("modalNovo").classList.remove("open");
      render();
      window.toast?.("Orçamento solicitado com sucesso!", "success");
    } catch (err) {
      alertEl.textContent = err.message; alertEl.style.display = "";
    } finally {
      btn.disabled = false; btn.textContent = "Solicitar";
    }
  };

  async function load() {
    try {
      const res = await fetch("/api/manut/cliente/orcamentos", { headers: { "x-cliente-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      allOrc = await res.json();
      document.getElementById("loadingState").style.display = "none";
      document.getElementById("tableWrap").style.display = "";
      render();
    } catch {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }
  load();
  window.addEventListener("portal:refresh", load);
</script>
