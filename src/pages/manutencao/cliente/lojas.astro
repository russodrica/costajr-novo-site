---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Minhas Lojas" tipo="cliente" activePage="lojas">
  <div class="section-header">
    <p style="margin:0;font-size:13.5px;color:#5B5F6B">Lojas cadastradas no seu contrato de manutenção.</p>
    <button class="btn btn-primary" id="btnNovaLoja">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Adicionar nova loja
    </button>
  </div>
  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando lojas...</div>
  <div id="lojasWrap" style="display:none"></div>

  <!-- Modal nova loja -->
  <div class="modal-bg" id="modalNL">
    <div class="modal" style="max-width:520px">
      <button class="modal-close" id="btnFecharNL">×</button>
      <h2>🎁 Adicione uma nova loja com 5% de desconto</h2>
      <p style="margin:0 0 18px;color:#5B5F6B;font-size:13.5px">Vamos gerar um cupom único para você usar na contratação. Você é redirecionado para o wizard com o cupom já aplicado.</p>
      <div id="alertNL" class="alert alert-error" style="display:none"></div>
      <div style="text-align:center;padding:20px;background:#FEF2F2;border:2px dashed #C41E3A;border-radius:10px">
        <div style="font-size:10.5px;color:#5B5F6B;letter-spacing:2px;text-transform:uppercase;font-weight:700">Cupom gerado</div>
        <div id="cupomGerado" style="font-family:'Montserrat',sans-serif;font-size:24px;font-weight:700;color:#C41E3A;letter-spacing:3px;margin-top:8px">—</div>
        <div style="font-size:11px;color:#5B5F6B;margin-top:6px">5% de desconto na nova loja</div>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:18px">
        <button class="btn btn-outline" id="btnCancelNL">Cancelar</button>
        <button class="btn btn-primary" id="btnIrContratarNL">Adicionar loja com desconto</button>
      </div>
    </div>
  </div>
</Portal>

<style>
  .loja-card {
    background:#fff; border:1px solid var(--border); border-radius:var(--radius-lg);
    padding:22px 24px; margin-bottom:12px;
    box-shadow:var(--shadow-sm); transition:var(--transition);
  }
  .loja-card:hover { box-shadow:var(--shadow); transform:translateY(-1px); }
  .loja-header { display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:14px; }
  .loja-nome { font-family:'Montserrat',sans-serif;font-weight:700;font-size:16px; }
  .loja-cidade { font-size:13px;color:#6B7280;margin-top:3px; }
  .loja-info { display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-top:4px; }
  .info-item strong { display:block;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#9CA3AF;margin-bottom:2px; }
  .info-item span { font-size:13.5px;color:#374151; }
  .esp-tag { display:inline-block;padding:3px 10px;border-radius:100px;font-size:11px;font-weight:600;background:#F3F4F6;color:#374151;margin:2px; }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  function badge(status) {
    const labels = { ativo:"Ativo", pendente:"Pendente", inativo:"Inativo" };
    return `<span class="badge badge-${status}">${labels[status] || status}</span>`;
  }

  async function load() {
    try {
      const res = await fetch("/api/manut/cliente/lojas", { headers: { "x-cliente-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      const lojas = await res.json();
      const wrap = document.getElementById("lojasWrap");
      document.getElementById("loadingState").style.display = "none";
      wrap.style.display = "";

      if (!lojas.length) {
        wrap.innerHTML = `<div class="card"><div class="empty-state">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <strong>Nenhuma loja cadastrada</strong>
          <p>Entre em contato com o suporte para adicionar lojas ao seu contrato.</p>
        </div></div>`;
        return;
      }

      wrap.innerHTML = lojas.map(l => `
        <div class="loja-card">
          <div class="loja-header">
            <div>
              <div class="loja-nome">${l.nome}</div>
              <div class="loja-cidade">📍 ${[l.endereco, l.cidade, l.uf].filter(Boolean).join(", ")}</div>
            </div>
            ${badge(l.status)}
          </div>
          <div class="loja-info">
            <div class="info-item"><strong>CEP</strong><span>${l.cep || "—"}</span></div>
            <div class="info-item"><strong>Tamanho</strong><span>${l.tamanho_m2 ? l.tamanho_m2 + " m²" : "—"}</span></div>
          </div>
          ${l.especialidades?.length ? `
          <div style="margin-top:14px;padding-top:12px;border-top:1px solid var(--border-light)">
            <div style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#9CA3AF;margin-bottom:6px">Especialidades</div>
            ${(l.especialidades||[]).map(e => `<span class="esp-tag">${e}</span>`).join("")}
          </div>` : ""}
        </div>
      `).join("");
    } catch {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }
  let cupomAtual = null;

  function fecharNL() { document.getElementById("modalNL").classList.remove("open"); }
  document.getElementById("btnNovaLoja").onclick = async () => {
    document.getElementById("alertNL").style.display = "none";
    document.getElementById("cupomGerado").textContent = "Gerando...";
    document.getElementById("modalNL").classList.add("open");
    try {
      const res = await fetch("/api/manut/cliente/cupons/nova-loja", {
        method: "POST",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: "{}"
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Erro ao gerar cupom");
      cupomAtual = data.codigo;
      document.getElementById("cupomGerado").textContent = data.codigo;
    } catch (err) {
      document.getElementById("alertNL").textContent = err.message;
      document.getElementById("alertNL").style.display = "";
      document.getElementById("cupomGerado").textContent = "—";
    }
  };
  document.getElementById("btnCancelNL").onclick = fecharNL;
  document.getElementById("btnFecharNL").onclick = fecharNL;
  document.getElementById("btnIrContratarNL").onclick = () => {
    if (!cupomAtual) return;
    window.location.href = `/manutencao/contratar?cupom=${encodeURIComponent(cupomAtual)}&loja_extra=1`;
  };

  load();
  window.addEventListener("portal:refresh", load);
</script>
