---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Dashboard" tipo="cliente" activePage="dashboard">
  <div id="loadingState" class="loading">Carregando dados...</div>
  <div id="bannerPendente" style="display:none;background:#FFFBEB;border:1px solid #FDE68A;border-radius:8px;padding:14px 18px;margin-bottom:20px;font-size:14px;color:#92400E">
    ⏳ <strong>Plano aguardando confirmação de pagamento.</strong> Após o pagamento ser processado, seu acesso completo será liberado automaticamente.
  </div>
  <div id="dashContent" style="display:none">
    <div class="stats-grid" id="statsGrid"></div>

    <div class="grid-3col" style="margin-bottom:20px">
      <div class="card" style="grid-column:span 2">
        <h3>Chamados por Tipo — Últimos 12 meses</h3>
        <div id="chartWrap" style="display:flex;align-items:center;gap:32px;flex-wrap:wrap"></div>
      </div>
      <div class="card">
        <h3>Ações Rápidas</h3>
        <div style="display:flex;flex-direction:column;gap:8px">
          <a href="/manutencao/cliente/chamados" class="btn btn-primary" style="justify-content:center">+ Abrir Chamado</a>
          <a href="/manutencao/cliente/preventivas" class="btn btn-outline" style="justify-content:center">Preventivas</a>
          <a href="/manutencao/cliente/orcamentos" class="btn btn-outline" style="justify-content:center">Orçamentos</a>
          <a href="/manutencao/cliente/lojas" class="btn btn-outline" style="justify-content:center">Minhas Lojas</a>
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px" class="grid-dash">
      <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
          <h3 style="margin:0">Minhas Lojas</h3>
          <a href="/manutencao/cliente/lojas" class="btn btn-outline btn-sm">Ver todas</a>
        </div>
        <div id="lojasList"></div>
      </div>
      <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
          <h3 style="margin:0">Próximas Preventivas</h3>
          <a href="/manutencao/cliente/preventivas" class="btn btn-outline btn-sm">Ver todas</a>
        </div>
        <div id="prevList"></div>
      </div>
    </div>
  </div>
</Portal>

<style>
  .grid-3col { display:grid; grid-template-columns:2fr 1fr; gap:20px; }
  @media (max-width:900px) { .grid-3col { grid-template-columns:1fr !important; } .grid-3col .card { grid-column:span 1 !important; } }
  @media (max-width:760px) { .grid-dash { grid-template-columns: 1fr !important; } }
  .loja-item { padding: 12px 0; border-bottom: 1px solid #E5E7EB; display: flex; align-items: center; justify-content: space-between; }
  .loja-item:last-child { border-bottom: 0; }
  .loja-nome { font-weight: 600; font-size: 14px; }
  .loja-sub { font-size: 12px; color: #6B7280; }
  .prev-item { padding: 10px 0; border-bottom: 1px solid #E5E7EB; font-size: 14px; }
  .prev-item:last-child { border-bottom: 0; }
  .empty { color: #9CA3AF; font-size: 14px; padding: 12px 0; }
  .legend-dot { display:inline-block;width:12px;height:12px;border-radius:50%;margin-right:6px;flex-shrink:0 }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  function badge(status) {
    const labels = { aberto:"Aberto", em_andamento:"Em andamento", aguardando_material:"Aguard. material", concluido:"Concluído", cancelado:"Cancelado", ativo:"Ativo", pendente:"Pendente", agendada:"Agendada", realizada:"Realizada" };
    return `<span class="badge badge-${status}">${labels[status] || status}</span>`;
  }
  function fmtDate(d) {
    if (!d) return "—";
    return new Date(d).toLocaleDateString("pt-BR");
  }

  function buildDonut(eletrica, hidraulica, civil) {
    const total = eletrica + hidraulica + civil;
    const wrap = document.getElementById("chartWrap");
    if (total === 0) {
      wrap.innerHTML = '<div class="empty">Nenhum chamado registrado no período.</div>';
      return;
    }
    const colors = ["#1D4ED8","#15803D","#C2410C"];
    const values = [eletrica, hidraulica, civil];
    const labels = ["Elétrica","Hidráulica","Civil"];
    const r = 52, cx = 64, cy = 64, stroke = 20;
    const circ = 2 * Math.PI * r;
    let offset = 0;
    let paths = "";
    values.forEach((v, i) => {
      const frac = v / total;
      const dash = frac * circ;
      const gap  = circ - dash;
      // start from top (-90deg = rotate -90)
      paths += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${colors[i]}" stroke-width="${stroke}"
        stroke-dasharray="${dash} ${gap}"
        stroke-dashoffset="${-(offset * circ - circ / 4)}"
        transform="rotate(-90 ${cx} ${cy})" style="transition:stroke-dasharray .4s"/>`;
      offset += frac;
    });
    const svg = `<svg width="128" height="128" viewBox="0 0 128 128" style="flex-shrink:0">
      ${paths}
      <text x="${cx}" y="${cy+6}" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="22" font-weight="800" fill="#2D2F36">${total}</text>
      <text x="${cx}" y="${cy+20}" text-anchor="middle" font-family="Open Sans,sans-serif" font-size="9" fill="#9CA3AF">TOTAL</text>
    </svg>`;
    const legend = `<div style="display:flex;flex-direction:column;gap:10px">
      ${values.map((v,i) => `
        <div style="display:flex;align-items:center;gap:8px">
          <span class="legend-dot" style="background:${colors[i]}"></span>
          <span style="font-size:14px;color:#5B5F6B;min-width:70px">${labels[i]}</span>
          <span style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:18px;color:#2D2F36">${v}</span>
          <span style="font-size:12px;color:#9CA3AF">(${Math.round(v/total*100)}%)</span>
        </div>`).join("")}
    </div>`;
    wrap.innerHTML = svg + legend;
  }

  async function load() {
    try {
      const res = await fetch("/api/manut/cliente/me", { headers: { "x-cliente-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      const { cliente, dashboard } = await res.json();

      if (cliente.senha_troca_obrigatoria) { window.location.replace("/manutencao/cliente/trocar-senha"); return; }
      if (cliente.status === "pendente") document.getElementById("bannerPendente").style.display = "";

      // Stats
      const materiaisPend = dashboard.materiaisPendentes?.length || 0;
      document.getElementById("statsGrid").innerHTML = `
        <div class="stat-card">
          <div class="stat-label">Chamados abertos</div>
          <div class="stat-value">${dashboard.chamadosAbertos || 0}</div>
          <div class="stat-sub"><a href="/manutencao/cliente/chamados" style="color:#C41E3A">Ver chamados →</a></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Lojas cadastradas</div>
          <div class="stat-value">${dashboard.lojas?.length || 0}</div>
          <div class="stat-sub"><a href="/manutencao/cliente/lojas" style="color:#C41E3A">Ver lojas →</a></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Próx. preventiva</div>
          <div class="stat-value" style="font-size:20px">${dashboard.proximasPreventivas?.[0] ? fmtDate(dashboard.proximasPreventivas[0].data_agendada) : "—"}</div>
          <div class="stat-sub"><a href="/manutencao/cliente/preventivas" style="color:#C41E3A">Ver preventivas →</a></div>
        </div>
        ${materiaisPend > 0 ? `
        <div class="stat-card accent">
          <div class="stat-label">Materiais pend. aprovação</div>
          <div class="stat-value">${materiaisPend}</div>
          <div class="stat-sub"><a href="/manutencao/cliente/materiais" style="color:#C41E3A">Ver materiais →</a></div>
        </div>` : ""}
      `;

      // Donut chart
      const ch = dashboard.distribuicao || {};
      buildDonut(ch.eletrica || 0, ch.hidraulica || 0, ch.civil || 0);

      // Lojas
      const lojaEl = document.getElementById("lojasList");
      if (!dashboard.lojas?.length) {
        lojaEl.innerHTML = '<div class="empty">Nenhuma loja cadastrada.</div>';
      } else {
        lojaEl.innerHTML = dashboard.lojas.slice(0,5).map(l => `
          <div class="loja-item">
            <div>
              <div class="loja-nome">${l.nome}</div>
              <div class="loja-sub">${l.cidade || ""}${l.uf ? " — " + l.uf : ""}</div>
            </div>
            ${badge(l.status)}
          </div>
        `).join("");
      }

      // Preventivas
      const prevEl = document.getElementById("prevList");
      if (!dashboard.proximasPreventivas?.length) {
        prevEl.innerHTML = '<div class="empty">Nenhuma preventiva agendada.</div>';
      } else {
        prevEl.innerHTML = dashboard.proximasPreventivas.slice(0,5).map(p => `
          <div class="prev-item">
            📅 <strong>${fmtDate(p.data_agendada)}</strong>
            <span style="font-size:12px;color:#6B7280;margin-left:8px">${badge(p.status)}</span>
          </div>
        `).join("");
      }

      document.getElementById("loadingState").style.display = "none";
      document.getElementById("dashContent").style.display = "";
    } catch (err) {
      document.getElementById("loadingState").textContent = "Erro ao carregar dados. Tente recarregar.";
    }
  }
  load();
  window.addEventListener("portal:refresh", load);
</script>
