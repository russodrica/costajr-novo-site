---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Estoque" tipo="cliente" activePage="estoque">
  <div class="section-header">
    <p style="margin:0;font-size:13.5px;color:#5B5F6B">Kit de material de preventiva por loja. Acompanhe usos, novos itens e solicite reposição.</p>
    <button class="btn btn-primary" id="btnNovoItem">+ Cadastrar item</button>
  </div>

  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando estoque...</div>

  <div id="estoqueContent" style="display:none">
    <!-- Filtro por loja -->
    <div class="card" style="margin-bottom:18px">
      <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap">
        <label style="font-size:13px;font-weight:600;color:var(--ink-mid)">Loja:</label>
        <select id="filtroLoja" style="padding:8px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:13.5px;font-family:'Open Sans',sans-serif;outline:none;min-width:240px">
          <option value="">Todas as lojas</option>
        </select>
      </div>
    </div>

    <!-- Reposições pendentes -->
    <div class="card" id="cardReposicoes" style="margin-bottom:18px;display:none">
      <h3 style="margin:0 0 12px;font-family:'Montserrat',sans-serif;font-size:15px">⚠ Solicitar reposição</h3>
      <p style="font-size:12.5px;color:var(--ink-mid);margin:0 0 12px">Itens usados ou trazidos pelo técnico nas últimas visitas. Marque os que você precisa repor para a próxima visita.</p>
      <div id="listaReposicoes"></div>
    </div>

    <!-- Estoque atual -->
    <div class="card" style="margin-bottom:18px">
      <h3 style="margin:0 0 12px;font-family:'Montserrat',sans-serif;font-size:15px">📦 Estoque atual</h3>
      <div id="listaItens"></div>
    </div>

    <!-- Histórico -->
    <div class="card">
      <h3 style="margin:0 0 12px;font-family:'Montserrat',sans-serif;font-size:15px">📜 Histórico de movimentações</h3>
      <div id="listaHistorico"></div>
    </div>
  </div>

  <!-- Modal Pix da reposição -->
  <div class="modal-bg" id="modalPixRep">
    <div class="modal" style="max-width:440px">
      <button class="modal-close" id="btnFecharPixRep">×</button>
      <h2>⚡ Pagar reposição via Pix</h2>
      <div style="margin-bottom:10px;font-size:13px;color:var(--ink-mid)">Valor: <strong id="pixRepValor" style="color:#15803D"></strong></div>
      <div id="pixRepStatus" style="font-size:12.5px;color:var(--ink-mid);margin-bottom:10px"></div>
      <div id="pixRepContent" style="display:none">
        <img id="pixRepQr" src="" alt="QR Code Pix" style="display:block;margin:0 auto 12px;width:220px;height:220px;background:#fff;border:1px solid var(--border);border-radius:8px;padding:6px">
        <label style="font-size:11.5px;font-weight:700;color:var(--ink-mid);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:4px">Pix copia e cola</label>
        <textarea id="pixRepCode" readonly rows="3" style="width:100%;padding:8px 10px;border:1.5px solid var(--border);border-radius:6px;font-family:monospace;font-size:11.5px;background:#fff;resize:none;outline:none"></textarea>
        <button type="button" id="btnCopiarPixRep" style="margin-top:8px;width:100%;padding:9px;background:#15803D;color:#fff;border:0;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;font-family:'Montserrat',sans-serif">📋 Copiar código Pix</button>
        <div id="pixRepCopiado" style="display:none;text-align:center;font-size:11.5px;color:#15803D;margin-top:6px;font-weight:600">✓ Código copiado!</div>
        <p style="font-size:11.5px;color:var(--ink-light);margin-top:10px;text-align:center">Assim que o pagamento for confirmado, o status muda automaticamente para "Pago". O técnico verá na próxima visita.</p>
      </div>
      <div style="display:flex;justify-content:flex-end;margin-top:14px">
        <button class="btn btn-outline" id="btnOkPixRep">Fechar</button>
      </div>
    </div>
  </div>

  <!-- Modal novo item -->
  <div class="modal-bg" id="modalNovo">
    <div class="modal">
      <button class="modal-close" id="btnFechar">×</button>
      <h2>Cadastrar item de estoque</h2>
      <p style="font-size:12.5px;color:var(--ink-mid);margin:0 0 14px">Itens que ficarão disponíveis na loja para o técnico usar nas preventivas.</p>
      <div id="alertNovo" class="alert alert-error" style="display:none"></div>
      <div class="form-group">
        <label>Loja *</label>
        <select id="novoLoja"></select>
      </div>
      <div class="form-group">
        <label>Nome do item *</label>
        <input id="novoNome" placeholder="Ex: Cabo flexível 2.5mm, Lâmpada LED 9W">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px" class="grid-3col">
        <div class="form-group"><label>Unidade</label><input id="novoUnidade" placeholder="un" value="un"></div>
        <div class="form-group"><label>Qtd atual</label><input id="novoQtdAtual" type="number" min="0" step="0.01" value="0"></div>
        <div class="form-group"><label>Qtd mínima</label><input id="novoQtdMin" type="number" min="0" step="0.01" value="1"></div>
      </div>
      <div class="form-group">
        <label>Valor unitário (R$) <span style="font-weight:400;color:#9CA3AF">— usado para reposição via Pix</span></label>
        <input id="novoPreco" type="number" min="0" step="0.01" placeholder="0,00">
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button class="btn btn-outline" id="btnCancelar">Cancelar</button>
        <button class="btn btn-primary" id="btnSalvar">Cadastrar</button>
      </div>
    </div>
  </div>
</Portal>

<style>
  .row-baixo td { background: #FEF2F2 !important; }

  .mov-row {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px; border-bottom: 1px solid var(--border-light);
    font-size: 13px;
  }
  .mov-row:last-child { border-bottom: 0; }
  .mov-tag {
    flex-shrink: 0; padding: 2px 8px; border-radius: 100px;
    font-size: 10.5px; font-weight: 700; text-transform: uppercase;
  }
  .mov-tag.baixa     { background: #FEF2F2; color: #B91C1C; }
  .mov-tag.adicao    { background: #FFFBEB; color: #92400E; }
  .mov-tag.reposicao { background: #EFF6FF; color: #1D4ED8; }
  .rep-status {
    flex-shrink: 0; padding: 2px 8px; border-radius: 100px;
    font-size: 10.5px; font-weight: 700;
  }
  .rep-status.solicitada { background: #FFFBEB; color: #92400E; }
  .rep-status.atendida   { background: #D1FAE5; color: #15803D; }

  @media (max-width: 600px) {
    .grid-3col { grid-template-columns: 1fr !important; }
    .estoque-row, .mov-row { flex-wrap: wrap; }
  }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  let dados = { itens: [], movimentos: [], lojas: [] };
  let filtroLoja = "";

  function api(path, opts = {}) {
    return fetch(path, { ...opts, headers: { ...(opts.headers||{}), "x-cliente-auth": token } });
  }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function render() {
    // Lista de itens filtrados
    const itens = filtroLoja ? dados.itens.filter(i => i.loja_id === filtroLoja) : dados.itens;
    const listaEl = document.getElementById("listaItens");
    if (!itens.length) {
      listaEl.innerHTML = '<div style="color:var(--ink-light);padding:14px 0;font-size:13.5px;text-align:center">Nenhum item cadastrado. Clique em "+ Cadastrar item" para começar.</div>';
    } else {
      listaEl.innerHTML = `<div class="table-wrap"><table>
        <thead>
          <tr>
            <th>Item</th>
            <th>Loja</th>
            <th style="text-align:right">Qtd atual</th>
            <th style="text-align:right">Mínimo</th>
            <th>Unidade</th>
            <th style="text-align:right">Valor unit.</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          ${itens.map(i => {
            const baixo = Number(i.quantidade_atual) < Number(i.quantidade_minima);
            const preco = Number(i.preco_unitario || 0);
            const precoTxt = preco > 0
              ? `R$ ${preco.toFixed(2).replace(".", ",")}`
              : `<span style="color:#9CA3AF;font-size:11.5px">—</span>`;
            return `<tr class="${baixo ? 'row-baixo' : ''}">
              <td><strong>${i.nome}</strong></td>
              <td>${i.manut_lojas?.nome || "—"}</td>
              <td style="text-align:right;font-family:'Montserrat',sans-serif;font-weight:700;color:${baixo ? '#B91C1C' : 'var(--ink)'}">${Number(i.quantidade_atual)}</td>
              <td style="text-align:right;color:var(--ink-mid)">${Number(i.quantidade_minima)}</td>
              <td style="color:var(--ink-mid)">${i.unidade}</td>
              <td style="text-align:right;color:var(--ink-mid)">${precoTxt}</td>
              <td>${baixo ? '<span class="badge badge-inadimplente">Em baixa</span>' : '<span class="badge badge-ativo">OK</span>'}</td>
            </tr>`;
          }).join("")}
        </tbody>
      </table></div>`;
    }

    // Reposições pendentes (movimentos de baixa/adição sem reposição pedida)
    const movs = filtroLoja ? dados.movimentos.filter(m => m.loja_id === filtroLoja) : dados.movimentos;
    const pendentes = movs.filter(m => m.reposicao_status === "nao_solicitada" && (m.tipo === "baixa" || m.tipo === "adicao"));
    const cardRep = document.getElementById("cardReposicoes");
    const listaRep = document.getElementById("listaReposicoes");
    if (pendentes.length === 0) {
      cardRep.style.display = "none";
    } else {
      cardRep.style.display = "";
      listaRep.innerHTML = pendentes.map(m => {
        const tagCls = m.tipo === "baixa" ? "baixa" : "adicao";
        const tagTxt = m.tipo === "baixa" ? "Baixa" : "Item novo";
        const preco = Number(m.manut_estoque?.preco_unitario || 0);
        const qtd = Number(m.quantidade);
        const valor = preco * qtd;
        const valorTxt = preco > 0
          ? `<strong style="color:#15803D">R$ ${valor.toFixed(2).replace(".", ",")}</strong>`
          : `<span style="color:#92400E;font-size:11.5px">⚠ sem valor cadastrado</span>`;
        return `<div class="rep-row">
          <div style="display:flex;align-items:flex-start;gap:10px;flex-wrap:wrap">
            <span class="mov-tag ${tagCls}">${tagTxt}</span>
            <div style="flex:1;min-width:220px">
              <strong>${m.manut_estoque?.nome || "—"}</strong> — ${qtd} ${m.manut_estoque?.unidade || "un"}
              <div style="font-size:11.5px;color:var(--ink-light);margin-top:2px">${m.manut_lojas?.nome || "—"} · ${fmtDate(m.created_at)}${m.manut_tecnicos?.nome ? ` · 👤 ${m.manut_tecnicos.nome}` : ""}</div>
              ${m.observacao ? `<div style="font-size:11.5px;color:var(--ink-mid);margin-top:2px;font-style:italic">💬 ${m.observacao}</div>` : ""}
              <div style="font-size:13px;margin-top:6px">Valor da reposição: ${valorTxt}</div>
            </div>
          </div>
          <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
            <button class="btn btn-primary btn-sm" data-pagar-pix="${m.id}" ${preco > 0 ? "" : "disabled title='Cadastre o valor unitário do item antes de pagar via Pix'"}>⚡ Pagar via Pix</button>
            <button class="btn btn-outline btn-sm" data-proxima-visita="${m.id}">🛒 Comprar até a próxima visita</button>
          </div>
        </div>`;
      }).join("");
    }

    // Histórico (todos os movimentos)
    const histEl = document.getElementById("listaHistorico");
    if (!movs.length) {
      histEl.innerHTML = '<div style="color:var(--ink-light);padding:14px 0;font-size:13.5px;text-align:center">Nenhuma movimentação ainda.</div>';
    } else {
      histEl.innerHTML = `<div class="table-wrap"><table>
        <thead>
          <tr>
            <th>Data</th>
            <th>Tipo</th>
            <th>Item</th>
            <th style="text-align:right">Qtd</th>
            <th>Loja</th>
            <th>Reposição</th>
          </tr>
        </thead>
        <tbody>
          ${movs.map(m => {
            const tagCls = m.tipo === "baixa" ? "baixa" : m.tipo === "adicao" ? "adicao" : "reposicao";
            const tagTxt = m.tipo === "baixa" ? "Baixa" : m.tipo === "adicao" ? "Item novo" : "Reposição";
            let repHtml = '<span style="color:#D1D5DB">—</span>';
            if (m.reposicao_status === "solicitada") repHtml = '<span class="rep-status solicitada">Solicitada</span>';
            else if (m.reposicao_status === "atendida") repHtml = '<span class="rep-status atendida">Reposto</span>';
            return `<tr>
              <td style="white-space:nowrap">${fmtDate(m.created_at)}</td>
              <td><span class="mov-tag ${tagCls}">${tagTxt}</span></td>
              <td><strong>${m.manut_estoque?.nome || "—"}</strong></td>
              <td style="text-align:right;font-family:'Montserrat',sans-serif;font-weight:700">${Number(m.quantidade)} ${m.manut_estoque?.unidade || "un"}</td>
              <td>${m.manut_lojas?.nome || "—"}</td>
              <td>${repHtml}</td>
            </tr>`;
          }).join("")}
        </tbody>
      </table></div>`;
    }
  }

  async function load() {
    try {
      const res = await api("/api/manut/cliente/estoque");
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      const json = await res.json();
      dados = { itens: json.itens || [], movimentos: json.movimentos || [], lojas: json.lojas || [] };

      // popular select de loja (filtro)
      const sel = document.getElementById("filtroLoja");
      sel.innerHTML = '<option value="">Todas as lojas</option>' + dados.lojas.map(l => `<option value="${l.id}">${l.nome}</option>`).join("");
      // popular select do modal
      const selNovo = document.getElementById("novoLoja");
      selNovo.innerHTML = dados.lojas.map(l => `<option value="${l.id}">${l.nome}</option>`).join("");

      document.getElementById("loadingState").style.display = "none";
      document.getElementById("estoqueContent").style.display = "";
      render();
    } catch (err) {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }

  document.getElementById("filtroLoja").addEventListener("change", (e) => {
    filtroLoja = e.target.value;
    render();
  });

  document.getElementById("btnNovoItem").addEventListener("click", () => {
    if (!dados.lojas.length) { alert("Você ainda não tem lojas cadastradas."); return; }
    document.getElementById("alertNovo").style.display = "none";
    document.getElementById("novoNome").value = "";
    document.getElementById("novoUnidade").value = "un";
    document.getElementById("novoQtdAtual").value = "0";
    document.getElementById("novoQtdMin").value = "1";
    document.getElementById("novoPreco").value = "";
    document.getElementById("modalNovo").classList.add("open");
  });

  function fecharModal() { document.getElementById("modalNovo").classList.remove("open"); }
  document.getElementById("btnFechar").addEventListener("click", fecharModal);
  document.getElementById("btnCancelar").addEventListener("click", fecharModal);

  document.getElementById("btnSalvar").addEventListener("click", async () => {
    const alertEl = document.getElementById("alertNovo");
    alertEl.style.display = "none";
    const loja_id = document.getElementById("novoLoja").value;
    const nome = document.getElementById("novoNome").value.trim();
    const unidade = document.getElementById("novoUnidade").value.trim() || "un";
    const quantidade_atual = parseFloat(document.getElementById("novoQtdAtual").value || "0");
    const quantidade_minima = parseFloat(document.getElementById("novoQtdMin").value || "1");
    const precoTxt = document.getElementById("novoPreco").value;
    const preco_unitario = precoTxt ? parseFloat(precoTxt) : null;
    if (!loja_id) { alertEl.textContent = "Selecione a loja."; alertEl.style.display = ""; return; }
    if (!nome) { alertEl.textContent = "Informe o nome."; alertEl.style.display = ""; return; }
    const btn = document.getElementById("btnSalvar");
    btn.disabled = true; btn.textContent = "Salvando...";
    try {
      const res = await api("/api/manut/cliente/estoque", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ loja_id, nome, unidade, quantidade_atual, quantidade_minima, preco_unitario }),
      });
      if (!res.ok) { const d = await res.json().catch(() => ({})); throw new Error(d.error || "Falha"); }
      fecharModal();
      await load();
      window.toast?.("Item cadastrado no estoque", "success");
    } catch (err) {
      alertEl.textContent = err.message; alertEl.style.display = "";
    } finally {
      btn.disabled = false; btn.textContent = "Cadastrar";
    }
  });

  // Próxima visita
  document.addEventListener("click", async (e) => {
    const btn = e.target.closest("[data-proxima-visita]");
    if (!btn) return;
    const movId = btn.dataset.proximaVisita;
    if (!confirm("Confirmar: você vai comprar este item até a próxima preventiva. O técnico verá no painel.")) return;
    btn.disabled = true; btn.textContent = "...";
    try {
      const res = await api(`/api/manut/cliente/estoque/movimentos/${movId}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ action: "proxima_visita" }),
      });
      if (!res.ok) { const d = await res.json().catch(() => ({})); throw new Error(d.error || "Falha"); }
      await load();
      window.toast?.("Marcado. O técnico verá pendente para reposição na próxima visita.", "success");
    } catch (err) {
      alert("Erro: " + err.message);
      btn.disabled = false; btn.textContent = "🛒 Comprar até a próxima visita";
    }
  });

  // Pagar via Pix
  document.addEventListener("click", async (e) => {
    const btn = e.target.closest("[data-pagar-pix]");
    if (!btn) return;
    const movId = btn.dataset.pagarPix;
    const modal = document.getElementById("modalPixRep");
    document.getElementById("pixRepStatus").textContent = "Gerando código Pix...";
    document.getElementById("pixRepContent").style.display = "none";
    document.getElementById("pixRepCopiado").style.display = "none";
    modal.classList.add("open");
    try {
      const res = await api(`/api/manut/cliente/estoque/movimentos/${movId}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ action: "pagar_pix" }),
      });
      const d = await res.json();
      if (!res.ok) throw new Error(d.error || "Falha");
      if (d.qr_code_base64) document.getElementById("pixRepQr").src = "data:image/png;base64," + d.qr_code_base64;
      document.getElementById("pixRepCode").value = d.qr_code || "";
      document.getElementById("pixRepValor").textContent = d.valor ? "R$ " + Number(d.valor).toFixed(2).replace(".", ",") : "";
      document.getElementById("pixRepContent").style.display = "";
      document.getElementById("pixRepStatus").textContent = "Escaneie o QR Code ou copie o código no app do banco.";
    } catch (err) {
      document.getElementById("pixRepStatus").innerHTML = '<span style="color:#B91C1C">⚠ ' + err.message + '</span>';
    }
  });

  // Modal Pix - copiar + fechar
  document.addEventListener("click", async (e) => {
    if (e.target?.id === "btnCopiarPixRep") {
      const code = document.getElementById("pixRepCode").value;
      if (!code) return;
      try { await navigator.clipboard.writeText(code); } catch { document.getElementById("pixRepCode").select(); document.execCommand("copy"); }
      const aviso = document.getElementById("pixRepCopiado");
      aviso.style.display = "";
      setTimeout(() => { aviso.style.display = "none"; }, 2500);
    }
    if (e.target?.id === "btnFecharPixRep" || e.target?.id === "btnOkPixRep") {
      document.getElementById("modalPixRep").classList.remove("open");
      load();
    }
  });

  load();
  window.addEventListener("portal:refresh", load);
</script>
