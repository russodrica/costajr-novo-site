---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Chamados" tipo="cliente" activePage="chamados">
  <div class="section-header">
    <div>
      <p style="margin:0;font-size:13.5px;color:#5B5F6B">Acompanhe e abra chamados de manutenção para suas lojas.</p>
    </div>
    <button class="btn btn-primary" id="btnAbrirModal">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Abrir chamado
    </button>
  </div>

  <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap">
    <button class="btn btn-outline btn-sm filtro active" data-filtro="">Todos</button>
    <button class="btn btn-outline btn-sm filtro" data-filtro="aberto">Abertos</button>
    <button class="btn btn-outline btn-sm filtro" data-filtro="em_andamento">Em andamento</button>
    <button class="btn btn-outline btn-sm filtro" data-filtro="aguardando_material">Aguard. material</button>
    <button class="btn btn-outline btn-sm filtro" data-filtro="concluido">Concluídos</button>
  </div>

  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando chamados...</div>

  <div class="card" id="chamadosCard" style="display:none">
    <div class="table-wrap">
      <table id="chamadosTable">
        <thead>
          <tr>
            <th>Tipo</th>
            <th>Loja</th>
            <th>Descrição</th>
            <th>Status</th>
            <th>Técnico</th>
            <th>Aberto em</th>
          </tr>
        </thead>
        <tbody id="chamadosTbody"></tbody>
      </table>
    </div>
    <div id="emptyMsg" style="display:none">
      <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        <strong>Nenhum chamado encontrado</strong>
        <p>Use o botão acima para abrir um novo chamado.</p>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div class="modal-bg" id="modalBg">
    <div class="modal">
      <button class="modal-close" id="btnFecharModal">×</button>
      <h2>Abrir Chamado</h2>
      <div id="modalAlert" class="alert alert-error" style="display:none"></div>
      <div class="form-group">
        <label>Loja</label>
        <select id="lojaSelect"><option value="">Selecione a loja...</option></select>
      </div>
      <div class="grid-2">
        <div class="form-group">
          <label>Tipo de manutenção</label>
          <select id="tipoSelect">
            <option value="">Selecione...</option>
            <option value="eletrica">⚡ Elétrica</option>
            <option value="hidraulica">💧 Hidráulica</option>
            <option value="civil">🏗️ Civil</option>
          </select>
        </div>
        <div class="form-group">
          <label>Local na loja <span style="font-weight:400;color:#9CA3AF">(opcional)</span></label>
          <input type="text" id="localInput" placeholder="Ex: Banheiro, Quadro elétrico...">
        </div>
      </div>
      <div class="form-group">
        <label>Descrição do problema</label>
        <textarea id="descricaoInput" placeholder="Descreva o problema com o máximo de detalhes possível..."></textarea>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:4px">
        <button class="btn btn-outline" id="btnCancelarModal">Cancelar</button>
        <button class="btn btn-primary" id="btnSubmitChamado">Abrir chamado</button>
      </div>
    </div>
  </div>
</Portal>

<style>
  .filtro.active { background: var(--brand); color: #fff; border-color: var(--brand); }
  .tipo-badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 5px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
  .tipo-eletrica  { background: #EFF6FF; color: #1D4ED8; }
  .tipo-hidraulica{ background: #F0FDF4; color: #15803D; }
  .tipo-civil     { background: #FFF7ED; color: #C2410C; }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  let allChamados = [];
  let lojas = [];
  let filtroAtual = "";

  function badge(status) {
    const labels = { aberto:"Aberto", em_andamento:"Em andamento", aguardando_material:"Aguard. material", concluido:"Concluído", cancelado:"Cancelado" };
    return `<span class="badge badge-${status}">${labels[status] || status}</span>`;
  }
  function tipoBadge(tipo) {
    const icons = { eletrica:"⚡", hidraulica:"💧", civil:"🏗️" };
    return `<span class="tipo-badge tipo-${tipo}">${icons[tipo]||""} ${tipo}</span>`;
  }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function renderChamados() {
    const tbody = document.getElementById("chamadosTbody");
    const emptyMsg = document.getElementById("emptyMsg");
    const filtered = filtroAtual ? allChamados.filter(c => c.status === filtroAtual) : allChamados;
    if (!filtered.length) {
      tbody.innerHTML = "";
      emptyMsg.style.display = "";
    } else {
      emptyMsg.style.display = "none";
      tbody.innerHTML = filtered.map(c => `
        <tr>
          <td>${tipoBadge(c.tipo)}</td>
          <td style="font-weight:600">${c.manut_lojas?.nome || "—"}</td>
          <td style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#5B5F6B">${c.descricao}</td>
          <td>${badge(c.status)}</td>
          <td style="font-size:12.5px;color:#5B5F6B">${c.manut_tecnicos?.nome || "Não atribuído"}</td>
          <td style="font-size:12.5px;color:#9CA3AF">${fmtDate(c.data_abertura)}</td>
        </tr>
      `).join("");
    }
  }

  async function load() {
    try {
      const [resMe, resChamados] = await Promise.all([
        fetch("/api/manut/cliente/me", { headers: { "x-cliente-auth": token } }),
        fetch("/api/manut/cliente/chamados", { headers: { "x-cliente-auth": token } })
      ]);
      if (resMe.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      const { dashboard } = await resMe.json();
      lojas = dashboard.lojas || [];
      allChamados = await resChamados.json();

      const sel = document.getElementById("lojaSelect");
      sel.innerHTML = '<option value="">Selecione a loja...</option>' + lojas.map(l => `<option value="${l.id}">${l.nome}</option>`).join("");

      document.getElementById("loadingState").style.display = "none";
      document.getElementById("chamadosCard").style.display = "";
      renderChamados();
    } catch {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }

  document.querySelectorAll(".filtro").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".filtro").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      filtroAtual = btn.dataset.filtro;
      renderChamados();
    });
  });

  function fecharModal() { document.getElementById("modalBg").classList.remove("open"); }
  document.getElementById("btnAbrirModal").onclick = () => {
    document.getElementById("modalAlert").style.display = "none";
    document.getElementById("tipoSelect").value = "";
    document.getElementById("descricaoInput").value = "";
    document.getElementById("localInput").value = "";
    document.getElementById("modalBg").classList.add("open");
  };
  document.getElementById("btnCancelarModal").onclick = fecharModal;
  document.getElementById("btnFecharModal").onclick = fecharModal;
  document.getElementById("modalBg").onclick = e => { if (e.target === e.currentTarget) fecharModal(); };

  document.getElementById("btnSubmitChamado").addEventListener("click", async () => {
    const alertEl = document.getElementById("modalAlert");
    alertEl.style.display = "none";
    const lojaId = document.getElementById("lojaSelect").value;
    const tipo = document.getElementById("tipoSelect").value;
    const descricao = document.getElementById("descricaoInput").value.trim();
    const localLoja = document.getElementById("localInput").value.trim();
    if (!lojaId)    { alertEl.textContent = "Selecione a loja."; alertEl.style.display = ""; return; }
    if (!tipo)      { alertEl.textContent = "Selecione o tipo de manutenção."; alertEl.style.display = ""; return; }
    if (!descricao) { alertEl.textContent = "Descreva o problema."; alertEl.style.display = ""; return; }
    const btn = document.getElementById("btnSubmitChamado");
    btn.disabled = true; btn.textContent = "Abrindo...";
    try {
      const res = await fetch("/api/manut/cliente/chamados", {
        method: "POST",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: JSON.stringify({ lojaId, tipo, descricao, localLoja })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Erro ao abrir chamado");
      allChamados.unshift(data);
      renderChamados();
      fecharModal();
      window.toast?.("Chamado aberto com sucesso!", "success");
    } catch (err) {
      alertEl.textContent = err.message; alertEl.style.display = "";
    } finally {
      btn.disabled = false; btn.textContent = "Abrir chamado";
    }
  });

  load();
  window.addEventListener("portal:refresh", load);
</script>
