---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Chamados" tipo="cliente" activePage="chamados">
  <div class="section-header">
    <div>
      <p style="margin:0;font-size:13.5px;color:#5B5F6B">Acompanhe e abra chamados de manutenção para suas lojas.</p>
    </div>
    <button class="btn btn-primary" id="btnAbrirModal">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Abrir chamado
    </button>
  </div>

  <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap">
    <button class="btn btn-outline btn-sm filtro active" data-filtro="">Todos</button>
    <button class="btn btn-outline btn-sm filtro" data-filtro="aberto">Abertos</button>
    <button class="btn btn-outline btn-sm filtro" data-filtro="em_andamento">Em andamento</button>
    <button class="btn btn-outline btn-sm filtro" data-filtro="aguardando_material">Aguard. material</button>
    <button class="btn btn-outline btn-sm filtro" data-filtro="concluido">Concluídos</button>
  </div>

  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando chamados...</div>

  <div class="card" id="chamadosCard" style="display:none">
    <div class="table-wrap">
      <table id="chamadosTable">
        <thead>
          <tr>
            <th>Tipo</th>
            <th>Loja</th>
            <th>Descrição</th>
            <th>Status</th>
            <th>Técnico</th>
            <th>Aberto em</th>
          </tr>
        </thead>
        <tbody id="chamadosTbody"></tbody>
      </table>
    </div>
    <div id="emptyMsg" style="display:none">
      <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        <strong>Nenhum chamado encontrado</strong>
        <p>Use o botão acima para abrir um novo chamado.</p>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div class="modal-bg" id="modalBg">
    <div class="modal" style="max-width:560px">
      <button class="modal-close" id="btnFecharModal">×</button>
      <h2>Abrir Chamado</h2>
      <div id="modalAlert" class="alert alert-error" style="display:none"></div>
      <div class="form-group">
        <label>Loja</label>
        <select id="lojaSelect"><option value="">Selecione a loja...</option></select>
      </div>
      <div class="grid-2">
        <div class="form-group">
          <label>Disciplina</label>
          <select id="tipoSelect">
            <option value="">Selecione...</option>
            <option value="eletrica">⚡ Elétrica</option>
            <option value="hidraulica">💧 Hidráulica</option>
            <option value="civil">🏗️ Civil</option>
          </select>
        </div>
        <div class="form-group">
          <label>Local na loja <span style="font-weight:400;color:#9CA3AF">(opcional)</span></label>
          <input type="text" id="localInput" placeholder="Ex: Banheiro, Quadro elétrico...">
        </div>
      </div>
      <div class="form-group">
        <label>Descrição do problema</label>
        <textarea id="descricaoInput" placeholder="Descreva o problema com o máximo de detalhes possível..."></textarea>
      </div>

      <label class="form-label-block" style="margin-top:8px">Quando você precisa do atendimento?</label>
      <div class="urg-grid" id="urgGrid">
        <div class="urg-opt selected" data-urg="normal">
          <div class="urg-title">📋 Normal</div>
          <div class="urg-sub">Atendido na próxima visita mensal</div>
          <div class="urg-price ok">Sem custo</div>
        </div>
        <div class="urg-opt" data-urg="extra">
          <div class="urg-title">🛠️ Extra · 48h</div>
          <div class="urg-sub">Visita extra em até 48h úteis</div>
          <div class="urg-price" id="urgPriceExtra">R$ 250,00</div>
        </div>
        <div class="urg-opt urg-emerg" data-urg="emergencial">
          <div class="urg-title">⚡ Emergencial · 24h</div>
          <div class="urg-sub">Atendimento no mesmo dia útil</div>
          <div class="urg-price red" id="urgPriceEmerg">R$ 350,00</div>
        </div>
      </div>

      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:14px">
        <button class="btn btn-outline" id="btnCancelarModal">Cancelar</button>
        <button class="btn btn-primary" id="btnSubmitChamado">Abrir chamado</button>
      </div>
    </div>
  </div>

  <!-- Modal Pix -->
  <div class="modal-bg" id="modalPixBg">
    <div class="modal" style="max-width:520px">
      <button class="modal-close" id="btnFecharPix">×</button>
      <h2>Pagamento via Pix</h2>
      <p style="margin:0 0 14px;color:#5B5F6B;font-size:13.5px">Escaneie o QR Code ou copie o código abaixo para pagar e ativar o chamado.</p>
      <div id="pixContent" style="text-align:center"></div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:14px">
        <button class="btn btn-primary" id="btnFecharPix2">Já paguei / Fechar</button>
      </div>
    </div>
  </div>
</Portal>

<style>
  .filtro.active { background: var(--brand); color: #fff; border-color: var(--brand); }
  .tipo-badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 5px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
  .tipo-eletrica  { background: #EFF6FF; color: #1D4ED8; }
  .tipo-hidraulica{ background: #F0FDF4; color: #15803D; }
  .tipo-civil     { background: #FFF7ED; color: #C2410C; }
  .urg-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
  .urg-opt { border: 2px solid #E5E7EB; border-radius: 8px; padding: 10px 11px; cursor: pointer; transition: .15s; background:#FFF; }
  .urg-opt:hover { border-color: #C41E3A; }
  .urg-opt.selected { border-color: #C41E3A; background:#FEF2F2; }
  .urg-opt.urg-emerg { border-color:#FECACA; }
  .urg-opt.urg-emerg.selected { border-color:#C41E3A; background:#FEF2F2; }
  .urg-title { font-weight:700; font-size: 12.5px; color:#2C2F36; }
  .urg-sub { font-size: 10.5px; color:#5B5F6B; margin-top: 2px; min-height:24px; }
  .urg-price { font-weight: 700; font-size: 13.5px; margin-top: 6px; }
  .urg-price.ok { color:#166534; }
  .urg-price.red { color:#C41E3A; }
  .urg-emerg .urg-title { color:#C41E3A; }
  .tipo-chamado-pill { font-size:10px; font-weight:700; padding:3px 7px; border-radius:99px; text-transform: uppercase; letter-spacing:.5px; }
  .pill-extra { background:#F3F4F6; color:#5B5F6B; }
  .pill-emerg { background:#FEE2E2; color:#C41E3A; }
  .pill-pago  { background:#DCFCE7; color:#166534; }
  .pill-incluso { background:#DCFCE7; color:#166534; }
  .urg-incluso { color:#15803D !important; font-weight:800; }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  let allChamados = [];
  let lojas = [];
  let filtroAtual = "";
  let urgenciaSelecionada = "normal";
  let saldoExtras = 0;
  let saldoEmerg = 0;

  function badge(status) {
    const labels = { aberto:"Aberto", em_andamento:"Em andamento", aguardando_material:"Aguard. material", concluido:"Concluído", cancelado:"Cancelado" };
    return `<span class="badge badge-${status}">${labels[status] || status}</span>`;
  }
  function tipoBadge(tipo) {
    const icons = { eletrica:"⚡", hidraulica:"💧", civil:"🏗️" };
    return `<span class="tipo-badge tipo-${tipo}">${icons[tipo]||""} ${tipo}</span>`;
  }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function renderChamados() {
    const tbody = document.getElementById("chamadosTbody");
    const emptyMsg = document.getElementById("emptyMsg");
    const filtered = filtroAtual ? allChamados.filter(c => c.status === filtroAtual) : allChamados;
    if (!filtered.length) {
      tbody.innerHTML = "";
      emptyMsg.style.display = "";
    } else {
      emptyMsg.style.display = "none";
      tbody.innerHTML = filtered.map(c => {
        const tc = c.tipo_chamado || 'normal';
        let extraPill = '';
        if (tc === 'extra') extraPill = `<span class="tipo-chamado-pill pill-extra">EXTRA 48h</span>`;
        else if (tc === 'emergencial') extraPill = `<span class="tipo-chamado-pill pill-emerg">⚡ EMERG. 24h</span>`;
        let pagamento = '';
        if (tc !== 'normal') {
          if (c.incluso_no_plano) pagamento = `<span class="tipo-chamado-pill pill-incluso">INCLUSO NO PLANO</span>`;
          else if (c.pago_em) pagamento = `<span class="tipo-chamado-pill pill-pago">PAGO</span>`;
          else pagamento = `<button class="btn btn-primary btn-sm" onclick="abrirPix('${c.id}')">Pagar Pix</button>`;
        }
        return `
        <tr>
          <td>${tipoBadge(c.tipo)}<div style="margin-top:4px">${extraPill}</div></td>
          <td style="font-weight:600">${c.manut_lojas?.nome || "—"}</td>
          <td style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#5B5F6B">${c.descricao}</td>
          <td>${badge(c.status)}${pagamento ? `<div style="margin-top:4px">${pagamento}</div>` : ''}</td>
          <td style="font-size:12.5px;color:#5B5F6B">${c.manut_tecnicos?.nome || "Não atribuído"}</td>
          <td style="font-size:12.5px;color:#9CA3AF">${fmtDate(c.data_abertura)}</td>
        </tr>
      `}).join("");
    }
  }

  async function load() {
    try {
      const [resMe, resChamados] = await Promise.all([
        fetch("/api/manut/cliente/me", { headers: { "x-cliente-auth": token } }),
        fetch("/api/manut/cliente/chamados", { headers: { "x-cliente-auth": token } })
      ]);
      if (resMe.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      const { cliente, dashboard } = await resMe.json();
      lojas = dashboard.lojas || [];
      allChamados = await resChamados.json();
      saldoExtras = Number(cliente?.extras_disponiveis || 0);
      saldoEmerg = Number(cliente?.emergenciais_disponiveis || 0);

      const sel = document.getElementById("lojaSelect");
      sel.innerHTML = '<option value="">Selecione a loja...</option>' + lojas.map(l => `<option value="${l.id}">${l.nome}</option>`).join("");

      // Atualiza os preços no modal com base no saldo incluso
      const elPrecoExtra = document.getElementById("urgPriceExtra");
      const elPrecoEmerg = document.getElementById("urgPriceEmerg");
      if (saldoExtras > 0) {
        elPrecoExtra.textContent = `Incluso (${saldoExtras} disp.)`;
        elPrecoExtra.classList.add("urg-incluso");
        elPrecoExtra.classList.remove("red");
      } else {
        elPrecoExtra.textContent = "R$ 250,00";
        elPrecoExtra.classList.remove("urg-incluso");
      }
      if (saldoEmerg > 0) {
        elPrecoEmerg.textContent = `Incluso (${saldoEmerg} disp.)`;
        elPrecoEmerg.classList.add("urg-incluso");
        elPrecoEmerg.classList.remove("red");
      } else {
        elPrecoEmerg.textContent = "R$ 350,00";
        elPrecoEmerg.classList.add("red");
        elPrecoEmerg.classList.remove("urg-incluso");
      }

      document.getElementById("loadingState").style.display = "none";
      document.getElementById("chamadosCard").style.display = "";
      renderChamados();
    } catch {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }

  document.querySelectorAll(".filtro").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".filtro").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      filtroAtual = btn.dataset.filtro;
      renderChamados();
    });
  });

  function fecharModal() { document.getElementById("modalBg").classList.remove("open"); }
  document.getElementById("btnAbrirModal").onclick = () => {
    document.getElementById("modalAlert").style.display = "none";
    document.getElementById("tipoSelect").value = "";
    document.getElementById("descricaoInput").value = "";
    document.getElementById("localInput").value = "";
    urgenciaSelecionada = "normal";
    document.querySelectorAll(".urg-opt").forEach(el => el.classList.toggle("selected", el.dataset.urg === "normal"));
    document.getElementById("modalBg").classList.add("open");
  };
  document.getElementById("btnCancelarModal").onclick = fecharModal;
  document.getElementById("btnFecharModal").onclick = fecharModal;
  document.getElementById("modalBg").onclick = e => { if (e.target === e.currentTarget) fecharModal(); };

  document.querySelectorAll(".urg-opt").forEach(el => {
    el.addEventListener("click", () => {
      urgenciaSelecionada = el.dataset.urg;
      document.querySelectorAll(".urg-opt").forEach(o => o.classList.toggle("selected", o === el));
    });
  });

  document.getElementById("btnSubmitChamado").addEventListener("click", async () => {
    const alertEl = document.getElementById("modalAlert");
    alertEl.style.display = "none";
    const lojaId = document.getElementById("lojaSelect").value;
    const tipo = document.getElementById("tipoSelect").value;
    const descricao = document.getElementById("descricaoInput").value.trim();
    const localLoja = document.getElementById("localInput").value.trim();
    if (!lojaId)    { alertEl.textContent = "Selecione a loja."; alertEl.style.display = ""; return; }
    if (!tipo)      { alertEl.textContent = "Selecione a disciplina."; alertEl.style.display = ""; return; }
    if (!descricao) { alertEl.textContent = "Descreva o problema."; alertEl.style.display = ""; return; }
    const btn = document.getElementById("btnSubmitChamado");
    btn.disabled = true; btn.textContent = "Abrindo...";
    try {
      const res = await fetch("/api/manut/cliente/chamados", {
        method: "POST",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: JSON.stringify({ lojaId, tipo, descricao, localLoja, tipoChamado: urgenciaSelecionada })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Erro ao abrir chamado");
      allChamados.unshift(data);
      renderChamados();
      fecharModal();
      if (urgenciaSelecionada === "normal") {
        window.toast?.("Chamado aberto! Será atendido na próxima visita.", "success");
      } else if (data.incluso_no_plano) {
        // Consumiu saldo do plano — atualiza saldo local e avisa
        if (urgenciaSelecionada === "extra") saldoExtras = Math.max(0, saldoExtras - 1);
        else if (urgenciaSelecionada === "emergencial") saldoEmerg = Math.max(0, saldoEmerg - 1);
        window.toast?.("Chamado aberto sem custo — incluso no seu plano.", "success");
      } else {
        // Gera Pix automaticamente para chamados pagos
        await abrirPix(data.id);
      }
    } catch (err) {
      alertEl.textContent = err.message; alertEl.style.display = "";
    } finally {
      btn.disabled = false; btn.textContent = "Abrir chamado";
    }
  });

  async function abrirPix(chamadoId) {
    const content = document.getElementById("pixContent");
    content.innerHTML = '<div class="spinner" style="margin:30px auto"></div>';
    document.getElementById("modalPixBg").classList.add("open");
    try {
      const res = await fetch(`/api/manut/cliente/chamados/${chamadoId}/pagamento`, {
        method: "POST",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: "{}"
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Erro ao gerar Pix");
      content.innerHTML = `
        ${data.qrCodeBase64 ? `<img src="data:image/png;base64,${data.qrCodeBase64}" alt="QR Code" style="width:200px;height:200px;border:1px solid #E5E7EB;border-radius:8px;padding:8px;background:#FFF" />` : ''}
        <div style="margin-top:12px;padding:10px;background:#F8FAFC;border:1px solid #E5E7EB;border-radius:8px">
          <div style="font-size:10.5px;color:#5B5F6B;text-transform:uppercase;letter-spacing:1px;font-weight:700">Pix copia-e-cola</div>
          <textarea readonly style="width:100%;height:60px;margin-top:6px;font-family:monospace;font-size:10px;border:none;background:transparent;resize:none">${data.qrCode || ''}</textarea>
          <button class="btn btn-outline btn-sm" onclick="navigator.clipboard.writeText('${(data.qrCode || '').replace(/'/g,"\\'")}').then(()=>window.toast?.('Copiado!','success'))">Copiar código</button>
        </div>
        ${data.ticketUrl ? `<p style="margin-top:10px;font-size:12px"><a href="${data.ticketUrl}" target="_blank" style="color:#C41E3A">Abrir comprovante no Mercado Pago →</a></p>` : ''}
      `;
    } catch (err) {
      content.innerHTML = `<div class="alert alert-error">${err.message}</div>`;
    }
  }
  (window).abrirPix = abrirPix;
  document.getElementById("btnFecharPix").onclick = () => { document.getElementById("modalPixBg").classList.remove("open"); load(); };
  document.getElementById("btnFecharPix2").onclick = () => { document.getElementById("modalPixBg").classList.remove("open"); load(); };

  load();
  window.addEventListener("portal:refresh", load);
</script>
