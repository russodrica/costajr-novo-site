---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Materiais" tipo="cliente" activePage="materiais">
  <div class="section-header">
    <p style="margin:0;font-size:13.5px;color:#5B5F6B">Aprove ou rejeite materiais solicitados pelos técnicos durante o atendimento.</p>
  </div>

  <!-- Filtros -->
  <div class="mat-filters">
    <div class="mat-filter-pills">
      <button class="mat-pill active" data-filtro="">Todos</button>
      <button class="mat-pill" data-filtro="pendente_aprovacao">Pendentes <span id="cnt-pendente_aprovacao" class="mat-cnt">0</span></button>
      <button class="mat-pill" data-filtro="aprovado">Aprovados <span id="cnt-aprovado" class="mat-cnt">0</span></button>
      <button class="mat-pill" data-filtro="pago">Pagos <span id="cnt-pago" class="mat-cnt">0</span></button>
      <button class="mat-pill" data-filtro="rejeitado">Rejeitados <span id="cnt-rejeitado" class="mat-cnt">0</span></button>
    </div>
    <div class="mat-search">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="mat-busca" placeholder="Buscar material, loja ou técnico..." />
    </div>
  </div>

  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando materiais...</div>
  <div id="matWrap" style="display:none"></div>

  <!-- Modal aprovação -->
  <div class="modal-bg" id="modalAprovar">
    <div class="modal">
      <button class="modal-close" id="btnFecharApr">×</button>
      <h2>Aprovar Material</h2>
      <div id="alertApr" class="alert alert-error" style="display:none"></div>
      <div id="modalAprBody"></div>

      <!-- Pagamento Pix -->
      <div id="pixBox" style="margin-top:16px;background:#F0FDF4;border:1.5px solid #BBF7D0;border-radius:10px;padding:16px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
          <div style="font-size:24px">⚡</div>
          <div>
            <div style="font-weight:700;font-size:14px;color:#15803D">Pagar via Pix</div>
            <div style="font-size:12px;color:#5B5F6B">Conta Mercado Pago da Costa Júnior</div>
          </div>
        </div>
        <div id="pixStatus" style="font-size:12.5px;color:var(--ink-mid);margin-bottom:10px">Gerando código Pix...</div>
        <div id="pixContent" style="display:none">
          <img id="pixQr" src="" alt="QR Code Pix" style="display:block;margin:0 auto 12px;width:200px;height:200px;background:#fff;border:1px solid var(--border);border-radius:8px;padding:6px">
          <label style="font-size:11.5px;font-weight:700;color:var(--ink-mid);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:4px">Pix copia e cola</label>
          <textarea id="pixCode" readonly rows="3" style="width:100%;padding:8px 10px;border:1.5px solid var(--border);border-radius:6px;font-family:monospace;font-size:11.5px;background:#fff;resize:none;outline:none"></textarea>
          <button type="button" id="btnCopiarPix" style="margin-top:8px;width:100%;padding:9px;background:#15803D;color:#fff;border:0;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;font-family:'Montserrat',sans-serif">📋 Copiar código Pix</button>
          <div id="pixCopiado" style="display:none;text-align:center;font-size:11.5px;color:#15803D;margin-top:6px;font-weight:600">✓ Código copiado!</div>
        </div>
      </div>

      <div class="form-group" style="margin-top:16px">
        <label>Comprovante de pagamento <span style="font-weight:400;color:#9CA3AF">(opcional)</span></label>
        <div id="compAreaSemFoto">
          <label for="comprovanteFile" style="display:flex;align-items:center;justify-content:center;gap:8px;padding:18px;border:2px dashed var(--border);border-radius:10px;background:#FAFBFC;cursor:pointer;transition:var(--transition);font-size:13px;color:var(--ink-mid)">
            <span style="font-size:22px">📎</span>
            <span><strong>Anexar comprovante</strong> — JPG, PNG, WEBP ou PDF (máx 10MB)</span>
          </label>
          <input type="file" id="comprovanteFile" accept="image/jpeg,image/png,image/webp,application/pdf" style="display:none">
        </div>
        <div id="compAreaComFoto" style="display:none;padding:12px;border:1.5px solid #BBF7D0;background:#F0FDF4;border-radius:10px">
          <div style="display:flex;align-items:center;gap:12px">
            <div style="font-size:22px">✅</div>
            <div style="flex:1;min-width:0">
              <div style="font-size:13px;font-weight:700;color:#15803D">Comprovante enviado</div>
              <a id="compLink" href="#" target="_blank" rel="noopener" style="font-size:11.5px;color:#5B5F6B;text-decoration:underline;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">ver arquivo</a>
            </div>
            <button type="button" id="btnRemoverComp" style="background:transparent;border:0;color:#B91C1C;cursor:pointer;font-size:13px;font-weight:600">✕ Remover</button>
          </div>
        </div>
        <div id="compStatus" style="font-size:12px;color:var(--ink-light);margin-top:6px"></div>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:4px">
        <button class="btn btn-outline" id="btnCancelarApr">Cancelar</button>
        <button class="btn btn-primary" id="btnConfAprovar">✓ Confirmar aprovação</button>
      </div>
    </div>
  </div>
</Portal>

<style>
  .mat-filters {
    display:flex; gap:14px; justify-content:space-between; align-items:center;
    flex-wrap:wrap; margin-bottom:18px;
  }
  .mat-filter-pills { display:flex; gap:6px; flex-wrap:wrap; }
  .mat-pill {
    background:#FFF; border:1px solid var(--border); border-radius:99px;
    padding:7px 14px; font-size:12.5px; font-weight:600; color:#5B5F6B;
    cursor:pointer; transition:.15s; display:inline-flex; align-items:center; gap:6px;
  }
  .mat-pill:hover { border-color:#C41E3A; color:#C41E3A; }
  .mat-pill.active { background:#C41E3A; color:#FFF; border-color:#C41E3A; }
  .mat-cnt { background:rgba(0,0,0,.1); color:inherit; font-size:10.5px; padding:1px 7px; border-radius:99px; font-weight:700; }
  .mat-pill.active .mat-cnt { background:rgba(255,255,255,.25); }
  .mat-search { position:relative; min-width:260px; max-width:320px; flex:1; }
  .mat-search svg { position:absolute; left:10px; top:50%; transform:translateY(-50%); color:#9CA3AF; }
  .mat-search input {
    width:100%; padding:9px 12px 9px 32px;
    border:1px solid var(--border); border-radius:8px;
    font-size:13px; outline:none; background:#FFF;
  }
  .mat-search input:focus { border-color:#C41E3A; }
  .mat-table-wrap { background:#FFF; border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; }
  .mat-table { width:100%; border-collapse:collapse; }
  .mat-table thead th {
    background:#F9FAFB; padding:11px 14px; text-align:left;
    font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em;
    color:#6B7280; border-bottom:1px solid var(--border);
  }
  .mat-table tbody td {
    padding:14px; font-size:13px; border-bottom:1px solid #F3F4F6; vertical-align:middle;
  }
  .mat-table tbody tr:last-child td { border-bottom:none; }
  .mat-table tbody tr:hover { background:#FAFBFC; }
  .mat-table tbody tr.pendente { background:linear-gradient(90deg, #FFFBEB 0%, #FFF 8%); }
  .mat-desc { font-weight:600; color:#1F2937; }
  .mat-meta-cell { display:flex; align-items:center; gap:6px; color:#5B5F6B; font-size:12.5px; }
  .mat-valor { font-family:'Montserrat',sans-serif; font-weight:700; font-size:15px; color:#C41E3A; text-align:right; white-space:nowrap; }
  .mat-actions { display:flex; gap:6px; }
  .mat-empty { padding:40px 20px; text-align:center; color:#9CA3AF; font-size:13.5px; }
  @media (max-width:760px) {
    .mat-hide-mobile { display:none; }
    .mat-table thead th, .mat-table tbody td { padding:10px 8px; font-size:12px; }
  }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  let allMat = [];
  let matAtivo = null;
  let filtroStatus = "";
  let buscaTexto = "";

  function badge(status) {
    const m = { pendente_aprovacao:"badge-aguardando_material", aprovado:"badge-concluido", rejeitado:"badge-cancelado", pago:"badge-concluido" };
    const l = { pendente_aprovacao:"Pendente", aprovado:"Aprovado", rejeitado:"Rejeitado", pago:"Pago" };
    return `<span class="badge ${m[status] || ""}">${l[status] || status}</span>`;
  }
  function fmt(v) { return v != null ? "R$ " + Number(v).toLocaleString("pt-BR",{minimumFractionDigits:2}) : "—"; }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function aplicarFiltros() {
    let list = allMat;
    if (filtroStatus) list = list.filter(m => m.status === filtroStatus);
    if (buscaTexto) {
      const q = buscaTexto.toLowerCase();
      list = list.filter(m =>
        (m.descricao || "").toLowerCase().includes(q) ||
        (m.manut_lojas?.nome || "").toLowerCase().includes(q) ||
        (m.manut_tecnicos?.nome || "").toLowerCase().includes(q)
      );
    }
    return list;
  }

  function atualizarContadores() {
    const counts = { pendente_aprovacao:0, aprovado:0, pago:0, rejeitado:0 };
    allMat.forEach(m => { if (counts[m.status] !== undefined) counts[m.status]++; });
    for (const k in counts) {
      const el = document.getElementById("cnt-" + k);
      if (el) el.textContent = counts[k];
    }
  }

  function render() {
    atualizarContadores();
    const wrap = document.getElementById("matWrap");
    if (!allMat.length) {
      wrap.innerHTML = `<div class="card"><div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        <strong>Nenhuma solicitação de material</strong>
        <p>Quando um técnico solicitar material, aparecerá aqui para sua aprovação.</p>
      </div></div>`;
      return;
    }
    const filtrados = aplicarFiltros();
    if (!filtrados.length) {
      wrap.innerHTML = `<div class="mat-table-wrap"><div class="mat-empty">Nenhum material encontrado para o filtro aplicado.</div></div>`;
      return;
    }
    const rows = filtrados.map(m => `
      <tr class="${m.status === 'pendente_aprovacao' ? 'pendente' : ''}">
        <td>
          <div class="mat-desc">${m.descricao}</div>
          ${m.status === "pendente_aprovacao" ? `
          <div class="mat-actions" style="margin-top:8px">
            <button class="btn btn-primary btn-sm" onclick="abrirAprovar('${m.id}')">Aprovar</button>
            <button class="btn btn-outline btn-sm" style="border-color:#B91C1C;color:#B91C1C" onclick="rejeitar('${m.id}')">Rejeitar</button>
          </div>` : ""}
        </td>
        <td class="mat-hide-mobile"><div class="mat-meta-cell">🏪 ${m.manut_lojas?.nome || "—"}</div></td>
        <td class="mat-hide-mobile"><div class="mat-meta-cell">🔧 ${m.manut_tecnicos?.nome || "—"}</div></td>
        <td class="mat-hide-mobile" style="color:#6B7280;font-size:12.5px">${fmtDate(m.created_at)}</td>
        <td class="mat-valor">${fmt(m.valor)}</td>
        <td>${badge(m.status)}</td>
        <td style="text-align:right">${m.comprovante_url ? `<a href="${m.comprovante_url}" target="_blank" class="btn btn-outline btn-sm">📎 Ver</a>` : '<span style="color:#D1D5DB">—</span>'}</td>
      </tr>
    `).join("");
    wrap.innerHTML = `
      <div class="mat-table-wrap">
        <table class="mat-table">
          <thead>
            <tr>
              <th>Material</th>
              <th class="mat-hide-mobile">Loja</th>
              <th class="mat-hide-mobile">Técnico</th>
              <th class="mat-hide-mobile">Data</th>
              <th style="text-align:right">Valor</th>
              <th>Status</th>
              <th style="text-align:right">Comprovante</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    `;
  }

  // Filtros e busca
  document.querySelectorAll(".mat-pill").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".mat-pill").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      filtroStatus = btn.dataset.filtro;
      render();
    });
  });
  document.getElementById("mat-busca").addEventListener("input", (e) => {
    buscaTexto = e.target.value.trim();
    render();
  });

  let comprovanteUrlAtual = null;
  function resetComprovanteUI() {
    document.getElementById("compAreaSemFoto").style.display = "";
    document.getElementById("compAreaComFoto").style.display = "none";
    document.getElementById("compStatus").textContent = "";
    document.getElementById("comprovanteFile").value = "";
    comprovanteUrlAtual = null;
  }

  window.abrirAprovar = async function(id) {
    matAtivo = allMat.find(m => m.id === id);
    if (!matAtivo) return;
    document.getElementById("alertApr").style.display = "none";
    resetComprovanteUI();
    document.getElementById("modalAprBody").innerHTML = `
      <div style="background:#FFF9F0;border:1px solid #FDE68A;border-radius:8px;padding:16px;margin-bottom:4px">
        <div style="font-size:12px;color:#92400E;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Confirmar aprovação</div>
        <div style="font-size:13.5px;margin-bottom:4px"><strong>Material:</strong> ${matAtivo.descricao}</div>
        <div style="font-size:13.5px;margin-bottom:4px"><strong>Técnico:</strong> ${matAtivo.manut_tecnicos?.nome || "—"}</div>
        <div style="font-size:20px;font-weight:800;font-family:'Montserrat',sans-serif;color:#C41E3A;margin-top:10px">${fmt(matAtivo.valor)}</div>
      </div>
    `;

    // Gera/recupera Pix
    const statusEl = document.getElementById("pixStatus");
    const content = document.getElementById("pixContent");
    statusEl.textContent = "Gerando código Pix...";
    content.style.display = "none";
    document.getElementById("pixCopiado").style.display = "none";
    document.getElementById("modalAprovar").classList.add("open");

    try {
      const res = await fetch(`/api/manut/cliente/materiais/${id}/pagamento`, {
        method: "POST",
        headers: { "content-type": "application/json", "x-cliente-auth": token },
        body: "{}",
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Falha ao gerar Pix");
      if (data.qr_code_base64) {
        document.getElementById("pixQr").src = "data:image/png;base64," + data.qr_code_base64;
      }
      document.getElementById("pixCode").value = data.qr_code || "";
      content.style.display = "";
      statusEl.textContent = "Escaneie o QR Code ou copie o código abaixo no app do seu banco.";
    } catch (err) {
      statusEl.innerHTML = '<span style="color:#B91C1C">⚠ Não foi possível gerar o Pix: ' + err.message + '</span>';
    }
  };

  // Copiar código Pix
  document.addEventListener("click", async (e) => {
    if (e.target?.id === "btnCopiarPix") {
      const code = document.getElementById("pixCode").value;
      if (!code) return;
      try {
        await navigator.clipboard.writeText(code);
        const aviso = document.getElementById("pixCopiado");
        aviso.style.display = "";
        setTimeout(() => { aviso.style.display = "none"; }, 2500);
      } catch {
        const ta = document.getElementById("pixCode");
        ta.select(); document.execCommand("copy");
      }
    }
  });

  window.rejeitar = async function(id) {
    if (!confirm("Tem certeza que deseja rejeitar esta solicitação de material?")) return;
    try {
      const res = await fetch("/api/manut/cliente/materiais", {
        method: "PUT",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: JSON.stringify({ id, acao: "rejeitar" }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      const idx = allMat.findIndex(m => m.id === id);
      if (idx >= 0) allMat[idx] = { ...allMat[idx], ...data };
      render();
      window.toast?.("Material rejeitado.", "info");
    } catch (err) {
      window.toast?.("Erro: " + err.message, "error");
    }
  };

  document.getElementById("btnCancelarApr").onclick = () => { document.getElementById("modalAprovar").classList.remove("open"); matAtivo = null; };
  document.getElementById("btnFecharApr").onclick   = () => { document.getElementById("modalAprovar").classList.remove("open"); matAtivo = null; };

  // Upload do comprovante (auto ao selecionar)
  async function blobToBase64(file) {
    const buf = await file.arrayBuffer();
    const bytes = new Uint8Array(buf);
    let s = "";
    const CHUNK = 0x8000;
    for (let i = 0; i < bytes.length; i += CHUNK) {
      s += String.fromCharCode.apply(null, bytes.subarray(i, i + CHUNK));
    }
    return btoa(s);
  }
  document.getElementById("comprovanteFile").addEventListener("change", async (e) => {
    const file = e.target.files?.[0]; if (!file || !matAtivo) return;
    const tiposOk = ["image/jpeg","image/png","image/webp","application/pdf"];
    if (!tiposOk.includes(file.type)) {
      document.getElementById("compStatus").innerHTML = '<span style="color:#B91C1C">⚠ Tipo inválido. Use JPG, PNG, WEBP ou PDF.</span>';
      return;
    }
    if (file.size > 10 * 1024 * 1024) {
      document.getElementById("compStatus").innerHTML = '<span style="color:#B91C1C">⚠ Arquivo grande demais (máx 10MB).</span>';
      return;
    }
    document.getElementById("compStatus").textContent = "Enviando...";
    try {
      const data_base64 = await blobToBase64(file);
      const res = await fetch(`/api/manut/cliente/materiais/${matAtivo.id}/comprovante`, {
        method: "POST",
        headers: { "content-type": "application/json", "x-cliente-auth": token },
        body: JSON.stringify({ mime: file.type, data_base64 }),
      });
      const d = await res.json();
      if (!res.ok) throw new Error(d.error || "Falha");
      comprovanteUrlAtual = d.url;
      document.getElementById("compAreaSemFoto").style.display = "none";
      document.getElementById("compAreaComFoto").style.display = "";
      document.getElementById("compLink").href = d.url;
      document.getElementById("compLink").textContent = file.name;
      document.getElementById("compStatus").textContent = "";
    } catch (err) {
      document.getElementById("compStatus").innerHTML = '<span style="color:#B91C1C">⚠ ' + err.message + '</span>';
    }
  });
  document.getElementById("btnRemoverComp").addEventListener("click", () => { resetComprovanteUI(); });

  document.getElementById("btnConfAprovar").onclick = async () => {
    if (!matAtivo) return;
    const alertEl = document.getElementById("alertApr");
    alertEl.style.display = "none";
    const comprovante_url = comprovanteUrlAtual;
    const btn = document.getElementById("btnConfAprovar");
    btn.disabled = true; btn.textContent = "Aprovando...";
    try {
      const res = await fetch("/api/manut/cliente/materiais", {
        method: "PUT",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: JSON.stringify({ id: matAtivo.id, acao: "aprovar", comprovante_url }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      const idx = allMat.findIndex(m => m.id === matAtivo.id);
      if (idx >= 0) allMat[idx] = { ...allMat[idx], ...data };
      document.getElementById("modalAprovar").classList.remove("open");
      matAtivo = null;
      render();
      window.toast?.("Material aprovado com sucesso!", "success");
    } catch (err) {
      alertEl.textContent = err.message; alertEl.style.display = "";
    } finally {
      btn.disabled = false; btn.textContent = "✓ Confirmar aprovação";
    }
  };

  async function load() {
    try {
      const res = await fetch("/api/manut/cliente/materiais", { headers: { "x-cliente-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      allMat = await res.json();
      document.getElementById("loadingState").style.display = "none";
      document.getElementById("matWrap").style.display = "";
      render();
    } catch {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }
  load();
  window.addEventListener("portal:refresh", load);
</script>
