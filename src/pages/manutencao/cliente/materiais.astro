---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Materiais" tipo="cliente" activePage="materiais">
  <div style="margin-bottom:24px">
    <p style="margin:0;font-size:13.5px;color:#5B5F6B">Aprove ou rejeite materiais solicitados pelos técnicos durante o atendimento.</p>
  </div>

  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando materiais...</div>
  <div id="matWrap" style="display:none"></div>

  <!-- Modal aprovação -->
  <div class="modal-bg" id="modalAprovar">
    <div class="modal">
      <button class="modal-close" id="btnFecharApr">×</button>
      <h2>Aprovar Material</h2>
      <div id="alertApr" class="alert alert-error" style="display:none"></div>
      <div id="modalAprBody"></div>
      <div class="form-group" style="margin-top:16px">
        <label>Comprovante de pagamento <span style="font-weight:400;color:#9CA3AF">(URL — opcional)</span></label>
        <input type="url" id="comprovanteUrl" placeholder="https://...">
        <p class="form-hint">Cole o link do comprovante se já tiver realizado o pagamento.</p>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:4px">
        <button class="btn btn-outline" id="btnCancelarApr">Cancelar</button>
        <button class="btn btn-primary" id="btnConfAprovar">✓ Confirmar aprovação</button>
      </div>
    </div>
  </div>
</Portal>

<style>
  .mat-card {
    background:#fff; border:1px solid var(--border); border-radius:var(--radius-lg);
    padding:20px 24px; margin-bottom:12px;
    box-shadow: var(--shadow-sm); transition: var(--transition);
  }
  .mat-card:hover { box-shadow: var(--shadow); }
  .mat-card.pendente { border-left:4px solid #F59E0B; }
  .mat-header { display:flex;align-items:flex-start;justify-content:space-between;gap:16px; }
  .mat-title { font-weight:700;font-size:15px;margin-bottom:5px;color:var(--ink); }
  .mat-meta { font-size:12.5px;color:#5B5F6B;display:flex;flex-wrap:wrap;gap:6px;align-items:center; }
  .mat-sep { color:#D1D5DB; }
  .mat-valor { font-family:'Montserrat',sans-serif;font-weight:800;font-size:22px;color:#C41E3A; text-align:right;}
  .mat-actions { display:flex;gap:8px;margin-top:14px;padding-top:14px;border-top:1px solid var(--border-light); }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  let allMat = [];
  let matAtivo = null;

  function badge(status) {
    const m = { pendente_aprovacao:"badge-aguardando_material", aprovado:"badge-concluido", rejeitado:"badge-cancelado", pago:"badge-concluido" };
    const l = { pendente_aprovacao:"Pend. aprovação", aprovado:"Aprovado", rejeitado:"Rejeitado", pago:"Pago" };
    return `<span class="badge ${m[status] || ""}">${l[status] || status}</span>`;
  }
  function fmt(v) { return v != null ? "R$ " + Number(v).toLocaleString("pt-BR",{minimumFractionDigits:2}) : "—"; }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function render() {
    const wrap = document.getElementById("matWrap");
    if (!allMat.length) {
      wrap.innerHTML = `<div class="card"><div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        <strong>Nenhuma solicitação de material</strong>
        <p>Quando um técnico solicitar material, aparecerá aqui para sua aprovação.</p>
      </div></div>`;
      return;
    }
    wrap.innerHTML = allMat.map(m => `
      <div class="mat-card ${m.status === 'pendente_aprovacao' ? 'pendente' : ''}">
        <div class="mat-header">
          <div style="flex:1;min-width:0">
            <div class="mat-title">${m.descricao}</div>
            <div class="mat-meta">
              <span>🏪 ${m.manut_lojas?.nome || "—"}</span>
              <span class="mat-sep">·</span>
              <span>🔧 ${m.manut_tecnicos?.nome || "—"}</span>
              <span class="mat-sep">·</span>
              <span>${fmtDate(m.created_at)}</span>
              <span class="mat-sep">·</span>
              ${badge(m.status)}
            </div>
          </div>
          <div>
            <div class="mat-valor">${fmt(m.valor)}</div>
          </div>
        </div>
        ${m.status === "pendente_aprovacao" ? `
        <div class="mat-actions">
          <button class="btn btn-primary btn-sm" onclick="abrirAprovar('${m.id}')">✓ Aprovar</button>
          <button class="btn btn-outline btn-sm" style="border-color:#B91C1C;color:#B91C1C" onclick="rejeitar('${m.id}')">✕ Rejeitar</button>
        </div>` : ""}
        ${m.comprovante_url ? `<div style="margin-top:10px"><a href="${m.comprovante_url}" target="_blank" class="btn btn-outline btn-sm">📎 Ver comprovante</a></div>` : ""}
      </div>
    `).join("");
  }

  window.abrirAprovar = function(id) {
    matAtivo = allMat.find(m => m.id === id);
    if (!matAtivo) return;
    document.getElementById("alertApr").style.display = "none";
    document.getElementById("comprovanteUrl").value = "";
    document.getElementById("modalAprBody").innerHTML = `
      <div style="background:#FFF9F0;border:1px solid #FDE68A;border-radius:8px;padding:16px;margin-bottom:4px">
        <div style="font-size:12px;color:#92400E;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Confirmar aprovação</div>
        <div style="font-size:13.5px;margin-bottom:4px"><strong>Material:</strong> ${matAtivo.descricao}</div>
        <div style="font-size:13.5px;margin-bottom:4px"><strong>Técnico:</strong> ${matAtivo.manut_tecnicos?.nome || "—"}</div>
        <div style="font-size:20px;font-weight:800;font-family:'Montserrat',sans-serif;color:#C41E3A;margin-top:10px">${fmt(matAtivo.valor)}</div>
      </div>
    `;
    document.getElementById("modalAprovar").classList.add("open");
  };

  window.rejeitar = async function(id) {
    if (!confirm("Tem certeza que deseja rejeitar esta solicitação de material?")) return;
    try {
      const res = await fetch("/api/manut/cliente/materiais", {
        method: "PUT",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: JSON.stringify({ id, acao: "rejeitar" }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      const idx = allMat.findIndex(m => m.id === id);
      if (idx >= 0) allMat[idx] = { ...allMat[idx], ...data };
      render();
      window.toast?.("Material rejeitado.", "info");
    } catch (err) {
      window.toast?.("Erro: " + err.message, "error");
    }
  };

  document.getElementById("btnCancelarApr").onclick = () => { document.getElementById("modalAprovar").classList.remove("open"); matAtivo = null; };
  document.getElementById("btnFecharApr").onclick   = () => { document.getElementById("modalAprovar").classList.remove("open"); matAtivo = null; };

  document.getElementById("btnConfAprovar").onclick = async () => {
    if (!matAtivo) return;
    const alertEl = document.getElementById("alertApr");
    alertEl.style.display = "none";
    const comprovante_url = document.getElementById("comprovanteUrl").value.trim() || null;
    const btn = document.getElementById("btnConfAprovar");
    btn.disabled = true; btn.textContent = "Aprovando...";
    try {
      const res = await fetch("/api/manut/cliente/materiais", {
        method: "PUT",
        headers: { "content-type":"application/json","x-cliente-auth":token },
        body: JSON.stringify({ id: matAtivo.id, acao: "aprovar", comprovante_url }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      const idx = allMat.findIndex(m => m.id === matAtivo.id);
      if (idx >= 0) allMat[idx] = { ...allMat[idx], ...data };
      document.getElementById("modalAprovar").classList.remove("open");
      matAtivo = null;
      render();
      window.toast?.("Material aprovado com sucesso!", "success");
    } catch (err) {
      alertEl.textContent = err.message; alertEl.style.display = "";
    } finally {
      btn.disabled = false; btn.textContent = "✓ Confirmar aprovação";
    }
  };

  async function load() {
    try {
      const res = await fetch("/api/manut/cliente/materiais", { headers: { "x-cliente-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      allMat = await res.json();
      document.getElementById("loadingState").style.display = "none";
      document.getElementById("matWrap").style.display = "";
      render();
    } catch {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }
  load();
  window.addEventListener("portal:refresh", load);
</script>
