---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Preventivas" tipo="cliente" activePage="preventivas">
  <div class="section-header">
    <p style="margin:0;font-size:13.5px;color:#5B5F6B">Histórico e agenda de manutenções preventivas das suas lojas.</p>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn btn-outline btn-sm filtro-prev active" data-status="">Todas</button>
      <button class="btn btn-outline btn-sm filtro-prev" data-status="agendada">Agendadas</button>
      <button class="btn btn-outline btn-sm filtro-prev" data-status="concluida">Concluídas</button>
      <button class="btn btn-outline btn-sm filtro-prev" data-status="cancelada">Canceladas</button>
    </div>
  </div>

  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando preventivas...</div>

  <div class="card" id="tableWrap" style="display:none">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Data</th>
            <th>Loja</th>
            <th>Técnico</th>
            <th>Status</th>
            <th>Relatório</th>
          </tr>
        </thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
    <div id="emptyMsg" style="display:none">
      <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        <strong>Nenhuma preventiva encontrada</strong>
        <p>As preventivas agendadas pela equipe aparecerão aqui.</p>
      </div>
    </div>
  </div>
</Portal>

<style>
  .filtro-prev.active { background:var(--brand);color:#fff;border-color:var(--brand); }
</style>

<script>
  const TOKEN_KEY = "manut_cliente_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/cliente/login");

  let allPrev = [];
  let filtro = "";

  function badge(status) {
    const m = { agendada:"badge-agendada", em_execucao:"badge-em_andamento", concluida:"badge-concluido", cancelada:"badge-cancelado" };
    const l = { agendada:"Agendada", em_execucao:"Em execução", concluida:"Concluída", cancelada:"Cancelada" };
    return `<span class="badge ${m[status]||""}">${l[status]||status}</span>`;
  }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function render() {
    const filtered = filtro ? allPrev.filter(p => p.status === filtro) : allPrev;
    const tbody = document.getElementById("tbody");
    const empty = document.getElementById("emptyMsg");
    if (!filtered.length) {
      tbody.innerHTML = "";
      empty.style.display = "";
      return;
    }
    empty.style.display = "none";
    tbody.innerHTML = filtered.map(p => `
      <tr>
        <td><strong>${fmtDate(p.data_agendada)}</strong></td>
        <td style="font-weight:600">${p.manut_lojas?.nome || "—"}<br><span style="font-size:11.5px;color:#9CA3AF;font-weight:400">${p.manut_lojas?.cidade||""}</span></td>
        <td style="font-size:13px;color:#5B5F6B">${p.manut_tecnicos?.nome || "—"}</td>
        <td>${badge(p.status)}</td>
        <td>${p.relatorio_url
          ? `<a href="${p.relatorio_url}" target="_blank" class="btn btn-outline btn-sm">📄 Ver relatório</a>`
          : '<span style="color:#D1D5DB;font-size:13px">—</span>'
        }</td>
      </tr>
    `).join("");
  }

  document.querySelectorAll(".filtro-prev").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".filtro-prev").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      filtro = btn.dataset.status;
      render();
    });
  });

  async function load() {
    try {
      const res = await fetch("/api/manut/cliente/preventivas", { headers: { "x-cliente-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/cliente/login"); return; }
      allPrev = await res.json();
      document.getElementById("loadingState").style.display = "none";
      document.getElementById("tableWrap").style.display = "";
      render();
    } catch {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }
  load();
  window.addEventListener("portal:refresh", load);
</script>
