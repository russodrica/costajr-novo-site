---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Dashboard" tipo="tecnico" activePage="dashboard">
  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando...</div>
  <div id="content" style="display:none">
    <div class="stats-grid" id="statsGrid"></div>

    <!-- Calendário do mês com eventos -->
    <div class="card" style="margin-bottom:20px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:8px;flex-wrap:wrap">
        <h3 style="margin:0">Seu mês</h3>
        <div style="display:flex;gap:6px;align-items:center">
          <button class="btn btn-outline btn-sm" id="calPrev">‹</button>
          <strong id="calTitulo" style="min-width:160px;text-align:center;font-family:'Montserrat',sans-serif"></strong>
          <button class="btn btn-outline btn-sm" id="calNext">›</button>
        </div>
      </div>
      <div class="cal-legenda">
        <span><span class="cal-dot cal-dot-prev"></span> Preventiva</span>
        <span><span class="cal-dot cal-dot-cham"></span> Chamado em aberto</span>
        <span><span class="cal-dot cal-dot-emerg"></span> Emergencial</span>
      </div>
      <div class="cal-grid-head">
        <div>D</div><div>S</div><div>T</div><div>Q</div><div>Q</div><div>S</div><div>S</div>
      </div>
      <div id="calGrid" class="cal-grid"></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px" class="dash-grid">
      <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
          <h3 style="margin:0">Próximas preventivas</h3>
          <a href="/manutencao/tecnico/agenda" class="btn btn-outline btn-sm">Ver agenda</a>
        </div>
        <div id="prevList"></div>
      </div>
      <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
          <h3 style="margin:0">Chamados abertos</h3>
          <a href="/manutencao/tecnico/chamados" class="btn btn-outline btn-sm">Ver todos</a>
        </div>
        <div id="chamList"></div>
      </div>
    </div>

    <div class="card">
      <h3 style="margin:0 0 14px">Lojas que você atende</h3>
      <div id="lojasList" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px"></div>
    </div>
  </div>
</Portal>

<style>
  .loja-card {
    border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px;
    background: #fff; transition: var(--transition);
  }
  .loja-card:hover { border-color: var(--brand); box-shadow: var(--shadow-sm); transform: translateY(-1px); }
  .loja-nome { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 14px; margin-bottom: 4px; }
  .loja-cli { font-size: 11.5px; color: var(--ink-light); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .loja-end { font-size: 12.5px; color: var(--ink-mid); }
  .prev-row, .cham-row { padding: 10px 0; border-bottom: 1px solid var(--border-light); font-size: 13.5px; }
  .prev-row:last-child, .cham-row:last-child { border-bottom: 0; }
  .empty-line { color: var(--ink-light); padding: 12px 0; font-size: 13px; }
  @media (max-width: 760px) { .dash-grid { grid-template-columns: 1fr !important; } }

  /* Calendário */
  .cal-legenda {
    display:flex; gap:14px; flex-wrap:wrap; margin-bottom:12px;
    font-size:11.5px; color:var(--ink-mid);
  }
  .cal-legenda span { display:inline-flex; align-items:center; gap:5px; }
  .cal-dot { width:9px; height:9px; border-radius:50%; display:inline-block; }
  .cal-dot-prev { background:#1D4ED8; }
  .cal-dot-cham { background:#F59E0B; }
  .cal-dot-emerg { background:#C41E3A; }
  .cal-grid-head, .cal-grid {
    display:grid; grid-template-columns:repeat(7,1fr); gap:4px;
  }
  .cal-grid-head { margin-bottom:4px; }
  .cal-grid-head > div {
    font-size:10.5px; font-weight:700; color:#9CA3AF;
    text-transform:uppercase; letter-spacing:.08em; text-align:center;
    padding:6px 0;
  }
  .cal-cell {
    min-height:64px; padding:6px 7px;
    border:1px solid var(--border); border-radius:6px;
    background:#FFF; position:relative;
    display:flex; flex-direction:column; gap:3px;
    cursor:default; transition:.15s;
  }
  .cal-cell.empty { background:transparent; border-color:transparent; }
  .cal-cell.hoje { border-color:#C41E3A; background:#FEF2F2; }
  .cal-cell.has-event { cursor:pointer; }
  .cal-cell.has-event:hover { border-color:#C41E3A; box-shadow:0 0 0 2px rgba(196,30,58,.08); }
  .cal-dia { font-size:12.5px; font-weight:700; color:#374151; }
  .cal-cell.hoje .cal-dia { color:#C41E3A; }
  .cal-ev {
    font-size:10.5px; padding:2px 5px; border-radius:4px;
    font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    line-height:1.2;
  }
  .cal-ev-prev  { background:#DBEAFE; color:#1D4ED8; }
  .cal-ev-cham  { background:#FEF3C7; color:#92400E; }
  .cal-ev-emerg { background:#FEE2E2; color:#C41E3A; }
  .cal-mais { font-size:10px; color:#6B7280; padding-left:5px; }
</style>

<script>
  const TOKEN_KEY = "manut_tecnico_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/tecnico/login");

  try {
    const u = JSON.parse(localStorage.getItem(TOKEN_KEY + "_user") || "{}");
    if (u.senha_troca_obrigatoria) window.location.replace("/manutencao/tecnico/trocar-senha");
  } catch {}

  const meses = ["jan","fev","mar","abr","mai","jun","jul","ago","set","out","nov","dez"];
  function fmtDate(d) {
    if (!d) return "—";
    const dt = new Date(d);
    return dt.getDate().toString().padStart(2,"0") + "/" + (dt.getMonth()+1).toString().padStart(2,"0") + "/" + dt.getFullYear();
  }
  function tipoCor(t) { return { eletrica:"#1D4ED8", hidraulica:"#15803D", civil:"#C2410C" }[t] || "#5B5F6B"; }

  async function load() {
    try {
      const headers = { "x-tecnico-auth": token };
      const hoje = new Date().toISOString().slice(0,7);
      const [resMe, resChamados, resAgenda] = await Promise.all([
        fetch("/api/manut/tecnico/me", { headers }),
        fetch("/api/manut/tecnico/chamados", { headers }),
        fetch(`/api/manut/tecnico/agenda?mes=${hoje}`, { headers }),
      ]);
      if (resMe.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/tecnico/login"); return; }
      const { tecnico } = await resMe.json();
      const chamados = await resChamados.json();
      const preventivas = await resAgenda.json();

      const meuId = tecnico.id;
      const lojas = tecnico.lojas || [];

      const abertosMeus = chamados.filter(c => c.tecnico_atribuido_id === meuId).length;
      const abertosOutros = chamados.filter(c => c.tecnico_atribuido_id !== meuId).length;
      const prevMes = preventivas.length;

      document.getElementById("statsGrid").innerHTML = `
        <div class="stat-card accent">
          <div class="stat-label">Chamados meus</div>
          <div class="stat-value">${abertosMeus}</div>
          <div class="stat-sub">Atribuídos a você</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Outros das minhas lojas</div>
          <div class="stat-value">${abertosOutros}</div>
          <div class="stat-sub">Aguardando atribuição</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Preventivas no mês</div>
          <div class="stat-value">${prevMes}</div>
          <div class="stat-sub">Agendadas</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Lojas que atende</div>
          <div class="stat-value">${lojas.length}</div>
          <div class="stat-sub">Vinculadas a você</div>
        </div>
      `;

      // Próximas preventivas (top 5)
      const prevEl = document.getElementById("prevList");
      if (!preventivas.length) {
        prevEl.innerHTML = '<div class="empty-line">Nenhuma preventiva este mês.</div>';
      } else {
        prevEl.innerHTML = preventivas.slice(0, 5).map(p => {
          const d = new Date(p.data_agendada);
          return `<div class="prev-row">
            <strong>${fmtDate(p.data_agendada)}</strong> · ${p.manut_lojas?.nome || "—"}
            <div style="font-size:12px;color:var(--ink-light);margin-top:2px">${p.manut_clientes?.nome || "—"} · ${p.manut_lojas?.cidade || ""}</div>
          </div>`;
        }).join("");
      }

      // Chamados abertos (top 5)
      const chamEl = document.getElementById("chamList");
      if (!chamados.length) {
        chamEl.innerHTML = '<div class="empty-line">Nenhum chamado em aberto.</div>';
      } else {
        chamEl.innerHTML = chamados.slice(0, 5).map(c => `
          <div class="cham-row">
            <div style="display:flex;justify-content:space-between;gap:8px;align-items:center">
              <strong style="color:${tipoCor(c.tipo)}">${c.tipo.toUpperCase()}</strong>
              <span style="font-size:11.5px;color:var(--ink-light)">${fmtDate(c.data_abertura)}</span>
            </div>
            <div style="margin-top:3px">${c.manut_lojas?.nome || "—"} ${c.tecnico_atribuido_id === meuId ? '<span style="color:#B91C1C;font-size:10.5px;font-weight:700">· seu</span>' : ""}</div>
            <div style="font-size:12px;color:var(--ink-light);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${c.descricao}</div>
          </div>
        `).join("");
      }

      // Lojas
      const lojasEl = document.getElementById("lojasList");
      if (!lojas.length) {
        lojasEl.innerHTML = '<div class="empty-line">Nenhuma loja vinculada. Procure o administrador para vincular as lojas que você atende.</div>';
      } else {
        lojasEl.innerHTML = lojas.map(l => `
          <div class="loja-card">
            <div class="loja-cli">${l.manut_clientes?.nome || "—"}</div>
            <div class="loja-nome">${l.nome}</div>
            <div class="loja-end">📍 ${[l.endereco, l.cidade, l.uf].filter(Boolean).join(", ") || "Sem endereço"}</div>
          </div>
        `).join("");
      }

      // Calendário
      renderCalendario(preventivas, chamados);

      document.getElementById("loadingState").style.display = "none";
      document.getElementById("content").style.display = "";
    } catch (e) {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }

  // ── Calendário ──────────────────────────────────────────────────
  let calYear = new Date().getFullYear();
  let calMonth = new Date().getMonth(); // 0-11
  let cacheEventos = { preventivas: [], chamados: [] };
  const mesesFull = ["Janeiro","Fevereiro","Março","Abril","Maio","Junho","Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"];

  function renderCalendario(preventivas, chamados) {
    cacheEventos = { preventivas: preventivas || cacheEventos.preventivas, chamados: chamados || cacheEventos.chamados };
    document.getElementById("calTitulo").textContent = mesesFull[calMonth] + " " + calYear;

    // Organiza eventos por dia (chave: 'YYYY-MM-DD')
    const eventos = {};
    function addEv(dateStr, payload) {
      if (!dateStr) return;
      const d = new Date(dateStr);
      if (d.getFullYear() !== calYear || d.getMonth() !== calMonth) return;
      const key = d.getDate();
      if (!eventos[key]) eventos[key] = [];
      eventos[key].push(payload);
    }
    (cacheEventos.preventivas || []).forEach(p => addEv(p.data_agendada, {
      tipo: "prev", label: (p.manut_lojas?.nome || "Preventiva"), href: `/manutencao/tecnico/preventiva/${p.id}`
    }));
    (cacheEventos.chamados || []).forEach(c => {
      const isEmerg = c.tipo_chamado === "emergencial";
      addEv(c.data_abertura, {
        tipo: isEmerg ? "emerg" : "cham",
        label: `${c.tipo}: ${c.manut_lojas?.nome || c.descricao || "chamado"}`,
        href: `/manutencao/tecnico/chamados?id=${c.id}`,
      });
    });

    const primeiroDiaSemana = new Date(calYear, calMonth, 1).getDay();
    const ultimoDia = new Date(calYear, calMonth + 1, 0).getDate();
    const hoje = new Date();
    const ehMesAtual = hoje.getFullYear() === calYear && hoje.getMonth() === calMonth;

    const grid = document.getElementById("calGrid");
    let html = "";
    for (let i = 0; i < primeiroDiaSemana; i++) html += `<div class="cal-cell empty"></div>`;
    for (let d = 1; d <= ultimoDia; d++) {
      const evs = eventos[d] || [];
      const isHoje = ehMesAtual && hoje.getDate() === d;
      const hasEv = evs.length > 0;
      const firstHref = evs[0]?.href || "";
      const evHtml = evs.slice(0, 2).map(e => `<div class="cal-ev cal-ev-${e.tipo}" title="${e.label.replace(/"/g, '&quot;')}">${e.label}</div>`).join("");
      const mais = evs.length > 2 ? `<div class="cal-mais">+${evs.length - 2} mais</div>` : "";
      html += `
        <div class="cal-cell ${isHoje ? "hoje" : ""} ${hasEv ? "has-event" : ""}"
             ${hasEv ? `data-href="${firstHref}"` : ""}>
          <div class="cal-dia">${d}</div>
          ${evHtml}${mais}
        </div>
      `;
    }
    grid.innerHTML = html;
    grid.querySelectorAll(".cal-cell.has-event").forEach(c => {
      c.addEventListener("click", () => { window.location.href = c.dataset.href; });
    });
  }

  document.getElementById("calPrev").onclick = () => {
    calMonth--; if (calMonth < 0) { calMonth = 11; calYear--; }
    renderCalendario();
  };
  document.getElementById("calNext").onclick = () => {
    calMonth++; if (calMonth > 11) { calMonth = 0; calYear++; }
    renderCalendario();
  };

  load();
  window.addEventListener("portal:refresh", load);
</script>
