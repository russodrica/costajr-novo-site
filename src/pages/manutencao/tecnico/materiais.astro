---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Materiais" tipo="tecnico" activePage="materiais">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
    <p style="margin:0;font-size:14px;color:#5B5F6B">Solicite materiais necessários para os atendimentos.</p>
    <button class="btn btn-primary" id="btnNovo">+ Solicitar Material</button>
  </div>

  <div id="loadingState" class="loading">Carregando solicitações...</div>
  <div id="matWrap" style="display:none"></div>

  <!-- Modal novo material -->
  <div class="modal-bg" id="modalNovo">
    <div class="modal">
      <h2>Solicitar Material</h2>
      <div id="alertNovo" class="alert alert-error" style="display:none"></div>
      <div class="form-group">
        <label>Chamado relacionado (opcional)</label>
        <select id="selChamado">
          <option value="">Carregando chamados...</option>
        </select>
      </div>
      <div class="form-group">
        <label>Descrição do material</label>
        <textarea id="descMat" placeholder="Descreva o material necessário, quantidade, especificações..."></textarea>
      </div>
      <div class="form-group">
        <label>Valor estimado (R$)</label>
        <input type="number" id="valorMat" min="0.01" step="0.01" placeholder="0,00">
      </div>
      <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:8px">
        <button class="btn btn-outline" id="btnCancelar">Cancelar</button>
        <button class="btn btn-primary" id="btnSubmit">Solicitar</button>
      </div>
    </div>
  </div>
</Portal>

<style>
  .mat-card { background:#fff;border:1px solid #E5E7EB;border-radius:10px;padding:20px 24px;margin-bottom:12px; }
  .mat-card.pendente { border-left:4px solid #F59E0B; }
  .mat-header { display:flex;align-items:flex-start;justify-content:space-between;gap:12px; }
  .mat-title { font-weight:700;font-size:15px;margin-bottom:4px; }
  .mat-sub { font-size:13px;color:#5B5F6B; }
  .mat-valor { font-family:'Montserrat',sans-serif;font-weight:800;font-size:20px;color:#C41E3A; }
</style>

<script>
  const TOKEN_KEY = "manut_tecnico_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/tecnico/login");

  let allMat = [];
  let chamados = [];

  function badge(status) {
    const m = { pendente_aprovacao:"badge-aguardando_material", aprovado:"badge-concluido", rejeitado:"badge-cancelado", pago:"badge-concluido" };
    const l = { pendente_aprovacao:"Aguard. aprovação", aprovado:"Aprovado", rejeitado:"Rejeitado", pago:"Pago" };
    return `<span class="badge ${m[status] || ""}">${l[status] || status}</span>`;
  }
  function fmt(v) { return v != null ? "R$ " + Number(v).toLocaleString("pt-BR",{minimumFractionDigits:2}) : "—"; }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function render() {
    const wrap = document.getElementById("matWrap");
    if (!allMat.length) {
      wrap.innerHTML = '<div class="card" style="text-align:center;padding:40px;color:#9CA3AF">Nenhuma solicitação de material encontrada.</div>';
      return;
    }
    wrap.innerHTML = allMat.map(m => `
      <div class="mat-card ${m.status === 'pendente_aprovacao' ? 'pendente' : ''}">
        <div class="mat-header">
          <div>
            <div class="mat-title">${m.descricao}</div>
            <div class="mat-sub">
              Cliente: <strong>${m.manut_clientes?.nome || "—"}</strong> &nbsp;|&nbsp;
              Loja: <strong>${m.manut_lojas?.nome || "—"}</strong> &nbsp;|&nbsp;
              ${fmtDate(m.created_at)}
            </div>
          </div>
          <div style="text-align:right">
            <div class="mat-valor">${fmt(m.valor)}</div>
            <div style="margin-top:4px">${badge(m.status)}</div>
          </div>
        </div>
        ${m.comprovante_url ? `<div style="margin-top:10px"><a href="${m.comprovante_url}" target="_blank" class="btn btn-outline btn-sm">📎 Ver comprovante</a></div>` : ""}
      </div>
    `).join("");
  }

  async function loadChamados() {
    try {
      const res = await fetch("/api/manut/tecnico/chamados", { headers: { "x-tecnico-auth": token } });
      chamados = await res.json();
    } catch {}
  }

  document.getElementById("btnNovo").onclick = async () => {
    document.getElementById("alertNovo").style.display = "none";
    if (!chamados.length) await loadChamados();
    const sel = document.getElementById("selChamado");
    sel.innerHTML = '<option value="">Sem chamado relacionado</option>' +
      chamados.map(c => `<option value="${c.id}" data-loja="${c.loja_id||''}" data-cli="${c.cliente_id||''}">${c.manut_lojas?.nome || c.id.slice(-6)} — ${c.tipo}</option>`).join("");
    document.getElementById("descMat").value = "";
    document.getElementById("valorMat").value = "";
    document.getElementById("modalNovo").classList.add("open");
  };
  document.getElementById("btnCancelar").onclick = () => document.getElementById("modalNovo").classList.remove("open");

  document.getElementById("btnSubmit").onclick = async () => {
    const alertEl = document.getElementById("alertNovo");
    alertEl.style.display = "none";
    const sel = document.getElementById("selChamado");
    const chamadoSel = chamados.find(c => c.id === sel.value);
    const descricao = document.getElementById("descMat").value.trim();
    const valor = parseFloat(document.getElementById("valorMat").value);

    if (!descricao) { alertEl.textContent = "Informe a descrição do material."; alertEl.style.display = ""; return; }
    if (!valor || valor <= 0) { alertEl.textContent = "Informe um valor válido."; alertEl.style.display = ""; return; }

    // Se não tem chamado selecionado, precisamos de loja/cliente — mas simplificamos: obrigatório para solicitação avulsa
    let loja_id = chamadoSel?.loja_id || null;
    let cliente_id = chamadoSel?.cliente_id || null;
    if (!loja_id || !cliente_id) {
      alertEl.textContent = "Selecione um chamado para vincular o material.";
      alertEl.style.display = "";
      return;
    }

    const btn = document.getElementById("btnSubmit");
    btn.disabled = true; btn.textContent = "Enviando...";
    try {
      const res = await fetch("/api/manut/tecnico/materiais", {
        method: "POST",
        headers: { "content-type":"application/json","x-tecnico-auth":token },
        body: JSON.stringify({ chamado_id: sel.value || null, loja_id, cliente_id, descricao, valor }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      allMat.unshift({ ...data, manut_lojas: chamadoSel?.manut_lojas, manut_clientes: { nome: "" } });
      document.getElementById("modalNovo").classList.remove("open");
      render();
    } catch (err) {
      alertEl.textContent = err.message; alertEl.style.display = "";
    } finally {
      btn.disabled = false; btn.textContent = "Solicitar";
    }
  };

  async function load() {
    try {
      const res = await fetch("/api/manut/tecnico/materiais", { headers: { "x-tecnico-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/tecnico/login"); return; }
      allMat = await res.json();
      document.getElementById("loadingState").style.display = "none";
      document.getElementById("matWrap").style.display = "";
      render();
    } catch {
      document.getElementById("loadingState").textContent = "Erro ao carregar. Recarregue a página.";
    }
  }
  load();
</script>
