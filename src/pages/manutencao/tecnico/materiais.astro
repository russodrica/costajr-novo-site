---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Materiais" tipo="tecnico" activePage="materiais">
  <div class="section-header">
    <p style="margin:0;font-size:13.5px;color:#5B5F6B">Solicite materiais necessários para os atendimentos.</p>
    <button class="btn btn-primary" id="btnNovo">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Solicitar Material
    </button>
  </div>

  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando solicitações...</div>
  <div id="matWrap" style="display:none"></div>

  <!-- Modal novo material -->
  <div class="modal-bg" id="modalNovo">
    <div class="modal">
      <button class="modal-close" id="btnFecharNovo">×</button>
      <h2>Solicitar Material</h2>
      <div id="alertNovo" class="alert alert-error" style="display:none"></div>
      <div class="form-group">
        <label>Chamado relacionado</label>
        <select id="selChamado"><option value="">Carregando chamados...</option></select>
        <p class="form-hint">Selecione o chamado para vincular o pedido de material.</p>
      </div>
      <div class="form-group">
        <label>Descrição do material</label>
        <textarea id="descMat" placeholder="Descreva o material necessário, quantidade, especificações..."></textarea>
      </div>
      <div class="form-group">
        <label>Valor estimado (R$)</label>
        <input type="number" id="valorMat" min="0.01" step="0.01" placeholder="0,00">
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:4px">
        <button class="btn btn-outline" id="btnCancelar">Cancelar</button>
        <button class="btn btn-primary" id="btnSubmit">Solicitar</button>
      </div>
    </div>
  </div>
</Portal>

<style>
  .mat-card {
    background:#fff; border:1px solid var(--border); border-radius:var(--radius-lg);
    padding:20px 24px; margin-bottom:12px;
    box-shadow:var(--shadow-sm); transition:var(--transition);
  }
  .mat-card:hover { box-shadow:var(--shadow); }
  .mat-card.pendente { border-left:4px solid #F59E0B; }
  .mat-header { display:flex;align-items:flex-start;justify-content:space-between;gap:16px; }
  .mat-title  { font-weight:700;font-size:15px;margin-bottom:5px; }
  .mat-meta   { font-size:12.5px;color:#5B5F6B;display:flex;flex-wrap:wrap;gap:6px;align-items:center; }
  .mat-sep    { color:#D1D5DB; }
  .mat-valor  { font-family:'Montserrat',sans-serif;font-weight:800;font-size:22px;color:#C41E3A;text-align:right; }
</style>

<script>
  const TOKEN_KEY = "manut_tecnico_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/tecnico/login");

  let allMat = [];
  let chamados = [];

  function badge(status) {
    const m = { pendente_aprovacao:"badge-aguardando_material", aprovado:"badge-concluido", rejeitado:"badge-cancelado", pago:"badge-concluido" };
    const l = { pendente_aprovacao:"Aguard. aprovação", aprovado:"Aprovado", rejeitado:"Rejeitado", pago:"Pago" };
    return `<span class="badge ${m[status] || ""}">${l[status] || status}</span>`;
  }
  function fmt(v) { return v != null ? "R$ " + Number(v).toLocaleString("pt-BR",{minimumFractionDigits:2}) : "—"; }
  function fmtDate(d) { return d ? new Date(d).toLocaleDateString("pt-BR") : "—"; }

  function render() {
    const wrap = document.getElementById("matWrap");
    if (!allMat.length) {
      wrap.innerHTML = `<div class="card"><div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        <strong>Nenhuma solicitação de material</strong>
        <p>Use o botão acima para solicitar um material para um atendimento.</p>
      </div></div>`;
      return;
    }
    wrap.innerHTML = allMat.map(m => `
      <div class="mat-card ${m.status === 'pendente_aprovacao' ? 'pendente' : ''}">
        <div class="mat-header">
          <div style="flex:1;min-width:0">
            <div class="mat-title">${m.descricao}</div>
            <div class="mat-meta">
              <span>🏪 ${m.manut_lojas?.nome || "—"}</span>
              <span class="mat-sep">·</span>
              <span>👤 ${m.manut_clientes?.nome || "—"}</span>
              <span class="mat-sep">·</span>
              <span>${fmtDate(m.created_at)}</span>
              <span class="mat-sep">·</span>
              ${badge(m.status)}
            </div>
          </div>
          <div>
            <div class="mat-valor">${fmt(m.valor)}</div>
          </div>
        </div>
        ${m.comprovante_url ? `<div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border-light)"><a href="${m.comprovante_url}" target="_blank" class="btn btn-outline btn-sm">📎 Ver comprovante de pagamento</a></div>` : ""}
      </div>
    `).join("");
  }

  async function loadChamados() {
    try {
      const res = await fetch("/api/manut/tecnico/chamados", { headers: { "x-tecnico-auth": token } });
      chamados = res.ok ? await res.json() : [];
    } catch {}
  }

  document.getElementById("btnNovo").onclick = async () => {
    document.getElementById("alertNovo").style.display = "none";
    if (!chamados.length) await loadChamados();
    const sel = document.getElementById("selChamado");
    sel.innerHTML = chamados.length
      ? '<option value="">Selecione o chamado...</option>' + chamados.map(c => `<option value="${c.id}" data-loja="${c.loja_id||''}" data-cli="${c.cliente_id||''}">${c.manut_lojas?.nome || "Loja"} — ${c.tipo}</option>`).join("")
      : '<option value="">Nenhum chamado ativo</option>';
    document.getElementById("descMat").value = "";
    document.getElementById("valorMat").value = "";
    document.getElementById("modalNovo").classList.add("open");
  };

  function fecharModal() { document.getElementById("modalNovo").classList.remove("open"); }
  document.getElementById("btnCancelar").onclick = fecharModal;
  document.getElementById("btnFecharNovo").onclick = fecharModal;

  document.getElementById("btnSubmit").onclick = async () => {
    const alertEl = document.getElementById("alertNovo");
    alertEl.style.display = "none";
    const sel = document.getElementById("selChamado");
    const chamadoSel = chamados.find(c => c.id === sel.value);
    const descricao = document.getElementById("descMat").value.trim();
    const valor = parseFloat(document.getElementById("valorMat").value);

    if (!sel.value)  { alertEl.textContent = "Selecione o chamado."; alertEl.style.display = ""; return; }
    if (!chamadoSel) { alertEl.textContent = "Chamado inválido."; alertEl.style.display = ""; return; }
    if (!descricao)  { alertEl.textContent = "Informe a descrição do material."; alertEl.style.display = ""; return; }
    if (!valor || valor <= 0) { alertEl.textContent = "Informe um valor válido."; alertEl.style.display = ""; return; }

    const btn = document.getElementById("btnSubmit");
    btn.disabled = true; btn.textContent = "Enviando...";
    try {
      const res = await fetch("/api/manut/tecnico/materiais", {
        method: "POST",
        headers: { "content-type":"application/json","x-tecnico-auth":token },
        body: JSON.stringify({ chamado_id: chamadoSel.id, loja_id: chamadoSel.loja_id, cliente_id: chamadoSel.cliente_id, descricao, valor }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      if (!Array.isArray(allMat)) allMat = [];
      allMat.unshift({ ...data, manut_lojas: chamadoSel?.manut_lojas, manut_clientes: { nome: "" } });
      fecharModal();
      render();
      window.toast?.("Material solicitado! Aguardando aprovação do cliente.", "success");
    } catch (err) {
      alertEl.textContent = err.message; alertEl.style.display = "";
    } finally {
      btn.disabled = false; btn.textContent = "Solicitar";
    }
  };

  async function load() {
    try {
      const res = await fetch("/api/manut/tecnico/materiais", { headers: { "x-tecnico-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/tecnico/login"); return; }
      const json = await res.json();
      allMat = Array.isArray(json) ? json : [];
      document.getElementById("loadingState").style.display = "none";
      document.getElementById("matWrap").style.display = "";
      render();
    } catch {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro ao carregar</strong><p>Recarregue a página.</p></div>';
    }
  }
  load();
  window.addEventListener("portal:refresh", load);
</script>
