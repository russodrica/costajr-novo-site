---
import Portal from "~/layouts/Portal.astro";
import { DISCIPLINAS, FOTOS_MIN_POR_DISCIPLINA } from "~/lib/manut/checklist";
export const prerender = false;
const { id } = Astro.params;
---
<Portal title="Preventiva" tipo="tecnico" activePage="agenda">
  <div style="margin-bottom:16px">
    <a href="/manutencao/tecnico/agenda" class="btn btn-outline btn-sm">← Voltar para agenda</a>
  </div>

  <div id="loadingState" class="loading"><div class="spinner"></div>Carregando preventiva...</div>

  <div id="content" style="display:none">
    <!-- Cabeçalho -->
    <div class="card prev-header" style="margin-bottom:18px">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap">
        <div>
          <h2 style="margin:0 0 4px;font-family:'Montserrat',sans-serif;font-size:20px" id="hLoja"></h2>
          <div style="font-size:13.5px;color:var(--ink-mid);margin-bottom:4px" id="hCliente"></div>
          <div style="font-size:12.5px;color:var(--ink-light)" id="hEndereco"></div>
        </div>
        <div style="text-align:right;flex-shrink:0">
          <div id="hStatusBadge" style="margin-bottom:6px"></div>
          <div style="font-size:11px;color:var(--ink-light);text-transform:uppercase;letter-spacing:0.05em">Data</div>
          <div id="hData" style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:15px"></div>
        </div>
      </div>

      <!-- Stepper -->
      <div class="stepper" id="stepper"></div>
    </div>

    <!-- Botão de iniciar quando agendada -->
    <div id="boxIniciar" class="card" style="display:none;text-align:center;padding:36px">
      <div style="font-size:48px;line-height:1;margin-bottom:12px">📋</div>
      <h3 style="margin:0 0 8px">Pronto para iniciar?</h3>
      <p style="font-size:14px;color:var(--ink-mid);margin:0 0 20px">Você será guiado pelas etapas: foto inicial → 3 disciplinas → assinatura do gerente.</p>
      <button class="btn btn-primary" id="btnIniciar">▶ Iniciar preventiva</button>
    </div>

    <!-- Wrapper das etapas -->
    <div id="wizardWrap" style="display:none">
      <!-- ETAPA: Foto inicial -->
      <div class="etapa-card" id="etapa-inicial" style="display:none">
        <h3 class="etapa-titulo">📸 Foto inicial — técnico uniformizado na loja</h3>
        <p class="etapa-desc">Tire ou envie uma foto sua, uniformizado, em frente à loja. Esta é a primeira evidência da visita.</p>
        <div class="upload-area" id="uploadInicial">
          <div class="upload-foto" id="uploadInicialFoto">
            <span class="upload-placeholder">Toque para abrir a câmera ou escolher uma foto</span>
            <input type="file" accept="image/*" capture="environment" class="upload-input" data-kind="inicial">
          </div>
        </div>
        <div class="etapa-actions">
          <button class="btn btn-primary" id="btnAvancarInicial" disabled>Avançar para Hidráulica →</button>
        </div>
      </div>

      <!-- ETAPAS: disciplinas (renderizadas dinamicamente) -->
      <div id="etapasDisciplinas"></div>

      <!-- ETAPA: Assinatura -->
      <div class="etapa-card" id="etapa-assinatura" style="display:none">
        <h3 class="etapa-titulo">✍️ Assinatura do gerente da loja</h3>
        <p class="etapa-desc">Antes de fechar, peça ao gerente do local que assine a ordem de serviço.</p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px" class="grid-2col">
          <div class="form-group">
            <label>Nome do gerente *</label>
            <input id="gerenteNome" type="text" placeholder="Nome completo">
          </div>
          <div class="form-group">
            <label>Cargo</label>
            <input id="gerenteCargo" type="text" placeholder="Ex: Gerente de loja">
          </div>
        </div>

        <label style="font-size:13px;font-weight:600;color:var(--ink-mid);margin-bottom:6px;display:block">Assinatura</label>
        <div class="sig-wrap">
          <canvas id="sigCanvas" width="600" height="220"></canvas>
          <div class="sig-baseline">Assine aqui</div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:8px;flex-wrap:wrap;gap:8px">
          <button type="button" class="btn btn-outline btn-sm" id="btnLimparAssinatura">Limpar</button>
          <div id="sigStatus" style="font-size:12.5px;color:var(--ink-light);align-self:center"></div>
        </div>

        <div class="form-group" style="margin-top:16px">
          <label>Observações gerais da visita</label>
          <textarea id="obsGerais" rows="3" placeholder="Anote qualquer observação que não tenha cabido nas disciplinas..."></textarea>
        </div>

        <div class="etapa-actions">
          <button class="btn btn-primary" id="btnConcluir" disabled>✓ Concluir preventiva</button>
        </div>
      </div>

      <!-- ETAPA: Concluído -->
      <div class="etapa-card" id="etapa-concluido" style="display:none">
        <div style="text-align:center;padding:24px 16px">
          <div style="font-size:56px;line-height:1">✅</div>
          <h3 style="margin:14px 0 4px">Preventiva concluída</h3>
          <p id="hExecutada" style="font-size:13.5px;color:var(--ink-mid);margin:0 0 24px"></p>
        </div>
        <div id="resumoFinal"></div>
      </div>
    </div>
  </div>
</Portal>

<style is:global>
  /* Stepper */
  .stepper {
    display: flex; gap: 6px; margin-top: 18px; padding-top: 18px;
    border-top: 1px solid var(--border-light); overflow-x: auto;
  }
  .step {
    flex: 1; min-width: 90px; padding: 8px 10px; border-radius: 8px;
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    background: #F4F6F9; color: #9CA3AF; text-align: center; transition: var(--transition);
  }
  .step.done { background: #D1FAE5; color: #15803D; }
  .step.active { background: var(--brand); color: #fff; box-shadow: 0 2px 8px rgba(196,30,58,.3); }

  /* Etapa cards */
  .etapa-card {
    background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: 24px; margin-bottom: 18px; box-shadow: var(--shadow-sm);
  }
  .etapa-titulo {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 18px;
    margin: 0 0 6px;
  }
  .etapa-desc { font-size: 13.5px; color: var(--ink-mid); margin: 0 0 20px; }
  .etapa-actions {
    margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--border-light);
    display: flex; justify-content: space-between; gap: 10px; flex-wrap: wrap;
  }

  /* Checklist amigável */
  .check-list { display: flex; flex-direction: column; gap: 10px; }
  .check-item {
    background: #FAFBFC; border: 1.5px solid var(--border); border-radius: var(--radius);
    padding: 14px 16px; transition: var(--transition);
  }
  .check-item:hover { border-color: #D1D5DB; background: #fff; }
  .check-item.ans-ok    { background: #F0FDF4; border-color: #BBF7D0; }
  .check-item.ans-nok   { background: #FEF2F2; border-color: #FECACA; }
  .check-item.ans-na    { background: #F9FAFB; border-color: var(--border); }
  .check-row {
    display: flex; align-items: center; gap: 14px; justify-content: space-between;
  }
  .check-label { font-size: 14px; color: var(--ink); flex: 1; font-weight: 500; }
  .check-num {
    flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%;
    background: #E5E7EB; color: #6B7280; font-size: 12px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }
  .check-item.ans-ok  .check-num { background: #15803D; color: #fff; }
  .check-item.ans-nok .check-num { background: #B91C1C; color: #fff; }
  .check-item.ans-na  .check-num { background: #6B7280; color: #fff; }
  .check-actions { display: flex; gap: 4px; flex-shrink: 0; }
  .check-btn {
    padding: 7px 12px; border-radius: 6px; border: 1.5px solid var(--border);
    background: #fff; cursor: pointer; font-size: 12px; font-weight: 700;
    transition: all .12s;
  }
  .check-btn.ok-btn  { color: #15803D; }
  .check-btn.nok-btn { color: #B91C1C; }
  .check-btn.na-btn  { color: #6B7280; }
  .check-btn.ok-btn:hover  { background: #F0FDF4; }
  .check-btn.nok-btn:hover { background: #FEF2F2; }
  .check-btn.na-btn:hover  { background: #F9FAFB; }
  .check-btn.active.ok-btn  { background: #15803D; color: #fff; border-color: #15803D; }
  .check-btn.active.nok-btn { background: #B91C1C; color: #fff; border-color: #B91C1C; }
  .check-btn.active.na-btn  { background: #6B7280; color: #fff; border-color: #6B7280; }
  .check-obs-wrap { margin-top: 10px; display: none; }
  .check-item.ans-nok .check-obs-wrap { display: block; }
  .check-obs {
    width: 100%; padding: 8px 12px; font-size: 13px;
    border: 1px solid #FECACA; border-radius: 6px; background: #fff;
    font-family: 'Open Sans', sans-serif; outline: none;
  }
  .check-obs:focus { border-color: #B91C1C; box-shadow: 0 0 0 3px rgba(185,28,28,.1); }

  /* Upload de fotos */
  .upload-area { margin: 16px 0; }
  .fotos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px; }
  .upload-foto {
    aspect-ratio: 4/3; border: 2px dashed var(--border); border-radius: var(--radius);
    background: #FAFBFC; display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: var(--transition); position: relative;
    overflow: hidden;
  }
  .upload-foto:hover { border-color: var(--brand); background: #FFF5F5; }
  .upload-foto.has-image { border-style: solid; background: #000; }
  .upload-foto img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .upload-placeholder {
    font-size: 12.5px; color: var(--ink-light); text-align: center; padding: 12px;
  }
  .upload-input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .foto-overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,.6); color: #fff;
    display: none; align-items: center; justify-content: center;
    font-size: 12.5px; font-weight: 600;
  }
  .upload-foto.uploading .foto-overlay { display: flex; }
  .foto-card { position: relative; }
  .foto-card .btn-remove {
    position: absolute; top: 6px; right: 6px; background: rgba(0,0,0,.7); color: #fff;
    border: 0; width: 24px; height: 24px; border-radius: 50%; cursor: pointer;
    font-size: 13px; line-height: 1; display: flex; align-items: center; justify-content: center;
  }
  .foto-card .btn-remove:hover { background: #B91C1C; }
  .contador-fotos {
    display: inline-block; padding: 4px 10px; border-radius: 100px;
    font-size: 11.5px; font-weight: 700; margin-left: 8px;
  }
  .contador-fotos.ok       { background: #D1FAE5; color: #15803D; }
  .contador-fotos.faltando { background: #FEF2F2; color: #B91C1C; }

  /* Assinatura */
  .sig-wrap {
    position: relative; border: 1.5px solid var(--border); border-radius: var(--radius);
    background: #fff; overflow: hidden; touch-action: none;
  }
  #sigCanvas { width: 100%; height: 220px; display: block; cursor: crosshair; }
  .sig-baseline {
    position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
    font-size: 11px; color: #D1D5DB; pointer-events: none; letter-spacing: 0.15em; text-transform: uppercase;
  }

  .form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--ink-mid); margin-bottom: 5px; }
  .form-group input, .form-group textarea {
    width: 100%; padding: 10px 13px; border: 1.5px solid var(--border);
    border-radius: 8px; font-family: 'Open Sans', sans-serif; font-size: 13.5px;
    color: var(--ink); background: #fff; transition: border .15s; outline: none;
  }
  .form-group input:focus, .form-group textarea:focus { border-color: var(--brand); }

  /* Resumo */
  .resumo-disc { padding: 12px 14px; border-bottom: 1px solid var(--border-light); }
  .resumo-disc:last-child { border-bottom: 0; }
  .resumo-disc h4 { margin: 0 0 6px; font-family: 'Montserrat', sans-serif; font-size: 13px; }
  .resumo-stats { font-size: 12.5px; color: var(--ink-mid); }

  @media (max-width: 600px) {
    .grid-2col { grid-template-columns: 1fr !important; }
    .check-row { flex-direction: column; align-items: stretch; gap: 10px; }
    .check-actions { justify-content: stretch; }
    .check-btn { flex: 1; padding: 9px 6px; font-size: 11.5px; }
    .check-num { display: none; }
  }
</style>

<script define:vars={{ preventivaId: id, DISCIPLINAS, FOTOS_MIN: FOTOS_MIN_POR_DISCIPLINA }}>
  const TOKEN_KEY = "manut_tecnico_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/tecnico/login");

  let preventiva = null;

  // ───────────────────────────────────────────────────────────────────
  // Helpers
  // ───────────────────────────────────────────────────────────────────
  function badge(status) {
    const m = { agendada:"badge-aberto", em_execucao:"badge-em_andamento", concluida:"badge-concluido", cancelada:"badge-cancelado" };
    const l = { agendada:"Agendada", em_execucao:"Em execução", concluida:"Concluída", cancelada:"Cancelada" };
    return `<span class="badge ${m[status]||""}">${l[status]||status}</span>`;
  }
  function fmtDate(d, withTime) {
    if (!d) return "—";
    const dt = new Date(d);
    const data = dt.toLocaleDateString("pt-BR");
    return withTime ? data + " · " + dt.toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"}) : data;
  }
  function api(path, opts = {}) {
    return fetch(path, { ...opts, headers: { ...(opts.headers||{}), "x-tecnico-auth": token } });
  }
  async function patchPreventiva(body) {
    const res = await api(`/api/manut/tecnico/preventivas/${preventivaId}`, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    if (!res.ok) {
      const d = await res.json().catch(() => ({}));
      throw new Error(d.error || "Erro ao salvar");
    }
    preventiva = await res.json();
    return preventiva;
  }

  // ───────────────────────────────────────────────────────────────────
  // Render: cabeçalho + stepper
  // ───────────────────────────────────────────────────────────────────
  function renderHeader() {
    document.getElementById("hLoja").textContent = preventiva.manut_lojas?.nome || "—";
    document.getElementById("hCliente").textContent = "👤 " + (preventiva.manut_clientes?.nome || "—");
    document.getElementById("hEndereco").textContent = "📍 " + [preventiva.manut_lojas?.endereco, preventiva.manut_lojas?.cidade, preventiva.manut_lojas?.uf].filter(Boolean).join(", ");
    document.getElementById("hStatusBadge").innerHTML = badge(preventiva.status);
    document.getElementById("hData").textContent = fmtDate(preventiva.data_agendada);
    renderStepper();
  }

  function renderStepper() {
    const etapas = [
      { id: "inicial",     label: "Foto inicial"     },
      { id: "hidraulica",  label: "Hidráulica"       },
      { id: "civil",       label: "Civil"            },
      { id: "eletrica",    label: "Elétrica"         },
      { id: "assinatura",  label: "Assinatura"       },
    ];
    const atual = preventiva.checklist?.etapa_atual || (preventiva.status === "concluida" ? "concluido" : "inicial");
    const order = ["inicial","hidraulica","civil","eletrica","assinatura","concluido"];
    const idxAtual = order.indexOf(atual);
    document.getElementById("stepper").innerHTML = etapas.map(e => {
      const idx = order.indexOf(e.id);
      const cls = idx < idxAtual ? "done" : idx === idxAtual ? "active" : "";
      return `<div class="step ${cls}">${e.label}</div>`;
    }).join("");
  }

  // ───────────────────────────────────────────────────────────────────
  // Upload de foto
  // ───────────────────────────────────────────────────────────────────
  async function blobToBase64(blob) {
    const buf = await blob.arrayBuffer();
    const bytes = new Uint8Array(buf);
    let s = "";
    const CHUNK = 0x8000;
    for (let i = 0; i < bytes.length; i += CHUNK) {
      s += String.fromCharCode.apply(null, bytes.subarray(i, i + CHUNK));
    }
    return btoa(s);
  }

  async function uploadFoto(file, kind) {
    const mime = ["image/png","image/webp"].includes(file.type) ? file.type : "image/jpeg";
    const data_base64 = await blobToBase64(file);
    const res = await api(`/api/manut/tecnico/preventivas/${preventivaId}/foto`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ kind, mime, data_base64 }),
    });
    if (!res.ok) {
      const d = await res.json().catch(() => ({}));
      throw new Error(d.error || "Falha no upload");
    }
    return (await res.json()).url;
  }

  async function uploadAssinaturaBlob(blob) {
    const data_base64 = await blobToBase64(blob);
    const res = await api(`/api/manut/tecnico/preventivas/${preventivaId}/foto`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ kind: "assinatura", mime: "image/png", data_base64 }),
    });
    if (!res.ok) {
      const d = await res.json().catch(() => ({}));
      throw new Error(d.error || "Falha no upload da assinatura");
    }
    return (await res.json()).url;
  }

  // ───────────────────────────────────────────────────────────────────
  // Render: etapa inicial
  // ───────────────────────────────────────────────────────────────────
  function renderEtapaInicial() {
    const ck = preventiva.checklist;
    const wrap = document.getElementById("uploadInicial");
    const fotoUrl = ck?.foto_inicial_url;
    wrap.innerHTML = fotoUrl
      ? `<div class="foto-card" style="max-width:360px">
           <div class="upload-foto has-image">
             <img src="${fotoUrl}" alt="Foto inicial">
             <button class="btn-remove" id="removeInicial" title="Remover">×</button>
           </div>
         </div>`
      : `<div class="foto-card" style="max-width:360px">
           <label class="upload-foto" for="inputInicial">
             <span class="upload-placeholder">📷 Toque para abrir a câmera ou escolher uma foto</span>
             <input id="inputInicial" type="file" accept="image/*" capture="environment" class="upload-input">
             <div class="foto-overlay">Enviando...</div>
           </label>
         </div>`;
    document.getElementById("btnAvancarInicial").disabled = !fotoUrl;

    if (!fotoUrl) {
      const inp = document.getElementById("inputInicial");
      inp?.addEventListener("change", async (e) => {
        const file = e.target.files?.[0]; if (!file) return;
        const lbl = inp.closest(".upload-foto");
        lbl.classList.add("uploading");
        try {
          const url = await uploadFoto(file, "inicial");
          await patchPreventiva({ checklist: { ...preventiva.checklist, foto_inicial_url: url } });
          renderTudo();
        } catch (err) {
          alert("Erro: " + err.message);
        } finally {
          lbl.classList.remove("uploading");
        }
      });
    } else {
      document.getElementById("removeInicial")?.addEventListener("click", async () => {
        if (!confirm("Remover a foto inicial?")) return;
        await patchPreventiva({ checklist: { ...preventiva.checklist, foto_inicial_url: null } });
        renderTudo();
      });
    }
  }

  // ───────────────────────────────────────────────────────────────────
  // Render: etapa disciplina (hidraulica | civil | eletrica)
  // ───────────────────────────────────────────────────────────────────
  function discCompleta(discId) {
    const d = preventiva.checklist?.disciplinas?.[discId];
    if (!d) return false;
    const todosRespondidos = d.itens.every(it => it.ok !== null);
    const fotosOk = (d.fotos?.length || 0) >= FOTOS_MIN;
    return todosRespondidos && fotosOk;
  }

  function renderEtapasDisciplinas() {
    const wrap = document.getElementById("etapasDisciplinas");
    wrap.innerHTML = DISCIPLINAS.map(d => {
      const idx = DISCIPLINAS.indexOf(d);
      const proxima = idx < DISCIPLINAS.length - 1 ? DISCIPLINAS[idx + 1] : null;
      const proxLabel = proxima ? `Avançar para ${proxima.nome}` : "Avançar para assinatura";
      return `
        <div class="etapa-card etapa-disc" id="etapa-${d.id}" style="display:none">
          <h3 class="etapa-titulo">${d.icone} ${d.nome}</h3>
          <p class="etapa-desc">Periodicidade sugerida: ${d.periodicidade}. Marque cada item e tire ao menos ${FOTOS_MIN} fotos da disciplina.</p>

          <h4 style="font-size:13px;font-weight:700;margin:0 0 10px;color:var(--ink-mid);text-transform:uppercase;letter-spacing:0.05em">Itens a verificar</h4>
          <div class="check-list" id="checklist-${d.id}"></div>

          <h4 style="font-size:13px;font-weight:700;margin:24px 0 10px;color:var(--ink-mid);text-transform:uppercase;letter-spacing:0.05em">
            Fotos da ${d.nome.toLowerCase()}
            <span class="contador-fotos" id="cont-${d.id}"></span>
          </h4>
          <div class="fotos-grid" id="fotos-${d.id}"></div>

          <div class="form-group" style="margin-top:24px">
            <label>Observações sobre ${d.nome.toLowerCase()} (opcional)</label>
            <textarea id="obs-${d.id}" rows="2" placeholder="Anote alguma observação geral da disciplina..."></textarea>
          </div>

          <div class="etapa-actions">
            <button type="button" class="btn btn-outline" data-voltar="${d.id}">← Voltar</button>
            <button type="button" class="btn btn-primary" data-avancar="${d.id}" disabled>${proxLabel} →</button>
          </div>
        </div>
      `;
    }).join("");
  }

  function renderChecklistDisciplina(discId) {
    const def = DISCIPLINAS.find(x => x.id === discId);
    const data = preventiva.checklist.disciplinas[discId];
    const wrap = document.getElementById("checklist-" + discId);
    wrap.innerHTML = data.itens.map((it, i) => {
      const cls = it.ok === true ? "ans-ok" : it.ok === false ? "ans-nok" : it.ok === null && it.obs === "__na__" ? "ans-na" : "";
      const showNa = it.obs === "__na__";
      return `
        <div class="check-item ${cls}" data-item="${it.id}">
          <div class="check-row">
            <div class="check-num">${i+1}</div>
            <div class="check-label">${it.label}</div>
            <div class="check-actions">
              <button type="button" class="check-btn ok-btn  ${it.ok === true ? 'active' : ''}" data-set="ok">✓ OK</button>
              <button type="button" class="check-btn nok-btn ${it.ok === false ? 'active' : ''}" data-set="nok">✕ Falha</button>
              <button type="button" class="check-btn na-btn  ${showNa ? 'active' : ''}" data-set="na">— N/A</button>
            </div>
          </div>
          <div class="check-obs-wrap">
            <input class="check-obs" placeholder="Descreva a falha encontrada..." value="${(it.obs && it.obs !== '__na__' ? it.obs : '').replace(/"/g,'&quot;')}">
          </div>
        </div>
      `;
    }).join("");

    wrap.querySelectorAll(".check-btn[data-set]").forEach(btn => {
      btn.addEventListener("click", async () => {
        const itemEl = btn.closest("[data-item]");
        const itemId = itemEl.dataset.item;
        const set = btn.dataset.set;
        const it = preventiva.checklist.disciplinas[discId].itens.find(x => x.id === itemId);
        if (!it) return;
        if (set === "ok")  { it.ok = true;  it.obs = ""; }
        if (set === "na")  { it.ok = null;  it.obs = "__na__"; }
        if (set === "nok") { it.ok = false; if (it.obs === "__na__") it.obs = ""; }
        renderChecklistDisciplina(discId);
        atualizarBotaoAvancar(discId);
        salvarSilencioso();
      });
    });
    wrap.querySelectorAll(".check-obs").forEach(inp => {
      inp.addEventListener("input", () => {
        const itemEl = inp.closest("[data-item]");
        const itemId = itemEl.dataset.item;
        const it = preventiva.checklist.disciplinas[discId].itens.find(x => x.id === itemId);
        if (it) { it.obs = inp.value; salvarSilencioso(); }
      });
    });
  }

  function renderFotosDisciplina(discId) {
    const data = preventiva.checklist.disciplinas[discId];
    const fotos = data.fotos || [];
    const wrap = document.getElementById("fotos-" + discId);
    const cont = document.getElementById("cont-" + discId);
    const slots = Math.max(FOTOS_MIN, fotos.length + 1);
    let html = "";
    for (let i = 0; i < fotos.length; i++) {
      html += `<div class="foto-card">
        <div class="upload-foto has-image">
          <img src="${fotos[i]}" alt="Foto ${i+1}">
          <button class="btn-remove" data-remove-foto="${i}" title="Remover">×</button>
        </div>
      </div>`;
    }
    // 1 slot vazio para adicionar mais
    html += `<div class="foto-card">
      <label class="upload-foto">
        <span class="upload-placeholder">📷 + Foto</span>
        <input type="file" accept="image/*" capture="environment" class="upload-input" data-add-foto-${discId}>
        <div class="foto-overlay">Enviando...</div>
      </label>
    </div>`;
    wrap.innerHTML = html;
    cont.textContent = `${fotos.length} / ${FOTOS_MIN} mínimo`;
    cont.className = "contador-fotos " + (fotos.length >= FOTOS_MIN ? "ok" : "faltando");

    wrap.querySelector(`input[data-add-foto-${discId}]`)?.addEventListener("change", async (e) => {
      const file = e.target.files?.[0]; if (!file) return;
      const lbl = e.target.closest(".upload-foto");
      lbl.classList.add("uploading");
      try {
        const url = await uploadFoto(file, discId);
        preventiva.checklist.disciplinas[discId].fotos = [...(preventiva.checklist.disciplinas[discId].fotos || []), url];
        await patchPreventiva({ checklist: preventiva.checklist });
        renderFotosDisciplina(discId);
        atualizarBotaoAvancar(discId);
      } catch (err) {
        alert("Erro: " + err.message);
      } finally {
        lbl.classList.remove("uploading");
      }
    });
    wrap.querySelectorAll("[data-remove-foto]").forEach(btn => {
      btn.addEventListener("click", async () => {
        const i = parseInt(btn.dataset.removeFoto);
        if (!confirm("Remover esta foto?")) return;
        preventiva.checklist.disciplinas[discId].fotos.splice(i, 1);
        await patchPreventiva({ checklist: preventiva.checklist });
        renderFotosDisciplina(discId);
        atualizarBotaoAvancar(discId);
      });
    });
  }

  function atualizarBotaoAvancar(discId) {
    const btn = document.querySelector(`[data-avancar="${discId}"]`);
    if (btn) btn.disabled = !discCompleta(discId);
  }

  // ───────────────────────────────────────────────────────────────────
  // Salvar silencioso (debounce)
  // ───────────────────────────────────────────────────────────────────
  let saveTimer = null;
  function salvarSilencioso() {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(async () => {
      try { await patchPreventiva({ checklist: preventiva.checklist }); } catch {}
    }, 800);
  }

  // ───────────────────────────────────────────────────────────────────
  // Render: assinatura
  // ───────────────────────────────────────────────────────────────────
  let sigCanvas = null, sigCtx = null, sigPainting = false, sigEmpty = true;
  function setupAssinatura() {
    sigCanvas = document.getElementById("sigCanvas");
    if (!sigCanvas) return;
    // Reset
    const rect = sigCanvas.getBoundingClientRect();
    const ratio = window.devicePixelRatio || 1;
    sigCanvas.width  = rect.width  * ratio;
    sigCanvas.height = 220 * ratio;
    sigCtx = sigCanvas.getContext("2d");
    sigCtx.scale(ratio, ratio);
    sigCtx.strokeStyle = "#1a1a1a";
    sigCtx.lineWidth = 2.4;
    sigCtx.lineCap = "round";
    sigCtx.lineJoin = "round";
    sigEmpty = true;
    atualizarBotaoConcluir();

    function pos(e) {
      const r = sigCanvas.getBoundingClientRect();
      const t = e.touches?.[0] || e;
      return { x: t.clientX - r.left, y: t.clientY - r.top };
    }
    function start(e) { e.preventDefault(); sigPainting = true; sigEmpty = false; const p = pos(e); sigCtx.beginPath(); sigCtx.moveTo(p.x, p.y); }
    function move(e)  { if (!sigPainting) return; e.preventDefault(); const p = pos(e); sigCtx.lineTo(p.x, p.y); sigCtx.stroke(); }
    function end()    { sigPainting = false; atualizarBotaoConcluir(); }

    sigCanvas.addEventListener("mousedown", start);
    sigCanvas.addEventListener("mousemove", move);
    window.addEventListener("mouseup", end);
    sigCanvas.addEventListener("touchstart", start, { passive: false });
    sigCanvas.addEventListener("touchmove",  move,  { passive: false });
    sigCanvas.addEventListener("touchend",   end);

    document.getElementById("btnLimparAssinatura")?.addEventListener("click", () => {
      sigCtx.clearRect(0, 0, sigCanvas.width, sigCanvas.height);
      sigEmpty = true; atualizarBotaoConcluir();
    });

    // Restaurar campos
    document.getElementById("gerenteNome").value = preventiva.checklist?.gerente_nome || "";
    document.getElementById("gerenteCargo").value = preventiva.checklist?.gerente_cargo || "";
    document.getElementById("obsGerais").value = preventiva.checklist?.observacoes_gerais || "";

    document.getElementById("gerenteNome").addEventListener("input", atualizarBotaoConcluir);
  }

  function atualizarBotaoConcluir() {
    const nome = (document.getElementById("gerenteNome")?.value || "").trim();
    const temNome = nome.length >= 3;
    const temAssinatura = !sigEmpty;
    const btn = document.getElementById("btnConcluir");
    if (btn) btn.disabled = !(temNome && temAssinatura);
    const status = document.getElementById("sigStatus");
    if (status) {
      if (!temNome && !temAssinatura) status.textContent = "Preencha o nome e colete a assinatura.";
      else if (!temNome) status.textContent = "Informe o nome do gerente.";
      else if (!temAssinatura) status.textContent = "Colete a assinatura no quadro acima.";
      else status.textContent = "Pronto para concluir.";
    }
  }

  // ───────────────────────────────────────────────────────────────────
  // Render: concluído
  // ───────────────────────────────────────────────────────────────────
  function renderConcluido() {
    document.getElementById("hExecutada").textContent = "Executada em " + fmtDate(preventiva.data_executada, true);
    const ck = preventiva.checklist || {};
    let html = "";
    if (ck.foto_inicial_url) {
      html += `<div class="resumo-disc">
        <h4>📸 Foto inicial</h4>
        <img src="${ck.foto_inicial_url}" style="max-width:240px;border-radius:8px;margin-top:8px">
      </div>`;
    }
    DISCIPLINAS.forEach(d => {
      const data = ck.disciplinas?.[d.id];
      if (!data) return;
      const okCount = data.itens.filter(it => it.ok === true).length;
      const nokCount = data.itens.filter(it => it.ok === false).length;
      const naCount = data.itens.filter(it => it.ok === null).length;
      const fotosHtml = (data.fotos || []).map(u => `<img src="${u}" style="height:72px;border-radius:6px">`).join(" ");
      html += `<div class="resumo-disc">
        <h4>${d.icone} ${d.nome}</h4>
        <div class="resumo-stats">${okCount} OK · ${nokCount} falhas · ${naCount} N/A · ${(data.fotos||[]).length} fotos</div>
        <div style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap">${fotosHtml}</div>
        ${data.itens.filter(it => it.ok === false).map(it => `<div style="margin-top:8px;font-size:12.5px;padding:8px 12px;background:#FEF2F2;border-radius:6px"><strong>${it.label}:</strong> ${it.obs || "—"}</div>`).join("")}
      </div>`;
    });
    if (ck.gerente_assinatura_url) {
      html += `<div class="resumo-disc">
        <h4>✍️ Assinatura do gerente</h4>
        <div style="font-size:13px;color:var(--ink-mid)">${ck.gerente_nome || "—"}${ck.gerente_cargo ? " · " + ck.gerente_cargo : ""}</div>
        <img src="${ck.gerente_assinatura_url}" style="max-width:300px;background:#fff;border:1px solid var(--border);border-radius:6px;padding:6px;margin-top:8px">
      </div>`;
    }
    if (ck.observacoes_gerais) {
      html += `<div class="resumo-disc"><h4>📝 Observações gerais</h4><p style="font-size:13.5px;color:var(--ink-mid);white-space:pre-wrap">${ck.observacoes_gerais}</p></div>`;
    }
    document.getElementById("resumoFinal").innerHTML = html;
  }

  // ───────────────────────────────────────────────────────────────────
  // Render principal
  // ───────────────────────────────────────────────────────────────────
  function mostrarEtapa(etapa) {
    document.querySelectorAll(".etapa-card").forEach(el => el.style.display = "none");
    const el = document.getElementById("etapa-" + etapa);
    if (el) el.style.display = "";
  }

  function renderTudo() {
    renderHeader();

    const status = preventiva.status;
    if (status === "agendada") {
      document.getElementById("boxIniciar").style.display = "";
      document.getElementById("wizardWrap").style.display = "none";
      return;
    }
    document.getElementById("boxIniciar").style.display = "none";
    document.getElementById("wizardWrap").style.display = "";

    if (status === "concluida") {
      mostrarEtapa("concluido");
      renderConcluido();
      return;
    }

    const etapa = preventiva.checklist?.etapa_atual || "inicial";
    mostrarEtapa(etapa);

    if (etapa === "inicial") {
      renderEtapaInicial();
    } else if (["hidraulica","civil","eletrica"].includes(etapa)) {
      renderChecklistDisciplina(etapa);
      renderFotosDisciplina(etapa);
      document.getElementById("obs-" + etapa).value = preventiva.checklist.disciplinas[etapa].observacoes || "";
      document.getElementById("obs-" + etapa).addEventListener("input", (e) => {
        preventiva.checklist.disciplinas[etapa].observacoes = e.target.value;
        salvarSilencioso();
      });
      atualizarBotaoAvancar(etapa);
    } else if (etapa === "assinatura") {
      setupAssinatura();
    }
  }

  // ───────────────────────────────────────────────────────────────────
  // Event delegation para botões Avançar / Voltar / Iniciar / Concluir
  // ───────────────────────────────────────────────────────────────────
  document.addEventListener("click", async (e) => {
    const target = e.target.closest("button");
    if (!target) return;

    // Iniciar preventiva
    if (target.id === "btnIniciar") {
      target.disabled = true; target.textContent = "Iniciando...";
      try {
        await patchPreventiva({ action: "iniciar" });
        renderTudo();
      } catch (err) {
        alert("Erro: " + err.message);
        target.disabled = false; target.textContent = "▶ Iniciar preventiva";
      }
      return;
    }

    // Avançar etapa inicial
    if (target.id === "btnAvancarInicial") {
      await patchPreventiva({ checklist: { ...preventiva.checklist, etapa_atual: "hidraulica" } });
      renderTudo();
      return;
    }

    // Avançar disciplina
    if (target.dataset.avancar) {
      const discId = target.dataset.avancar;
      const idx = DISCIPLINAS.findIndex(d => d.id === discId);
      const proxima = idx < DISCIPLINAS.length - 1 ? DISCIPLINAS[idx + 1].id : "assinatura";
      await patchPreventiva({ checklist: { ...preventiva.checklist, etapa_atual: proxima } });
      renderTudo();
      return;
    }

    // Voltar disciplina
    if (target.dataset.voltar) {
      const discId = target.dataset.voltar;
      const idx = DISCIPLINAS.findIndex(d => d.id === discId);
      const anterior = idx > 0 ? DISCIPLINAS[idx - 1].id : "inicial";
      await patchPreventiva({ checklist: { ...preventiva.checklist, etapa_atual: anterior } });
      renderTudo();
      return;
    }

    // Concluir
    if (target.id === "btnConcluir") {
      const nome = document.getElementById("gerenteNome").value.trim();
      const cargo = document.getElementById("gerenteCargo").value.trim();
      const obsGerais = document.getElementById("obsGerais").value;
      if (nome.length < 3) return alert("Informe o nome do gerente.");
      if (sigEmpty) return alert("Colete a assinatura.");

      target.disabled = true; target.textContent = "Salvando assinatura...";
      try {
        const blob = await new Promise(res => sigCanvas.toBlob(res, "image/png"));
        const url = await uploadAssinaturaBlob(blob);
        const novoChecklist = {
          ...preventiva.checklist,
          gerente_nome: nome,
          gerente_cargo: cargo,
          gerente_assinatura_url: url,
          observacoes_gerais: obsGerais,
          etapa_atual: "concluido",
        };
        await patchPreventiva({ action: "concluir", checklist: novoChecklist });
        renderTudo();
      } catch (err) {
        alert("Erro: " + err.message);
        target.disabled = false; target.textContent = "✓ Concluir preventiva";
      }
    }
  });

  // ───────────────────────────────────────────────────────────────────
  // Load
  // ───────────────────────────────────────────────────────────────────
  async function load() {
    try {
      const res = await api(`/api/manut/tecnico/preventivas/${preventivaId}`);
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/tecnico/login"); return; }
      if (!res.ok) {
        const d = await res.json().catch(() => ({}));
        document.getElementById("loadingState").innerHTML = `<div class="empty-state"><strong>Erro</strong><p>${d.error || "Não foi possível carregar."}</p></div>`;
        return;
      }
      preventiva = await res.json();
      document.getElementById("loadingState").style.display = "none";
      document.getElementById("content").style.display = "";
      renderEtapasDisciplinas();
      renderTudo();
    } catch {
      document.getElementById("loadingState").innerHTML = '<div class="empty-state"><strong>Erro</strong><p>Recarregue a página.</p></div>';
    }
  }
  load();
</script>
