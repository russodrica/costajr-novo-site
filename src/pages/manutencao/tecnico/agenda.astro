---
import Portal from "~/layouts/Portal.astro";
export const prerender = false;
---
<Portal title="Agenda" tipo="tecnico" activePage="agenda">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px">
    <p style="margin:0;font-size:14px;color:#5B5F6B">Suas preventivas agendadas.</p>
    <div style="display:flex;align-items:center;gap:8px">
      <button class="btn btn-outline btn-sm" id="btnMesAnterior">‹ Mês anterior</button>
      <span id="labelMes" style="font-family:'Montserrat',sans-serif;font-weight:700;min-width:140px;text-align:center"></span>
      <button class="btn btn-outline btn-sm" id="btnProxMes">Próx. mês ›</button>
    </div>
  </div>

  <div id="loadingState" class="loading">Carregando agenda...</div>
  <div id="agendaWrap" style="display:none"></div>
</Portal>

<style>
  .prev-card { background:#fff;border:1px solid #E5E7EB;border-radius:10px;padding:20px 24px;margin-bottom:12px;display:flex;align-items:flex-start;gap:16px; }
  .prev-date { background:#C41E3A;color:#fff;border-radius:8px;padding:8px 12px;text-align:center;min-width:60px;flex-shrink:0; }
  .prev-date .dia { font-family:'Montserrat',sans-serif;font-weight:800;font-size:24px;line-height:1; }
  .prev-date .mes { font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin-top:2px; }
  .prev-body { flex:1; }
  .prev-title { font-family:'Montserrat',sans-serif;font-weight:700;font-size:15px;margin-bottom:4px; }
  .prev-sub { font-size:13px;color:#5B5F6B; }
  .prev-addr { font-size:12px;color:#9CA3AF;margin-top:4px; }
</style>

<script>
  const TOKEN_KEY = "manut_tecnico_token";
  const token = localStorage.getItem(TOKEN_KEY);
  if (!token) window.location.replace("/manutencao/tecnico/login");

  const meses = ["Janeiro","Fevereiro","Março","Abril","Maio","Junho","Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"];
  const mesesCurtos = ["jan","fev","mar","abr","mai","jun","jul","ago","set","out","nov","dez"];

  let hoje = new Date();
  let ano = hoje.getFullYear();
  let mes = hoje.getMonth(); // 0-based

  function fmtMes(m, a) { return meses[m] + " " + a; }

  function badge(status) {
    const m = { agendada:"badge-aberto", realizada:"badge-concluido", cancelada:"badge-cancelado" };
    const l = { agendada:"Agendada", realizada:"Realizada", cancelada:"Cancelada" };
    return `<span class="badge ${m[status] || ""}">${l[status] || status}</span>`;
  }

  async function load() {
    document.getElementById("loadingState").style.display = "";
    document.getElementById("agendaWrap").style.display = "none";
    document.getElementById("labelMes").textContent = fmtMes(mes, ano);

    const pad = n => String(n).padStart(2, "0");
    const mesStr = `${ano}-${pad(mes + 1)}`;

    try {
      const res = await fetch(`/api/manut/tecnico/agenda?mes=${mesStr}`, { headers: { "x-tecnico-auth": token } });
      if (res.status === 401) { localStorage.removeItem(TOKEN_KEY); window.location.replace("/manutencao/tecnico/login"); return; }
      const prev = await res.json();

      const wrap = document.getElementById("agendaWrap");
      document.getElementById("loadingState").style.display = "none";
      wrap.style.display = "";

      if (!prev.length) {
        wrap.innerHTML = '<div class="card" style="text-align:center;padding:40px;color:#9CA3AF">Nenhuma preventiva agendada para este mês.</div>';
        return;
      }

      wrap.innerHTML = prev.map(p => {
        const d = new Date(p.data_agendada + "T12:00:00");
        return `
          <div class="prev-card">
            <div class="prev-date">
              <div class="dia">${d.getDate()}</div>
              <div class="mes">${mesesCurtos[d.getMonth()]}</div>
            </div>
            <div class="prev-body">
              <div class="prev-title">${p.manut_lojas?.nome || "—"}</div>
              <div class="prev-sub">${p.manut_clientes?.nome || "—"} &nbsp; ${badge(p.status)}</div>
              <div class="prev-addr">${[p.manut_lojas?.endereco, p.manut_lojas?.cidade, p.manut_lojas?.uf].filter(Boolean).join(", ")}</div>
              ${p.observacoes ? `<div style="font-size:13px;color:#5B5F6B;margin-top:6px;font-style:italic">${p.observacoes}</div>` : ""}
            </div>
          </div>
        `;
      }).join("");
    } catch {
      document.getElementById("loadingState").textContent = "Erro ao carregar. Recarregue a página.";
    }
  }

  document.getElementById("btnMesAnterior").onclick = () => {
    mes--; if (mes < 0) { mes = 11; ano--; }
    load();
  };
  document.getElementById("btnProxMes").onclick = () => {
    mes++; if (mes > 11) { mes = 0; ano++; }
    load();
  };

  load();
</script>
