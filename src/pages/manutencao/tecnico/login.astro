---
export const prerender = false;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Login — Portal do Técnico — Costa Júnior</title>
  <meta name="theme-color" content="#C41E3A">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Open+Sans:wght@400;600&display=swap">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root { --brand: #C41E3A; --brand-dark: #A01828; --ink: #2D2F36; --border: #E5E7EB; }
    body { margin: 0; font-family: 'Open Sans', sans-serif; background: #1E2128; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .wrap { width: 100%; max-width: 400px; padding: 24px; }
    .login-logo { text-align: center; margin-bottom: 28px; }
    .logo-mark { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; width: 32px; height: 32px; margin: 0 auto 12px; }
    .logo-mark span:nth-child(1), .logo-mark span:nth-child(4) { background: #C41E3A; }
    .logo-mark span:nth-child(2), .logo-mark span:nth-child(3) { background: #4B5563; }
    .login-logo h1 { font-family: 'Montserrat', sans-serif; font-size: 20px; font-weight: 800; margin: 0 0 4px; color: #fff; }
    .login-logo p { font-size: 13px; color: #6B7280; margin: 0; }
    .card { background: #fff; border-radius: 12px; padding: 32px; }
    .card h2 { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 19px; margin: 0 0 22px; text-align: center; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
    .form-group input { width: 100%; padding: 11px 14px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 14px; font-family: 'Open Sans', sans-serif; outline: none; transition: border .15s; }
    .form-group input:focus { border-color: var(--brand); }
    .btn { width: 100%; padding: 13px; background: var(--brand); color: #fff; border: 0; border-radius: 8px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 14px; cursor: pointer; transition: background .15s; }
    .btn:hover { background: var(--brand-dark); }
    .btn:disabled { opacity: .6; cursor: not-allowed; }
    .alert { padding: 11px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 14px; background: #FEF2F2; color: #B91C1C; border: 1px solid #FECACA; }
    .link-back { display: block; text-align: center; font-size: 13px; color: #4B5563; margin-top: 20px; }
    .link-back:hover { color: #C41E3A; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="login-logo">
      <div class="logo-mark"><span></span><span></span><span></span><span></span></div>
      <h1>Costa Júnior</h1>
      <p>Portal do Técnico</p>
    </div>
    <div class="card">
      <h2>Acesso restrito</h2>
      <div id="alert" class="alert" style="display:none"></div>
      <form id="form">
        <div class="form-group">
          <label>E-mail</label>
          <input type="email" id="email" placeholder="tecnico@costajr.com.br" required autocomplete="email">
        </div>
        <div class="form-group">
          <label>Senha</label>
          <input type="password" id="senha" placeholder="••••••••" required autocomplete="current-password">
        </div>
        <button type="submit" class="btn" id="btn">Entrar</button>
      </form>
    </div>
    <a href="/" class="link-back">← Voltar ao site</a>
  </div>

  <script>
    const TOKEN_KEY = "manut_tecnico_token";
    if (localStorage.getItem(TOKEN_KEY)) window.location.replace("/manutencao/tecnico/dashboard");

    document.getElementById("form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const alert = document.getElementById("alert");
      const btn = document.getElementById("btn");
      alert.style.display = "none";
      btn.disabled = true; btn.textContent = "Entrando...";
      try {
        const res = await fetch("/api/manut/tecnico/login", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ email: document.getElementById("email").value.trim(), senha: document.getElementById("senha").value })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Credenciais inválidas");
        localStorage.setItem(TOKEN_KEY, data.token);
        localStorage.setItem(TOKEN_KEY + "_user", JSON.stringify(data.tecnico));
        window.location.replace("/manutencao/tecnico/dashboard");
      } catch (err) {
        alert.textContent = err.message; alert.style.display = "";
        btn.disabled = false; btn.textContent = "Entrar";
      }
    });
  </script>
</body>
</html>
