---
import Base from "~/layouts/Base.astro";
---
<Base
  title="Contato — Costa Júnior Engenharia e Construções"
  description="Solicite um orçamento ou tire dúvidas técnicas. Atendemos em todo o Brasil com sede em São Paulo. Resposta em até 1 dia útil."
>
  <section class="page-hero">
    <div class="container page-hero-content">
      <span class="hero-eyebrow">Fale com a engenharia</span>
      <h1>Conte sua obra. <span class="hl">Devolvemos com solução</span>.</h1>
      <p class="page-hero-sub">
        Atendemos demanda de loja única a redes nacionais. Resposta em até 1 dia útil. Para emergências de manutenção, ligue diretamente.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contato-grid">
      <!-- COLUNA ESQUERDA — DADOS -->
      <aside class="contato-info">
        <span class="kicker">Canais oficiais</span>
        <h2 style="margin-bottom:24px">Como nos encontrar</h2>

        <div class="info-block">
          <h3>E-mail</h3>
          <p>
            <a href="mailto:contato@costajr.com.br">contato@costajr.com.br</a>
          </p>
        </div>

        <div class="info-block">
          <h3>WhatsApp</h3>
          <p>
            <a href="https://wa.me/551123696462" target="_blank" rel="noopener" class="wa-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Chamar no WhatsApp
            </a>
          </p>
        </div>

        <div class="info-block">
          <h3>Horário</h3>
          <p>Segunda a sexta · 08h às 18h<br>Plantão de manutenção 24/7 para clientes contratados</p>
        </div>
      </aside>

      <!-- COLUNA DIREITA — FORM -->
      <form id="contato-form" class="contato-form" novalidate>
        <span class="kicker">Solicite orçamento</span>
        <h2 style="margin-bottom:24px">Conte sobre seu projeto</h2>

        <label>
          <span>Nome completo *</span>
          <input type="text" name="nome" required>
        </label>

        <div class="form-row">
          <label>
            <span>Empresa</span>
            <input type="text" name="empresa">
          </label>
          <label>
            <span>Cargo</span>
            <input type="text" name="cargo">
          </label>
        </div>

        <div class="form-row">
          <label>
            <span>E-mail *</span>
            <input type="email" name="email" required>
          </label>
          <label>
            <span>Telefone *</span>
            <input type="tel" name="telefone" required>
          </label>
        </div>

        <label>
          <span>Tipo de demanda *</span>
          <select name="tipo" required>
            <option value="">Selecione…</option>
            <option value="construcao">Construção / Reforma</option>
            <option value="manutencao">Manutenção predial</option>
            <option value="fundacao">Fundação / Contenção</option>
            <option value="projeto">Projeto / Consultoria</option>
            <option value="fiscalizacao">Fiscalização técnica</option>
            <option value="outro">Outro</option>
          </select>
        </label>

        <label>
          <span>Localização da obra (cidade / UF)</span>
          <input type="text" name="localizacao" placeholder="Ex.: São Paulo / SP">
        </label>

        <label>
          <span>Descreva sua demanda *</span>
          <textarea name="mensagem" rows="5" required placeholder="Conte sobre prazos, escopo, particularidades técnicas…"></textarea>
        </label>

        <label class="checkbox">
          <input type="checkbox" name="lgpd" required>
          <span>Concordo com o tratamento dos meus dados conforme a <a href="/privacidade">Política de Privacidade</a>.</span>
        </label>

        <button type="submit" class="btn btn-primary" style="margin-top:8px">
          Enviar mensagem
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
        </button>

        <p id="form-status" class="form-status" hidden></p>
      </form>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById("contato-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status") as HTMLParagraphElement | null;
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  if (form && status && btn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = "Enviando…";
      const data = new FormData(form);
      try {
        const res = await fetch("/api/contato", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            nome: data.get("nome"),
            empresa: data.get("empresa") || "",
            cargo: data.get("cargo") || "",
            email: data.get("email"),
            telefone: data.get("telefone"),
            tipo: data.get("tipo"),
            localizacao: data.get("localizacao") || "",
            mensagem: data.get("mensagem"),
          }),
        });
        if (res.ok) {
          form.reset();
          status.hidden = false;
          status.style.background = "rgba(34,197,94,.12)";
          status.style.color = "#15803d";
          status.textContent = "✅ Mensagem enviada! Retornaremos em até 1 dia útil.";
        } else {
          throw new Error("erro");
        }
      } catch {
        status.hidden = false;
        status.style.background = "rgba(196,30,58,.08)";
        status.style.color = "var(--brand)";
        status.textContent = "Erro ao enviar. Por favor escreva diretamente para comercial@costajr.com.br.";
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Enviar mensagem <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>';
      }
    });
  }
</script>

<style>
  .page-hero {
    position: relative;
    background:
      radial-gradient(circle at 78% 30%, rgba(196,30,58,.45) 0%, transparent 55%),
      linear-gradient(135deg, #1A1C20 0%, #2D2F36 60%, #3A1419 100%);
    color: #fff; overflow: hidden;
  }
  .page-hero-content { position: relative; padding: 96px 0 80px; max-width: 820px; }
  .hero-eyebrow {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand);
    border-left: 3px solid var(--brand); padding-left: 12px; margin-bottom: 24px;
  }
  .page-hero h1 { color: #fff; margin: 0 0 20px; }
  .page-hero h1 .hl { color: var(--brand); }
  .page-hero-sub { font-size: clamp(16px, 1.4vw, 18px); line-height: 1.7; color: #E5E7EB; max-width: 680px; margin: 0; }
  .kicker {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;
  }

  .contato-grid {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 56px;
    align-items: flex-start;
  }
  .contato-info .info-block { margin-bottom: 28px; }
  .contato-info h3 {
    font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--brand); margin: 0 0 8px;
    font-family: 'Montserrat', sans-serif; font-weight: 700;
  }
  .contato-info p { color: var(--ink-mid); font-size: 15px; line-height: 1.75; margin: 0; }
  .contato-info a { color: var(--ink); border-bottom: 1px solid var(--border); }
  .contato-info a:hover { color: var(--brand); border-color: var(--brand); }
  .wa-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: #25D366 !important; border-color: transparent !important;
    font-weight: 600;
  }
  .wa-link:hover { color: #128C7E !important; }

  .contato-form {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 40px; display: grid; gap: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,.04);
  }
  .contato-form label { display: grid; gap: 6px; }
  .contato-form label > span {
    font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 13px;
    color: var(--ink); letter-spacing: 0.02em;
  }
  .contato-form input,
  .contato-form select,
  .contato-form textarea {
    font-family: 'Open Sans', sans-serif;
    font-size: 15px; padding: 12px 14px;
    border: 1px solid var(--border); border-radius: 6px;
    background: #fff; color: var(--ink);
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .contato-form input:focus,
  .contato-form select:focus,
  .contato-form textarea:focus {
    outline: 0; border-color: var(--brand);
    box-shadow: 0 0 0 3px rgba(196,30,58,.12);
  }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .checkbox { display: flex; gap: 10px; align-items: flex-start; font-size: 13px; color: var(--ink-mid); }
  .checkbox input { width: 16px; height: 16px; margin-top: 3px; }
  .checkbox a { color: var(--brand); border-bottom: 1px solid var(--brand-soft); }
  .form-status {
    margin: 12px 0 0; padding: 12px 14px;
    background: var(--brand-soft); color: var(--brand);
    border-radius: 6px; font-size: 14px;
  }

  @media (max-width: 900px) {
    .page-hero-content { padding: 64px 0 56px; }
    .contato-grid { grid-template-columns: 1fr; gap: 40px; }
    .contato-form { padding: 28px; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
