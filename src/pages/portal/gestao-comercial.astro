---
export const prerender = false;
import Portal from "~/layouts/Portal.astro";
---
<Portal title="Gestão Comercial" tipo="colaborador" activePage="comercial">
  <div class="section-header">
    <h2>Gestão Comercial</h2>
    <button class="gc-btn" onclick="abrirNovoLead()">+ Novo lead</button>
  </div>

  <div id="loading" class="loading"><div class="spinner"></div> Carregando funil...</div>
  <div id="sem-permissao" style="display:none"></div>

  <div id="content" style="display:none">
    <!-- Indicadores -->
    <div class="gc-stats">
      <div class="gc-stat"><div class="gc-stat-v" id="st-funil">—</div><div class="gc-stat-l">No funil</div></div>
      <div class="gc-stat"><div class="gc-stat-v" id="st-valor" style="color:#16A34A">—</div><div class="gc-stat-l">Valor potencial</div></div>
      <div class="gc-stat"><div class="gc-stat-v" id="st-novos" style="color:#1D4ED8">—</div><div class="gc-stat-l">Novos no mês</div></div>
      <div class="gc-stat"><div class="gc-stat-v" id="st-conv" style="color:#16A34A">—</div><div class="gc-stat-l">Convertidos no mês</div></div>
      <div class="gc-stat"><div class="gc-stat-v" id="st-taxa">—</div><div class="gc-stat-l">Taxa de conversão</div></div>
      <div class="gc-stat"><div class="gc-stat-v" id="st-atrasados" style="color:#B91C1C">—</div><div class="gc-stat-l">Contatos atrasados</div></div>
      <div class="gc-stat"><div class="gc-stat-v" id="st-semcontato" style="color:#D97706">—</div><div class="gc-stat-l">Sem contato +15 dias</div></div>
    </div>

    <!-- Rankings (30 dias) -->
    <div class="gc-ranks">
      <div class="gc-rank"><div class="gc-rank-t">🏆 Ranking de interações (30d)</div><div id="rank-inter"></div></div>
      <div class="gc-rank"><div class="gc-rank-t">🥇 Ranking de cadastros (30d)</div><div id="rank-cad"></div></div>
    </div>

    <!-- Kanban -->
    <div class="gc-kanban" id="kanban"></div>
  </div>

  <!-- Modal lead (novo/editar) -->
  <div class="gc-overlay" id="modalLead">
    <div class="gc-modal">
      <h3 id="modalLeadTitulo">Novo lead</h3>
      <div id="msgLead"></div>
      <form id="formLead">
        <input type="hidden" name="id" />
        <div class="gc-row">
          <div class="gc-field"><label>Nome *</label><input name="nome" required /></div>
          <div class="gc-field"><label>Empresa / Loja</label><input name="nome_loja" /></div>
        </div>
        <div class="gc-row">
          <div class="gc-field"><label>E-mail</label><input name="email" type="email" /></div>
          <div class="gc-field"><label>Telefone</label><input name="telefone" /></div>
        </div>
        <div class="gc-row">
          <div class="gc-field"><label>Etapa</label>
            <select name="etapa">
              <option value="novo">Novo</option>
              <option value="contato_feito">Contato feito</option>
              <option value="proposta_enviada">Proposta enviada</option>
              <option value="negociando">Negociando</option>
              <option value="convertido">Convertido</option>
              <option value="perdido">Perdido</option>
            </select>
          </div>
          <div class="gc-field"><label>Origem</label><input name="origem" placeholder="Indicação, site, ligação..." /></div>
        </div>
        <div class="gc-row">
          <div class="gc-field"><label>Tipo de cliente</label>
            <select name="tipo_cliente">
              <option value="">—</option>
              <option>Varejo</option>
              <option>Hospital</option>
              <option>Galpão</option>
              <option>Indústria</option>
              <option>Condomínio</option>
              <option>Outro</option>
            </select>
          </div>
          <div class="gc-field"><label>Registrar contato agora</label><div style="display:flex;gap:6px;flex-wrap:wrap"><button type="button" class="gc-btn sec" onclick="registrarContato(&quot;whatsapp&quot;)">💬 WhatsApp</button><button type="button" class="gc-btn sec" onclick="registrarContato(&quot;ligacao&quot;)">📞 Ligação</button><button type="button" class="gc-btn sec" onclick="registrarContato(&quot;email&quot;)">✉️ E-mail</button><button type="button" class="gc-btn sec" onclick="registrarContato(&quot;visita&quot;)">🏢 Visita</button></div></div>
        </div>
        <div class="gc-row">
          <div class="gc-field"><label>Plano / serviço</label><input name="plano" /></div>
          <div class="gc-field"><label>Valor (R$)</label><input name="valor" type="number" step="0.01" min="0" /></div>
        </div>
        <div class="gc-row">
          <div class="gc-field"><label>Responsável</label><input name="responsavel" /></div>
          <div class="gc-field"><label>Próximo contato</label><input name="proximo_contato" type="date" /></div>
        </div>
        <div class="gc-field"><label>Observações</label><textarea name="observacoes" rows="3"></textarea></div>
        <div class="gc-acoes">
          <button type="button" class="gc-btn sec" onclick="fecharModalLead()">Cancelar</button>
          <button type="submit" class="gc-btn">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .gc-btn { background: var(--brand); color: #fff; border: 0; border-radius: 8px; padding: 9px 18px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Open Sans', sans-serif; transition: .15s; }
    .gc-btn:hover { opacity: .88; }
    .gc-btn.sec { background: #F3F4F6; color: #374151; border: 1px solid #D1D5DB; }
    .gc-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; margin-bottom: 20px; }
    .gc-stat { background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 14px 16px; }
    .gc-stat-v { font-family: 'Montserrat', sans-serif; font-size: 22px; font-weight: 800; color: var(--ink); }
    .gc-stat-l { font-size: 11.5px; color: var(--ink-mid); margin-top: 2px; }

    .gc-ranks { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
    @media (max-width: 700px) { .gc-ranks { grid-template-columns: 1fr; } }
    .gc-rank { background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 14px 16px; }
    .gc-rank-t { font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 800; margin-bottom: 10px; }
    .gc-rank-linha { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; font-size: 12.5px; }
    .gc-rank-nome { width: 130px; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .gc-rank-bar { flex: 1; background: #F2F4F8; border-radius: 99px; height: 14px; overflow: hidden; }
    .gc-rank-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg, #C41E3A, #E04860); }
    .gc-rank-v { width: 90px; text-align: right; color: var(--ink-mid); font-size: 11px; }
    .gc-kanban { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 16px; align-items: flex-start; }
    .gc-col { min-width: 250px; width: 250px; background: #F2F4F8; border-radius: 12px; flex: none; }
    .gc-col-head { padding: 10px 14px; font-family: 'Montserrat', sans-serif; font-size: 12px; font-weight: 800; color: #fff; border-radius: 12px 12px 0 0; display: flex; justify-content: space-between; align-items: center; }
    .gc-col-head .soma { font-size: 10.5px; font-weight: 600; opacity: .9; }
    .gc-col-body { padding: 8px; min-height: 80px; display: flex; flex-direction: column; gap: 8px; }
    .gc-col-body.dragover { background: rgba(196,30,58,.06); border-radius: 0 0 12px 12px; }
    .gc-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 10px 12px; cursor: grab; box-shadow: 0 1px 3px rgba(16,24,40,.06); transition: .15s; }
    .gc-card:hover { box-shadow: 0 4px 12px rgba(16,24,40,.1); border-color: var(--brand); }
    .gc-card.arrastando { opacity: .5; }
    .gc-card h4 { font-size: 13px; font-weight: 800; margin: 0 0 2px; color: var(--ink); font-family: 'Montserrat', sans-serif; }
    .gc-card .loja { font-size: 11.5px; color: var(--ink-mid); }
    .gc-card .valor { font-size: 12.5px; font-weight: 700; color: #16A34A; margin-top: 4px; }
    .gc-card .meta { font-size: 10.5px; color: var(--ink-light); margin-top: 4px; display: flex; gap: 8px; flex-wrap: wrap; }
    .gc-card .atrasado { color: #B91C1C; font-weight: 700; }
    .gc-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 1000; display: none; align-items: center; justify-content: center; padding: 16px; }
    .gc-overlay.open { display: flex; }
    .gc-modal { background: #fff; border-radius: 14px; padding: 24px; max-width: 560px; width: 100%; max-height: 92vh; overflow-y: auto; }
    .gc-modal h3 { font-family: 'Montserrat', sans-serif; margin: 0 0 16px; }
    .gc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .gc-field { margin-bottom: 12px; }
    .gc-field label { display: block; font-size: 12px; font-weight: 700; color: #555; margin-bottom: 4px; }
    .gc-field input, .gc-field select, .gc-field textarea { width: 100%; padding: 9px 12px; border: 1.5px solid #D1D5DB; border-radius: 8px; font-size: 13.5px; font-family: 'Open Sans', sans-serif; outline: none; box-sizing: border-box; }
    .gc-field input:focus, .gc-field select:focus, .gc-field textarea:focus { border-color: var(--brand); }
    .gc-acoes { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .gc-erro { background: #FEE2E2; color: #991B1B; border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-bottom: 12px; }
    @media (max-width: 640px) { .gc-row { grid-template-columns: 1fr; } }
  </style>

  <script>
    const token = localStorage.getItem("portal_colab_token");
    if (!token) { window.location.replace("/portal/login"); throw 0; }
    const H = { "x-portal-auth": token!, "content-type": "application/json" };

    const ETAPAS = [
      { id: "novo", titulo: "Novo", cor: "#3B82F6" },
      { id: "contato_feito", titulo: "Contato feito", cor: "#D9A406" },
      { id: "proposta_enviada", titulo: "Proposta enviada", cor: "#EA7317" },
      { id: "negociando", titulo: "Negociando", cor: "#7C3AED" },
      { id: "convertido", titulo: "Convertido", cor: "#16A34A" },
      { id: "perdido", titulo: "Perdido", cor: "#6B7280" },
    ];
    let leads: any[] = [];
    let interacoes: any[] = [];

    function esc(s: any) { return String(s ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;"); }
    function brl(v: any) { return v == null ? "" : Number(v).toLocaleString("pt-BR", { style: "currency", currency: "BRL" }); }
    function diasDesde(d: string) { return Math.floor((Date.now() - new Date(d).getTime()) / 864e5); }
    function diasSemContato(l: any) { const ref = l.ultima_interacao_em || l.updated_at || l.created_at; return ref ? diasDesde(ref) : 999; }

    async function carregar() {
      const res = await fetch("/api/portal/comercial/leads", { headers: { "x-portal-auth": token! } });
      document.getElementById("loading")!.style.display = "none";
      if (res.status === 403) {
        document.getElementById("sem-permissao")!.style.display = "";
        document.getElementById("sem-permissao")!.innerHTML = `<div class="gc-erro">Esta área é exclusiva para o time comercial. Fale com o administrador se precisar de acesso.</div>`;
        return;
      }
      if (!res.ok) {
        document.getElementById("sem-permissao")!.style.display = "";
        document.getElementById("sem-permissao")!.innerHTML = `<div class="gc-erro">Erro ao carregar os leads. Atualize a página.</div>`;
        return;
      }
      leads = await res.json();
      try { const ri = await fetch("/api/portal/comercial/interacoes?dias=30", { headers: { "x-portal-auth": token! } }); interacoes = ri.ok ? await ri.json() : []; } catch { interacoes = []; }
      document.getElementById("content")!.style.display = "";
      render();
    }

    function render() {
      const mes = new Date().toISOString().slice(0, 7);
      const hoje = new Date().toISOString().slice(0, 10);
      const noFunil = leads.filter(l => !["convertido", "perdido"].includes(l.etapa));
      const valorFunil = noFunil.reduce((s, l) => s + (Number(l.valor) || 0), 0);
      const novosMes = leads.filter(l => (l.created_at || "").slice(0, 7) === mes).length;
      const convMes = leads.filter(l => l.etapa === "convertido" && (l.updated_at || "").slice(0, 7) === mes).length;
      const convTotal = leads.filter(l => l.etapa === "convertido").length;
      const taxa = leads.length ? Math.round((convTotal / leads.length) * 100) : 0;
      const atrasados = noFunil.filter(l => l.proximo_contato && l.proximo_contato < hoje).length;
      (document.getElementById("st-funil") as HTMLElement).textContent = String(noFunil.length);
      (document.getElementById("st-valor") as HTMLElement).textContent = valorFunil ? brl(valorFunil) : "R$ 0";
      (document.getElementById("st-novos") as HTMLElement).textContent = String(novosMes);
      (document.getElementById("st-conv") as HTMLElement).textContent = String(convMes);
      (document.getElementById("st-taxa") as HTMLElement).textContent = taxa + "%";
      (document.getElementById("st-atrasados") as HTMLElement).textContent = String(atrasados);
      const semContato15 = noFunil.filter(l => diasSemContato(l) > 15).length;
      (document.getElementById("st-semcontato") as HTMLElement).textContent = String(semContato15);

      // rankings 30 dias
      const porVend: Record<string, Record<string, number>> = {};
      for (const i of interacoes) { const v = String(i.vendedor || "—").split("@")[0]; porVend[v] = porVend[v] || {}; porVend[v][i.tipo] = (porVend[v][i.tipo] || 0) + 1; }
      const rankI = Object.entries(porVend).map(([v, tipos]) => ({ v, total: Object.values(tipos).reduce((a, b) => a + b, 0), tipos })).sort((a, b) => b.total - a.total).slice(0, 5);
      const maxI = Math.max(1, ...rankI.map(r => r.total));
      const ICONE_TIPO: Record<string, string> = { whatsapp: "💬", ligacao: "📞", email: "✉️", visita: "🏢", outro: "•" };
      const MEDALHAS = ["🥇", "🥈", "🥉", "4º", "5º"];
      document.getElementById("rank-inter")!.innerHTML = rankI.length ? rankI.map((r, idx) =>
        `<div class="gc-rank-linha"><span>${MEDALHAS[idx]}</span><span class="gc-rank-nome">${esc(r.v)}</span>` +
        `<div class="gc-rank-bar"><div class="gc-rank-fill" style="width:${(r.total / maxI) * 100}%"></div></div>` +
        `<span class="gc-rank-v"><strong>${r.total}</strong> ${Object.entries(r.tipos).map(([t2, n]) => (ICONE_TIPO[t2] || "") + n).join(" ")}</span></div>`
      ).join("") : '<div style="font-size:12px;color:#9CA3AF">Nenhuma interação registrada nos últimos 30 dias. Use os botões 💬📞✉️🏢 no card do lead.</div>';
      const desde30 = new Date(Date.now() - 30 * 864e5).toISOString();
      const cad: Record<string, number> = {};
      for (const l of leads) if ((l.created_at || "") >= desde30) { const v = String(l.responsavel || "—").split("@")[0]; cad[v] = (cad[v] || 0) + 1; }
      const rankC = Object.entries(cad).map(([v, n]) => ({ v, n })).sort((a, b) => b.n - a.n).slice(0, 5);
      const maxC = Math.max(1, ...rankC.map(r => r.n));
      document.getElementById("rank-cad")!.innerHTML = rankC.length ? rankC.map((r, idx) =>
        `<div class="gc-rank-linha"><span>${MEDALHAS[idx]}</span><span class="gc-rank-nome">${esc(r.v)}</span>` +
        `<div class="gc-rank-bar"><div class="gc-rank-fill" style="width:${(r.n / maxC) * 100}%;background:linear-gradient(90deg,#16A34A,#22C55E)"></div></div>` +
        `<span class="gc-rank-v"><strong>${r.n}</strong> cadastros</span></div>`
      ).join("") : '<div style="font-size:12px;color:#9CA3AF">Nenhum cadastro nos últimos 30 dias.</div>';

      const kb = document.getElementById("kanban")!;
      kb.innerHTML = ETAPAS.map(e => {
        const itens = leads.filter(l => l.etapa === e.id);
        const soma = itens.reduce((s, l) => s + (Number(l.valor) || 0), 0);
        const cards = itens.map(l => `
          <div class="gc-card" draggable="true" data-id="${l.id}" onclick="editarLead('${l.id}')">
            <h4>${esc(l.nome)}</h4>
            ${l.nome_loja ? `<div class="loja">${esc(l.nome_loja)}</div>` : ""}
            ${l.valor != null ? `<div class="valor">${brl(l.valor)}${l.plano ? ` · ${esc(l.plano)}` : ""}</div>` : (l.plano ? `<div class="loja">${esc(l.plano)}</div>` : "")}
            <div class="meta">
              ${l.tipo_cliente ? `<span>🏢 ${esc(l.tipo_cliente)}</span>` : ""}
              ${l.responsavel ? `<span>👤 ${esc(String(l.responsavel).split("@")[0])}</span>` : ""}
              ${(() => { const d = diasSemContato(l); return d > 15 && !["convertido","perdido"].includes(l.etapa) ? `<span class="${d > 30 ? "atrasado" : ""}" style="${d <= 30 ? "color:#D97706;font-weight:700" : ""}">⏰ ${d}d sem contato</span>` : ""; })()}
              ${l.proximo_contato ? `<span class="${l.proximo_contato < hoje ? "atrasado" : ""}">📞 ${l.proximo_contato.slice(8, 10)}/${l.proximo_contato.slice(5, 7)}${l.proximo_contato < hoje ? " atrasado" : ""}</span>` : ""}
              <span>há ${diasDesde(l.created_at)}d</span>
            </div>
          </div>`).join("");
        return `
          <div class="gc-col">
            <div class="gc-col-head" style="background:${e.cor}">
              <span>${e.titulo} (${itens.length})</span>
              <span class="soma">${soma ? brl(soma) : ""}</span>
            </div>
            <div class="gc-col-body" data-etapa="${e.id}">${cards}</div>
          </div>`;
      }).join("");

      kb.querySelectorAll(".gc-card").forEach(card => {
        card.addEventListener("dragstart", (ev: any) => { ev.dataTransfer.setData("text/plain", (card as HTMLElement).dataset.id!); card.classList.add("arrastando"); });
        card.addEventListener("dragend", () => card.classList.remove("arrastando"));
      });
      kb.querySelectorAll(".gc-col-body").forEach(col => {
        col.addEventListener("dragover", (ev) => { ev.preventDefault(); col.classList.add("dragover"); });
        col.addEventListener("dragleave", () => col.classList.remove("dragover"));
        col.addEventListener("drop", async (ev: any) => {
          ev.preventDefault();
          col.classList.remove("dragover");
          const id = ev.dataTransfer.getData("text/plain");
          const etapa = (col as HTMLElement).dataset.etapa!;
          const lead = leads.find(l => l.id === id);
          if (!lead || lead.etapa === etapa) return;
          const anterior = lead.etapa;
          lead.etapa = etapa;
          render();
          const res = await fetch(`/api/portal/comercial/leads?id=${id}`, { method: "PATCH", headers: H, body: JSON.stringify({ etapa }) });
          if (!res.ok) { lead.etapa = anterior; render(); alert("Erro ao mover o lead."); }
        });
      });
    }

    function abrirNovoLead() {
      const f = document.getElementById("formLead") as HTMLFormElement;
      f.reset();
      (f.querySelector("[name=id]") as HTMLInputElement).value = "";
      document.getElementById("modalLeadTitulo")!.textContent = "Novo lead";
      document.getElementById("msgLead")!.innerHTML = "";
      document.getElementById("modalLead")!.classList.add("open");
    }
    function editarLead(id: string) {
      const l = leads.find(x => x.id === id);
      if (!l) return;
      const f = document.getElementById("formLead") as HTMLFormElement;
      f.reset();
      for (const [k, v] of Object.entries(l)) {
        const input = f.querySelector(`[name="${k}"]`) as HTMLInputElement | null;
        if (input && v != null) input.value = k === "proximo_contato" ? String(v).slice(0, 10) : String(v);
      }
      document.getElementById("modalLeadTitulo")!.textContent = "Editar lead";
      document.getElementById("msgLead")!.innerHTML = "";
      document.getElementById("modalLead")!.classList.add("open");
    }
    function fecharModalLead() { document.getElementById("modalLead")!.classList.remove("open"); }
    async function registrarContato(tipo) {
      const f = document.getElementById("formLead") as HTMLFormElement;
      const id = (f.querySelector("[name=id]") as HTMLInputElement).value;
      if (!id) { alert("Salve o lead primeiro."); return; }
      const res = await fetch("/api/portal/comercial/interacoes", { method: "POST", headers: H, body: JSON.stringify({ lead_id: id, tipo }) });
      if (res.ok) { fecharModalLead(); carregar(); } else alert("Erro ao registrar contato.");
    }

    document.getElementById("formLead")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const body: Record<string, any> = Object.fromEntries(new FormData(f).entries());
      const id = body.id; delete body.id;
      if (body.valor) body.valor = Number(body.valor);
      const res = id
        ? await fetch(`/api/portal/comercial/leads?id=${id}`, { method: "PATCH", headers: H, body: JSON.stringify(body) })
        : await fetch("/api/portal/comercial/leads", { method: "POST", headers: H, body: JSON.stringify(body) });
      const d = await res.json().catch(() => ({}));
      if (res.ok) { fecharModalLead(); carregar(); }
      else document.getElementById("msgLead")!.innerHTML = `<div class="gc-erro">${esc(d.error || "Erro ao salvar")}</div>`;
    });

    (window as any).abrirNovoLead = abrirNovoLead;
    (window as any).editarLead = editarLead;
    (window as any).fecharModalLead = fecharModalLead;
    (window as any).registrarContato = registrarContato;
    carregar();
  </script>
</Portal>
