---
export const prerender = false;
import Portal from "~/layouts/Portal.astro";
---
<Portal title="Gestão de Manutenção" tipo="colaborador" activePage="gestao">
  <div class="section-header">
    <h2>Gestão de Manutenção</h2>
    <a href="/admin" class="btn btn-outline btn-sm">Painel admin completo →</a>
  </div>

  <div id="loading" class="loading"><div class="spinner"></div> Carregando dados...</div>
  <div id="content" style="display:none">

    <div class="stats-grid" style="margin-bottom:24px">
      <div class="stat-card accent">
        <div class="stat-label">Clientes Ativos</div>
        <div class="stat-value" id="stat-clientes">—</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Chamados Abertos</div>
        <div class="stat-value" id="stat-chamados">—</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Preventivas (mês)</div>
        <div class="stat-value" id="stat-prev">—</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Técnicos Ativos</div>
        <div class="stat-value" id="stat-tec">—</div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
      <div class="card">
        <h2 style="margin:0 0 16px;font-size:15px">Chamados recentes</h2>
        <div id="chamados-list"></div>
        <a href="/admin/chamados" style="display:block;text-align:center;margin-top:14px;font-size:13px;font-weight:700;color:var(--brand)">Ver todos →</a>
      </div>
      <div class="card">
        <h2 style="margin:0 0 16px;font-size:15px">Próximas preventivas</h2>
        <div id="prev-list"></div>
        <a href="/admin/preventivas" style="display:block;text-align:center;margin-top:14px;font-size:13px;font-weight:700;color:var(--brand)">Ver todas →</a>
      </div>
    </div>
  </div>

  <style>
    .item-row { border-bottom:1px solid var(--border-light); padding:10px 0; font-size:13px; }
    .item-row:last-child { border-bottom:0; }
    .item-row strong { display:block; color:var(--ink); }
    .item-row span { color:var(--ink-light); font-size:12px; }
    @media (max-width:700px) {
      div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns:1fr !important; }
    }
  </style>

  <script>
    const token = localStorage.getItem("portal_colab_token");
    if (!token) { window.location.replace("/portal/login"); throw 0; }
    const userData = JSON.parse(localStorage.getItem("portal_colab_token_user") || "{}");
    const role = userData.role || "";
    if (!["admin","operacional","manutencao_operacao","manutencao_administrativo"].includes(role)) {
      document.getElementById("loading")!.innerHTML = '<div class="empty-state"><strong>Acesso restrito</strong><p>Esta área é exclusiva para a equipe de operações.</p></div>';
    } else { loadData(); }

    async function loadData() {
      try {
        const adminToken = localStorage.getItem("manut_portal_token") || "";
        const authH = adminToken || token!;
        const hKey  = adminToken ? "x-portal-auth" : "x-portal-auth";

        const [clRes, chRes, prRes, tcRes] = await Promise.all([
          fetch("/api/admin/clientes/index", { headers: { "x-portal-auth": authH } }).catch(()=>null),
          fetch("/api/admin/chamados/index", { headers: { "x-portal-auth": authH } }).catch(()=>null),
          fetch("/api/admin/preventivas/index", { headers: { "x-portal-auth": authH } }).catch(()=>null),
          fetch("/api/admin/tecnicos/index", { headers: { "x-portal-auth": authH } }).catch(()=>null),
        ]);

        document.getElementById("loading")!.style.display = "none";
        document.getElementById("content")!.style.display = "";

        const parse = async (r: Response|null) => r?.ok ? r.json() : [];
        const [clientes, chamados, preventivas, tecnicos] = await Promise.all([parse(clRes), parse(chRes), parse(prRes), parse(tcRes)]);

        document.getElementById("stat-clientes")!.textContent = String((clientes||[]).filter((c:any)=>c.status==="ativo").length);
        document.getElementById("stat-chamados")!.textContent = String((chamados||[]).filter((c:any)=>c.status==="aberto").length);
        document.getElementById("stat-tec")!.textContent      = String((tecnicos||[]).filter((t:any)=>t.status==="ativo").length);

        const mes = new Date().getMonth(); const ano = new Date().getFullYear();
        const prevMes = (preventivas||[]).filter((p:any) => {
          const d = new Date(p.data_agendada); return d.getMonth()===mes && d.getFullYear()===ano;
        });
        document.getElementById("stat-prev")!.textContent = String(prevMes.length);

        document.getElementById("chamados-list")!.innerHTML = (chamados||[]).slice(0,5).map((c:any)=>`
          <div class="item-row">
            <strong>${c.tipo} — ${c.descricao?.slice(0,40)||""}</strong>
            <span><span class="badge badge-${c.status}">${c.status}</span> · ${new Date(c.data_abertura).toLocaleDateString("pt-BR")}</span>
          </div>`).join("") || "<p style='font-size:13px;color:var(--ink-light)'>Nenhum chamado aberto.</p>";

        document.getElementById("prev-list")!.innerHTML = prevMes.slice(0,5).map((p:any)=>`
          <div class="item-row">
            <strong>Preventiva agendada</strong>
            <span>${new Date(p.data_agendada).toLocaleDateString("pt-BR",{day:"2-digit",month:"short"})} · <span class="badge badge-${p.status}">${p.status}</span></span>
          </div>`).join("") || "<p style='font-size:13px;color:var(--ink-light)'>Nenhuma preventiva este mês.</p>";

      } catch(e) {
        document.getElementById("loading")!.innerHTML = `<div class="empty-state"><strong>Erro ao carregar</strong><p>Verifique suas permissões ou tente novamente.</p></div>`;
      }
    }
  </script>
</Portal>
