---
export const prerender = false;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Portal do Colaborador — Costa Júnior</title>
  <meta name="robots" content="noindex">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;500;600&display=swap">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root { --brand: #C41E3A; --brand-dark: #A01828; }
    html, body { margin: 0; padding: 0; height: 100%; }
    body {
      font-family: 'Open Sans', sans-serif;
      background: linear-gradient(135deg, #1A1C20 0%, #2D2F36 60%, #3A1419 100%);
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh; padding: 20px;
    }
    .login-card {
      background: #fff; border-radius: 16px;
      padding: 48px 40px; width: 100%; max-width: 420px;
      box-shadow: 0 24px 64px rgba(0,0,0,.4);
    }
    .logo-wrap { text-align: center; margin-bottom: 32px; }
    .logo-wrap img { height: 40px; }
    .logo-wrap p {
      margin: 10px 0 0;
      font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.15em; color: #9CA3AF;
    }
    h1 { font-family: 'Montserrat', sans-serif; font-size: 22px; font-weight: 800; margin: 0 0 6px; color: #1E2128; }
    .sub { font-size: 14px; color: #6B7280; margin: 0 0 28px; }
    label { display: block; font-size: 12.5px; font-weight: 600; color: #374151; margin-bottom: 5px; }
    input {
      width: 100%; padding: 11px 14px; border: 1.5px solid #E5E7EB;
      border-radius: 9px; font-size: 14px; font-family: 'Open Sans', sans-serif;
      color: #1E2128; outline: none; transition: border .15s, box-shadow .15s;
    }
    input:focus { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(196,30,58,.1); }
    .field { margin-bottom: 18px; }
    .btn {
      width: 100%; padding: 12px; border-radius: 9px; border: 0; cursor: pointer;
      background: var(--brand); color: #fff;
      font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 14px;
      letter-spacing: 0.03em; transition: all .18s; margin-top: 8px;
    }
    .btn:hover:not(:disabled) { background: var(--brand-dark); transform: translateY(-1px); box-shadow: 0 6px 16px rgba(196,30,58,.35); }
    .btn:disabled { opacity: .6; cursor: not-allowed; }
    .error { background: #FEF2F2; color: #B91C1C; border: 1px solid #FECACA; border-radius: 8px; padding: 11px 14px; font-size: 13px; margin-bottom: 16px; display: none; }
    .error.show { display: block; }
    .back { text-align: center; margin-top: 20px; font-size: 13px; color: #9CA3AF; }
    .back a { color: var(--brand); font-weight: 600; }
    .link-forgot { display: block; text-align: center; margin-top: 16px; font-size: 13px; color: #6B7280; cursor: pointer; }
    .link-forgot:hover { color: var(--brand); }
    .ok { background: #DCFCE7; color: #166534; border: 1px solid #BBF7D0; border-radius: 8px; padding: 11px 14px; font-size: 13px; margin-bottom: 16px; display: none; }
    .ok.show { display: block; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo-wrap">
      <img src="/logo-cjr.png" alt="Costa Júnior">
      <p>Portal do Colaborador</p>
    </div>
    <h1>Acesso interno</h1>
    <p class="sub">Use o e-mail e senha fornecidos pelo RH.</p>

    <div class="error" id="erro"></div>

    <form id="formLogin">
      <div class="field">
        <label for="email">E-mail</label>
        <input type="email" id="email" name="email" placeholder="seu@costajr.com.br" required autocomplete="username">
      </div>
      <div class="field">
        <label for="senha">Senha</label>
        <input type="password" id="senha" name="senha" placeholder="Sua senha" required autocomplete="current-password">
      </div>
      <button class="btn" type="submit" id="btnEntrar">Entrar no portal</button>
    </form>
    <span class="link-forgot" id="showReset">Esqueci minha senha</span>

    <!-- RESET SENHA -->
    <div id="resetSection" style="display:none;margin-top:18px;border-top:1px solid #E5E7EB;padding-top:18px">
      <p class="sub" style="margin-bottom:14px">Informe seu e-mail. Enviaremos uma senha temporária.</p>
      <div class="error" id="resetErro"></div>
      <div class="ok" id="resetOk"></div>
      <div class="field">
        <label for="resetEmail">E-mail</label>
        <input type="email" id="resetEmail" placeholder="seu@costajr.com.br">
      </div>
      <button class="btn" type="button" id="btnReset">Enviar senha temporária</button>
      <span class="link-forgot" id="showLogin">Voltar para o login</span>
    </div>

    <p class="back"><a href="/">← Voltar ao site</a></p>
  </div>

  <script>
    const form = document.getElementById("formLogin") as HTMLFormElement;
    const btn  = document.getElementById("btnEntrar") as HTMLButtonElement;
    const erro = document.getElementById("erro") as HTMLDivElement;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      erro.classList.remove("show");
      btn.disabled = true;
      btn.textContent = "Entrando...";

      const email = (document.getElementById("email") as HTMLInputElement).value.trim();
      const senha = (document.getElementById("senha") as HTMLInputElement).value;

      try {
        const res = await fetch("/api/portal/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, senha }),
        });
        const data = await res.json();
        if (!res.ok) {
          erro.textContent = data.error || "Erro ao fazer login.";
          erro.classList.add("show");
          return;
        }
        localStorage.setItem("portal_colab_token", data.token);
        localStorage.setItem("portal_colab_token_user", JSON.stringify(data.user));
        window.location.replace("/portal");
      } catch {
        erro.textContent = "Erro de conexão. Tente novamente.";
        erro.classList.add("show");
      } finally {
        btn.disabled = false;
        btn.textContent = "Entrar no portal";
      }
    });

    // ─── Esqueci minha senha (reaproveita /api/admin/forgot-senha) ──────
    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    $("showReset").addEventListener("click", () => {
      form.style.display = "none"; $("resetSection").style.display = "block";
      ($("resetEmail") as HTMLInputElement).value = ($("email") as HTMLInputElement).value || "";
    });
    $("showLogin").addEventListener("click", () => {
      $("resetSection").style.display = "none"; form.style.display = "";
    });
    $("btnReset").addEventListener("click", async () => {
      const rb = $("btnReset") as HTMLButtonElement;
      const rErro = $("resetErro"); const rOk = $("resetOk");
      rErro.classList.remove("show"); rOk.classList.remove("show");
      const email = ($("resetEmail") as HTMLInputElement).value.trim();
      if (!email) { rErro.textContent = "Informe o e-mail."; rErro.classList.add("show"); return; }
      rb.disabled = true; rb.textContent = "Enviando...";
      try {
        const res = await fetch("/api/admin/forgot-senha", {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok) {
          rOk.textContent = data.message || "Se o e-mail estiver cadastrado, enviaremos uma senha temporária.";
          rOk.classList.add("show");
        } else {
          rErro.textContent = data.error || "Não foi possível processar."; rErro.classList.add("show");
        }
      } catch {
        rErro.textContent = "Erro de conexão. Tente novamente."; rErro.classList.add("show");
      } finally {
        rb.disabled = false; rb.textContent = "Enviar senha temporária";
      }
    });
  </script>
</body>
</html>
