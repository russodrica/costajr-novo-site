---
export const prerender = false;
import Portal from "~/layouts/Portal.astro";
---
<Portal title="Meu RH" tipo="colaborador" activePage="meu-rh" subtitle="Seus documentos, férias e EPIs — autoatendimento" accent="#0EA5E9">
  <div id="loading" class="loading"><div class="spinner"></div> Carregando seus dados...</div>
  <div id="semvinculo" style="display:none"></div>
  <div id="conteudo" style="display:none">
    <div class="mrh-grid">
      <!-- Dados pessoais -->
      <div class="card mrh-dados">
        <h2>🪪 Meus dados</h2>
        <div id="dados"></div>
      </div>
      <!-- Férias -->
      <div class="card">
        <h2>🏖️ Minhas férias</h2>
        <div id="ferias"></div>
      </div>
    </div>
    <!-- Documentos -->
    <div class="card" style="margin-top:18px">
      <h2>📄 Meus documentos</h2>
      <div id="docs"></div>
    </div>
    <!-- EPIs -->
    <div class="card" style="margin-top:18px">
      <h2>🦺 Meus EPIs</h2>
      <div id="epis"></div>
    </div>
  </div>

  <style>
    .mrh-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    @media (max-width: 760px) { .mrh-grid { grid-template-columns: 1fr; } }
    .card h2 { font-family:'Montserrat',sans-serif; font-weight:800; font-size:16px; margin:0 0 16px; color:var(--ink); }
    .mrh-linha { display:flex; justify-content:space-between; gap:12px; padding:8px 0; border-bottom:1px solid var(--border-light); font-size:13.5px; }
    .mrh-linha:last-child { border-bottom:0; }
    .mrh-linha .rot { color:var(--ink-light); font-weight:600; }
    .mrh-linha .val { color:var(--ink); text-align:right; }
    .mrh-item { display:flex; align-items:center; gap:12px; padding:11px 0; border-bottom:1px solid var(--border-light); }
    .mrh-item:last-child { border-bottom:0; }
    .mrh-item .ic { font-size:22px; flex:none; }
    .mrh-item .corpo { flex:1; min-width:0; }
    .mrh-item .corpo strong { display:block; font-size:13.5px; color:var(--ink); }
    .mrh-item .corpo span { font-size:12px; color:var(--ink-light); }
    .mrh-badge { font-size:11px; font-weight:700; padding:2px 9px; border-radius:99px; white-space:nowrap; }
    .b-ok { background:#F0FDF4; color:#15803D; } .b-aviso { background:#FFFBEB; color:#B45309; } .b-venc { background:#FEF2F2; color:#B91C1C; } .b-cinza { background:#F3F4F6; color:#6B7280; }
    .mrh-vazio { color:var(--ink-light); font-size:13px; text-align:center; padding:14px 0; }
    .mrh-down { background:#fff; border:1.5px solid var(--border); border-radius:8px; padding:5px 12px; font-size:12px; font-weight:700; cursor:pointer; color:var(--brand); font-family:'Montserrat',sans-serif; flex:none; }
    .mrh-down:hover { border-color:var(--brand); background:var(--brand-light); }
  </style>

  <script>
    const token = localStorage.getItem("portal_colab_token");
    if (!token) { window.location.replace("/portal/login"); throw 0; }
    const H = { "x-portal-auth": token! };
    const hoje = new Date().toISOString().slice(0, 10);
    const br = (d: string) => d ? d.split("-").reverse().join("/") : "—";
    const esc = (s: any) => String(s ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

    function badgeValidade(v: string | null, na: boolean) {
      if (na) return '<span class="mrh-badge b-cinza">sem validade</span>';
      if (!v) return '<span class="mrh-badge b-cinza">—</span>';
      const cls = v < hoje ? "b-venc" : (v < new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10) ? "b-aviso" : "b-ok");
      return `<span class="mrh-badge ${cls}">${v < hoje ? "vencido " : "vence "}${br(v)}</span>`;
    }

    async function baixarDoc(id: string) {
      try {
        const r = await fetch(`/api/portal/meu-rh/documento/${id}`, { headers: H });
        const d = await r.json();
        if (d.url) window.open(d.url, "_blank", "noopener");
        else alert(d.error || "Arquivo indisponível.");
      } catch { alert("Erro ao abrir o documento."); }
    }
    (window as any).baixarDoc = baixarDoc;

    function render(d: any) {
      // Dados
      const c = d.colaborador;
      const linhas: [string, string][] = [
        ["Nome", c.nome], ["Cargo", c.cargo || "—"], ["Regime", (c.regime || "—").toUpperCase()],
        ["Admissão", br(c.data_admissao)], ["E-mail", c.email || "—"], ["Telefone", c.telefone || c.telefone_pessoal || "—"],
        ["Cidade/UF", [c.cidade, c.uf].filter(Boolean).join(" / ") || "—"],
      ];
      document.getElementById("dados")!.innerHTML = linhas.map(([r, v]) => `<div class="mrh-linha"><span class="rot">${r}</span><span class="val">${esc(v)}</span></div>`).join("");

      // Férias
      const fEl = document.getElementById("ferias")!;
      if (!d.ferias.length) fEl.innerHTML = '<p class="mrh-vazio">Nenhum período de férias programado.</p>';
      else fEl.innerHTML = d.ferias.map((p: any) => {
        const parc = (p.parcelas || []).map((x: any) => `<div class="mrh-linha"><span class="rot">${x.dias} dias a partir de ${br(x.data_inicio)}</span><span class="val"><span class="mrh-badge ${x.status === "confirmada" || x.status === "gozada" ? "b-ok" : "b-aviso"}">${esc(x.status)}</span></span></div>`).join("") || '<p class="mrh-vazio">Sem parcelas programadas.</p>';
        return `<div style="margin-bottom:14px"><div style="font-size:12px;color:var(--ink-light);font-weight:700;margin-bottom:4px">Período aquisitivo ${br(p.inicio_aquisitivo)} a ${br(p.fim_aquisitivo)} · limite ${br(p.limite_concessivo)}</div>${parc}</div>`;
      }).join("");

      // Documentos
      const docsEl = document.getElementById("docs")!;
      if (!d.documentos.length) docsEl.innerHTML = '<p class="mrh-vazio">Nenhum documento anexado pelo RH.</p>';
      else docsEl.innerHTML = d.documentos.map((doc: any) => `
        <div class="mrh-item">
          <span class="ic">📄</span>
          <div class="corpo"><strong>${esc(doc.titulo)}</strong><span>${esc(doc.tipo || "documento")}</span></div>
          ${badgeValidade(doc.validade, doc.validade_na)}
          ${(doc.storage_path || doc.url) ? `<button class="mrh-down" onclick="baixarDoc('${doc.id}')">Abrir</button>` : ""}
        </div>`).join("");

      // EPIs
      const episEl = document.getElementById("epis")!;
      if (!d.epis.length) episEl.innerHTML = '<p class="mrh-vazio">Nenhum EPI registrado.</p>';
      else episEl.innerHTML = d.epis.map((e: any) => `
        <div class="mrh-item">
          <span class="ic">🦺</span>
          <div class="corpo"><strong>${esc(e.epi)}</strong><span>${e.ca && e.ca !== "NA" ? "CA " + esc(e.ca) : "sem CA"}${e.tamanho ? " · tam. " + esc(e.tamanho) : ""}${e.data_entrega ? " · entregue " + br(e.data_entrega) : ""}</span></div>
          ${badgeValidade(e.data_validade, false)}
        </div>`).join("");

      document.getElementById("loading")!.style.display = "none";
      document.getElementById("conteudo")!.style.display = "";
    }

    fetch("/api/portal/meu-rh", { headers: H })
      .then(r => r.ok ? r.json() : Promise.reject())
      .then(d => {
        document.getElementById("loading")!.style.display = "none";
        if (!d.vinculado) {
          document.getElementById("semvinculo")!.style.display = "";
          document.getElementById("semvinculo")!.innerHTML = '<div class="card"><div class="empty-state"><strong>Sem ficha de RH vinculada</strong><p>Seu login ainda não está ligado a um cadastro no RH. Fale com o RH/DP para vincular.</p></div></div>';
          return;
        }
        render(d);
      })
      .catch(() => { document.getElementById("loading")!.innerHTML = "Erro ao carregar seus dados. Tente novamente."; });
  </script>
</Portal>
