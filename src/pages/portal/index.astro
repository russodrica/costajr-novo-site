---
export const prerender = false;
import Portal from "~/layouts/Portal.astro";
---
<Portal title="Início" tipo="colaborador" activePage="home">
  <div id="hub-loading" class="loading">
    <div class="spinner"></div> Carregando portal...
  </div>

  <div id="hub-content" style="display:none">
    <div id="welcome-banner">
      <div class="wb-text">
        <p class="wb-eyebrow">Portal do Colaborador</p>
        <h2 class="wb-title">Olá, <span id="welcomeName">colaborador</span>! 👋</h2>
        <p class="wb-sub">Que bom te ver por aqui. Escolha um atalho abaixo para começar.</p>
      </div>
      <div class="wb-role">
        <p class="wb-role-label">Seu acesso</p>
        <p id="welcomeRole" class="wb-role-value">—</p>
      </div>
    </div>

    <!-- Atalhos / módulos -->
    <p class="secao-titulo">Seus atalhos</p>
    <div id="modules-grid"></div>

    <!-- Comunicados -->
    <p class="secao-titulo" style="margin-top:34px">📢 Comunicados</p>
    <div class="card avisos-card">
      <div id="avisos-list"><div class="loading"><div class="spinner"></div></div></div>
    </div>
  </div>

  <style is:global>
    /* ─── Banner de boas-vindas ─── */
    #welcome-banner {
      background: linear-gradient(135deg, #1A1C20 0%, #2D2F36 55%, #3A1419 100%);
      border-radius: 18px; padding: 34px 38px; color: #fff; margin-bottom: 30px;
      display: flex; align-items: center; justify-content: space-between; gap: 24px;
    }
    .wb-eyebrow { font-size: 13px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; color: #FC8181; margin: 0 0 10px; }
    .wb-title { font-family: 'Montserrat', sans-serif; font-size: 32px; font-weight: 800; margin: 0 0 10px; color: #fff; line-height: 1.1; }
    .wb-sub { margin: 0; color: #D1D5DB; font-size: 17px; }
    .wb-role { text-align: right; flex-shrink: 0; }
    .wb-role-label { margin: 0; font-size: 12px; color: #9CA3AF; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; }
    .wb-role-value { margin: 6px 0 0; font-family: 'Montserrat', sans-serif; font-size: 20px; font-weight: 800; color: #FC8181; }

    .secao-titulo {
      font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 19px;
      color: var(--ink); margin: 0 0 16px;
    }

    /* ─── Cards de módulo (atalhos) ─── */
    #modules-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px,1fr)); gap: 18px; }
    .module-card {
      background: #fff; border: 1.5px solid var(--border); border-radius: 18px;
      padding: 26px 24px; cursor: pointer; text-decoration: none; color: inherit;
      display: flex; align-items: center; gap: 18px;
      transition: all .2s ease; position: relative; overflow: hidden;
    }
    .module-card:hover { transform: translateY(-3px); box-shadow: 0 14px 34px rgba(0,0,0,.12); border-color: rgba(196,30,58,.3); }
    .module-icon {
      width: 62px; height: 62px; border-radius: 16px; flex-shrink: 0;
      background: var(--brand-light); color: var(--brand);
      display: flex; align-items: center; justify-content: center; font-size: 30px;
    }
    .module-icon img { width: 50px; height: 50px; object-fit: contain; }
    .module-body { min-width: 0; }
    .module-card h3 {
      font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 800;
      margin: 0 0 4px; color: var(--ink); display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .module-card p { font-size: 14.5px; color: var(--ink-mid); margin: 0; line-height: 1.45; }
    .mod-tag {
      font-family: 'Open Sans', sans-serif; font-size: 11px; font-weight: 700;
      background: var(--brand); color: #fff; border-radius: 100px; padding: 2px 9px;
      text-transform: none; letter-spacing: 0;
    }
    /* Destaque do JunIA (substitui a base de conhecimento) */
    .module-card.destaque { border-color: rgba(196,30,58,.4); background: linear-gradient(135deg,#fff 60%,#FFF5F6); }
    .module-card.destaque .module-icon { background: var(--brand); color: #fff; }

    /* ─── Comunicados ─── */
    .avisos-card { padding: 22px 26px; }
    .aviso-item { display: flex; align-items: baseline; gap: 14px; border-bottom: 1px solid var(--border-light); padding: 14px 0; }
    .aviso-item:first-child { padding-top: 0; }
    .aviso-item:last-child { border-bottom: 0; padding-bottom: 0; }
    .aviso-item strong { font-size: 16px; font-weight: 700; color: var(--ink); flex: 1; }
    .aviso-item .aviso-data { font-size: 13px; color: var(--ink-light); white-space: nowrap; flex-shrink: 0; }
    .avisos-vazio { color: var(--ink-light); font-size: 15px; margin: 6px 0; text-align: center; padding: 18px 0; }

    @media (max-width: 640px) {
      #welcome-banner { flex-direction: column; align-items: flex-start; padding: 26px 24px; }
      .wb-role { text-align: left; }
      .wb-title { font-size: 27px; }
      #modules-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    const token = localStorage.getItem("portal_colab_token");
    if (!token) { window.location.replace("/portal/login"); throw 0; }

    const userData = JSON.parse(localStorage.getItem("portal_colab_token_user") || "{}");
    const nome = userData.nome || userData.email || "colaborador";
    document.getElementById("welcomeName")!.textContent = nome.split(" ")[0];

    const ROTULO: Record<string, string> = {
      admin: "Administrador", manutencao_operacao: "Manutenção - Operação",
      manutencao_administrativo: "Manutenção - Administrativo", operacional: "Operação",
      rh: "RH / DP", financeiro: "Financeiro", comercial: "Comercial", juridico: "Jurídico",
    };
    const AREAS_BASICAS = ["onboarding", "treinamentos", "forum", "documentos", "meus-equipamentos"];

    // Módulos liberados por ÁREA (bate com a matriz de /admin/permissoes). area:null = sempre.
    const modules = [
      { icon: '<img src="/junia-mascote.png" alt="JunIA" style="width:50px;height:50px;object-fit:contain">', title: "JunIA", desc: "Pergunte aqui — a inteligência da Costa Júnior responde na hora", href: "/portal/junia", area: null, destaque: true },
      { icon: "✅", title: "Onboarding", desc: "Sua integração e boas-vindas", href: "/portal/onboarding", area: "onboarding" },
      { icon: "🎬", title: "Treinamentos", desc: "Vídeos e materiais do seu setor", href: "/portal/treinamentos", area: "treinamentos" },
      { icon: "💬", title: "Fórum", desc: "Troca de ideias com a equipe", href: "/portal/forum", area: "forum" },
      { icon: "📄", title: "Documentos", desc: "Manuais e procedimentos técnicos", href: "/portal/documentos", area: "documentos" },
      { icon: "🎒", title: "Meus Equipamentos", desc: "Equipamentos sob sua responsabilidade", href: "/portal/meus-equipamentos", area: "meus-equipamentos" },
      { icon: "💰", title: "Gest. Comercial", desc: "Leads, contratos e metas", href: "/portal/gestao-comercial", area: "comercial" },
      { icon: "🔧", title: "Gest. Manutenção", desc: "Clientes, chamados e técnicos", href: "/portal/gestao-manutencao", area: "gestao" },
      { icon: "🙍", title: "Minha Conta", desc: "Editar nome e trocar senha", href: "/portal/minha-conta", area: null },
    ];

    function renderHub(areas: string[], role: string) {
      document.getElementById("welcomeRole")!.textContent = ROTULO[role] || role || "—";
      const grid = document.getElementById("modules-grid")!;
      grid.innerHTML = "";
      modules.forEach((m: any) => {
        if (m.area && !areas.includes(m.area)) return;
        const a = document.createElement("a");
        a.className = "module-card" + (m.destaque ? " destaque" : "");
        a.href = m.href;
        a.innerHTML = `
          <div class="module-icon">${m.icon}</div>
          <div class="module-body">
            <h3>${m.title}${m.destaque ? '<span class="mod-tag">💬 chat</span>' : ""}</h3>
            <p>${m.desc}</p>
          </div>`;
        grid.appendChild(a);
      });
      document.getElementById("hub-loading")!.style.display = "none";
      document.getElementById("hub-content")!.style.display = "";
    }

    // Busca perfis/áreas FRESCOS do servidor (refletem mudança de perfil sem relogar).
    fetch("/api/portal/permissoes", { headers: { "x-portal-auth": token } })
      .then(r => r.ok ? r.json() : Promise.reject())
      .then(d => renderHub(d.areas?.length ? d.areas : AREAS_BASICAS, d.role || userData.role))
      .catch(() => {
        // fallback: deriva as áreas dos perfis salvos no localStorage
        const roles = (userData.roles && userData.roles.length ? userData.roles : [userData.role]).filter(Boolean);
        const areas = [...AREAS_BASICAS];
        if (roles.some((r: string) => ["admin", "comercial"].includes(r))) areas.push("comercial");
        if (roles.some((r: string) => ["admin", "operacional", "manutencao_operacao", "manutencao_administrativo"].includes(r))) areas.push("gestao");
        renderHub(areas, userData.role || "operacional");
      });

    // Comunicados
    fetch("/api/portal/comunicados", { headers: { "x-portal-auth": token } })
      .then(r => r.ok ? r.json() : [])
      .then((items: any[]) => {
        const el = document.getElementById("avisos-list")!;
        if (!items.length) { el.innerHTML = '<p class="avisos-vazio">Nenhum comunicado no momento. 🙂</p>'; return; }
        el.innerHTML = items.slice(0, 6).map((a: any) => `
          <div class="aviso-item">
            <strong>${a.title}</strong>
            <span class="aviso-data">${new Date(a.created_at).toLocaleDateString("pt-BR")}</span>
          </div>`).join("");
      }).catch(() => { document.getElementById("avisos-list")!.innerHTML = '<p class="avisos-vazio">Erro ao carregar.</p>'; });
  </script>
</Portal>
