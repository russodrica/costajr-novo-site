---
import Base from "~/layouts/Base.astro";

const grupos = [
  {
    titulo: "Projeto e Consultoria",
    desc: "Da viabilidade técnica ao projeto executivo — engenharia que antecipa problemas em vez de empurrá-los para a obra.",
    itens: [
      "Consultoria de Fundações",
      "Consultoria de Contenções",
      "Estabilidade de Taludes",
      "Levantamentos topográficos e cadastrais",
      "Projetos de Arquitetura",
      "Projetos Complementares (estrutura, hidráulica, elétrica)",
    ],
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
  },
  {
    titulo: "Execução e Construção",
    desc: "Obras corporativas, comerciais, industriais e de saúde — do pequeno ao grande porte, em todos os 26 estados.",
    itens: [
      "Construção e Reforma — Varejo",
      "Construção e Reforma — Corporativo",
      "Construção e Reforma — Indústria",
      "Construção e Reforma — Condomínios",
      "Galpões logísticos e centros de distribuição",
      "Retrofit e adequações operacionais",
    ],
    icon: "M3 21h18M5 21V7l8-4 8 4v14M9 9h1M9 13h1M9 17h1M14 9h1M14 13h1M14 17h1",
  },
  {
    titulo: "Fiscalização técnica",
    desc: "Olhos da engenharia na sua obra, mesmo quando a execução é de outra construtora.",
    itens: [
      "Fiscalização Full Time",
      "Fiscalização Periódica",
      "Vistoria Pontual",
      "Relatórios Técnicos",
      "Auditoria de medições",
      "Recebimento de obra",
    ],
    icon: "M21 21l-4.35-4.35M11 19a8 8 0 1 1 0-16 8 8 0 0 1 0 16z",
  },
  {
    titulo: "Manutenção predial",
    desc: "Plataforma digital, técnico vinculado e contratos sob medida — preventiva e corretiva sem dor de cabeça.",
    itens: [
      "Manutenção Preventiva",
      "Manutenção Corretiva",
      "Contratos mensais e anuais",
      "Atendimento sob demanda",
      "Plataforma com chamados e checklist",
      "Assinatura via Mercado Pago",
    ],
    icon: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z",
  },
  {
    titulo: "Fundação",
    desc: "Mais de 15 anos de consultoria de solos antes de virar construtora — fundação é o nosso DNA.",
    itens: [
      "Hélice Contínua",
      "Strauss",
      "Estaca Raiz",
      "Estaca Pré-Moldada",
      "Estaca Escavada",
      "Tubulões e Sapatas",
      "Hollow Auger",
      "Pareceres técnicos de fundação",
    ],
    icon: "M12 2v20M5 12h14M3 19h18M3 5h18",
  },
  {
    titulo: "Contenção",
    desc: "Soluções para terrenos difíceis, taludes e divisas urbanas exigentes.",
    itens: [
      "Perfis Metálicos",
      "Estacas Justapostas",
      "Solo Grampeado",
      "Sisbat",
      "Gabiões",
      "Parede Diafragma",
    ],
    icon: "M3 12l9-9 9 9M5 10v10h14V10",
  },
];
---
<Base
  title="Serviços — Costa Júnior Engenharia e Construções"
  description="Projeto, consultoria, execução, fiscalização, manutenção, fundação e contenção. Engenharia integrada para obras corporativas, comerciais e industriais."
>
  <section class="page-hero">
    <div class="container page-hero-content">
      <span class="hero-eyebrow">O que fazemos</span>
      <h1>Engenharia <span class="hl">integrada</span> — do projeto à manutenção.</h1>
      <p class="page-hero-sub">
        Projeto, execução, fiscalização e manutenção em um único parceiro. Reduzimos interfaces, riscos e custos para empresas que precisam de obras entregues com prazo, custo e qualidade.
      </p>
      <div style="margin-top:32px;display:flex;gap:12px;flex-wrap:wrap">
        <a href="/contato" class="btn btn-primary">Solicite um orçamento
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
        </a>
        <a href="/manutencao/contratar" class="btn btn-ghost-light">Contratar manutenção</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grupos-grid">
        {grupos.map(g => (
          <article class="grupo-card">
            <div class="grupo-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={`<path d="${g.icon}"/>`}></svg>
            </div>
            <h3>{g.titulo}</h3>
            <p>{g.desc}</p>
            <ul>
              {g.itens.map(i => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{i}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <div class="cta-final">
        <div>
          <span class="kicker" style="color:#fff;opacity:.85">Próximo passo</span>
          <h2 style="color:#fff;margin-bottom:16px">Conte sua obra. Devolvemos com solução.</h2>
          <p style="color:#D1D5DB;font-size:18px;margin:0 0 28px;max-width:520px">
            Atendemos demanda de loja única a redes nacionais. Resposta em até 1 dia útil.
          </p>
          <a href="/contato" class="btn btn-primary">Solicitar orçamento
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    position: relative;
    background:
      radial-gradient(circle at 78% 30%, rgba(196,30,58,.45) 0%, transparent 55%),
      linear-gradient(135deg, #1A1C20 0%, #2D2F36 60%, #3A1419 100%);
    color: #fff;
    overflow: hidden;
  }
  .page-hero::before {
    content: "";
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 56px 56px;
    pointer-events: none;
  }
  .page-hero-content {
    position: relative;
    padding: 96px 0 80px;
    max-width: 820px;
  }
  .hero-eyebrow {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--brand);
    border-left: 3px solid var(--brand); padding-left: 12px;
    margin-bottom: 24px;
  }
  .page-hero h1 { color: #fff; margin: 0 0 20px; }
  .page-hero h1 .hl { color: var(--brand); }
  .page-hero-sub {
    font-size: clamp(16px, 1.4vw, 18px); line-height: 1.7;
    color: #E5E7EB; max-width: 680px; margin: 0;
  }
  .kicker {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 16px;
  }

  .grupos-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }
  .grupo-card {
    background: #fff; border: 1px solid var(--border); border-radius: 12px;
    padding: 36px 32px;
    transition: all .2s ease;
    position: relative; overflow: hidden;
  }
  .grupo-card::before {
    content: ""; position: absolute; top: 0; left: 0; height: 3px; width: 0;
    background: var(--brand); transition: width .25s ease;
  }
  .grupo-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,.08);
    border-color: var(--brand-soft);
  }
  .grupo-card:hover::before { width: 100%; }
  .grupo-icon {
    width: 56px; height: 56px; border-radius: 10px;
    background: var(--brand-soft); color: var(--brand);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px;
  }
  .grupo-card h3 { margin: 0 0 8px; }
  .grupo-card > p { color: var(--ink-mid); font-size: 14px; line-height: 1.65; margin: 0 0 20px; }
  .grupo-card ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
  .grupo-card li {
    display: flex; gap: 10px; align-items: flex-start;
    font-size: 14px; color: var(--ink-mid);
  }
  .grupo-card li svg { flex: none; margin-top: 4px; }

  .cta-final {
    background: linear-gradient(135deg, #1F2126 0%, #2D2F36 100%);
    border-radius: 16px;
    padding: 56px 64px;
    position: relative; overflow: hidden;
  }
  .cta-final::before {
    content: ""; position: absolute; top: -30%; right: -15%;
    width: 500px; height: 500px; border-radius: 50%;
    background: radial-gradient(circle, rgba(196,30,58,.25) 0%, transparent 65%);
    pointer-events: none;
  }
  .cta-final > * { position: relative; }

  @media (max-width: 900px) {
    .page-hero-content { padding: 64px 0 56px; }
    .cta-final { padding: 40px 28px; }
  }
</style>
