---
// Layout compartilhado para o Portal do Representante (/manutencao/representante/*).
// Auth é feita 100% client-side (token no localStorage como em /manutencao/cliente/*).
export interface Props {
  title: string;
  current: "dashboard" | "perfil" | "materiais";
}
const { title, current } = Astro.props as Props;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{title} — Portal do Representante — Costa Júnior</title>
  <meta name="theme-color" content="#C41E3A">
  <meta name="robots" content="noindex,nofollow">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;500;600&display=swap">
  <style is:global>
    *,*::before,*::after{box-sizing:border-box}
    :root{--brand:#C41E3A;--brand-dark:#A01828;--ink:#2D2F36;--ink-mid:#5B5F6B;--border:#E5E7EB;--bg:#F4F6F9;--ok:#166534;--warn:#92400E;--err:#B91C1C}
    body{margin:0;font-family:'Open Sans',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh}
    .shell{display:grid;grid-template-columns:240px 1fr;min-height:100vh}
    .sidebar{background:#FFF;border-right:1px solid var(--border);padding:24px 0;position:sticky;top:0;height:100vh;overflow-y:auto}
    .sidebar-brand{display:flex;flex-direction:column;align-items:center;padding:0 20px 18px;border-bottom:1px solid var(--border);margin-bottom:18px}
    .sidebar-brand img{width:140px;height:auto}
    .sidebar-brand .label{margin-top:6px;font-size:11.5px;color:var(--ink-mid);text-align:center;font-weight:600;letter-spacing:0.04em}
    .sidebar-brand .badge{margin-top:6px;background:linear-gradient(135deg,#FEF3C7 0%,#FDE68A 100%);color:#92400E;padding:3px 10px;border-radius:99px;font-size:10px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase}
    .sidebar nav{padding:0 12px;display:flex;flex-direction:column;gap:2px}
    .sidebar nav a{display:flex;align-items:center;gap:10px;padding:11px 14px;border-radius:8px;color:var(--ink-mid);text-decoration:none;font-size:14px;font-weight:600;transition:all .15s}
    .sidebar nav a:hover{background:#F8FAFC;color:var(--ink)}
    .sidebar nav a.active{background:#FEF2F2;color:var(--brand)}
    .sidebar nav a .ico{font-size:16px}
    .sidebar-foot{margin-top:auto;padding:18px 20px 0;border-top:1px solid var(--border)}
    .sidebar-user{padding:0 20px;margin-top:18px}
    .sidebar-user .name{font-size:13.5px;font-weight:700}
    .sidebar-user .email{font-size:11.5px;color:var(--ink-mid);word-break:break-all}
    .btn-logout{margin:18px 12px 0;display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:8px;background:transparent;border:1px solid var(--border);color:var(--ink-mid);cursor:pointer;font-size:13px;font-weight:600;width:calc(100% - 24px)}
    .btn-logout:hover{background:#FEF2F2;color:var(--brand);border-color:#FECACA}

    .main{padding:28px 36px 60px}
    .page-head{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;margin-bottom:22px}
    .page-head h1{font-family:'Montserrat',sans-serif;font-size:24px;font-weight:700;margin:0}
    .page-head .sub{color:var(--ink-mid);font-size:13.5px;margin-top:4px}

    .card{background:#FFF;border-radius:12px;padding:22px;box-shadow:0 1px 3px rgba(0,0,0,.04);margin-bottom:18px}
    .card-title{font-family:'Montserrat',sans-serif;font-weight:700;font-size:15px;margin:0 0 14px}

    .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px}
    .stat{background:#FFF;border-radius:12px;padding:18px;text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.04)}
    .stat .lbl{font-size:10.5px;color:var(--ink-mid);text-transform:uppercase;letter-spacing:1.4px;font-weight:700}
    .stat .val{font-family:'Montserrat',sans-serif;font-size:24px;font-weight:700;margin-top:6px;color:var(--ink)}
    .stat.brand .val{color:var(--brand)}
    .stat.ok .val{color:var(--ok)}
    .stat.warn .val{color:var(--warn)}

    .table-wrap{overflow-x:auto}
    table{width:100%;border-collapse:collapse;font-size:13.5px}
    th,td{padding:10px 12px;text-align:left;border-bottom:1px solid var(--border)}
    th{background:#F8FAFC;color:var(--ink-mid);font-weight:700;font-size:11.5px;text-transform:uppercase;letter-spacing:0.06em}
    tr:hover td{background:#FAFAFA}

    .badge{display:inline-block;padding:2px 8px;border-radius:99px;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em}
    .badge.ok{background:#DCFCE7;color:#166534}
    .badge.warn{background:#FEF3C7;color:#92400E}
    .badge.err{background:#FEE2E2;color:#B91C1C}

    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .form-grid .form-group{margin:0}
    .form-group{margin-bottom:14px}
    .form-group label{display:block;font-size:12.5px;font-weight:600;margin-bottom:5px;color:var(--ink-mid);text-transform:uppercase;letter-spacing:0.04em}
    .form-group input,.form-group select,.form-group textarea{width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:7px;font-size:14px;font-family:'Open Sans',sans-serif;outline:none}
    .form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--brand)}

    .btn{display:inline-block;padding:10px 18px;background:var(--brand);color:#fff;border:0;border-radius:7px;font-family:'Montserrat',sans-serif;font-weight:700;font-size:13px;cursor:pointer;text-decoration:none;letter-spacing:0.04em}
    .btn:hover{background:var(--brand-dark)}
    .btn:disabled{opacity:.6;cursor:not-allowed}
    .btn-outline{background:transparent;color:var(--brand);border:1.5px solid var(--brand)}
    .btn-outline:hover{background:#FEF2F2}
    .btn-sm{padding:6px 12px;font-size:12px}

    .alert{padding:12px 16px;border-radius:8px;font-size:13.5px;margin-bottom:12px}
    .alert-ok{background:#F0FDF4;color:#15803D;border:1px solid #BBF7D0}
    .alert-err{background:#FEF2F2;color:#B91C1C;border:1px solid #FECACA}
    .alert-warn{background:#FEF3C7;color:#92400E;border:1px solid #FDE68A}

    .empty{text-align:center;color:var(--ink-mid);padding:32px;font-size:13.5px}
    .empty .ico{font-size:32px;margin-bottom:8px}

    @media (max-width: 820px){
      .shell{grid-template-columns:1fr}
      .sidebar{position:fixed;top:0;left:-260px;width:240px;transition:left .25s;z-index:99}
      .sidebar.open{left:0}
      .menu-toggle{display:flex !important}
      .stats{grid-template-columns:repeat(2,1fr)}
      .form-grid{grid-template-columns:1fr}
      .main{padding:80px 16px 40px}
    }
    .menu-toggle{display:none;position:fixed;top:14px;left:14px;width:44px;height:44px;background:#FFF;border:1px solid var(--border);border-radius:8px;align-items:center;justify-content:center;cursor:pointer;z-index:100}
  </style>
</head>
<body>
  <button class="menu-toggle" id="menuToggle" aria-label="Abrir menu">☰</button>
  <div class="shell">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-brand">
        <img src="/logo-cjr.png" alt="Costa Júnior">
        <div class="label">Portal do Representante</div>
        <span class="badge">🤝 Indique e Ganhe</span>
      </div>
      <nav>
        <a href="/manutencao/representante/dashboard" class={current === "dashboard" ? "active" : ""}><span class="ico">📊</span> Dashboard</a>
        <a href="/manutencao/representante/materiais" class={current === "materiais" ? "active" : ""}><span class="ico">📚</span> Materiais</a>
        <a href="/manutencao/representante/perfil" class={current === "perfil" ? "active" : ""}><span class="ico">⚙️</span> Meu Perfil</a>
      </nav>
      <div class="sidebar-user">
        <div class="name" id="userName">—</div>
        <div class="email" id="userEmail">—</div>
      </div>
      <button class="btn-logout" id="btnLogout"><span>↪</span> Sair</button>
    </aside>

    <main class="main">
      <slot />
    </main>
  </div>

  <script is:inline>
    (function() {
      const TOKEN_KEY = "manut_rep_token";
      const USER_KEY = "manut_rep_user";
      const token = localStorage.getItem(TOKEN_KEY);
      if (!token) {
        window.location.replace("/manutencao/representante/login");
        return;
      }
      try {
        const user = JSON.parse(localStorage.getItem(USER_KEY) || "{}");
        const nameEl = document.getElementById("userName");
        const emailEl = document.getElementById("userEmail");
        if (user && user.nome && nameEl) nameEl.textContent = user.nome;
        if (user && user.email && emailEl) emailEl.textContent = user.email;
      } catch (e) {}

      const btnLogout = document.getElementById("btnLogout");
      if (btnLogout) {
        btnLogout.addEventListener("click", () => {
          localStorage.removeItem(TOKEN_KEY);
          localStorage.removeItem(USER_KEY);
          window.location.replace("/manutencao/representante/login");
        });
      }

      // Helper global pra páginas filhas usarem
      window.repFetch = function(url, opts) {
        opts = opts || {};
        const headers = Object.assign({}, opts.headers || {}, { "x-rep-auth": token, "content-type": "application/json" });
        return fetch(url, Object.assign({}, opts, { headers }));
      };

      // Menu mobile
      const toggle = document.getElementById("menuToggle");
      const sidebar = document.getElementById("sidebar");
      if (toggle && sidebar) {
        toggle.addEventListener("click", () => sidebar.classList.toggle("open"));
        document.addEventListener("click", (e) => {
          if (!sidebar.contains(e.target) && !toggle.contains(e.target)) {
            sidebar.classList.remove("open");
          }
        });
      }
    })();
  </script>
</body>
</html>
