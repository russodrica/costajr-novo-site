---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = "Costa Júnior — Engenharia e Construções",
  description = "Construindo sonhos desde 2004. Engenharia, manutenção predial e construção corporativa. A confiança de quem atende Coca-Cola, Bradesco, Santander, Carrefour e RaiaDrogasil.",
  ogImage = "/og-default.jpg",
} = Astro.props;
const url = Astro.url.href;
const pathname = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:url" content={url}>
  <meta property="og:type" content="website">
  <meta name="theme-color" content="#C41E3A">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="alternate icon" href="/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=Open+Sans:wght@400;500;600;700&display=swap">
  <style is:global>
    :root {
      --brand: #C41E3A;
      --brand-dark: #A01828;
      --brand-soft: rgba(196,30,58,.10);
      --ink: #2D2F36;
      --ink-mid: #5B5F6B;
      --ink-light: #808080;
      --bg: #FFFFFF;
      --bg-soft: #F2F2F2;
      --border: #E5E7EB;
    }
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: var(--ink);
      background: #fff;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    a:hover { color: var(--brand); }
    img { max-width: 100%; display: block; }
    .container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
    @media (max-width: 480px) {
      .container { padding: 0 20px; }
    }

    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 28px; border-radius: 4px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 700; font-size: 14px; letter-spacing: 0.04em; text-transform: uppercase;
      transition: all .18s ease; cursor: pointer; border: 0;
    }
    .btn-primary { background: var(--brand); color: #fff; }
    .btn-primary:hover { background: var(--brand-dark); color: #fff; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(196,30,58,.25); }
    .btn-gray { background: #64748B; color: #fff; }
    .btn-gray:hover { background: #475569; color: #fff; }
    .btn-outline {
      background: transparent; color: var(--ink);
      border: 2px solid var(--ink-mid);
    }
    .btn-outline:hover { border-color: var(--brand); color: var(--brand); }
    .btn-light {
      background: rgba(255,255,255,.92); color: var(--ink);
    }
    .btn-light:hover { background: #fff; color: var(--brand); }
    .btn-ghost-light {
      background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.85);
    }
    .btn-ghost-light:hover { background: #fff; color: var(--brand); border-color: #fff; }

    .section { padding: 96px 0; }
    .section-soft { background: var(--bg-soft); }

    h1, h2, h3, h4, .display {
      font-family: 'Montserrat', sans-serif;
      letter-spacing: -0.015em; line-height: 1.15;
      color: var(--ink);
    }
    h1 { font-size: clamp(34px, 5vw, 56px); font-weight: 800; margin: 0 0 24px; }
    h2 { font-size: clamp(28px, 3.5vw, 42px); font-weight: 700; margin: 0 0 16px; }
    h3 { font-size: 22px; font-weight: 700; margin: 0 0 12px; }
    h4 { font-size: 18px; font-weight: 700; margin: 0 0 10px; }
    p.lead { font-size: 18px; color: var(--ink-mid); }

    /* Header */
    .header {
      position: sticky; top: 0; z-index: 50;
      background: rgba(255,255,255,.96);
      backdrop-filter: saturate(180%) blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .header-row {
      display: flex; align-items: center; justify-content: space-between;
      height: 80px;
    }
    .logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .logo-mark {
      display: grid; grid-template-columns: 1fr 1fr; gap: 2px;
      width: 28px; height: 28px;
    }
    .logo-mark span:nth-child(1) { background: var(--brand); }
    .logo-mark span:nth-child(2) { background: var(--ink-mid); }
    .logo-mark span:nth-child(3) { background: var(--ink-mid); }
    .logo-mark span:nth-child(4) { background: var(--brand); }
    .logo-text {
      font-family: 'Montserrat', sans-serif;
      font-weight: 800; font-size: 22px; line-height: 1;
      display: flex; flex-direction: column; gap: 2px;
    }
    .logo-text strong { color: var(--brand); }
    .logo-text em { color: var(--ink-mid); font-style: normal; }
    .logo-text small {
      font-size: 8px; font-weight: 600; letter-spacing: 0.18em;
      color: var(--ink-light); text-transform: uppercase;
    }

    .nav { display: flex; gap: 28px; align-items: center; }
    .nav a {
      font-family: 'Montserrat', sans-serif;
      font-weight: 600; font-size: 14px;
      color: var(--ink); text-transform: uppercase; letter-spacing: 0.04em;
    }
    .nav a:hover { color: var(--brand); }
    .nav a.active { color: var(--brand); font-weight: 800; }
    .nav .btn { padding: 10px 20px; font-size: 13px; }

    /* Footer */
    footer {
      background: #1F2126; color: #C8CACE; padding: 64px 0 28px;
      margin-top: 80px;
    }
    footer h4 {
      color: #fff; margin: 0 0 18px; font-size: 13px;
      text-transform: uppercase; letter-spacing: 0.08em;
      font-family: 'Montserrat', sans-serif; font-weight: 700;
    }
    footer a { color: #C8CACE; font-size: 14px; }
    footer a:hover { color: var(--brand); }
    .footer-grid {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1.4fr; gap: 40px; margin-bottom: 40px;
    }
    .footer-bottom {
      border-top: 1px solid #2F3137; padding-top: 24px;
      display: flex; justify-content: space-between; align-items: center;
      font-size: 12px; color: #8E9097; flex-wrap: wrap; gap: 12px;
    }
    .footer-tagline {
      color: #fff; font-family: 'Montserrat', sans-serif;
      font-weight: 700; font-size: 15px; margin: 16px 0 8px;
    }
    .footer-slogan {
      color: var(--brand); font-family: 'Montserrat', sans-serif;
      font-weight: 600; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase;
    }
    .social-row { display: flex; gap: 12px; margin-top: 16px; }
    .social-row a {
      width: 36px; height: 36px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      background: #2F3137; color: #fff; transition: all .15s ease;
    }
    .social-row a:hover { background: var(--brand); color: #fff; }

    @media (max-width: 900px) {
      .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
      .nav { gap: 14px; }
      .nav a:not(.btn) { display: none; }
      .logo-text { font-size: 18px; }
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="container header-row">
      <a href="/" aria-label="Costa Júnior Engenharia">
        <img src="/logo-cjr.png" alt="Costa Júnior Engenharia e Construções" height="48" style="display:block">
      </a>
      <nav class="nav">
        <a href="/sobre" class={pathname.startsWith('/sobre') ? 'active' : ''}>Sobre</a>
        <a href="/servicos" class={pathname.startsWith('/servicos') ? 'active' : ''}>Serviços</a>
        <a href="/manutencao" class={pathname.startsWith('/manutencao') ? 'active' : ''}>Manutenção</a>
        <a href="/artigos" class={pathname.startsWith('/artigos') ? 'active' : ''}>Artigos</a>
        <a href="/contato" class={pathname.startsWith('/contato') ? 'active' : ''}>Contato</a>
        <a href="/intranet" class="btn btn-gray">Intranet</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="container">
      <div class="footer-grid">
        <div>
          <a href="/" aria-label="Costa Júnior Engenharia">
            <img src="/logo-cjr.png" alt="Costa Júnior Engenharia e Construções" height="44" style="display:block;filter:brightness(0) invert(1)">
          </a>
          <p class="footer-tagline">Construindo sonhos desde 2004</p>
          <p class="footer-slogan">Segurança · Responsabilidade · Excelência</p>
          <div class="social-row">
            <a href="https://instagram.com/costajreng" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="https://facebook.com/costajreng" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="https://linkedin.com/company/costajreng" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          </div>
        </div>
        <div>
          <h4>Empresa</h4>
          <ul style="list-style:none;padding:0;margin:0;display:grid;gap:10px">
            <li><a href="/sobre">Sobre nós</a></li>
            <li><a href="/servicos">Serviços</a></li>
            <li><a href="/artigos">Artigos</a></li>
            <li><a href="/quero-ser-parceiro">Quero ser parceiro</a></li>
          </ul>
        </div>
        <div>
          <h4>Soluções</h4>
          <ul style="list-style:none;padding:0;margin:0;display:grid;gap:10px">
            <li><a href="/manutencao">Manutenção predial</a></li>
            <li><a href="/intranet">Intranet</a></li>
            <li><a href="/contato">Solicitar orçamento</a></li>
          </ul>
        </div>
        <div>
          <h4>Contato</h4>
          <ul style="list-style:none;padding:0;margin:0;display:grid;gap:10px">
            <li><a href="mailto:contato@costajr.com.br">contato@costajr.com.br</a></li>
            <li>
              <a href="https://wa.me/551123696462" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:8px">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© 2026 Costa Júnior Engenharia e Construções LTDA — CNPJ 07.132.942/0001-72</span>
        <span><a href="/privacidade">Política de Privacidade</a> · <a href="/lgpd">LGPD</a></span>
      </div>
    </div>
  </footer>
</body>
</html>
