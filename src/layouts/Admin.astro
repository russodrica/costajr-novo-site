---
export interface Props {
  title: string;
  current?: string;
}
const { title, current = "" } = Astro.props;

const nav = [
  { href: "/admin", label: "Dashboard", icon: "📊", key: "dashboard" },
  { href: "/admin/analytics", label: "Analytics", icon: "📈", key: "analytics" },
  // Manutenção
  { label: "— Manutenção —", key: "_sep1", href: "", sep: true },
  { href: "/admin/clientes", label: "Clientes", icon: "👥", key: "clientes" },
  { href: "/admin/tecnicos", label: "Técnicos", icon: "🔧", key: "tecnicos" },
  { href: "/admin/chamados", label: "Chamados", icon: "📋", key: "chamados" },
  { href: "/admin/preventivas", label: "Preventivas", icon: "🗓️", key: "preventivas" },
  { href: "/admin/pagamentos", label: "Pagamentos", icon: "💰", key: "pagamentos" },
  { href: "/admin/materiais", label: "Materiais", icon: "🔩", key: "materiais" },
  { href: "/admin/estoque-alteracoes", label: "Alt. Preço Estoque", icon: "💲", key: "estoque-alteracoes" },
  { href: "/admin/leads", label: "Pré-cadastros", icon: "📣", key: "leads" },
  { href: "/admin/cupons", label: "Cupons & Cashback", icon: "🎁", key: "cupons" },
  { href: "/admin/representantes", label: "Representantes", icon: "🤝", key: "representantes" },
  { href: "/admin/parametrizacao", label: "Parametrização", icon: "⚙️", key: "parametrizacao" },
  // Portal do Colaborador
  { label: "— Portal Colab. —", key: "_sep2", href: "", sep: true },
  { href: "/admin/membros", label: "Membros", icon: "🪪", key: "membros" },
  { href: "/admin/portal-comunicados", label: "Comunicados", icon: "📢", key: "portal-comunicados" },
  { href: "/admin/portal-kb", label: "Base de Conhecimento", icon: "🔍", key: "portal-kb" },
  { href: "/admin/portal-onboarding", label: "Onboarding", icon: "✅", key: "portal-onboarding" },
  { href: "/admin/portal-treinamentos", label: "Treinamentos", icon: "🎬", key: "portal-treinamentos" },
  { href: "/admin/portal-integracao", label: "Docs Integração", icon: "📄", key: "portal-integracao" },
  // Institucional
  { label: "— Institucional —", key: "_sep3", href: "", sep: true },
  { href: "/admin/suporte", label: "Suporte", icon: "💬", key: "suporte" },
  { href: "/admin/blog", label: "Blog", icon: "📝", key: "blog" },
];
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title} — CJR Admin</title>
  <meta name="theme-color" content="#16181F">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <meta name="robots" content="noindex,nofollow" />
</head>
<body>
  <div class="shell">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <span class="logo-text">CJR</span>
        <span class="logo-sub">Admin</span>
      </div>
      <nav class="sidebar-nav">
        {nav.map(item => (
          (item as any).sep
            ? <div class="nav-sep">{item.label}</div>
            : <a href={item.href} class={`nav-item ${current === item.key ? "active" : ""}`}>
                <span class="nav-icon">{item.icon}</span>
                <span>{item.label}</span>
              </a>
        ))}
      </nav>
      <div class="sidebar-footer">
        <button class="btn-logout" onclick="logout()">⬅ Sair</button>
      </div>
    </aside>

    <!-- Main -->
    <div class="main-wrap">
      <header class="topbar">
        <button class="menu-toggle" onclick="toggleSidebar()" aria-label="Menu">☰</button>
        <h1 class="page-title">{title}</h1>
        <span class="topbar-brand">Costa Júnior Engenharia</span>
      </header>
      <main class="main-content">
        <slot />
      </main>
    </div>
  </div>

  <script>
    function logout() {
      fetch("/api/admin/logout", { method: "POST", headers: { "content-type": "application/json" }, body: "{}" }).finally(() => {
        window.location.href = "/admin/login";
      });
    }
    function toggleSidebar() {
      document.getElementById("sidebar")?.classList.toggle("open");
    }
    // Fechar sidebar ao clicar fora (mobile)
    document.addEventListener("click", (e) => {
      const sidebar = document.getElementById("sidebar");
      const toggle = document.querySelector(".menu-toggle");
      if (sidebar?.classList.contains("open") && !sidebar.contains(e.target as Node) && e.target !== toggle) {
        sidebar.classList.remove("open");
      }
    });
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Open Sans', sans-serif; background: #F4F5F7; color: #2D2F36; }

    .shell { display: flex; min-height: 100vh; }

    /* ── Sidebar ── */
    .sidebar {
      width: 220px; min-width: 220px;
      background: #1C1E22; color: #fff;
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; height: 100vh;
      overflow-y: auto; z-index: 200;
      transition: transform 0.25s ease;
    }
    .sidebar-logo {
      display: flex; align-items: baseline; gap: 6px;
      padding: 20px 20px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .logo-text { font-family: 'Montserrat', sans-serif; font-size: 1.5rem; font-weight: 700; color: #C41E3A; }
    .logo-sub  { font-size: 0.75rem; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 1px; }

    .sidebar-nav { flex: 1; padding: 12px 0; }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 20px; color: #B0B3B8;
      text-decoration: none; font-size: 0.875rem; font-weight: 500;
      transition: background 0.15s, color 0.15s;
    }
    .nav-item:hover { background: rgba(255,255,255,0.06); color: #fff; }
    .nav-item.active { background: rgba(196,30,58,0.2); color: #fff; border-left: 3px solid #C41E3A; }
    .nav-icon { font-size: 1rem; width: 20px; text-align: center; }
    .nav-sep { padding: 12px 20px 4px; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #4B5563; pointer-events: none; }

    .sidebar-footer { padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.08); }
    .btn-logout {
      width: 100%; padding: 8px 12px;
      background: transparent; border: 1px solid rgba(255,255,255,0.15);
      color: #B0B3B8; border-radius: 6px; cursor: pointer;
      font-size: 0.8rem; transition: all 0.15s;
    }
    .btn-logout:hover { background: rgba(255,255,255,0.08); color: #fff; }

    /* ── Main ── */
    .main-wrap { flex: 1; margin-left: 220px; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar {
      background: #fff; border-bottom: 1px solid #E0E0E0;
      padding: 0 24px; height: 56px;
      display: flex; align-items: center; gap: 16px;
      position: sticky; top: 0; z-index: 100;
    }
    .menu-toggle { display: none; background: none; border: none; font-size: 1.25rem; cursor: pointer; color: #2D2F36; }
    .page-title { font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 700; color: #2D2F36; flex: 1; }
    .topbar-brand { font-size: 0.75rem; color: #888; white-space: nowrap; }
    .main-content { padding: 24px; flex: 1; }

    /* ── Cards ── */
    .card { background: #fff; border-radius: 10px; border: 1px solid #E8E8E8; padding: 20px; }
    .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .stat-card { background: #fff; border-radius: 10px; border: 1px solid #E8E8E8; padding: 20px; }
    .stat-value { font-family: 'Montserrat', sans-serif; font-size: 2rem; font-weight: 700; color: #C41E3A; }
    .stat-label { font-size: 0.8rem; color: #666; margin-top: 4px; }

    /* ── Tabelas ── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    th { text-align: left; padding: 10px 12px; background: #F8F8F8; border-bottom: 2px solid #E0E0E0; font-weight: 600; color: #555; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }
    td { padding: 10px 12px; border-bottom: 1px solid #F0F0F0; vertical-align: middle; }
    tr:hover td { background: #FAFAFA; }

    /* ── Badges ── */
    .badge { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: 0.72rem; font-weight: 600; }
    .badge-green  { background: #DCFCE7; color: #166534; }
    .badge-yellow { background: #FEF9C3; color: #854D0E; }
    .badge-red    { background: #FEE2E2; color: #991B1B; }
    .badge-blue   { background: #DBEAFE; color: #1E40AF; }
    .badge-gray   { background: #F3F4F6; color: #374151; }
    .badge-orange { background: #FFEDD5; color: #9A3412; }

    /* ── Botões ── */
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; border: none; transition: opacity 0.15s; text-decoration: none; }
    .btn:hover { opacity: 0.85; }
    .btn-primary { background: #C41E3A; color: #fff; }
    .btn-secondary { background: #F3F4F6; color: #374151; border: 1px solid #D1D5DB; }
    .btn-success { background: #22C55E; color: #fff; }
    .btn-danger  { background: #EF4444; color: #fff; }
    .btn-warning { background: #F59E0B; color: #fff; }
    .btn-info    { background: #3B82F6; color: #fff; }
    .btn-sm { padding: 4px 10px; font-size: 0.75rem; }

    /* ── Toolbar ── */
    .toolbar { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
    .toolbar-title { font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 700; flex: 1; }
    .search-input { padding: 7px 12px; border: 1px solid #D1D5DB; border-radius: 6px; font-size: 0.85rem; min-width: 200px; }
    select.filter-select { padding: 7px 10px; border: 1px solid #D1D5DB; border-radius: 6px; font-size: 0.85rem; background: #fff; }

    /* ── Modal ── */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: none; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal { background: #fff; border-radius: 12px; padding: 28px; max-width: 500px; width: 90%; max-height: 90vh; overflow-y: auto; }
    .modal-title { font-family: 'Montserrat', sans-serif; font-size: 1.1rem; font-weight: 700; margin-bottom: 20px; }
    .modal-box { background: #fff; border-radius: 12px; width: 90%; max-width: 520px; max-height: 90vh; overflow-y: auto; }
    .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px 16px; border-bottom: 1px solid #E5E7EB; }
    .modal-header h2 { font-family: 'Montserrat', sans-serif; font-size: 1.1rem; font-weight: 700; margin: 0; }
    .modal-close { background: none; border: 0; font-size: 18px; cursor: pointer; color: #9CA3AF; line-height: 1; padding: 0; }
    .modal-close:hover { color: #374151; }
    .modal-box .form-group, .modal-box .form-row { padding: 0 24px; }
    .modal-box > .form-group:first-of-type, .modal-box > .form-row:first-of-type { padding-top: 16px; }
    .modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 24px; border-top: 1px solid #E5E7EB; margin-top: 16px; }
    .form-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px,1fr)); gap: 12px; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 0.8rem; font-weight: 600; color: #555; margin-bottom: 5px; }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 8px 12px; border: 1px solid #D1D5DB; border-radius: 6px; font-size: 0.875rem;
      font-family: 'Open Sans', sans-serif; outline: none; transition: border .15s;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: #C41E3A; }
    .form-group textarea { min-height: 80px; resize: vertical; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }

    /* ── Alert ── */
    .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 0.875rem; }
    .alert-success { background: #DCFCE7; color: #166534; border: 1px solid #BBF7D0; }
    .alert-error   { background: #FEE2E2; color: #991B1B; border: 1px solid #FECACA; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .main-wrap { margin-left: 0; }
      .menu-toggle { display: block; }
      .topbar-brand { display: none; }
      .card-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
<script is:inline>
  if ("serviceWorker" in navigator) {
    window.addEventListener("load", () => navigator.serviceWorker.register("/sw.js").catch(() => {}));
  }
</script>
</body>
</html>
