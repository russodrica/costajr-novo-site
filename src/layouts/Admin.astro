---
export interface Props {
  title: string;
  current?: string;
}
import { verifyToken, type AdminClaims } from "../lib/auth";
import { nivelEfetivo, carregarOverridesUsuario, perfisFrescos, rotuloPerfil, type NivelPerm } from "../lib/permissoes";
import { supabaseAdmin } from "../lib/supabase";
const { title, current = "" } = Astro.props;

// Perfis + overrides FRESCOS do usuário — para liberar os módulos do admin POR USUÁRIO
// (override do perfil, com nível ver/editar). Lidos do banco a cada request.
// A FONTE dos módulos/grupos-padrão é src/lib/permissoes.ts (a matriz e o enforcement
// usam a mesma lógica). O array `grupos` abaixo continua sendo a fonte do MENU.
let perfisUser: string[] = [];
let overridesUser: Record<string, NivelPerm> = {};
let userNome = "";
let userEmail = "";
let userAvatar = "";
try {
  const tk = Astro.cookies.get("admin_token")?.value;
  if (tk) {
    const c = await verifyToken<AdminClaims>(tk);
    perfisUser = await perfisFrescos(c);
    overridesUser = await carregarOverridesUsuario(c.sub);
    userEmail = c.email || "";
    try {
      const { data: prof } = await supabaseAdmin()
        .from("portal_profiles")
        .select("display_name, full_name, avatar_url, email")
        .eq("id", c.sub)
        .maybeSingle();
      if (prof) {
        userNome = prof.display_name || prof.full_name || "";
        userAvatar = prof.avatar_url || "";
        userEmail = prof.email || userEmail;
      }
    } catch { /* perfil não encontrado -> usa o e-mail do token */ }
  }
} catch { /* sem perfis -> nao filtra; a propria pagina ja autentica */ }
const temPerfis = perfisUser.length > 0;

// Identidade exibida no painel (cabeçalho + rodapé da sidebar).
const perfilLabel = perfisUser.length ? rotuloPerfil(perfisUser[0]) : "";
const nomeExibicao = (userNome || (userEmail ? userEmail.split("@")[0] : "") || "Usuário").trim();
const inicialUser = (nomeExibicao || "U").charAt(0).toUpperCase();

// Nível efetivo (nenhum|ver|editar) de um módulo p/ este usuário; acessível se != nenhum.
const nivelDe = (key: string): NivelPerm => nivelEfetivo(key, perfisUser, overridesUser);
const podeModulo = (key: string): boolean => {
  if (!temPerfis) return true;                        // sem perfis lidos -> não filtra (a página autentica)
  return nivelDe(key) !== "nenhum";
};

type NavItem = { href: string; label: string; ic: string; key: string };
type NavGroup = { id: string; label: string | null; cor: string; items: NavItem[] };

// cor = cor da ÁREA (direção "Vibrante Monday"): cada área tem sua cor, aplicada no
// rótulo do grupo e no item ativo (faixa lateral + tint). Espelha GRUPO_COR do hub.
const grupos: NavGroup[] = [
  {
    id: "geral", label: null, cor: "#475569",
    items: [
      { href: "/admin/analytics", label: "Análise do Site", ic: "chart-line", key: "analytics" },
    ],
  },
  {
    id: "meu-espaco", label: "Meu Espaço", cor: "#C41E3A",
    items: [
      { href: "/admin/meu-onboarding", label: "Onboarding", ic: "checklist", key: "meu-onboarding" },
      { href: "/admin/junia", label: "Fórum / JunIA", ic: "robot", key: "junia" },
      { href: "/admin/documentos-portal", label: "Documentos", ic: "file-text", key: "documentos-portal" },
      { href: "/admin/treinamentos-portal", label: "Treinamentos", ic: "player-play", key: "treinamentos-portal" },
      { href: "/admin/meus-equipamentos", label: "Meus Equipamentos", ic: "device-laptop", key: "meus-equipamentos" },
    ],
  },
  {
    id: "manutencao", label: "Manutenção", cor: "#D97706",
    items: [
      { href: "/admin/dashboard", label: "Painel de Manutenção", ic: "gauge", key: "dashboard" },
      { href: "/admin/clientes", label: "Clientes", ic: "users", key: "clientes" },
      { href: "/admin/tecnicos", label: "Técnicos", ic: "tool", key: "tecnicos" },
      { href: "/admin/chamados", label: "Chamados", ic: "clipboard-list", key: "chamados" },
      { href: "/admin/preventivas", label: "Preventivas", ic: "calendar-event", key: "preventivas" },
      { href: "/admin/pagamentos", label: "Pagamentos", ic: "cash", key: "pagamentos" },
      { href: "/admin/materiais", label: "Materiais", ic: "package", key: "materiais" },
      { href: "/admin/estoque-alteracoes", label: "Alt. Preço Estoque", ic: "receipt-2", key: "estoque-alteracoes" },
      { href: "/admin/leads", label: "Pré-cadastros", ic: "speakerphone", key: "leads" },
      { href: "/admin/cupons", label: "Cupons & Cashback", ic: "gift", key: "cupons" },
      { href: "/admin/representantes", label: "Representantes", ic: "users-group", key: "representantes" },
      { href: "/admin/materiais-representante", label: "Materiais Indique", ic: "books", key: "materiais-representante" },
      { href: "/admin/parametrizacao", label: "Parametrização", ic: "settings", key: "parametrizacao" },
    ],
  },
  {
    id: "operacoes", label: "Operações & Obras", cor: "#EA580C",
    items: [
      { href: "/admin/ativos", label: "Ativos Patrimoniais", ic: "tag", key: "ativos" },
      { href: "/admin/obras", label: "Obras & Projetos", ic: "building-skyscraper", key: "obras" },
      { href: "/admin/vobi-projetos", label: "Projetos Ativos (Vobi)", ic: "building-community", key: "vobi-projetos" },
      { href: "/admin/depositos", label: "Depósitos", ic: "building-warehouse", key: "depositos" },
    ],
  },
  {
    id: "rh", label: "RH & Pessoas", cor: "#0EA5E9",
    items: [
      { href: "/admin/rh", label: "RH — Pessoas", ic: "id-badge-2", key: "rh" },
      { href: "/admin/caixa-entrada", label: "Caixa de Entrada", ic: "inbox", key: "caixa-entrada" },
      { href: "/admin/recrutamento", label: "Recrutamento (R&S)", ic: "user-plus", key: "recrutamento" },
      { href: "/admin/avaliacoes", label: "Avaliação de Desempenho", ic: "star", key: "avaliacoes" },
      { href: "/admin/clima", label: "Pesquisa de Clima", ic: "mood-smile", key: "clima" },
      { href: "/admin/rh-analytics", label: "People Analytics (RH)", ic: "chart-histogram", key: "rh-analytics" },
    ],
  },
  {
    id: "financeiro", label: "Financeiro", cor: "#16A34A",
    items: [
      { href: "/admin/financeiro", label: "Financeiro", ic: "building-bank", key: "financeiro" },
      { href: "/admin/vobi-financeiro", label: "Financeiro Vobi", ic: "report-money", key: "vobi-financeiro" },
      { href: "/admin/fin-conciliacao", label: "Conciliação (OFX)", ic: "arrows-exchange", key: "fin-conciliacao" },
    ],
  },
  {
    id: "comercial", label: "Comercial", cor: "#7C3AED",
    items: [
      { href: "/admin/comercial", label: "Comercial (CRM)", ic: "businessplan", key: "comercial" },
      { href: "/admin/vobi-comercial", label: "Oportunidades Vobi", ic: "target-arrow", key: "vobi-comercial" },
    ],
  },
  {
    id: "juridico", label: "Jurídico & Documentos", cor: "#9333EA",
    items: [
      { href: "/admin/doc-empresa", label: "Documentos da Empresa", ic: "files", key: "doc-empresa" },
      { href: "/admin/doc-bancarios", label: "Documentos Bancários", ic: "building-bank", key: "doc-bancarios" },
      { href: "/admin/assinaturas", label: "Assinaturas (D4Sign)", ic: "signature", key: "assinaturas" },
    ],
  },
  {
    id: "portal", label: "Portal Colaborador", cor: "#DB2777",
    items: [
      { href: "/admin/membros", label: "Membros", ic: "id", key: "membros" },
      { href: "/admin/permissoes", label: "Permissões de Acesso", ic: "lock", key: "permissoes" },
      { href: "/admin/portal-comunicados", label: "Comunicados", ic: "speakerphone", key: "portal-comunicados" },
      { href: "/admin/portal-kb", label: "Base de Conhecimento", ic: "book-2", key: "portal-kb" },
      { href: "/admin/perguntas", label: "Perguntas (JunIA)", ic: "help", key: "perguntas" },
      { href: "/admin/portal-onboarding", label: "Onboarding", ic: "checklist", key: "portal-onboarding" },
      { href: "/admin/portal-treinamentos", label: "Treinamentos", ic: "player-play", key: "portal-treinamentos" },
      { href: "/admin/portal-integracao", label: "Docs Integração", ic: "file-text", key: "portal-integracao" },
    ],
  },
  {
    id: "institucional", label: "Institucional", cor: "#0D9488",
    items: [
      { href: "/admin/suporte", label: "Suporte", ic: "headset", key: "suporte" },
      { href: "/admin/blog", label: "Blog", ic: "news", key: "blog" },
    ],
  },
  {
    id: "sistema", label: "Sistema", cor: "#64748B",
    items: [
      { href: "/admin/logs", label: "Auditoria (Logs)", ic: "list-details", key: "logs" },
      { href: "/admin/lixeira", label: "Lixeira", ic: "trash", key: "lixeira" },
      { href: "/admin/telegram", label: "Bot Telegram", ic: "brand-telegram", key: "telegram" },
    ],
  },
  {
    id: "conta", label: "Conta", cor: "#475569",
    items: [
      { href: "/admin/minha-conta", label: "Minha Conta", ic: "user", key: "minha-conta" },
    ],
  },
];

// Lista achatada dos módulos acessíveis — alimenta a busca global (Ctrl+K).
const modulosBusca = grupos
  .map(g => ({ ...g, items: g.items.filter(i => podeModulo(i.key)) }))
  .filter(g => g.items.length)
  .flatMap(g => g.items.map(i => ({ l: i.label, h: i.href, ic: i.ic, g: g.label || "Geral", c: g.cor })));

// grupo que contém a página atual (abre por padrão)
const grupoAtivo = grupos.find(g => g.items.some(i => i.key === current))?.id ?? "geral";

// Liberação POR MÓDULO/USUÁRIO: cada grupo mostra só os módulos acessíveis; grupo
// sem nenhum módulo acessível some. O bloqueio de acesso é por MÓDULO (não por grupo).
const gruposVisiveis = grupos
  .map(g => ({ ...g, items: g.items.filter(i => podeModulo(i.key)) }))
  .filter(g => g.items.length);
const moduloDaPagina = current ? grupos.flatMap(g => g.items).find(i => i.key === current) : null;
// Bloqueio REAL de acesso: o slot só renderiza se o módulo da página é acessível
// (o redirect NÃO funciona dentro de um layout).
const semAcessoPagina = !!(temPerfis && current && moduloDaPagina && !podeModulo(current));

// Modo SOMENTE-LEITURA: o usuário tem nível "ver" neste módulo (acessa, mas não edita).
const nivelPaginaAtual: NivelPerm = (current && current !== "home") ? nivelDe(current) : "editar";
const somenteLeitura = temPerfis && !semAcessoPagina && nivelPaginaAtual === "ver";
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title} — CJR Admin</title>
  <meta name="theme-color" content="#16181F">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3/dist/tabler-icons.min.css" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/icons/apple-touch-icon.png" />
  <meta name="robots" content="noindex,nofollow" />
</head>
<body>
  <style is:inline>{`
    /* Modo somente-leitura: esconde controles marcados como edição. */
    .ro-mode [data-requer-edicao] { display: none !important; }
  `}</style>
  <div class="shell">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <a href="/admin" class="logo-link" aria-label="Visão geral">
          <img src="/logo-cjr.png" alt="Costa Júnior Engenharia" class="logo-img" />
          <span class="logo-mark" aria-hidden="true">CJ</span>
        </a>
        <span class="logo-sub">Portal CJR</span>
        <button class="rail-toggle" onclick="toggleRail()" title="Recolher menu" aria-label="Recolher menu" type="button">
          <i class="ti ti-chevrons-left" aria-hidden="true"></i>
        </button>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin" title="Visão geral" style="--area:#475569" class={`nav-item ${current === "home" ? "active" : ""}`}>
          <i class="ti ti-layout-dashboard nav-icon" aria-hidden="true"></i>
          <span class="nav-label">Visão geral</span>
        </a>
        {gruposVisiveis.map(g => (
          g.label === null
            ? g.items.map(item => (
                <a href={item.href} title={item.label} style={`--area:${g.cor}`} class={`nav-item ${current === item.key ? "active" : ""}`}>
                  <i class={`ti ti-${item.ic} nav-icon`} aria-hidden="true"></i>
                  <span class="nav-label">{item.label}</span>
                </a>
              ))
            : <div class={`nav-group ${g.id === grupoAtivo ? "open" : ""}`} data-group={g.id} style={`--area:${g.cor}`}>
                <button type="button" class="nav-group-head">
                  <span class="nav-group-label">{g.label}</span>
                  <span class="nav-group-chev"><i class="ti ti-chevron-down" aria-hidden="true"></i></span>
                </button>
                <div class="nav-group-items">
                  {g.items.map(item => (
                    <a href={item.href} title={item.label} class={`nav-item ${current === item.key ? "active" : ""}`}>
                      <i class={`ti ti-${item.ic} nav-icon`} aria-hidden="true"></i>
                      <span class="nav-label">{item.label}</span>
                    </a>
                  ))}
                </div>
              </div>
        ))}
      </nav>
      <div class="sidebar-footer">
        <div class="user-chip" title={userEmail}>
          {userAvatar
            ? <img src={userAvatar} alt="" class="user-avatar-img" />
            : <span class="user-avatar">{inicialUser}</span>}
          <div class="user-meta">
            <span class="user-name">{nomeExibicao}</span>
            {perfilLabel && <span class="user-perfil">{perfilLabel}</span>}
          </div>
        </div>
        <button class="btn-logout" onclick="logout()"><i class="ti ti-logout" aria-hidden="true"></i> <span class="nav-label">Sair</span></button>
      </div>
    </aside>

    <!-- Main -->
    <div class="main-wrap">
      <header class="topbar">
        <button class="menu-toggle" onclick="toggleSidebar()" aria-label="Menu" type="button"><i class="ti ti-menu-2" aria-hidden="true"></i></button>
        <h1 class="page-title">{title}</h1>
        <button class="cmd-trigger" onclick="openCmd()" type="button" aria-label="Buscar módulo">
          <i class="ti ti-search" aria-hidden="true"></i>
          <span>Buscar módulo…</span>
          <kbd>Ctrl K</kbd>
        </button>
        <div class="notif-wrap">
          <button class="btn-notif" id="btnNotif" title="Notificações" aria-label="Notificações" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <span class="notif-badge" id="notifBadge" style="display:none">0</span>
          </button>
          <div class="notif-drop" id="notifDrop">
            <div class="notif-drop-head">
              <strong>Notificações</strong>
              <button id="notifTodas" type="button">Marcar todas como lidas</button>
            </div>
            <div class="notif-list" id="notifList"><p class="notif-empty">Carregando...</p></div>
          </div>
        </div>
        <div class="topbar-user" title={userEmail}>
          {userAvatar
            ? <img src={userAvatar} alt="" class="tb-avatar-img" />
            : <span class="tb-avatar">{inicialUser}</span>}
          <div class="tb-meta">
            <span class="tb-name">{nomeExibicao}</span>
            {perfilLabel && <span class="tb-perfil">{perfilLabel}</span>}
          </div>
        </div>
      </header>
      <main class={somenteLeitura ? "main-content ro-mode" : "main-content"}>
        {semAcessoPagina ? (
          <div style="text-align:center;padding:80px 24px;color:#5B5F6B">
            <div style="font-size:48px;margin-bottom:12px">🔒</div>
            <h2 style="font-family:'Montserrat',sans-serif;font-size:20px;color:#1E2128;margin:0 0 8px">Acesso restrito</h2>
            <p style="margin:0 0 18px">Seu perfil não tem acesso a este módulo. Fale com o administrador.</p>
            <a href="/admin" style="display:inline-block;background:#C41E3A;color:#fff;text-decoration:none;padding:10px 22px;border-radius:8px;font-weight:700">Voltar ao início</a>
          </div>
        ) : (
          <Fragment>
            {somenteLeitura && (
              <div style="display:flex;align-items:center;gap:10px;background:#EFF6FF;border:1px solid #BFDBFE;color:#1E40AF;border-radius:10px;padding:10px 14px;margin-bottom:16px;font-size:13.5px">
                <span style="font-size:18px">👁</span>
                <span><strong>Somente leitura.</strong> Você pode visualizar este módulo, mas não editar. Para alterar, fale com o administrador.</span>
              </div>
            )}
            <slot />
          </Fragment>
        )}
      </main>
    </div>
  </div>

  <!-- Busca global / command palette (Ctrl+K) -->
  <div class="cmd-overlay" id="cmdOverlay" onclick="if(event.target===this)closeCmd()">
    <div class="cmd-box" role="dialog" aria-label="Buscar módulo">
      <div class="cmd-input-wrap">
        <i class="ti ti-search" aria-hidden="true"></i>
        <input id="cmdInput" type="text" placeholder="Buscar módulo…" autocomplete="off" spellcheck="false" />
        <kbd>Esc</kbd>
      </div>
      <div class="cmd-results" id="cmdResults"></div>
    </div>
  </div>
  <script id="cmdData" type="application/json" is:inline set:html={JSON.stringify(modulosBusca)}></script>

  <script>
    function logout() {
      // Limpa o cookie-ponte do RH embutido (domínio, não-HttpOnly) no cliente —
      // o /api/admin/logout limpa o host-only + domínio no servidor.
      if (location.hostname.indexOf("costajr.com.br") !== -1) {
        document.cookie = "admin_token=; path=/; domain=.costajr.com.br; max-age=0";
      }
      document.cookie = "admin_token=; path=/; max-age=0";
      fetch("/api/admin/logout", { method: "POST", headers: { "content-type": "application/json" }, body: "{}" }).finally(() => {
        window.location.href = "/admin/login";
      });
    }
    function toggleSidebar() {
      document.getElementById("sidebar")?.classList.toggle("open");
    }
    // Fechar sidebar ao clicar fora (mobile)
    document.addEventListener("click", (e) => {
      const sidebar = document.getElementById("sidebar");
      const toggle = document.querySelector(".menu-toggle");
      if (sidebar?.classList.contains("open") && !sidebar.contains(e.target as Node) && e.target !== toggle) {
        sidebar.classList.remove("open");
      }
    });
    // Grupos colapsáveis com persistência
    document.querySelectorAll(".nav-group-head").forEach((head) => {
      head.addEventListener("click", () => {
        const group = head.closest(".nav-group") as HTMLElement;
        group.classList.toggle("open");
        const abertos = Array.from(document.querySelectorAll(".nav-group.open")).map(g => (g as HTMLElement).dataset.group);
        try { localStorage.setItem("admin-nav-open", JSON.stringify(abertos)); } catch {}
      });
    });
    try {
      const salvos = JSON.parse(localStorage.getItem("admin-nav-open") || "null");
      if (Array.isArray(salvos)) {
        document.querySelectorAll(".nav-group").forEach((g) => {
          const el = g as HTMLElement;
          // o grupo da página atual fica sempre aberto
          if (el.querySelector(".nav-item.active")) { el.classList.add("open"); return; }
          el.classList.toggle("open", salvos.includes(el.dataset.group));
        });
      }
    } catch {}
  </script>

  <script>
    // ── Sino de notificações (mesmo backend do portal; autentica pelo cookie admin_token) ──
    (function () {
      const btnN = document.getElementById("btnNotif");
      const drop = document.getElementById("notifDrop");
      const badge = document.getElementById("notifBadge");
      const lista = document.getElementById("notifList");
      if (!btnN || !drop || !badge || !lista) return;
      let notifs = [];
      function tempoRel(d) {
        const min = Math.floor((Date.now() - new Date(d).getTime()) / 60000);
        if (min < 1) return "agora";
        if (min < 60) return "há " + min + " min";
        const h = Math.floor(min / 60);
        if (h < 24) return "há " + h + "h";
        return new Date(d).toLocaleDateString("pt-BR");
      }
      function escN(s) { return String(s == null ? "" : s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;"); }
      function render() {
        if (!notifs.length) { lista.innerHTML = '<p class="notif-empty">Nenhuma notificação por aqui. 🔕</p>'; return; }
        lista.innerHTML = notifs.map(function (n) {
          return '<a class="notif-item ' + (n.lida ? "" : "nao-lida") + '" data-id="' + n.id + '" data-link="' + escN(n.link || "") + '">'
            + '<strong>' + escN(n.titulo) + '</strong>'
            + (n.mensagem ? '<p>' + escN(n.mensagem) + '</p>' : '')
            + '<span>' + tempoRel(n.created_at) + '</span></a>';
        }).join("");
        lista.querySelectorAll(".notif-item").forEach(function (el) {
          el.addEventListener("click", async function (e) {
            e.preventDefault();
            const id = el.getAttribute("data-id");
            const link = el.getAttribute("data-link");
            try { await fetch("/api/portal/notificacoes", { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ id: id }) }); } catch (_) {}
            if (link) window.location.href = link; else { el.classList.remove("nao-lida"); carregar(); }
          });
        });
      }
      async function carregar() {
        try {
          const res = await fetch("/api/portal/notificacoes");
          if (!res.ok) return;
          const d = await res.json();
          notifs = d.notificacoes || [];
          const naoLidas = d.nao_lidas || 0;
          badge.style.display = naoLidas > 0 ? "flex" : "none";
          badge.textContent = naoLidas > 9 ? "9+" : String(naoLidas);
          render();
        } catch (_) {}
      }
      btnN.addEventListener("click", function (e) { e.stopPropagation(); drop.classList.toggle("open"); });
      document.addEventListener("click", function (e) { if (!drop.contains(e.target) && !btnN.contains(e.target)) drop.classList.remove("open"); });
      const todas = document.getElementById("notifTodas");
      if (todas) todas.addEventListener("click", async function () {
        try { await fetch("/api/portal/notificacoes", { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ todas: true }) }); } catch (_) {}
        carregar();
      });
      carregar();
      setInterval(carregar, 60000);
    })();
  </script>

  <script is:inline>
    /* Recolher menu (rail) + busca global (Ctrl+K) — JS puro, expõe no window p/ os onclick inline */
    (function () {
      var shell = document.querySelector(".shell");
      try { if (localStorage.getItem("admin-collapsed") === "1" && shell) shell.classList.add("collapsed"); } catch (e) {}
      window.toggleRail = function () {
        if (!shell) return;
        var on = shell.classList.toggle("collapsed");
        try { localStorage.setItem("admin-collapsed", on ? "1" : "0"); } catch (e) {}
      };
      var overlay = document.getElementById("cmdOverlay");
      var input = document.getElementById("cmdInput");
      var results = document.getElementById("cmdResults");
      var mods = [];
      try { mods = JSON.parse((document.getElementById("cmdData") || {}).textContent || "[]"); } catch (e) {}
      function esc(s) { return String(s == null ? "" : s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;"); }
      function norm(s) { return String(s || "").toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, ""); }
      var sel = 0, filtered = [];
      function draw() {
        if (!results) return;
        if (!filtered.length) { results.innerHTML = '<div class="cmd-empty">Nada encontrado.</div>'; return; }
        results.innerHTML = filtered.map(function (m, i) {
          return '<a class="cmd-item' + (i === sel ? " on" : "") + '" href="' + esc(m.h) + '">'
            + '<span class="cmd-ic" style="color:' + esc(m.c) + '"><i class="ti ti-' + esc(m.ic) + '"></i></span>'
            + '<span class="cmd-l">' + esc(m.l) + '</span><span class="cmd-g">' + esc(m.g) + '</span></a>';
        }).join("");
      }
      function filtrar() {
        if (!input) return;
        var q = norm(input.value.trim());
        filtered = !q ? mods.slice(0, 8) : mods.filter(function (m) { return norm(m.l).indexOf(q) >= 0 || norm(m.g).indexOf(q) >= 0; }).slice(0, 14);
        sel = 0; draw();
      }
      window.openCmd = function () { if (!overlay) return; overlay.classList.add("open"); if (input) input.value = ""; filtrar(); setTimeout(function () { input && input.focus(); }, 30); };
      window.closeCmd = function () { overlay && overlay.classList.remove("open"); };
      if (input) {
        input.addEventListener("input", filtrar);
        input.addEventListener("keydown", function (e) {
          if (e.key === "ArrowDown") { e.preventDefault(); sel = Math.min(sel + 1, filtered.length - 1); draw(); }
          else if (e.key === "ArrowUp") { e.preventDefault(); sel = Math.max(sel - 1, 0); draw(); }
          else if (e.key === "Enter") { e.preventDefault(); if (filtered[sel]) window.location.href = filtered[sel].h; }
          else if (e.key === "Escape") { window.closeCmd(); }
        });
      }
      document.addEventListener("keydown", function (e) {
        if ((e.ctrlKey || e.metaKey) && (e.key === "k" || e.key === "K")) {
          e.preventDefault();
          if (overlay && overlay.classList.contains("open")) window.closeCmd(); else window.openCmd();
        }
      });
    })();
  </script>

  <style is:global>
    :root {
      /* marca */
      --brand: #C41E3A;
      --brand-hover: #A8182F;
      --brand-active: #8E1428;
      --brand-dark: #A8182F;              /* alias retrocompat */
      --brand-50: #FBE9EC;
      --brand-100: #F5D2D9;
      --brand-light: var(--brand-50);     /* alias retrocompat */
      --brand-ring: rgba(196,30,58,.22);
      /* tinta + escala de cinza */
      --ink: #1A1D24;
      --ink-mid: #5B6270;
      --ink-light: #8A92A0;
      --ink-soft: #8A92A0;
      --gray-50: #F7F8FA;
      --gray-100: #EFF1F5;
      --gray-200: #E4E7EC;
      --gray-300: #D2D6DE;
      --bg: #F4F6FA;
      --surface: #FFFFFF;
      --surface-sunken: #F4F6FA;
      --border: #E4E7EC;
      --border-strong: #D2D6DE;
      --border-light: #F1F3F6;
      --sidebar-bg: #FFFFFF;
      /* semânticos (trio fg/bg) + alias dos nomes antigos */
      --success: #15843B; --success-bg: #DCFCE7; --success-fg: #0F6B30;
      --warning: #B45309; --warning-bg: #FEF3C7; --warning-fg: #854D0E;
      --danger:  #C1272D; --danger-bg:  #FEE2E2; --danger-fg:  #991B1B;
      --info:    #1D4ED8; --info-bg:    #DBEAFE; --info-fg:    #1E40AF;
      --purple:  #7C3AED; --purple-bg:  #EDE9FE; --purple-fg:  #5B21B6;
      --orange:  #C2410C; --orange-bg:  #FFEDD5; --orange-fg:  #9A3412;
      --green: #16A34A; --green-bg: #DCFCE7;
      --amber: #B45309; --amber-bg: #FEF3C7;
      --red: #B91C1C;   --red-bg: #FEE2E2;
      --blue: #1D4ED8;  --blue-bg: #DBEAFE;
      /* raios */
      --radius-sm: 6px; --radius-md: 8px; --radius-lg: 12px; --radius-xl: 16px;
      --radius: 12px;
      /* sombras em 2 camadas + foco */
      --shadow-xs: 0 1px 2px rgba(16,24,40,.05);
      --shadow-sm: 0 1px 3px rgba(16,24,40,.07), 0 1px 2px rgba(16,24,40,.04);
      --shadow-md: 0 4px 12px rgba(16,24,40,.08), 0 2px 4px rgba(16,24,40,.04);
      --shadow-lg: 0 12px 28px rgba(16,24,40,.12), 0 4px 8px rgba(16,24,40,.06);
      --shadow-focus: 0 0 0 3px var(--brand-ring);
      --transition: all .18s cubic-bezier(.4,0,.2,1);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Open Sans', sans-serif; background: var(--bg); color: var(--ink); }

    .shell { display: flex; min-height: 100vh; }

    /* ── Sidebar ── */
    .sidebar {
      width: 252px; min-width: 252px;
      background: var(--sidebar-bg); color: #1F2937;
      border-right: 1px solid #E5E7EB;
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; height: 100vh;
      overflow-y: auto; z-index: 200;
      transition: transform 0.25s ease;
      scrollbar-width: thin; scrollbar-color: #CBD5E1 transparent;
    }
    .sidebar-logo {
      display: flex; flex-direction: column; align-items: center; gap: 7px;
      padding: 18px 16px 14px; position: relative;
      border-bottom: 1px solid var(--border-light);
    }
    .logo-link { display: flex; flex-direction: column; align-items: center; width: 100%; text-decoration: none; }
    .logo-img { width: 100%; max-width: 188px; height: auto; display: block; }
    .logo-mark { display: none; width: 36px; height: 36px; border-radius: 9px; background: var(--brand); color: #fff; font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 15px; align-items: center; justify-content: center; }
    .logo-sub  { font-size: 0.72rem; font-weight: 700; color: var(--ink-light); text-transform: uppercase; letter-spacing: 1.5px; }
    .rail-toggle { position: absolute; top: 8px; right: 8px; width: 26px; height: 26px; border: 1px solid var(--border); background: #fff; border-radius: 7px; color: var(--ink-light); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 15px; }
    .rail-toggle:hover { color: var(--brand); border-color: var(--brand); }

    .sidebar-nav { flex: 1; padding: 10px 10px 16px; }
    .nav-item {
      display: flex; align-items: center; gap: 11px;
      padding: 10px 12px; margin: 2px 0; color: #374151;
      text-decoration: none; font-size: 0.97rem; font-weight: 600;
      border-radius: 8px;
      transition: background 0.15s, color 0.15s;
    }
    .nav-item:hover { background: var(--gray-100); color: #111827; }
    .nav-item.active {
      background: var(--brand-50);
      color: var(--area, var(--brand));
      background: color-mix(in srgb, var(--area, var(--brand)) 14%, #fff);
      color: color-mix(in srgb, var(--area, var(--brand)) 80%, #1A1D24);
      font-weight: 700; box-shadow: inset 3px 0 0 var(--area, var(--brand));
    }
    .nav-item.active .nav-icon { color: var(--area, var(--brand)); }
    .nav-icon { font-size: 19px; width: 22px; flex: none; color: var(--ink-light); display: inline-flex; align-items: center; justify-content: center; }
    .nav-item:hover .nav-icon { color: inherit; }

    /* itens dentro de uma área ganham um leve recuo + linha-guia */
    .nav-group .nav-group-items { border-left: 2px solid #EEF1F5; margin-left: 14px; padding-left: 4px; }
    .nav-group .nav-group-items .nav-item { font-size: 0.93rem; font-weight: 500; }
    .nav-group .nav-group-items .nav-item.active { font-weight: 700; }

    .nav-group { margin-top: 8px; }
    .nav-group-head {
      display: flex; align-items: center; justify-content: space-between; width: 100%;
      background: none; border: 0; cursor: pointer;
      padding: 9px 12px 6px; font-size: 0.78rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.06em; color: #6B7280;
      font-family: 'Open Sans', sans-serif;
    }
    .nav-group-label { color: var(--area, #6B7280); }
    .nav-group-head:hover .nav-group-label { opacity: .75; }
    .nav-group-chev { font-size: 14px; display: inline-flex; transition: transform .2s; transform: rotate(-90deg); color: var(--ink-light); }
    .nav-group.open .nav-group-chev { transform: rotate(0); }
    .nav-group-items { display: none; }
    .nav-group.open .nav-group-items { display: block; }

    .sidebar-footer { padding: 12px 14px; border-top: 1px solid #EEF1F5; }
    .user-chip {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 10px; margin-bottom: 10px;
      background: #F8F9FB; border: 1px solid #EEF1F5; border-radius: 10px;
    }
    .user-meta { display: flex; flex-direction: column; line-height: 1.2; min-width: 0; }
    .user-name { font-size: 0.86rem; font-weight: 700; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .user-perfil { font-size: 0.72rem; color: var(--brand); font-weight: 600; }
    .btn-logout {
      width: 100%; padding: 9px 12px;
      background: transparent; border: 1px solid #E5E7EB;
      color: #6B7280; border-radius: 8px; cursor: pointer;
      font-size: 0.88rem; transition: all 0.15s;
    }
    .btn-logout:hover { background: #FEF2F2; color: var(--brand); border-color: #FCA5A5; }

    /* ── Sidebar recolhível (rail) — só no desktop ── */
    @media (min-width: 769px) {
      .shell.collapsed .sidebar { width: 68px; min-width: 68px; }
      .shell.collapsed .main-wrap { margin-left: 68px; }
      .shell.collapsed .logo-img,
      .shell.collapsed .logo-sub,
      .shell.collapsed .nav-label,
      .shell.collapsed .nav-group-head,
      .shell.collapsed .user-meta { display: none; }
      .shell.collapsed .logo-mark { display: flex; }
      .shell.collapsed .sidebar-logo { padding: 14px 0 12px; }
      .shell.collapsed .sidebar-nav { padding: 10px 8px 16px; }
      .shell.collapsed .nav-group { margin-top: 4px; }
      .shell.collapsed .nav-group-items { display: block !important; border-left: 0; margin-left: 0; padding-left: 0; }
      .shell.collapsed .nav-item { justify-content: center; padding: 11px 0; gap: 0; }
      .shell.collapsed .nav-item.active { box-shadow: inset 0 0 0 1.5px var(--area, var(--brand)); }
      .shell.collapsed .rail-toggle { position: static; margin: 6px auto 0; }
      .shell.collapsed .rail-toggle i { transform: rotate(180deg); }
      .shell.collapsed .user-chip { justify-content: center; padding: 8px; }
      .shell.collapsed .btn-logout { display: flex; justify-content: center; }
      .shell.collapsed .btn-logout .nav-label { display: none; }
    }

    /* ── Main ── */
    .main-wrap { flex: 1; margin-left: 252px; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar {
      background: var(--surface); border-bottom: 1px solid var(--border);
      padding: 0 24px; height: 60px;
      display: flex; align-items: center; gap: 14px;
      position: sticky; top: 0; z-index: 100;
    }
    .menu-toggle { display: none; background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--ink); align-items: center; }
    .page-title { font-family: 'Montserrat', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--ink); flex: 1; letter-spacing: -.01em; }
    .main-content { padding: 24px; flex: 1; max-width: 1480px; }

    /* ── Busca global (gatilho na topbar) ── */
    .cmd-trigger { display: flex; align-items: center; gap: 8px; height: 36px; padding: 0 12px; background: var(--gray-50); border: 1px solid var(--border); border-radius: 8px; color: var(--ink-light); font-size: 0.84rem; cursor: pointer; min-width: 190px; font-family: 'Open Sans', sans-serif; }
    .cmd-trigger:hover { border-color: var(--border-strong); color: var(--ink-mid); }
    .cmd-trigger > span { flex: 1; text-align: left; }
    .cmd-trigger i { font-size: 16px; }
    .cmd-trigger kbd { font-family: 'Open Sans', sans-serif; font-size: 0.66rem; background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 1px 5px; color: var(--ink-light); }

    /* ── Command palette (overlay) ── */
    .cmd-overlay { position: fixed; inset: 0; background: rgba(16,24,40,.45); z-index: 1200; display: none; align-items: flex-start; justify-content: center; padding-top: 11vh; }
    .cmd-overlay.open { display: flex; }
    .cmd-box { width: 560px; max-width: 92vw; background: #fff; border: 1px solid var(--border); border-radius: 14px; box-shadow: var(--shadow-lg); overflow: hidden; }
    .cmd-input-wrap { display: flex; align-items: center; gap: 10px; padding: 14px 16px; border-bottom: 1px solid var(--border); }
    .cmd-input-wrap > i { font-size: 18px; color: var(--ink-light); }
    .cmd-input-wrap input { flex: 1; border: 0; outline: 0; font-size: 1rem; color: var(--ink); background: transparent; font-family: 'Open Sans', sans-serif; }
    .cmd-input-wrap kbd { font-size: 0.66rem; border: 1px solid var(--border); border-radius: 4px; padding: 1px 6px; color: var(--ink-light); }
    .cmd-results { max-height: 52vh; overflow-y: auto; padding: 6px; }
    .cmd-item { display: flex; align-items: center; gap: 10px; padding: 9px 10px; border-radius: 8px; text-decoration: none; color: var(--ink); }
    .cmd-item:hover, .cmd-item.on { background: var(--gray-100); }
    .cmd-ic { width: 24px; text-align: center; font-size: 17px; flex: none; }
    .cmd-l { flex: 1; font-size: 0.92rem; }
    .cmd-g { font-size: 0.72rem; color: var(--ink-light); }
    .cmd-empty { padding: 22px; text-align: center; color: var(--ink-light); font-size: 0.86rem; }

    /* ── Identidade do usuário (topbar) ── */
    .topbar-user { display: flex; align-items: center; gap: 10px; white-space: nowrap; }
    .tb-avatar, .user-avatar {
      width: 34px; height: 34px; border-radius: 50%; flex: none;
      display: inline-flex; align-items: center; justify-content: center;
      background: var(--brand); color: #fff; font-weight: 700; font-size: 0.92rem;
      font-family: 'Montserrat', sans-serif;
    }
    .tb-avatar-img, .user-avatar-img { width: 34px; height: 34px; border-radius: 50%; object-fit: cover; flex: none; }
    .tb-meta { display: flex; flex-direction: column; line-height: 1.2; }
    .tb-name { font-size: 0.84rem; font-weight: 700; color: var(--ink); max-width: 180px; overflow: hidden; text-overflow: ellipsis; }
    .tb-perfil { font-size: 0.7rem; color: var(--ink-light); font-weight: 600; }

    /* ── Sino de notificações ── */
    .notif-wrap { position: relative; }
    .btn-notif { position: relative; background: none; border: 0; color: var(--ink-mid); cursor: pointer; padding: 7px; border-radius: 8px; display: flex; align-items: center; }
    .btn-notif:hover { background: #F1F5F9; color: var(--brand); }
    .notif-badge { position: absolute; top: 0; right: 0; min-width: 16px; height: 16px; padding: 0 4px; background: var(--brand); color: #fff; border-radius: 99px; font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
    .notif-drop { position: absolute; top: calc(100% + 10px); right: 0; width: 340px; max-width: 86vw; background: #fff; border: 1px solid var(--border); border-radius: 12px; box-shadow: var(--shadow-md); z-index: 300; display: none; overflow: hidden; }
    .notif-drop.open { display: block; }
    .notif-drop-head { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid var(--border); }
    .notif-drop-head strong { font-family: 'Montserrat', sans-serif; font-size: .92rem; }
    .notif-drop-head button { background: none; border: 0; color: var(--brand); font-size: .74rem; cursor: pointer; font-weight: 600; }
    .notif-list { max-height: 380px; overflow-y: auto; }
    .notif-item { display: block; padding: 12px 16px; border-bottom: 1px solid var(--border-light); text-decoration: none; color: inherit; cursor: pointer; }
    .notif-item:hover { background: #FAFBFC; }
    .notif-item.nao-lida { background: #EFF6FF; }
    .notif-item.nao-lida:hover { background: #E0EDFF; }
    .notif-item strong { display: block; font-size: .84rem; color: var(--ink); margin-bottom: 2px; }
    .notif-item p { margin: 0 0 3px; font-size: .78rem; color: var(--ink-mid); line-height: 1.4; }
    .notif-item span { font-size: .7rem; color: var(--ink-light); }
    .notif-empty { padding: 24px 16px; text-align: center; color: var(--ink-light); font-size: .82rem; }

    /* ── Cards ── */
    .card { background: var(--surface); border-radius: var(--radius); border: 1px solid var(--border); padding: 20px; box-shadow: var(--shadow-sm); }
    .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 14px; margin-bottom: 24px; }
    .stat-card {
      background: var(--surface); border-radius: var(--radius); border: 1px solid var(--border);
      padding: 18px 20px; box-shadow: var(--shadow-sm); transition: var(--transition);
      display: block; text-decoration: none; color: inherit; position: relative; overflow: hidden;
    }
    a.stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .stat-value { font-family: 'Montserrat', sans-serif; font-size: 2.05rem; font-weight: 700; color: var(--brand); line-height: 1.15; }
    .stat-label { font-size: 0.86rem; color: var(--ink-mid); margin-top: 5px; }

    /* ── Tabelas ── (diagramação: fontes maiores e mais respiro em todo o admin) */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
    th { text-align: left; padding: 12px 14px; background: var(--gray-50); border-bottom: 1px solid var(--border); font-weight: 700; color: var(--ink-mid); font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.5px; }
    td { padding: 13px 14px; border-bottom: 1px solid var(--border-light); vertical-align: middle; }
    tbody tr:hover td { background: var(--gray-100); }
    /* zebra opcional: adicione class="table-zebra" na <table> */
    .table-zebra tbody tr:nth-child(even) td { background: var(--gray-50); }
    .table-zebra tbody tr:hover td { background: var(--gray-100); }

    /* ── Badges ── */
    .badge { display: inline-block; padding: 3px 11px; border-radius: 999px; font-size: 0.78rem; font-weight: 600; white-space: nowrap; }
    .badge-green  { background: var(--green-bg); color: #166534; }
    .badge-yellow { background: #FEF9C3; color: #854D0E; }
    .badge-red    { background: var(--red-bg); color: #991B1B; }
    .badge-blue   { background: var(--blue-bg); color: #1E40AF; }
    .badge-gray   { background: #F3F4F6; color: #374151; }
    .badge-orange { background: #FFEDD5; color: #9A3412; }
    .badge-purple { background: #EDE9FE; color: #5B21B6; }

    /* ── Botões ── */
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 15px; border-radius: var(--radius-md); font-size: 0.86rem; font-weight: 600; cursor: pointer; border: 1px solid transparent; transition: var(--transition); text-decoration: none; }
    .btn:hover { transform: translateY(-1px); box-shadow: var(--shadow-sm); }
    .btn:active { transform: translateY(0); box-shadow: none; }
    .btn:focus-visible { outline: none; box-shadow: var(--shadow-focus); }
    .btn:disabled, .btn[disabled] { opacity: .5; cursor: not-allowed; transform: none; box-shadow: none; }
    .btn-primary { background: var(--brand); color: #fff; }
    .btn-primary:hover { background: var(--brand-hover); }
    .btn-primary:active { background: var(--brand-active); }
    .btn-secondary { background: var(--gray-100); color: #374151; border-color: var(--gray-300); }
    .btn-secondary:hover { background: var(--gray-200); }
    .btn-success { background: var(--success); color: #fff; }
    .btn-danger  { background: var(--danger); color: #fff; }
    .btn-warning { background: var(--warning); color: #fff; }
    .btn-info    { background: var(--info); color: #fff; }
    .btn-outline { background: transparent; border-color: var(--gray-300); color: #374151; }
    .btn-outline:hover { background: var(--gray-100); }
    .btn-sm { padding: 5px 11px; font-size: 0.8rem; }

    /* ── Toolbar ── */
    .toolbar { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
    .toolbar-title { font-family: 'Montserrat', sans-serif; font-size: 1.12rem; font-weight: 700; flex: 1; }
    .search-input { padding: 8px 12px; border: 1px solid var(--border-strong); border-radius: var(--radius-md); font-size: 0.9rem; min-width: 200px; outline: none; transition: border .15s, box-shadow .15s; }
    select.filter-select { padding: 8px 10px; border: 1px solid var(--border-strong); border-radius: var(--radius-md); font-size: 0.9rem; background: #fff; outline: none; transition: border .15s, box-shadow .15s; }
    .search-input:focus, select.filter-select:focus { border-color: var(--brand); box-shadow: var(--shadow-focus); }

    /* ── Abas (pills) ── */
    .pills { display: flex; gap: 6px; flex-wrap: wrap; }
    .pill {
      background: #FFF; border: 1px solid var(--border); border-radius: 99px;
      padding: 7px 14px; font-size: 12.5px; font-weight: 600; color: var(--ink-mid); cursor: pointer; transition: .15s;
      text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
    }
    .pill:hover { border-color: var(--brand); color: var(--brand); }
    .pill.active { background: var(--brand); color: #FFF; border-color: var(--brand); }
    .pill .count { background: rgba(0,0,0,.08); border-radius: 99px; padding: 0 7px; font-size: 11px; }
    .pill.active .count { background: rgba(255,255,255,.25); }

    /* ── Modal ── */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: none; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal { background: #fff; border-radius: 12px; padding: 28px; max-width: 500px; width: 90%; max-height: 90vh; overflow-y: auto; }
    .modal-title { font-family: 'Montserrat', sans-serif; font-size: 1.1rem; font-weight: 700; margin-bottom: 20px; }
    .modal-box { background: #fff; border-radius: 12px; width: 90%; max-width: 520px; max-height: 90vh; overflow-y: auto; }
    .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px 16px; border-bottom: 1px solid #E5E7EB; }
    .modal-header h2 { font-family: 'Montserrat', sans-serif; font-size: 1.1rem; font-weight: 700; margin: 0; }
    .modal-close { background: none; border: 0; font-size: 18px; cursor: pointer; color: #9CA3AF; line-height: 1; padding: 0; }
    .modal-close:hover { color: #374151; }
    .modal-box .form-group, .modal-box .form-row { padding: 0 24px; }
    .modal-box > .form-group:first-of-type, .modal-box > .form-row:first-of-type { padding-top: 16px; }
    .modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 24px; border-top: 1px solid #E5E7EB; margin-top: 16px; }
    .form-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px,1fr)); gap: 12px; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 0.86rem; font-weight: 600; color: #555; margin-bottom: 5px; }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 9px 12px; border: 1px solid var(--border-strong); border-radius: var(--radius-md); font-size: 0.93rem;
      font-family: 'Open Sans', sans-serif; outline: none; transition: border .15s, box-shadow .15s;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--brand); box-shadow: var(--shadow-focus); }
    .form-group textarea { min-height: 80px; resize: vertical; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }

    /* ── Alert ── */
    .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 0.875rem; }
    .alert-success { background: #DCFCE7; color: #166534; border: 1px solid #BBF7D0; }
    .alert-error   { background: #FEE2E2; color: #991B1B; border: 1px solid #FECACA; }

    /* ── Empty state / loading ── */
    .empty-state { text-align: center; padding: 36px 16px; color: var(--ink-light); }
    .empty-state strong { display: block; color: var(--ink-mid); margin-bottom: 4px; font-size: .95rem; }
    .loading { display: flex; align-items: center; gap: 10px; color: var(--ink-mid); padding: 24px 8px; font-size: .9rem; }
    .spinner { width: 18px; height: 18px; border: 2.5px solid var(--border); border-top-color: var(--brand); border-radius: 50%; animation: spin .7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Seções ── */
    .section-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
    .section-title { font-family: 'Montserrat', sans-serif; font-size: 1.05rem; font-weight: 700; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); width: 252px; min-width: 252px; }
      .sidebar.open { transform: translateX(0); }
      .main-wrap { margin-left: 0 !important; }
      .menu-toggle { display: flex; }
      .rail-toggle { display: none; }
      .tb-meta { display: none; }
      .page-title { font-size: 1.05rem; }
      .cmd-trigger { min-width: 0; padding: 0 9px; }
      .cmd-trigger > span, .cmd-trigger kbd { display: none; }
      .card-grid { grid-template-columns: repeat(2, 1fr); }
      .main-content { padding: 16px; }
    }
  </style>
<script is:inline>
  if ("serviceWorker" in navigator) {
    window.addEventListener("load", () => navigator.serviceWorker.register("/sw.js").catch(() => {}));
  }
</script>
</body>
</html>
