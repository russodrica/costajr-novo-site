    { href: "/manutencao/tecnico/dashboard",  label: "Dashboard", id: "dashboard"  },
    { href: "/manutencao/tecnico/chamados",   label: "Chamados",  id: "chamados"   },
    { href: "/manutencao/tecnico/agenda",     label: "Agenda",    id: "agenda"     },
