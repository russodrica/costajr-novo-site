    { href: "/manutencao/cliente/chamados",     label: "Chamados",     id: "chamados"    },
    { href: "/manutencao/cliente/lojas",        label: "Lojas",        id: "lojas"       },
    { href: "/manutencao/cliente/preventivas",  label: "Preventivas",  id: "preventivas" },
    { href: "/manutencao/cliente/estoque",      label: "Estoque",      id: "estoque"     },
