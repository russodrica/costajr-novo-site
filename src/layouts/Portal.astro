const tipoLabel = { cliente: "Portal do Cliente", tecnico: "Portal do Técnico", admin: "Administração", colaborador: "Portal do Colaborador" }[tipo];
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <title>{title} — Costa Júnior</title>
  <meta name="theme-color" content="#16181F">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="CJR Manutenção">
  <meta name="mobile-web-app-capable" content="yes">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;500;600&display=swap">
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --brand: #C41E3A; --brand-dark: #A01828; --brand-light: rgba(196,30,58,.1);
      --ink: #1E2128; --ink-mid: #5B5F6B; --ink-light: #9CA3AF;
      --bg: #F2F4F8; --border: #E5E7EB; --border-light: #F3F4F6;
      --sidebar-bg: #16181F; --sidebar-w: 290px;
      --radius: 10px; --radius-lg: 14px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
      --shadow: 0 4px 12px rgba(0,0,0,.08), 0 1px 3px rgba(0,0,0,.04);
      --shadow-lg: 0 12px 32px rgba(0,0,0,.12), 0 4px 8px rgba(0,0,0,.06);
      --transition: all .18s cubic-bezier(.4,0,.2,1);
    }
    html, body { margin: 0; padding: 0; height: 100%; }
    body { font-family: 'Open Sans', -apple-system, sans-serif; background: var(--bg); color: var(--ink); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }
    .portal-shell { display: flex; min-height: 100vh; }

    /* ─── Sidebar ─────────────────────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w); flex-shrink: 0;
      background: var(--sidebar-bg);
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 50;
      transition: transform .25s cubic-bezier(.4,0,.2,1);
    }
    .sidebar-logo {
      padding: 28px 24px 22px;
      border-bottom: 1px solid rgba(255,255,255,.06);
      text-align: center;
    }
    .sidebar-logo a { display: block; }
    .sidebar-logo img { height: 56px; max-width: 100%; display: block; margin: 0 auto; filter: brightness(0) invert(1); opacity: .95; }
    .sidebar-badge-tipo {
      margin-top: 8px;
      display: inline-block; padding: 2px 8px; border-radius: 4px;
      background: rgba(196,30,58,.2); color: #F87171;
      font-size: 9.5px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    }
    .sidebar-nav { flex: 1; padding: 10px 10px; display: flex; flex-direction: column; gap: 1px; overflow-y: auto; }
    .sidebar-nav a {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 12px; border-radius: 8px;
      font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 12.5px;
      color: #64748B; transition: var(--transition); position: relative;
      text-decoration: none;
    }
    .sidebar-nav a svg { flex-shrink: 0; opacity: .7; transition: var(--transition); }
    .sidebar-nav a:hover { background: rgba(255,255,255,.06); color: #CBD5E1; }
    .sidebar-nav a:hover svg { opacity: 1; }
    .sidebar-nav a.active { background: rgba(196,30,58,.15); color: #FC8181; }
    .sidebar-nav a.active::before {
      content: ''; position: absolute; left: 0; top: 6px; bottom: 6px;
      width: 3px; border-radius: 0 3px 3px 0; background: #C41E3A;
    }
    .sidebar-nav a.active svg { opacity: 1; color: #FC8181; }
    .nav-badge {
      display: none; margin-left: auto;
      background: #C41E3A; color: #fff; border-radius: 10px;
      font-size: 10px; font-weight: 700; padding: 1px 6px; min-width: 18px; text-align: center;
    }
    .nav-section {
      font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em;
      color: #374151; padding: 14px 12px 4px; pointer-events: none;
    }
    .sidebar-bottom {
      padding: 14px 10px; border-top: 1px solid rgba(255,255,255,.06);
    }
    .sidebar-user {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 10px; margin-bottom: 6px; border-radius: 8px;
    }
    .user-avatar {
      width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
      background: var(--brand); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 13px;
    }
    .user-info { overflow: hidden; }
    .user-info strong { display: block; color: #E2E8F0; font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-info span { font-size: 11px; color: #4B5563; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .btn-logout {
      width: 100%; padding: 9px 12px; border-radius: 8px;
      background: transparent; border: 1px solid rgba(255,255,255,.08);
      color: #6B7280; cursor: pointer; text-align: left;
      font-family: 'Open Sans', sans-serif; font-size: 12.5px;
      transition: var(--transition); display: flex; align-items: center; gap: 8px;
    }
    .btn-logout:hover { background: rgba(255,255,255,.06); color: #CBD5E1; border-color: rgba(255,255,255,.15); }

    /* ─── Mobile overlay ───────────────────────────────────────────── */
    .sidebar-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,.55);
      z-index: 49; backdrop-filter: blur(2px);
    }
    .sidebar-overlay.open { display: block; }

    /* ─── Main area ────────────────────────────────────────────────── */
    .main-area { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
    .portal-topbar {
      background: #fff; border-bottom: 1px solid var(--border);
      padding: 0 28px; height: 62px;
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
      position: sticky; top: 0; z-index: 30;
      box-shadow: 0 1px 0 var(--border);
    }
    .topbar-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
    .topbar-left h1 {
      font-family: 'Montserrat', sans-serif; font-weight: 700;
      font-size: 18px; margin: 0; color: var(--ink); white-space: nowrap;
    }
    .topbar-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
    .btn-hamburger {
      display: none; padding: 8px; border-radius: 6px; border: 0;
      background: transparent; cursor: pointer; color: var(--ink); line-height: 0;
    }
    .btn-hamburger:hover { background: var(--border-light); }
    .btn-refresh {
      display: flex; align-items: center; gap: 6px;
      padding: 8px 14px; border-radius: 8px; border: 1.5px solid var(--border);
      background: #fff; color: var(--ink-mid); cursor: pointer;
      font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px;
      transition: var(--transition);
    }
    .btn-refresh:hover:not(:disabled) { border-color: var(--brand); color: var(--brand); }
    .btn-refresh:disabled { opacity: .5; cursor: not-allowed; }
    .notif-wrap { position: relative; }
    .btn-notif {
      width: 36px; height: 36px; border-radius: 50%; border: 1px solid var(--border);
      background: #fff; color: var(--ink-mid); cursor: pointer;
      display: flex; align-items: center; justify-content: center; position: relative;
      transition: .15s;
    }
    .btn-notif:hover { border-color: var(--brand); color: var(--brand); }
    .notif-badge {
      position: absolute; top: -4px; right: -4px; min-width: 17px; height: 17px;
      border-radius: 99px; background: var(--brand); color: #fff;
      font-size: 10px; font-weight: 800; display: flex; align-items: center; justify-content: center;
      padding: 0 4px; border: 2px solid #fff;
    }
    .notif-drop {
      display: none; position: absolute; right: 0; top: 44px; width: 340px; max-width: 90vw;
      background: #fff; border: 1px solid var(--border); border-radius: 14px;
      box-shadow: 0 16px 48px rgba(0,0,0,.16); z-index: 200; overflow: hidden;
    }
    .notif-drop.open { display: block; }
    .notif-drop-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 14px; border-bottom: 1px solid var(--border-light); font-size: 13px;
    }
    .notif-drop-head button { background: none; border: 0; color: var(--brand); font-size: 11.5px; font-weight: 700; cursor: pointer; font-family: 'Open Sans', sans-serif; }
    .notif-list { max-height: 360px; overflow-y: auto; }
    .notif-item { display: block; padding: 11px 14px; border-bottom: 1px solid var(--border-light); text-decoration: none; color: inherit; cursor: pointer; transition: background .12s; }
    .notif-item:hover { background: #F7F8FA; }
    .notif-item.nao-lida { background: #FFF8F0; }
    .notif-item.nao-lida:hover { background: #FFF1E0; }
    .notif-item strong { display: block; font-size: 12.5px; color: var(--ink); }
    .notif-item p { margin: 3px 0 0; font-size: 12px; color: var(--ink-mid); line-height: 1.45; }
    .notif-item span { display: block; margin-top: 4px; font-size: 10.5px; color: var(--ink-light); }
    .notif-empty { padding: 22px 14px; text-align: center; font-size: 12.5px; color: var(--ink-light); margin: 0; }
    .topbar-user-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: var(--brand); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 13px;
      flex-shrink: 0; cursor: default;
    }
    .portal-content { padding: 28px 32px; flex: 1; max-width: 1280px; }

    /* ─── Cards ────────────────────────────────────────────────────── */
    .card {
      background: #fff; border-radius: var(--radius-lg);
      border: 1px solid var(--border); padding: 24px;
      box-shadow: var(--shadow-sm);
    }
    .card h2 { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 17px; margin: 0 0 16px; }
    .card h3 { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 14px; margin: 0 0 14px; color: var(--ink); }

    /* Stat cards */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(175px,1fr)); gap: 14px; margin-bottom: 24px; }
    .stat-card {
      background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg);
      padding: 20px 22px; box-shadow: var(--shadow-sm);
      transition: var(--transition); cursor: default;
    }
    .stat-card:hover { box-shadow: var(--shadow); transform: translateY(-1px); }
    .stat-card .stat-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
    .stat-card .stat-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.09em; color: var(--ink-light); margin-bottom: 4px; }
    .stat-card .stat-value { font-family: 'Montserrat', sans-serif; font-size: 30px; font-weight: 800; color: var(--ink); line-height: 1; }
    .stat-card .stat-sub { font-size: 11.5px; color: var(--ink-light); margin-top: 6px; }
    .stat-card.accent { border-color: rgba(196,30,58,.25); background: linear-gradient(135deg,#fff 60%,#FFF5F5); }
    .stat-card.accent .stat-value { color: var(--brand); }

    /* ─── Table ────────────────────────────────────────────────────── */
    .table-wrap { overflow-x: auto; border-radius: var(--radius); }
    table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    th { text-align: left; padding: 10px 16px; font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-light); border-bottom: 1.5px solid var(--border); background: #FAFBFC; }
    td { padding: 12px 16px; border-bottom: 1px solid var(--border-light); vertical-align: middle; }
    tr:last-child td { border-bottom: 0; }
    tbody tr { transition: background .12s; }
    tbody tr:hover td { background: #F9FAFB; }

    /* ─── Badges ────────────────────────────────────────────────────── */
    .badge {
      display: inline-flex; align-items: center;
      padding: 3px 10px; border-radius: 100px;
      font-size: 10.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
      white-space: nowrap;
    }
    .badge-aberto           { background: #EFF6FF; color: #1D4ED8; }
    .badge-em_andamento     { background: #FFF7ED; color: #C2410C; }
    .badge-aguardando_material { background: #FEFCE8; color: #A16207; }
    .badge-concluido        { background: #F0FDF4; color: #15803D; }
    .badge-cancelado        { background: #F3F4F6; color: #6B7280; }
    .badge-ativo            { background: #F0FDF4; color: #15803D; }
    .badge-pendente         { background: #FEFCE8; color: #A16207; }
    .badge-inadimplente     { background: #FEF2F2; color: #B91C1C; }
    .badge-agendada         { background: #EFF6FF; color: #1D4ED8; }

    /* ─── Buttons ──────────────────────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      padding: 9px 18px; border-radius: 8px; border: 0; cursor: pointer;
      font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 13px;
      letter-spacing: 0.02em; transition: var(--transition); white-space: nowrap;
    }
    .btn:disabled { opacity: .55; cursor: not-allowed; }
    .btn-primary { background: var(--brand); color: #fff; box-shadow: 0 2px 6px rgba(196,30,58,.3); }
    .btn-primary:hover:not(:disabled) { background: var(--brand-dark); box-shadow: 0 4px 10px rgba(196,30,58,.4); transform: translateY(-1px); }
    .btn-outline { background: #fff; color: var(--ink); border: 1.5px solid var(--border); }
    .btn-outline:hover:not(:disabled) { border-color: var(--brand); color: var(--brand); background: var(--brand-light); }
    .btn-sm { padding: 5px 12px; font-size: 11.5px; border-radius: 6px; }
    .btn-ghost { background: transparent; color: var(--ink-mid); border: 0; }
    .btn-ghost:hover { background: var(--border-light); color: var(--ink); }

    /* ─── Modal ────────────────────────────────────────────────────── */
    .modal-bg {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.48); z-index: 100;
      align-items: center; justify-content: center;
      backdrop-filter: blur(3px);
      padding: 20px;
    }
    .modal-bg.open { display: flex; animation: fadeIn .18s ease; }
    .modal {
      background: #fff; border-radius: var(--radius-lg); padding: 32px;
      max-width: 520px; width: 100%; max-height: 90vh; overflow-y: auto;
      box-shadow: var(--shadow-lg); animation: slideUp .2s ease;
    }
    .modal h2 { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 19px; margin: 0 0 22px; }
    .modal-close { float: right; background: none; border: 0; font-size: 20px; cursor: pointer; color: var(--ink-light); line-height: 1; padding: 0; margin: -4px -4px 0 0; }
    .modal-close:hover { color: var(--ink); }

    /* ─── Forms ────────────────────────────────────────────────────── */
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 12.5px; font-weight: 600; margin-bottom: 5px; color: var(--ink-mid); }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 10px 13px; border: 1.5px solid var(--border);
      border-radius: 8px; font-family: 'Open Sans', sans-serif; font-size: 13.5px;
      color: var(--ink); background: #fff; transition: border .15s, box-shadow .15s; outline: none;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      border-color: var(--brand); box-shadow: 0 0 0 3px rgba(196,30,58,.1);
    }
    .form-group textarea { min-height: 90px; resize: vertical; line-height: 1.5; }
    .form-hint { font-size: 11.5px; color: var(--ink-light); margin-top: 4px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

    /* ─── Alerts ───────────────────────────────────────────────────── */
    .alert { padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 16px; display: flex; align-items: flex-start; gap: 8px; }
    .alert-error   { background: #FEF2F2; color: #B91C1C; border: 1px solid #FECACA; }
    .alert-success { background: #F0FDF4; color: #15803D; border: 1px solid #BBF7D0; }
    .alert-warn    { background: #FFFBEB; color: #92400E; border: 1px solid #FDE68A; }

    /* ─── Empty state ──────────────────────────────────────────────── */
    .empty-state {
      text-align: center; padding: 56px 24px; color: var(--ink-light);
    }
    .empty-state svg { opacity: .3; margin-bottom: 14px; }
    .empty-state p { font-size: 14px; margin: 0; }
    .empty-state strong { display: block; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 15px; color: var(--ink-mid); margin-bottom: 4px; }

    /* ─── Loading ──────────────────────────────────────────────────── */
    .loading { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 56px; color: var(--ink-light); font-size: 14px; }
    .spinner { width: 22px; height: 22px; border: 2.5px solid var(--border); border-top-color: var(--brand); border-radius: 50%; animation: spin .7s linear infinite; flex-shrink: 0; }

    /* ─── Toast ────────────────────────────────────────────────────── */
    #toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; pointer-events: none; }
    .toast {
      display: flex; align-items: center; gap: 10px;
      padding: 13px 18px; border-radius: 10px;
      font-size: 13.5px; font-weight: 500; max-width: 340px;
      box-shadow: var(--shadow-lg); pointer-events: all;
      transform: translateX(120%); opacity: 0; transition: transform .3s cubic-bezier(.4,0,.2,1), opacity .3s;
    }
    .toast.show { transform: translateX(0); opacity: 1; }
    .toast-success { background: #1a2e1a; color: #86efac; border: 1px solid rgba(134,239,172,.2); }
    .toast-error   { background: #2e1a1a; color: #fca5a5; border: 1px solid rgba(252,165,165,.2); }
    .toast-info    { background: #1a1e2e; color: #93c5fd; border: 1px solid rgba(147,197,253,.2); }
    .toast-icon { font-size: 16px; flex-shrink: 0; }

    /* ─── Misc ─────────────────────────────────────────────────────── */
    .mt-20 { margin-top: 20px; }
    .mt-24 { margin-top: 24px; }
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; flex-wrap: wrap; gap: 12px; }
    .section-header h2 { margin: 0; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 17px; }
    .divider { border: 0; border-top: 1px solid var(--border); margin: 20px 0; }

    /* ─── Animations ───────────────────────────────────────────────── */
    @keyframes spin    { to { transform: rotate(360deg); } }
    @keyframes spin-icon { to { transform: rotate(360deg); } }
    @keyframes fadeIn  { from { opacity: 0; } to { opacity: 1; } }
    @keyframes slideUp { from { transform: translateY(16px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    /* ─── Responsive ───────────────────────────────────────────────── */
    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); box-shadow: var(--shadow-lg); }
      .main-area { margin-left: 0; }
      .portal-content { padding: 20px 16px; }
      .btn-hamburger { display: flex; }
      .portal-topbar { padding: 0 16px; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 560px) {
      .stats-grid { grid-template-columns: 1fr; }
      .grid-2 { grid-template-columns: 1fr; }
      .modal { padding: 24px 20px; }
    }
  </style>
</head>
<body>
<div id="toast-container"></div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="portal-shell">
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <a href="/"><img src="/logo-cjr.png" alt="Costa Júnior"></a>
      <span class="sidebar-badge-tipo">{tipoLabel}</span>
    </div>

    <nav class="sidebar-nav" id="sidebarNav">
      {nav.map(item => (
        <a
          href={item.href}
          class={[activePage === item.id ? "active" : "", item.roles ? "role-gated" : "", (item as any).area ? "area-gated" : ""].join(" ").trim()}
          id={`nav-item-${item.id}`}
          data-roles={item.roles ? item.roles.join(",") : ""}
          data-area={(item as any).area || ""}
          style={(item.roles || (item as any).area) ? "display:none" : ""}
        >
          <Fragment set:html={icons[item.id] || icons["documentos"]} />
          {item.label}
          {item.badge && <span class="nav-badge" id={`badge-${item.id}`}></span>}
        </a>
      ))}
    </nav>

    <div class="sidebar-bottom">
      <div class="sidebar-user">
        <div class="user-avatar" id="userAvatar">?</div>
        <div class="user-info" id="sidebarUser">
          <strong>Carregando...</strong>
          <span></span>
        </div>
      </div>
      <button class="btn-logout" id="logoutBtn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sair da conta
      </button>
    </div>
  </aside>

  <div class="main-area">
    <header class="portal-topbar">
      <div class="topbar-left">
        <button class="btn-hamburger" id="btnHamburger" aria-label="Menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <h1>{title}</h1>
      </div>
      <div class="topbar-right">
        <button class="btn-refresh" id="btnAtualizarPortal" title="Atualizar dados">
          <svg id="iconRefresh" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          <span id="labelRefresh">Atualizar</span>
        </button>
        {tipo === "colaborador" && (
          <div class="notif-wrap">
            <button class="btn-notif" id="btnNotif" title="Notificações" aria-label="Notificações">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              <span class="notif-badge" id="notifBadge" style="display:none">0</span>
            </button>
            <div class="notif-drop" id="notifDrop">
              <div class="notif-drop-head">
                <strong>Notificações</strong>
                <button id="notifTodas" type="button">Marcar todas como lidas</button>
              </div>
              <div class="notif-list" id="notifList"><p class="notif-empty">Carregando...</p></div>
            </div>
          </div>
        )}
        <div class="topbar-user-avatar" id="topbarAvatar" title="">?</div>
      </div>
    </header>
    <main class="portal-content">
      <slot />
    </main>
  </div>
</div>

<script define:vars={{ tipo, loginHref }}>
  // ── Auth ──
  const tokenKey = { cliente: "manut_cliente_token", tecnico: "manut_tecnico_token", admin: "manut_portal_token", colaborador: "portal_colab_token" }[tipo];
  const userKey  = tokenKey + "_user";
  const token = localStorage.getItem(tokenKey);
  if (!token) window.location.replace(loginHref);

  // ── User display ──
  function getInitial(name) {
    return (name || "?").trim().charAt(0).toUpperCase();
  }
  const userData = localStorage.getItem(userKey);
  if (userData) {
    try {
      const u = JSON.parse(userData);
      const nome = u.nome || u.email || "Usuário";
      const email = u.email || "";
      const initial = getInitial(nome);

      const sidebarEl = document.getElementById("sidebarUser");
      if (sidebarEl) sidebarEl.innerHTML = `<strong>${nome}</strong><span>${email}</span>`;

      const avatarEl = document.getElementById("userAvatar");
      if (avatarEl) avatarEl.textContent = initial;

      const topbarAv = document.getElementById("topbarAvatar");
      if (topbarAv) { topbarAv.textContent = initial; topbarAv.title = nome; }
    } catch {}
  }

  // ── Gating do menu (colaborador): consulta a matriz de Permissões de Acesso ──
  if (tipo === "colaborador") {
    const tk = localStorage.getItem(tokenKey);
    const aplicarFallback = () => {
      const userData2 = localStorage.getItem(userKey);
      let userRoles = ["operacional"];
      if (userData2) { try { const u = JSON.parse(userData2); userRoles = (u.roles && u.roles.length ? u.roles : [u.role || "operacional"]); } catch {} }
      document.querySelectorAll(".area-gated").forEach(el => {
        const area = el.getAttribute("data-area");
        const basicas = ["onboarding","treinamentos","forum","documentos","meus-equipamentos"];
        const ok = basicas.includes(area || "") ||
          (area === "comercial" && userRoles.some(r => ["admin","coordenador","comercial"].includes(r))) ||
          (area === "gestao" && userRoles.some(r => ["admin","coordenador","operacional"].includes(r)));
        if (ok) (el as HTMLElement).style.display = "";
      });
    };
    if (tk) {
      fetch("/api/portal/permissoes", { headers: { "x-portal-auth": tk } })
        .then(r => r.ok ? r.json() : Promise.reject())
        .then(d => {
          const areas = d.areas || [];
          document.querySelectorAll(".area-gated").forEach(el => {
            const area = el.getAttribute("data-area");
            if (!area || areas.includes(area)) (el as HTMLElement).style.display = "";
          });
        })
        .catch(aplicarFallback);
    } else aplicarFallback();
  }

  // ── Notificações (colaborador) ──
  if (tipo === "colaborador") {
    const tk2 = localStorage.getItem(tokenKey);
    const btnN = document.getElementById("btnNotif");
    const drop = document.getElementById("notifDrop");
    const badge = document.getElementById("notifBadge");
    const lista = document.getElementById("notifList");
    let notifs = [];

    function tempoRel(d) {
      const min = Math.floor((Date.now() - new Date(d).getTime()) / 60000);
      if (min < 1) return "agora";
      if (min < 60) return `há ${min} min`;
      const h = Math.floor(min / 60);
      if (h < 24) return `há ${h}h`;
      return new Date(d).toLocaleDateString("pt-BR");
    }
    function escN(s) { return String(s ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;"); }

    function renderNotifs() {
      if (!lista) return;
      if (!notifs.length) { lista.innerHTML = '<p class="notif-empty">Nenhuma notificação por aqui. 🔕</p>'; return; }
      lista.innerHTML = notifs.map(n => `
        <a class="notif-item ${n.lida ? "" : "nao-lida"}" data-id="${n.id}" data-link="${escN(n.link || "")}">
          <strong>${escN(n.titulo)}</strong>
          ${n.mensagem ? `<p>${escN(n.mensagem)}</p>` : ""}
          <span>${tempoRel(n.created_at)}</span>
        </a>`).join("");
      lista.querySelectorAll(".notif-item").forEach(el => {
        el.addEventListener("click", async (e) => {
          e.preventDefault();
          const id = el.getAttribute("data-id");
          const link = el.getAttribute("data-link");
          try { await fetch("/api/portal/notificacoes", { method: "PATCH", headers: { "x-portal-auth": tk2, "content-type": "application/json" }, body: JSON.stringify({ id }) }); } catch {}
          if (link) window.location.href = link; else { el.classList.remove("nao-lida"); carregarNotifs(); }
        });
      });
    }

    async function carregarNotifs() {
      if (!tk2) return;
      try {
        const res = await fetch("/api/portal/notificacoes", { headers: { "x-portal-auth": tk2 } });
        if (!res.ok) return;
        const d = await res.json();
        notifs = d.notificacoes || [];
        const naoLidas = d.nao_lidas || 0;
        if (badge) {
          badge.style.display = naoLidas > 0 ? "flex" : "none";
          badge.textContent = naoLidas > 9 ? "9+" : String(naoLidas);
        }
        renderNotifs();
      } catch {}
    }

    btnN?.addEventListener("click", (e) => { e.stopPropagation(); drop?.classList.toggle("open"); });
    document.addEventListener("click", (e) => { if (drop && !drop.contains(e.target) && e.target !== btnN) drop.classList.remove("open"); });
    document.getElementById("notifTodas")?.addEventListener("click", async () => {
      try { await fetch("/api/portal/notificacoes", { method: "PATCH", headers: { "x-portal-auth": tk2, "content-type": "application/json" }, body: JSON.stringify({ todas: true }) }); } catch {}
      carregarNotifs();
    });

    carregarNotifs();
    setInterval(carregarNotifs, 60000);
  }

  // ── Logout ──
  document.getElementById("logoutBtn")?.addEventListener("click", () => {
    localStorage.removeItem(tokenKey);
    localStorage.removeItem(userKey);
    window.location.replace(loginHref);
  });

  // ── Refresh button ──
  const btnRef = document.getElementById("btnAtualizarPortal");
  if (btnRef) {
    btnRef.addEventListener("click", () => {
      if (btnRef.disabled) return;
      btnRef.disabled = true;
      const icon = document.getElementById("iconRefresh");
      const label = document.getElementById("labelRefresh");
      if (label) label.textContent = "Atualizando...";
      if (icon) icon.style.animation = "spin-icon .7s linear infinite";
      window.dispatchEvent(new CustomEvent("portal:refresh"));
      setTimeout(() => {
        btnRef.disabled = false;
        if (label) label.textContent = "Atualizar";
        if (icon) icon.style.animation = "";
      }, 1400);
    });
  }

  // ── Mobile sidebar ──
  const sidebar  = document.getElementById("sidebar");
  const overlay  = document.getElementById("sidebarOverlay");
  const hamburger = document.getElementById("btnHamburger");
  function openSidebar()  { sidebar?.classList.add("open"); overlay?.classList.add("open"); }
  function closeSidebar() { sidebar?.classList.remove("open"); overlay?.classList.remove("open"); }
  hamburger?.addEventListener("click", openSidebar);
  overlay?.addEventListener("click", closeSidebar);

  // ── Toast system (global) ──
  window.toast = function(msg, tipo = "success") {
    const container = document.getElementById("toast-container");
    if (!container) return;
    const icons = { success: "✓", error: "✕", info: "ℹ" };
    const t = document.createElement("div");
    t.className = `toast toast-${tipo}`;
    t.innerHTML = `<span class="toast-icon">${icons[tipo] || "ℹ"}</span><span>${msg}</span>`;
    container.appendChild(t);
    requestAnimationFrame(() => requestAnimationFrame(() => t.classList.add("show")));
    setTimeout(() => {
      t.classList.remove("show");
      setTimeout(() => t.remove(), 350);
    }, 3800);
  };

  // ── Badge: materiais pendentes (cliente) ──
  if (tipo === "cliente" && token) {
    fetch("/api/manut/cliente/materiais", { headers: { "x-cliente-auth": token } })
      .then(r => r.ok ? r.json() : [])
      .then(mats => {
        const pend = (mats || []).filter(m => m.status === "pendente_aprovacao").length;
        if (pend > 0) {
          const el = document.getElementById("badge-materiais");
          if (el) { el.textContent = pend; el.style.display = "inline-block"; }
        }
      })
      .catch(() => {});
  }
</script>

<!-- PWA: registro do service worker + botão "Instalar app" -->
<button id="pwa-install-btn" type="button" aria-label="Instalar aplicativo" style="display:none;position:fixed;right:18px;bottom:18px;z-index:9999;background:#C41E3A;color:#FFF;border:0;border-radius:99px;padding:12px 18px;font-family:'Open Sans',sans-serif;font-weight:700;font-size:13.5px;letter-spacing:.02em;box-shadow:0 6px 18px rgba(196,30,58,.35);cursor:pointer">📲 Instalar app</button>
<script is:inline>
  (function () {
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", function () {
        navigator.serviceWorker.register("/sw.js").catch(function (e) { console.warn("SW falhou:", e); });
      });
    }
    let deferredPrompt = null;
    const btn = document.getElementById("pwa-install-btn");
    window.addEventListener("beforeinstallprompt", function (e) {
      e.preventDefault();
      deferredPrompt = e;
      if (btn) btn.style.display = "";
    });
    if (btn) btn.addEventListener("click", async function () {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      await deferredPrompt.userChoice;
      deferredPrompt = null;
      btn.style.display = "none";
    });
    window.addEventListener("appinstalled", function () { if (btn) btn.style.display = "none"; });
  })();
</script>
</body>
</html>
