---
interface Props {
  title?: string;
  tipo: "cliente" | "tecnico" | "admin";
  activePage?: string;
}
const { title = "Portal", tipo, activePage = "" } = Astro.props;

const navs = {
  cliente: [
    { href: "/manutencao/cliente/dashboard", label: "Dashboard", id: "dashboard" },
    { href: "/manutencao/cliente/chamados",  label: "Chamados",  id: "chamados"  },
  ],
  tecnico: [
    { href: "/manutencao/tecnico/dashboard", label: "Meus Chamados", id: "dashboard" },
  ],
  admin: [
    { href: "/manutencao/admin",              label: "Clientes",  id: "clientes"  },
    { href: "/manutencao/admin?tab=chamados", label: "Chamados",  id: "chamados"  },
    { href: "/manutencao/admin?tab=tecnicos", label: "Técnicos",  id: "tecnicos"  },
  ],
};
const loginHref = { cliente: "/manutencao/cliente/login", tecnico: "/manutencao/tecnico/login", admin: "/manutencao/admin/login" }[tipo];
const nav = navs[tipo];
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{title} — Costa Júnior</title>
  <meta name="theme-color" content="#C41E3A">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;500;600&display=swap">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --brand: #C41E3A; --brand-dark: #A01828;
      --ink: #2D2F36; --ink-mid: #5B5F6B; --ink-light: #9CA3AF;
      --bg: #F4F6F9; --border: #E5E7EB;
      --sidebar-w: 240px;
    }
    html, body { margin: 0; padding: 0; height: 100%; }
    body {
      font-family: 'Open Sans', -apple-system, sans-serif;
      background: var(--bg); color: var(--ink);
      line-height: 1.6; -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    .portal-shell { display: flex; min-height: 100vh; }

    /* ── Sidebar ── */
    .sidebar {
      width: var(--sidebar-w); flex-shrink: 0;
      background: #1E2128; color: #CBD5E1;
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0;
      z-index: 40;
    }
    .sidebar-logo {
      padding: 24px 20px 20px; border-bottom: 1px solid #2D3139;
    }
    .sidebar-logo a { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-mark {
      display: grid; grid-template-columns: 1fr 1fr; gap: 2px;
      width: 24px; height: 24px; flex-shrink: 0;
    }
    .logo-mark span:nth-child(1) { background: #C41E3A; }
    .logo-mark span:nth-child(2) { background: #5B5F6B; }
    .logo-mark span:nth-child(3) { background: #5B5F6B; }
    .logo-mark span:nth-child(4) { background: #C41E3A; }
    .logo-text { font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 16px; color: #fff; line-height: 1.1; }
    .logo-text small { display: block; font-size: 9px; font-weight: 600; letter-spacing: 0.14em; color: #6B7280; text-transform: uppercase; }
    .sidebar-tipo {
      padding: 8px 20px 0;
      font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: #C41E3A;
    }
    .sidebar-nav { flex: 1; padding: 12px 12px; display: flex; flex-direction: column; gap: 2px; }
    .sidebar-nav a {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; border-radius: 6px;
      font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 13px;
      color: #94A3B8; transition: all .15s;
    }
    .sidebar-nav a:hover { background: #2D3139; color: #E2E8F0; }
    .sidebar-nav a.active { background: rgba(196,30,58,.18); color: #F87171; }
    .sidebar-bottom {
      padding: 16px 12px; border-top: 1px solid #2D3139;
    }
    .sidebar-user { padding: 0 8px 12px; font-size: 13px; color: #6B7280; word-break: break-all; }
    .sidebar-user strong { display: block; color: #CBD5E1; font-size: 14px; margin-bottom: 2px; word-break: normal; }
    .btn-logout {
      width: 100%; padding: 9px 12px; border-radius: 6px;
      background: transparent; border: 1px solid #374151;
      color: #9CA3AF; cursor: pointer; text-align: left;
      font-family: 'Open Sans', sans-serif; font-size: 13px;
      transition: all .15s;
    }
    .btn-logout:hover { background: #374151; color: #E2E8F0; }

    /* ── Main area ── */
    .main-area {
      margin-left: var(--sidebar-w); flex: 1;
      display: flex; flex-direction: column; min-height: 100vh;
    }
    .portal-topbar {
      background: #fff; border-bottom: 1px solid var(--border);
      padding: 0 32px; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 30;
    }
    .portal-topbar h1 {
      font-family: 'Montserrat', sans-serif; font-weight: 700;
      font-size: 20px; margin: 0; color: var(--ink);
    }
    .portal-content { padding: 32px; flex: 1; }

    /* ── Cards ── */
    .card {
      background: #fff; border-radius: 10px;
      border: 1px solid var(--border); padding: 24px;
    }
    .card h2 { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 18px; margin: 0 0 16px; }
    .card h3 { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 15px; margin: 0 0 12px; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); gap: 16px; margin-bottom: 28px; }
    .stat-card {
      background: #fff; border: 1px solid var(--border); border-radius: 10px;
      padding: 20px 24px;
    }
    .stat-card .stat-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-light); margin-bottom: 6px; }
    .stat-card .stat-value { font-family: 'Montserrat', sans-serif; font-size: 32px; font-weight: 800; color: var(--ink); }
    .stat-card .stat-sub { font-size: 12px; color: var(--ink-light); margin-top: 4px; }
    .stat-card.accent { border-color: var(--brand); }
    .stat-card.accent .stat-value { color: var(--brand); }

    /* ── Table ── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    th { text-align: left; padding: 10px 14px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--ink-light); border-bottom: 2px solid var(--border); background: #FAFAFA; }
    td { padding: 12px 14px; border-bottom: 1px solid var(--border); vertical-align: top; }
    tr:last-child td { border-bottom: 0; }
    tr:hover td { background: #FAFBFC; }

    /* ── Badges ── */
    .badge {
      display: inline-block; padding: 2px 10px; border-radius: 100px;
      font-size: 11px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    }
    .badge-aberto      { background: #EFF6FF; color: #1D4ED8; }
    .badge-em_andamento { background: #FFF7ED; color: #C2410C; }
    .badge-aguardando_material { background: #FEFCE8; color: #A16207; }
    .badge-concluido   { background: #F0FDF4; color: #15803D; }
    .badge-cancelado   { background: #F9FAFB; color: #6B7280; }
    .badge-ativo       { background: #F0FDF4; color: #15803D; }
    .badge-pendente    { background: #FEFCE8; color: #A16207; }
    .badge-inadimplente { background: #FEF2F2; color: #B91C1C; }

    /* ── Buttons ── */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 18px; border-radius: 6px; border: 0; cursor: pointer;
      font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 13px;
      letter-spacing: 0.03em; transition: all .15s;
    }
    .btn-primary { background: var(--brand); color: #fff; }
    .btn-primary:hover { background: var(--brand-dark); }
    .btn-outline { background: #fff; color: var(--ink); border: 1px solid var(--border); }
    .btn-outline:hover { border-color: var(--brand); color: var(--brand); }
    .btn-sm { padding: 6px 12px; font-size: 12px; }

    /* ── Modal ── */
    .modal-bg {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.5); z-index: 100;
      align-items: center; justify-content: center;
    }
    .modal-bg.open { display: flex; }
    .modal {
      background: #fff; border-radius: 12px; padding: 32px;
      max-width: 520px; width: 100%; max-height: 90vh; overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0,0,0,.2);
    }
    .modal h2 { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 20px; margin: 0 0 24px; }

    /* ── Form ── */
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; color: var(--ink); }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 10px 14px; border: 1.5px solid var(--border);
      border-radius: 6px; font-family: 'Open Sans', sans-serif; font-size: 14px;
      color: var(--ink); background: #fff; transition: border .15s; outline: none;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--brand); }
    .form-group textarea { min-height: 90px; resize: vertical; }

    /* ── Misc ── */
    .loading { color: var(--ink-light); padding: 40px; text-align: center; font-size: 15px; }
    .alert { padding: 12px 16px; border-radius: 6px; font-size: 14px; margin-bottom: 16px; }
    .alert-error { background: #FEF2F2; color: #B91C1C; border: 1px solid #FECACA; }
    .alert-success { background: #F0FDF4; color: #15803D; border: 1px solid #BBF7D0; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .mt-24 { margin-top: 24px; }

    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); }
      .main-area { margin-left: 0; }
      .portal-content { padding: 20px; }
      .grid-2 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="portal-shell">
  <aside class="sidebar">
    <div class="sidebar-logo">
      <a href="/" style="display:block">
        <img src="/logo-cjr.png" alt="Costa Júnior" style="height:36px;display:block;filter:brightness(0) invert(1)">
      </a>
      <div style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#4B5563;margin-top:6px">Manutenção Predial</div>
    </div>
    <div class="sidebar-tipo">{tipo === "cliente" ? "Portal Cliente" : tipo === "tecnico" ? "Portal Técnico" : "Administração"}</div>
    <nav class="sidebar-nav">
      {nav.map(item => (
        <a href={item.href} class={activePage === item.id ? "active" : ""}>{item.label}</a>
      ))}
    </nav>
    <div class="sidebar-bottom">
      <div class="sidebar-user" id="sidebarUser"><strong>Carregando...</strong></div>
      <button class="btn-logout" id="logoutBtn">Sair</button>
    </div>
  </aside>

  <div class="main-area">
    <header class="portal-topbar">
      <h1>{title}</h1>
    </header>
    <main class="portal-content">
      <slot />
    </main>
  </div>
</div>

<script define:vars={{ tipo, loginHref }}>
  const tokenKey = { cliente: "manut_cliente_token", tecnico: "manut_tecnico_token", admin: "manut_portal_token" }[tipo];
  const userKey  = tokenKey + "_user";
  const token = localStorage.getItem(tokenKey);
  if (!token) { window.location.replace(loginHref); }

  const userData = localStorage.getItem(userKey);
  if (userData) {
    try {
      const u = JSON.parse(userData);
      const el = document.getElementById("sidebarUser");
      if (el) el.innerHTML = `<strong>${u.nome || u.email || "Usuário"}</strong>${u.email || ""}`;
    } catch {}
  }

  document.getElementById("logoutBtn")?.addEventListener("click", () => {
    localStorage.removeItem(tokenKey);
    localStorage.removeItem(userKey);
    window.location.replace(loginHref);
  });
</script>
</body>
</html>
