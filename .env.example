# ─── Supabase ───────────────────────────────────────────────────────────────
# Crie um projeto em https://supabase.com e pegue daqui: Settings → API
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── JWT ────────────────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
JWT_SECRET=trocar_em_producao

# ─── Mercado Pago ───────────────────────────────────────────────────────────
# https://www.mercadopago.com.br/developers/panel/credentials
MP_ACCESS_TOKEN=APP_USR-xxxxx
MP_PUBLIC_KEY=APP_USR-xxxxx
MP_WEBHOOK_SECRET=xxxxx

# ─── Resend (email transacional) ────────────────────────────────────────────
# https://resend.com — 3.000 emails/mês grátis
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=contato@costajr.com.br

# ─── Site ───────────────────────────────────────────────────────────────────
SITE_BASE_URL=https://costajr.com.br
ADMIN_BYPASS_KEY=cjr-2026

# ─── Admin do painel de manutenção ─────────────────────────────────────────
# ADMIN_EMAIL: e-mail do admin
# ADMIN_PASSWORD_HASH: SHA-256 da senha concatenada com ::cjr-manut-salt-v1
# Gerar hash no console do browser:
#   const enc = new TextEncoder().encode("suasenha::cjr-manut-salt-v1");
#   const h = await crypto.subtle.digest("SHA-256", enc);
#   console.log(Array.from(new Uint8Array(h)).map(b=>b.toString(16).padStart(2,"0")).join(""))
ADMIN_EMAIL=adriana@costajr.com.br
ADMIN_PASSWORD_HASH=

# ─── Wix import (one-time) ─────────────────────────────────────────────────
# Pra rodar o script de migração db:import depois
WIX_SITE_BASE=https://costajr.com.br
WIX_ADMIN_KEY=cjr-2026

# ─── D4Sign webhook (segurança) ─────────────────────────────────────────────
# Segredo compartilhado p/ validar o webhook da D4Sign (evita forjar "termo assinado").
# Defina aqui e configure a URL do webhook na D4Sign como:
#   https://costajr.com.br/api/d4sign/webhook?key=<MESMO_VALOR>
# Enquanto vazio, o webhook funciona sem checagem (rollout gradual).
D4SIGN_WEBHOOK_SECRET=

# ─── Verificação de novo dispositivo (step-up por OTP) ──────────────────────
# Quando =1, logar de um dispositivo novo (ou após 30 dias) exige um código
# enviado por e-mail antes de liberar o acesso (defende contra senha clonada).
# Deixe vazio/0 para manter o login atual. O código é fail-open (se algo falhar,
# cai no login normal — nunca trava o acesso). Ative só quando quiser.
STEPUP_ENABLED=
