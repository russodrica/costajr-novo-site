# ─── Supabase ───────────────────────────────────────────────────────────────
# Crie um projeto em https://supabase.com e pegue daqui: Settings → API
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── JWT ────────────────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
JWT_SECRET=trocar_em_producao

# ─── Mercado Pago ───────────────────────────────────────────────────────────
# https://www.mercadopago.com.br/developers/panel/credentials
MP_ACCESS_TOKEN=APP_USR-xxxxx
MP_PUBLIC_KEY=APP_USR-xxxxx
MP_WEBHOOK_SECRET=xxxxx

# ─── Resend (email transacional) ────────────────────────────────────────────
# https://resend.com — 3.000 emails/mês grátis
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=contato@costajr.com.br

# ─── Site ───────────────────────────────────────────────────────────────────
SITE_BASE_URL=https://costajr.com.br
ADMIN_BYPASS_KEY=cjr-2026

# ─── Wix import (one-time) ─────────────────────────────────────────────────
# Pra rodar o script de migração db:import depois
WIX_SITE_BASE=https://costajr.com.br
WIX_ADMIN_KEY=cjr-2026
